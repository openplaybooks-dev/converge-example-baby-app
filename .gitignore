# Flutter / Dart build artifacts (never commit these)
.dart_tool/
.packages
build/
*.iml
.metadata
.flutter-plugins
.flutter-plugins-dependencies
*.g.dart
*.freezed.dart

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Secrets
.env
.env.local
.env.*.local

# Claude Code
.claude/
wip/

# Pub (do not commit; the playbook regenerates the lockfile from pubspec.yaml)
pubspec.lock
.pub-cache/
.pub/

# Node (some scripts run via Node; node_modules is local-only)
node_modules/

# Platform scaffolds — regenerated by `flutter create --platforms=...` as needed
# (keep ios/android/web/macos out of the showcase; reviewers run `flutter create`
# locally if they want to build for a specific target)
macos/
android/
ios/
web/
linux/
windows/

# Converge runtime state that ISN'T part of the showcase
.converge/inventory/
.converge/checkpoints/
.converge/cache/
.converge/artifacts/

# Spawn artifacts the runner writes into the playbook source tree (these are
# rebuilt on every run; keeping them out of git prevents enormous diffs)
.converge/playbooks/*/tasks/**/tasks/

# NOTE: we DO commit the following (they're the proof of a real run):
#   .converge/journal/          ← run telemetry (events, attempts, metrics)
#   .stitch/                    ← design layer outputs
#   lib/                        ← generated Flutter code
#   assets/illustrations/*/     ← generated SVGs
#   test/                       ← generated widget tests
#   docs/                       ← extracted metrics + screenshots
