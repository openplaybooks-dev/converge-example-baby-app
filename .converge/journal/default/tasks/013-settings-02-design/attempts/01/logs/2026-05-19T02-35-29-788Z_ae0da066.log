  "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Baby Bump - Settings</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root {\n      --color-primary: #7C3AED;\n      --color-secondary: #F9A8D4;\n      --color-tertiary: #6EE7B7;\n      --color-background: #F5F3FF;\n      --color-surface: #FAFAFA;\n      --color-text-primary: #1F2937;\n      --color-text-secondary: #6B7280;\n      --color-border: #E5E7EB;\n      --color-error: #EF4444;\n      --color-white: #FFFFFF;\n      --radius-card: 16px;\n      --radius-list-item: 12px;\n      --spacing-unit: 8px;\n      --font-family: 'Nunito', sans-serif;\n    }\n\n    *, *::before, *::after {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        animation-iteration-count: 1 !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n\n    body {\n      font-family: var(--font-family);\n      background: #1E1B2E;\n      min-height: 100vh;\n      display: flex;\n      justify-content: center;\n      align-items: flex-start;\n      padding: 20px 0;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      background: var(--color-background);\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .status-bar {\n      height: 44px;\n      background: var(--color-background);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      padding: 0 8px;\n      background: var(--color-background);\n    }\n\n    .back-btn {\n      width: 48px;\n      height: 48px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: transparent;\n      border: none;\n      cursor: pointer;\n      border-radius: 50%;\n      transition: background 200ms ease-out;\n    }\n\n    .back-btn:active {\n      background: rgba(124, 58, 237, 0.1);\n    }\n\n    .back-btn svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-primary);\n    }\n\n    .app-bar-title {\n      flex: 1;\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      text-align: center;\n      padding-right: 48px;\n    }\n\n    .content {\n      padding: 0 16px 24px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-top: 24px;\n    }\n\n    .card {\n      background: var(--color-surface);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .section-header {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      line-height: 24px;\n      margin-bottom: 12px;\n    }\n\n    .list-item {\n      display: flex;\n      flex-direction: row;\n      align-items: center;\n      gap: 12px;\n      background: transparent;\n      border: none;\n      width: 100%;\n      padding: 12px 0;\n      cursor: pointer;\n      font-family: var(--font-family);\n      text-align: left;\n      min-height: 56px;\n      transition: opacity 200ms ease-out;\n    }\n\n    .list-item:not(