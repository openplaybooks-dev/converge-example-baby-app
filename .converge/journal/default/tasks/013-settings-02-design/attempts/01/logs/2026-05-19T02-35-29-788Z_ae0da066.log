order-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .status-bar {\n      height: 44px;\n      background: var(--color-background);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      padding: 0 8px;\n      background: var(--color-background);\n    }\n\n    .back-btn {\n      width: 48px;\n      height: 48px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: transparent;\n      border: none;\n      cursor: pointer;\n      border-radius: 50%;\n      transition: background 200ms ease-out;\n    }\n\n    .back-btn:active {\n      background: rgba(124, 58, 237, 0.1);\n    }\n\n    .back-btn svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-primary);\n    }\n\n    .app-bar-title {\n      flex: 1;\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      text-align: center;\n      padding-right: 48px;\n    }\n\n    .content {\n      padding: 0 16px 24px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-top: 24px;\n    }\n\n    .card {\n      background: var(--color-surface);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .section-header {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      line-height: 24px;\n      margin-bottom: 12px;\n    }\n\n    .list-item {\n      display: flex;\n      flex-direction: row;\n      align-items: center;\n      gap: 12px;\n      background: transparent;\n      border: none;\n      width: 100%;\n      padding: 12px 0;\n      cursor: pointer;\n      font-family: var(--font-family);\n      text-align: left;\n      min-height: 56px;\n      transition: opacity 200ms ease-out;\n    }\n\n    .list-item:not(:last-child) {\n      border-bottom: 1px solid var(--color-border);\n    }\n\n    .list-item:active {\n      opacity: 0.7;\n    }\n\n    .list-item-icon {\n      width: 40px;\n      height: 40px;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      flex-shrink: 0;\n      background: rgba(124, 58, 237, 0.1);\n    }\n\n    .list-item-icon svg {\n      width: 20px;\n      height: 20px;\n      color: var(--color-primary);\n    }\n\n    .list-item-icon.destructive {\n      background: rgba(239, 68, 68, 0.1);\n    }\n\n    .list-item-icon.destructive svg {\n      color: var(--color-error);\n    }\n\n    .list-item-content {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n      gap: 2px;\n    }\n\n    .list-item-title {\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      line-height: 20px;\n    }\n\n    .list-item-description {\n      font-size: 14px;\n      font-weight: 400;\n      color: var(--color-text-secondary);\n      line-height: 20px;\n    }\n\n    .list-item-value {\n      font-size: 14px;\n      font-weight: 400;\n      color: var(--color-text-secondary);\n      flex-shrink: 0;\n    }\n\n    .list-item-chevron {\n      color: var(--color-text-secondary);\n      flex-shrink: 0;\n    }\n\n    .list-item-chevron svg {\n      width: 20px;\n      height: 20px;\n    }\n\n    /* Switch styles */\n    .switch-row {\n      display: flex;\n      flex-direction: row;\n      align-items: center;\n      gap: 12px;\n      padding: 12px 0;\n      min-height: 56px;\n    }\n\n    .switch-row:not(:last-child) {\n      bord