tton>\n          </div>\n\n          <div class=\"switch-row\">\n            <div class=\"switch-content\">\n              <span class=\"switch-label\">Symptom Alerts</span>\n              <span class=\"switch-description\">Track and log symptom changes</span>\n            </div>\n            <button class=\"switch-track active\" role=\"switch\" aria-checked=\"true\" aria-label=\"Symptom Alerts, notifications enabled, double tap to toggle\">\n              <div class=\"switch-thumb\"></div>\n            </button>\n          </div>\n\n          <div class=\"switch-row\">\n            <div class=\"switch-content\">\n              <span class=\"switch-label\">Appointment Reminders</span>\n              <span class=\"switch-description\">Upcoming prenatal visit alerts</span>\n            </div>\n            <button class=\"switch-track\" role=\"switch\" aria-checked=\"false\" aria-label=\"Appointment Reminders, notifications disabled, double tap to toggle\">\n              <div class=\"switch-thumb\"></div>\n            </button>\n          </div>\n\n          <div class=\"switch-row\">\n            <div class=\"switch-content\">\n              <span class=\"switch-label\">Weekly Digest</span>\n              <span class=\"switch-description\">Summary of your pregnancy journey</span>\n            </div>\n            <button class=\"switch-track\" role=\"switch\" aria-checked=\"false\" aria-label=\"Weekly Digest, notifications disabled, double tap to toggle\">\n              <div class=\"switch-thumb\"></div>\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <!-- Section 3: Data -->\n      <section class=\"section\">\n        <div class=\"card\">\n          <div class=\"section-header\">Data</div>\n\n          <button class=\"action-row\" aria-label=\"Export data, double tap to save and share your data\">\n            <div class=\"action-icon export\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"/>\n                <polyline points=\"7 10 12 15 17 10\"/>\n                <line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\"/>\n              </svg>\n            </div>\n            <div class=\"action-content\">\n              <span class=\"action-label\">Export Data</span>\n              <span class=\"action-description\">Save and share your data as JSON</span>\n            </div>\n            <div class=\"action-chevron\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M9 18l6-6-6-6\"/>\n              </svg>\n            </div>\n          </button>\n\n          <button class=\"action-row destructive\" aria-label=\"Clear all data, double tap to delete all app data. This action cannot be undone.\">\n            <div class=\"action-icon clear\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <polyline points=\"3 6 5 6 21 6\"/>\n                <path d=\"M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2\"/>\n                <line x1=\"10\" y1=\"11\" x2=\"10\" y2=\"17\"/>\n                <line x1=\"14\" y1=\"11\" x2=\"14\" y2=\"17\"/>\n              </svg>\n            </div>\n            <div class=\"action-content\">\n              <span class=\"action-label\">Clear All Data</span>\n              <span class=\"action-description\">Delete all app data permanently</span>\n            </div>\n            <div class=\"action-chevron\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M9 18l6-6-6-6\"/>\n              </svg>\n            </div>\n          </button>\n        </div>\n      </section>\n\n      <!-- Section 4: About -->\n      <section class=\"section\">\n        <div class=\"card\">\n          <div class=\"section-header\">About</div>\n\n          <div class=\"about-row\">\n            <span class=\"about-label\">Version</span>\n            <span class=\"about-value\">1.0.0</span>\n          </div>\n\n          <button class=\"about-link\" aria-label=\"Privacy policy, opens in browser\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>\n            </svg>\n            Privacy Policy\n            <svg style=\"margin-left: auto\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M9 18l6-6-6-6\"/>\n            </svg>\n          </button>\n\n          <button class=\"about-link\" aria-label=\"Terms of service, opens in browser\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/>\n              <polyline points=\"14 2 14 8 20 8\"/>\n              <line x1=\"16\" y1=\"13\" x2=\"8\" y2=\"13\"/>\n              <line x1=\"16\" y1=\"17\" x2=\"8\" y2=\"17\"/>\n              <polyline points=\"10 9 9 9 8 9\"/>\n            </svg>\n            Terms of Service\n            <svg style=\"margin-left: auto\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M9 18l6-6-6-6\"/>\n            </svg>\n          </button>\n        </div>\n      </section>\n    </main>\n\n    <div class=\"home-indicator\"></div>\n  </div>\n</body>\n</html>"
