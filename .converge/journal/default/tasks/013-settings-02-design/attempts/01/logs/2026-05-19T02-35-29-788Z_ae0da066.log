ter;\n      flex-shrink: 0;\n    }\n\n    .action-icon.export {\n      background: rgba(110, 231, 183, 0.2);\n    }\n\n    .action-icon.export svg {\n      color: var(--color-tertiary);\n    }\n\n    .action-icon.clear {\n      background: rgba(239, 68, 68, 0.1);\n    }\n\n    .action-icon.clear svg {\n      color: var(--color-error);\n    }\n\n    .action-icon svg {\n      width: 20px;\n      height: 20px;\n    }\n\n    .action-content {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n      gap: 2px;\n    }\n\n    .action-label {\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      line-height: 20px;\n    }\n\n    .action-description {\n      font-size: 14px;\n      font-weight: 400;\n      color: var(--color-text-secondary);\n      line-height: 20px;\n    }\n\n    .action-chevron {\n      color: var(--color-text-secondary);\n      flex-shrink: 0;\n    }\n\n    .action-chevron svg {\n      width: 20px;\n      height: 20px;\n    }\n\n    /* About section */\n    .about-row {\n      display: flex;\n      flex-direction: row;\n      align-items: center;\n      gap: 12px;\n      padding: 12px 0;\n      min-height: 48px;\n    }\n\n    .about-row:not(:last-child) {\n      border-bottom: 1px solid var(--color-border);\n    }\n\n    .about-row:last-child {\n      border-bottom: none;\n    }\n\n    .about-label {\n      flex: 1;\n      font-size: 14px;\n      font-weight: 400;\n      color: var(--color-text-secondary);\n    }\n\n    .about-value {\n      font-size: 14px;\n      font-weight: 400;\n      color: var(--color-text-primary);\n    }\n\n    .about-link {\n      flex: 1;\n      display: flex;\n      flex-direction: row;\n      align-items: center;\n      gap: 8px;\n      background: transparent;\n      border: none;\n      font-family: var(--font-family);\n      font-size: 14px;\n      font-weight: 500;\n      color: var(--color-primary);\n      cursor: pointer;\n      padding: 0;\n      min-height: 4