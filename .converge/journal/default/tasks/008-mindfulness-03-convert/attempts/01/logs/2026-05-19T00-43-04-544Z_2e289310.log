[2026-05-19T00:43:22.982Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_xrqt19a43n2x_2","type":"tool_result","content":"1\timport 'package:flutter/material.dart';\n2\timport 'package:go_router/go_router.dart';\n3\t\n4\timport '../../theme/app_theme.dart';\n5\t\n6\tclass PregnancyProgressScreen extends StatefulWidget {\n7\t  const PregnancyProgressScreen({super.key});\n8\t\n9\t  @override\n10\t  State<PregnancyProgressScreen> createState() => _PregnancyProgressScreenState();\n11\t}\n12\t\n13\tclass _PregnancyProgressScreenState extends State<PregnancyProgressScreen> {\n14\t  late PageController _pageController;\n15\t  int _currentWeek = 12;\n16\t\n17\t  @override\n18\t  void initState() {\n19\t    super.initState();\n20\t    _pageController = PageController(initialPage: _currentWeek - 1);\n21\t  }\n22\t\n23\t  @override\n24\t  void dispose() {\n25\t    _pageController.dispose();\n26\t    super.dispose();\n27\t  }\n28\t\n29\t  @override\n30\t  Widget build(BuildContext context) {\n31\t    final theme = Theme.of(context);\n32\t    final colorScheme = theme.colorScheme;\n33\t    final textTheme = theme.textTheme;\n34\t\n35\t    return Scaffold(\n36\t      backgroundColor: colorScheme.surfaceContainer,\n37\t      appBar: AppBar(\n38\t        backgroundColor: colorScheme.surfaceContainer,\n39\t        elevation: 0,\n40\t        leading: IconButton(\n41\t          onPressed: () => context.pop(),\n42\t          icon: const Icon(Icons.arrow_back_ios, size: 24),\n43\t          padding: EdgeInsets.zero,\n44\t          constraints: const BoxConstraints(minWidth: 48, minHeight: 48),\n45\t        ),\n46\t        title: Text(\n47\t          'My Pregnancy',\n48\t          style: textTheme.headlineSmall?.copyWith(\n49\t            color: colorScheme.onSurface,\n50\t          ),\n51\t        ),\n52\t        centerTitle: true,\n53\t      ),\n54\t      body: Stack(\n55\t        children: [\n56\t          PageView.builder(\n57\t            controller: _pageController,\n58\t            itemCount: 40,\n59\t            onPageChanged: (index) {\n60\t              setState(() {\n61\t                _currentWeek = index + 1;\n62\t              });\n63\t            },\n64\t            itemBuilder: (context, index) {\n65\t              final week = index + 1;\n66\t              return _WeekPage(week: week);\n67\t            },\n68\t          ),\n69\t          Positioned(\n70\t            left: 0,\n71\t            right: 0,\n72\t            bottom: 0,\n73\t            child: _DueDateSummaryCard(currentWeek: _currentWeek),\n74\t          ),\n75\t        ],\n76\t      ),\n77\t    );\n78\t  }\n79\t}\n80\t\n81\tclass _WeekPage extends StatelessWidget {\n82\t  final int week;\n83\t\n84\t  const _WeekPage({required this.week});\n85\t\n86\t  @override\n87\t  Widget build(BuildContext context) {\n88\t    final trimester = _getTrimester(week);\n89\t    final weeksRemaining = 40 - week;\n90\t    final dueDate = DateTime(2026, 1, 15);\n91\t    final fruitEmoji = _getFruitEmoji(week);\n92\t\n93\t    return SingleChildScrollView(\n94\t      padding: const EdgeInsets.only(\n95\t        left: AppTheme.spaceMd,\n96\t        right: AppTheme.spaceMd,\n97\t        top: AppTheme.spaceXs,\n98\t        bottom: 160,\n99\t      ),\n100\t      child: Column(\n101\t        children: [\n102\t          _WeekHeroCard(\n103\t            week: week,\n104\t            trimester: trimester,\n105\t            weeksRemaining: weeksRemaining,\n106\t            dueDate: dueDate,\n107\t            fruitEmoji: fruitEmoji,\n108\t          ),\n109\t          const SizedBox(height: AppTheme.spaceMd),\n110\t          _BodyChangesCard(week: week),\n111\t          const SizedBox(height: AppTheme.spaceMd),\n112\t          _BabyDevelopmentCard(week: week),\n113\t          const SizedBox(height: AppTheme.spaceMd),\n114\t          _SelfCareTipsCard(week: week),\n115\t        ],\n116\t      ),\n117\t    );\n118\t  }\n119\t\n120\t  String _getTrimester(int week) {\n121\t    if (week <= 13) return 'First Trimester';\n122\t    if (week <= 26) return 'Second Trimester';\n123\t    return 'Third Trimester';\n124\t  }\n125\t\n126\t  String _getFruitEmoji(int week) {\n127\t    const fruits = [\n128\t      ' poppy seed', // 4\n129\t      ' sesame seed', // 5\n130\t      '🫐 blueberry', // 6\n131\t      '🫐 blueberry', // 7\n132\t      '🫐 blueberry', // 8\n133\t      '🫐 blueberry', // 9\n134\t      '🫐 blueberry', // 10\n135\t      '🍒 cherry', // 11\n136\t      '🍒 cherry', // 12\n137\t      '🍒 cherry', // 12\n138\t      '🍅 tomato', // 12\n139\t    ];\n140\t    if (week < 4) return '🌱 seed';\n141\t    if (week > 12) return '🍅 tomato';\n142\t    return fruits[week - 4];\n143\t  }\n144\t}\n145\t\n146\tclass _WeekHeroCard extends StatelessWidget {\n147\t  final int week;\n148\t  final String trimester;\n149\t  final int weeksRemaining;\n150\t  final DateTime dueDate;\n151\t  final String fruitEmoji;\n152\t\n153\t  const _WeekHeroCard({\n154\t    required this.week,\n155\t    required this.trimester,\n156\t    required this.weeksRemaining,\n157\t    required this.dueDate,\n158\t    required this.fruitEmoji,\n159\t  });\n160\t\n161\t  @override\n162\t  Widget build(BuildContext context) {\n163\t    final theme = Theme.of(context);\n164\t    final colorScheme = theme.colorScheme;\n165\t    final textTheme = theme.textTheme;\n166\t\n167\t    return Container(\n168\t      width: double.infinity,\n169\t      padding: const EdgeInsets.all(AppTheme.spaceLg),\n170\t      decoration: BoxDecoration(\n171\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n172\t        gradient: LinearGradient(\n173\t          begin: Alignment.topCenter,\n174\t          end: Alignment.bottomCenter,\n175\t          colors: [\n176\t            colorScheme.tertiary,\n177\t            colorScheme.surface,\n178\t          ],\n179\t        ),\n180\t      ),\n181\t      child: Column(\n182\t        children: [\n183\t          Container(\n184\t            width: 80,\n185\t            height: 80,\n186\t            decoration: BoxDecoration(\n187\t              color: colorScheme.tertiary.withValues(alpha: 0.5),\n188\t              shape: BoxShape.circle,\n189\t            ),\n190\t            child: Center(\n191\t              child: Text(\n192\t                fruitEmoji.split(' ').first,\n193\t                style: const TextStyle(fontSize: 40),\n194\t              ),\n195\t            ),\n196\t          ),\n197\t          const SizedBox(height: AppTheme.spaceSm),\n198\t          Text(\n199\t            'Week $week',\n200\t            style: TextStyle(\n201\t              fontSize: 57,\n202\t              fontWeight: FontWeight.w700,\n203\t              height: 64 / 57,\n204\t              color: colorScheme.primary,\n205\t            ),\n206\t          ),\n207\t          const SizedBox(height: AppTheme.spaceXs),\n208\t          Container(\n209\t            padding: const EdgeInsets.symmetric(\n210\t              horizontal: AppTheme.spaceSm,\n211\t              vertical: AppTheme.spaceXxs,\n212\t            ),\n213\t            decoration: BoxDecoration(\n214\t              color: colorScheme.tertiary.withValues(alpha: 0.3),\n215\t              borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n216\t            ),\n217\t            child: Row(\n218\t              mainAxisSize: MainAxisSize.min,\n219\t              children: [\n220\t                Text(\n221\t                  trimester,\n222\t                  style: textTheme.labelLarge?.copyWith(\n223\t                    color: colorScheme.primary,\n224\t                  ),\n225\t                ),\n226\t              ],\n227\t            ),\n228\t          ),\n229\t          const SizedBox(height: AppTheme.spaceXs),\n230\t          Text(\n231\t            '$weeksRemaining weeks to go',\n232\t            style: textTheme.bodyMedium?.copyWith(\n233\t              color: colorScheme.onSurfaceVariant,\n234\t            ),\n235\t          ),\n236\t          co