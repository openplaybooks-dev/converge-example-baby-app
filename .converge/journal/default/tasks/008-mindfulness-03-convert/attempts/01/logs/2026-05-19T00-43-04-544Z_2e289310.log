eturn Container(\n352\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n353\t      decoration: BoxDecoration(\n354\t        color: colorScheme.surface,\n355\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n356\t        boxShadow: const [\n357\t          BoxShadow(\n358\t            color: AppTheme.shadow,\n359\t            blurRadius: 24,\n360\t            offset: Offset(0, 8),\n361\t          ),\n362\t        ],\n363\t      ),\n364\t      child: Column(\n365\t        crossAxisAlignment: CrossAxisAlignment.start,\n366\t        children: [\n367\t          Text(\n368\t            'Baby\\'s Development',\n369\t            style: textTheme.titleLarge?.copyWith(\n370\t              color: colorScheme.onSurface,\n371\t            ),\n372\t          ),\n373\t          const SizedBox(height: AppTheme.spaceSm),\n374\t          Text(\n375\t            _getBabyDevelopment(week),\n376\t            style: textTheme.bodyLarge?.copyWith(\n377\t              color: colorScheme.onSurface,\n378\t            ),\n379\t          ),\n380\t        ],\n381\t      ),\n382\t    );\n383\t  }\n384\t\n385\t  String _getBabyDevelopment(int week) {\n386\t    const developments = {\n387\t      12:\n388\t          'Your baby is now about 2 inches long — the size of a plum! Fingers and toes are fully formed, and tooth buds are appearing beneath the gums. The brain continues to develop rapidly, and your baby may start making small movements you can\\'t feel yet.',\n389\t      24:\n390\t          'Your baby is about 12 inches long — the size of a papaya! The brain is developing rapidly, and the baby can hear your voice. Fat is beginning to accumulate, giving the skin a smoother appearance.',\n391\t    };\n392\t    return developments[week] ??\n393\t        'Your baby is growing and developing. Each week brings new milestones.';\n394\t  }\n395\t}\n396\t\n397\tclass _SelfCareTipsCard extends StatefulWidget {\n398\t  final int week;\n399\t\n400\t  const _SelfCareTipsCard({required