261	@keyframes fade-in {
262	  from { opacity: 0; transform: translateY(8px); }
263	  to { opacity: 1; transform: translateY(0); }
264	}
265	[data-animate="fade-in"] {
266	  animation: fade-in var(--duration-normal) var(--ease-out) backwards;
267	}
268	[data-animate-delay="100"] { animation-delay: 100ms; }
269	[data-animate-delay="200"] { animation-delay: 200ms; }
