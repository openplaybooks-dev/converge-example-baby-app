641	  Widget _buildNavDestination(
642	    BuildContext context,
643	    IconData icon,
644	    String label,
645	    bool isActive,
646	  ) {
647	    final theme = Theme.of(context);
648	    final colorScheme = theme.colorScheme;
649	
650	    return Container(
651	      padding: const EdgeInsets.symmetric(
652	        horizontal: AppTheme.spaceMd,
653	        vertical: AppTheme.spaceXs,
654	      ),
655	      decoration: isActive
656	          ? BoxDecoration(
657	              color: colorScheme.primary.withValues(alpha: 0.15),
658	              borderRadius: BorderRadius.circular(AppTheme.radiusPill),
659	            )
660	          : null,
661	      child: Column(
662	        mainAxisSize: MainAxisSize.min,
663	        children: [
664	          Icon(
665	            icon,
666	            size: 24,
667	            color: isActive ? colorScheme.primary : colorScheme.onSurfaceVariant,
668	          ),
669	          const SizedBox(height: AppTheme.spaceXxs),
670	          Text(
671	            label,
672	            style: TextStyle(
673	              fontSize: 12,
674	              fontWeight: isActive ? FontWeight.w600 : FontWeight.w500,
675	              color: isActive ? colorScheme.primary : colorScheme.onSurfaceVariant,
676	            ),
677	          ),
678	        ],
679	      ),
680	    );
681	  }
682	}
