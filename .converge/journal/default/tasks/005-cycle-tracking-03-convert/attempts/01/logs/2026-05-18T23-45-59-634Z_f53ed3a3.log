629	          mainAxisAlignment: MainAxisAlignment.spaceAround,
630	          children: [
631	            _buildNavDestination(context, Icons.home, 'Home', true),
632	            _buildNavDestination(context, Icons.search, 'Browse', false),
633	            _buildNavDestination(context, Icons.bookmark_outline, 'Library', false),
634	            _buildNavDestination(context, Icons.person_outline, 'Profile', false),
635	          ],
636	        ),
637	      ),
638	    );
639	  }
