  .radius-full { border-radius: 999px; }\n\n    /* Text styles */\n    .text-hero { font-size: 57px; font-weight: 700; line-height: 64px; color: var(--lavender-bloom); }\n    .text-title { font-size: 22px; font-weight: 600; line-height: 28px; color: var(--deep-graphite); }\n    .text-subtitle { font-size: 16px; font-weight: 500; line-height: 24px; color: var(--deep-graphite); }\n    .text-body { font-size: 16px; font-weight: 400; line-height: 24px; color: var(--deep-graphite); }\n    .text-body-sm { font-size: 14px; font-weight: 400; line-height: 20px; color: var(--deep-graphite); }\n    .text-caption { font-size: 11px; font-weight: 500; line-height: 16px; color: var(--stone-grey); }\n    .text-muted { font-size: 14px; font-weight: 400; line-height: 20px; color: var(--stone-grey); }\n\n    /* Bottom safe area */\n    .safe-bottom { padding-bottom: 34px; }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n\n    <!-- Scaffold -->\n    <div data-flutter=\"scaffold\" data-bg=\"lavenderTint\" class=\"flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- AppBar: no elevation, Lavender Tint background -->\n      <header data-flutter=\"app-bar\" class=\"h-14 flex items-center px-1 bg-lavender-tint\" style=\"box-shadow: none;\">\n        <!-- Back button -->\n        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"w-12 h-12 flex items-center justify-center rounded-full\">\n          <svg class=\"w-6 h-6\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n            <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n          </svg>\n        </button>\n        <!-- Title -->\n        <h1 data-flutter=\"app-bar-title\" class=\"flex-1 text-center mr-12 text-xl font-semibold\" style=\"color: var(--deep-graphite);\">My Pregnancy</h1>\n      </header>\n\n      <!-- Body: PageView for week-by-week swiper -->\n      <main data-flutter=\"body\" class=\"flex-1 overflow-y-auto pb-[140px]\">\n\n        <!-- PageView container (shows week 