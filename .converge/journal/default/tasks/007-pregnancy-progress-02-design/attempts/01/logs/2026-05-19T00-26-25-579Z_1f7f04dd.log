r-title\" class=\"flex-1 text-center mr-12 text-xl font-semibold\" style=\"color: var(--deep-graphite);\">My Pregnancy</h1>\n      </header>\n\n      <!-- Body: PageView for week-by-week swiper -->\n      <main data-flutter=\"body\" class=\"flex-1 overflow-y-auto pb-[140px]\">\n\n        <!-- PageView container (shows week 12 as example) -->\n        <div data-flutter=\"page-view\" data-controller=\"pageView\" class=\"min-h-full\">\n\n          <!-- Individual Week Page -->\n          <div data-page=\"12\" class=\"px-4 pt-2 pb-4\">\n\n            <!-- 7.1 WeekHeroCard: full-width, ~40% screen height -->\n            <div class=\"radius-lg p-6 text-center relative overflow-hidden\" style=\"background: linear-gradient(180deg, #F9A8D4 0%, #FFFFFF 100%); min-height: 280px;\">\n              <!-- Fruit emoji -->\n              <div class=\"mb-4\">\n                <div class=\"w-20 h-20 mx-auto rounded-full overflow-hidden flex items-center justify-center\" style=\"background: #FBC4E0;\">\n                  <span class=\"text-5xl\">🍅</span>\n                </div>\n              </div>\n              <!-- Week number hero -->\n              <div data-flutter=\"text\" data-text=\"displayLarge\" class=\"text-hero\">Week 12</div>\n              <!-- Trimester badge -->\n              <div data-flutter=\"chip\" data-color=\"blushRose\" class=\"inline-flex items-center gap-1 px-3 py-1 rounded-full mt-2\" style=\"background: rgba(249,168,212,0.3);\">\n                <span class=\"text-sm font-semibold\" style=\"color: var(--lavender-bloom);\">First Trimester</span>\n              </div>\n              <!-- Countdown text -->\n              <p class=\"text-muted mt-3\">18 weeks to go</p>\n              <!-- Due date -->\n              <p class=\"text-caption mt-1\">Due January 15, 2026</p>\n            </div>\n\n            <!-- 7.2 BodyChangesCard -->\n            <div data-flutter=\"card\" class=\"radius-lg p-4 mt-4 bg-warm-white card-shadow\">\n              <h2 data-flutter=\"text\" data-text=\"titleLarge\" class=\"text-title mb-3\">Body Changes</h2>\n              <ul data-flutter=\"list\" class=\"space-y-3\">\n                <li data-flutter=\"list-item\" class=\"flex items-start gap-3\">\n                  <span class=\"w-2 h-2 rounded-full mt-2 shrink-0\" style=\"background: var(--blush-rose);\"></span>\n                  <span class=\"text-body-sm\">Your uterus is now about the size of a grapefruit</span>\n                </li>\n                <li data-flutter=\"list-item\" class=\"flex items-start gap-3\">\n                  <span class=\"w-2 h-2 rounded-full mt-2 shrink-0\" style=\"background: var(--blush-rose);\"></span>\n                  <span class=\"text-body-sm\">You may experience mild cramping or round ligament pain</span>\n                </li>\n                <li data-flutter=\"list-item\" class=\"flex items-start gap-3\">\n                  <span class=\"w-2 h-2 rounded-full mt-2 shrink-0\" style=\"background: var(--blush-rose);\"></span>\n                  <span class=\"text-body-sm\">Fatigue may continue, but energy often improves this trimester</span>\n                </li>\n              </ul>\n            </div>\n\n            <!-- 7.3 BabyDevelopmentCard -->\n            <div data-flutter=\"card\" class=\"radius-lg p-4 mt-4 bg-warm-white card-shadow\">\n              <h2 data-flutter=\"text\" data-text=\"titleLarge\" class=\"text-title mb-3\">Baby's Development</h2>\n              <p class=\"text-body\">Your baby is now about 2 inches long — the size of a plum! Fingers and toes are fully formed, and tooth buds are appearing beneath the gums. The brain continues to develop rapidly, and your baby may start making small movements you can't feel yet.</p>\n            </div>\n\n            <!-- 7.4 SelfCareTipsCard -->\n            <div data-flutter=\"card\" class=\"radius-lg p-4 mt-4 bg-warm-white card-shadow\">\n              <h2 data-flutter=\"text\" data-text=\"titleLarge\" class=\"text-title mb-4\">Self-Care Tips</h2>\n              <div data-flutter=\"column\" data-spacing=\"md\" class=\"space-y-3\">\n\n                <!-- Tip 1 -->\n                <div data-flutter=\"expandable-tip\" class=\"radius-md p-3 border\" style=\"border-color: var(--misty-border);\">\n                  <div data-flutter=\"row\" data-cross-axis=\"center\" class=\"items-center gap-3\">\n                    <div data-flutter=\"avatar\" data-color=\"blushRose\" class=\"w-8 h-8 rounded-full flex items-center justify-center shrink-0\" style=\"background: var(--blush-rose);\">\n                      <span class=\"text-sm font-semibold\" style=\"color: var(--warm-white);\">1</span>\n                    </div>\n                    <span class=\"text-subtitle flex-1\">Stay hydrated</span>\n                    <svg class=\"w-5 h-5 text-stone-grey\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                      <path d=\"M19 9l-7 7-7-7\"/>\n                    </svg>\n                  </div>\n                  <p class=\"text-body-sm mt-3 pl-11\">Aim for 8-10 glasses of water daily. Staying hydrated helps prevent UTIs and constipation, common during pregnancy.</p>\n                </div>\n\n                <!-- Tip 2 -->\n                <div data-flutter=\"expandable-tip\" class=\"radius-md p-3 border\" style=\"border-color: var(--misty-border);\">\n                  <div data-flutter=\"row\" data-cross-axis=\"center\" class=\"items-center gap-3\">\n                    <div data-flutter=\"avatar\" data-color=\"blushRose\" class=\"w-8 h-8 rounded-full flex items-center justify-center shrink-0\" style=\"background: var(--blush-rose);\">\n                      <span class=\"text-sm font-semibold\" style=\"color: var(--warm-white);\">2</span>\n                    </div>\n                    <span class=\"text-subtitle flex-1\">Try gentle exercise</span>\n                    <svg class=\"w-5 h-5 text-stone-grey\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                      <path d=\"M19 9l-7 7-7-7\"/>\n                    </svg>\n                  </div>\n                  <p class=\"text-body-sm mt-3 pl-11\">Walking or prenatal yoga can help with energy levels and prepare your body for labor.</p>\n                </div>\n\n                <!-- Tip 3 -->\n                <div data-flutter=\"expandable-tip\" class=\"radius-md p-3 border\" style=\"border-color: var(--misty-border);\">\n                  <div data-flutter=\"row\" data-cross-axis=\"center\" class=\"items-center gap-3\">\n                    <div data-flutter=\"avatar\" data-color=\"blushRose\" class=\"w-8 h-8 rounded-full flex items-center justify-center shrink-0\" style=\"background: var(--blush-rose);\">\n                      <span class=\"text-sm font-semibold\" style=\"color: var(--warm-white);\">3</span>\n                    </div>\n                    <span class=\"text-subtitle flex-1\">Schedule your anatomy scan</span>\n                    <svg class=\"w-5 h-5 text-stone-grey\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                      <path d=\"M19 9l-7 7-7-7\"/>\n                    </svg>\n                  </div>\n                  <p class=\"text-body-sm mt-3 pl-11\">Your 20-week anatomy scan is approaching. This detailed ultrasound checks baby's development and is often covered by insurance.</p>\n                </div>\n\n              </div>\n            </div>\n\n          </div>\n          <!-- End week page -->\n\n        </div>\n        <!-- End PageView -->\n\n      </main>\n      <!-- End Body -->\n\n      <!-- 7.5 DueDateSummaryCard: pinned at bottom, always visible -->\n      <div data-flutter=\"container\" class=\"absolute bottom-0 left-0 right-0 radius-sheet bg-warm-white card-shadow safe-bottom\" style=\"padding-bottom: env(safe-area-inset-bottom, 0);\">\n\n        <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"px-5 py-4\">\n          <!-- Left: Trimester + Due date -->\n          <div>\n            <div data-flutter=\"chip\" class=\"inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full mb-2\" style=\"background: var(--lavender-bloom);\">\n              <svg class=\"w-4 h-4\" viewBox=\"0 0 24 24\" fill=\"var(--warm-white)\">\n                <path d=\"M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z\"/>\n              </svg>\n              <span class=\"text-xs font-semibold\" style=\"color: var(--warm-white);\">First Trimester</span>\n            </div>\n            <p class=\"text-caption\">Due Date</p>\n            <p data-flutter=\"text\" data-text=\"titleMedium\" class=\"text-subtitle\">January 15, 2026</p>\n          </div>\n          <!-- Right: Days remaining -->\n          <div class=\"text-right\">\n            <p data-flutter=\"text\" data-text=\"displayLarge\" class=\"text-3xl font-bold\" style=\"color: var(--soft-mint);\">126</p>\n            <p class=\"text-muted text-sm\">days to go</p>\n          </div>\n        </div>\n\n      </div>\n      <!-- End DueDateSummaryCard -->\n\n    </div>\n    <!-- End Scaffold -->\n\n  </div>\n</body>\n</html>","structuredPatch":[],"originalFile":null,"userModified":false}}
