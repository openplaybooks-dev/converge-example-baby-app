: 50%;\n203\t      display: flex;\n204\t      align-items: center;\n205\t      justify-content: center;\n206\t      flex-shrink: 0;\n207\t    }\n208\t\n209\t    .icon-container.mindfulness {\n210\t      background: rgba(249, 168, 212, 0.2);\n211\t    }\n212\t\n213\t    .icon-container.settings {\n214\t      background: rgba(124, 58, 237, 0.15);\n215\t    }\n216\t\n217\t    .icon-container svg {\n218\t      width: 24px;\n219\t      height: 24px;\n220\t    }\n221\t\n222\t    .icon-container.mindfulness svg {\n223\t      color: var(--color-secondary);\n224\t    }\n225\t\n226\t    .icon-container.settings svg {\n227\t      color: var(--color-primary);\n228\t    }\n229\t\n230\t    .nav-card-content {\n231\t      flex: 1;\n232\t      display: flex;\n233\t      flex-direction: column;\n234\t      gap: 2px;\n235\t    }\n236\t\n237\t    .nav-card-title {\n238\t      font-size: 16px;\n239\t      font-weight: 600;\n240\t      color: var(--color-text-primary);\n241\t      line-height: 24px;\n242\t    }\n243\t\n244\t    .nav-card-description {\n245\t      font-size: 14px;\n246\t      font-weight: 400;\n247\t      color: var(--color-text-secondary);\n248\t      line-height: 20px;\n249\t    }\n250\t\n251\t    .chevron {\n252\t      color: var(--color-text-secondary);\n253\t      flex-shrink: 0;\n254\t    }\n255\t\n256\t    .chevron svg {\n257\t      width: 24px;\n258\t      height: 24px;\n259\t    }\n260\t\n261\t    .about-card {\n262\t      background: var(--color-white);\n263\t      border-radius: var(--radius-card);\n264\t      padding: 16px;\n265\t      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n266\t    }\n267\t\n268\t    .about-title {\n269\t      font-size: 16px;\n270\t      font-weight: 600;\n271\t      color: var(--color-text-primary);\n272\t      line-height: 24px;\n273\t      margin-bottom: 4px;\n274\t    }\n275\t\n276\t    .about-version {\n277\t      font-size: 12px;\n278\t      font-weight: 400;\n279\t      color: var(--color-text-secondary);\n280\t      line-height