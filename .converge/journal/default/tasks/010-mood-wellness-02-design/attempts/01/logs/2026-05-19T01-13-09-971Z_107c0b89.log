in-bottom: 4px;\n281\t    }\n282\t\n283\t    .tip-text {\n284\t      font-size: 14px;\n285\t      font-weight: 500;\n286\t      line-height: 20px;\n287\t    }\n288\t\n289\t    .state-indicator {\n290\t      position: absolute;\n291\t      top: 60px;\n292\t      right: 16px;\n293\t      padding: 4px 12px;\n294\t      border-radius: 12px;\n295\t      font-size: 11px;\n296\t      font-weight: 600;\n297\t      text-transform: uppercase;\n298\t      letter-spacing: 0.5pt;\n299\t    }\n300\t\n301\t    .state-indicator.empty {\n302\t      background: var(--color-border);\n303\t      color: var(--color-text-secondary);\n304\t    }\n305\t\n306\t    .state-indicator.filling {\n307\t      background: var(--color-secondary);\n308\t      opacity: 0.3;\n309\t      color: var(--color-text-primary);\n310\t    }\n311\t\n312\t    .state-indicator.complete {\n313\t      background: var(--color-tertiary);\n314\t      color: var(--color-text-primary);\n315\t    }\n316\t\n317\t    .bottom-nav {\n318\t      position: absolute;\n319\t      bottom: 0;\n320\t      left: 0;\n321\t      right: 0;\n322\t      height: 80px;\n323\t      background: var(--color-white);\n324\t      display: flex;\n325\t      justify-content: space-around;\n326\t      align-items: flex-start;\n327\t      padding-top: 8px;\n328\t      border-top: 1px solid var(--color-border);\n329\t    }\n330\t\n331\t    .nav-item {\n332\t      display: flex;\n333\t      flex-direction: column;\n334\t      align-items: center;\n335\t      gap: 4px;\n336\t      padding: 8px 16px;\n337\t      border: none;\n338\t      background: none;\n339\t      cursor: pointer;\n340\t      position: relative;\n341\t    }\n342\t\n343\t    .nav-item.active::before {\n344\t      content: '';\n345\t      position: absolute;\n346\t      top: 0;\n347\t      width: 40px;\n348\t      height: 4px;\n349\t      background: var(--color-primary);\n350\t      border-radius: 2px;\n351\t      opacity: 0.15;\n352\t    }\n353\t\n354\t    .nav-item svg {\n355\t      