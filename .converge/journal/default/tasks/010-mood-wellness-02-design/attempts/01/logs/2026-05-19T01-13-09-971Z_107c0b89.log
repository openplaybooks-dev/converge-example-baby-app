ackwards;\n    }\n    .chart-dot {\n      transition: transform 200ms ease-out;\n    }\n    .chart-dot:hover {\n      transform: scale(1.5);\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n\n    <!-- Scaffold -->\n    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- AppBar -->\n      <header data-flutter=\"app-bar\" class=\"flex items-center h-14 px-4 bg-lavender-tint\">\n        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n          <svg class=\"icon w-6 h-6 text-graphite\" data-name=\"arrow_back\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n            <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n          </svg>\n        </button>\n        <h1 class=\"flex-1 text-xl font-semibold text-graphite text-center pr-12\">Mood & Wellness</h1>\n      </header>\n\n      <!-- Body - CustomScrollView with sections -->\n      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto px-4 pb-6\">\n\n        <!-- Section 1: Today's Mood Card (SliverAppBar expanded child) -->\n        <section class=\"mt-6 mb-6 animate-section\" style=\"animation-delay: 0ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n            <!-- Header row -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n              <div>\n                <h2 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">How are you feeling today?</h2>\n                <p class=\"text-sm text-stone\" style=\"line-height: 20px;\">May 19, 2026</p>\n              </div>\n              <span class=\"badge-pill bg-mint/20 text-graphite\">Today</span>\n            </div>\n\n            <!-- Emoji row -->\n            <div data-flutter=\"row\" data-main-axis=\"space-evenly\" data-spacing=\"sm\" class=\"flex justify-between items-center gap-2 mb-4\">\n              <button class=\"emoji-btn\" aria-label=\"Terrible mood, tap to log\" aria-pressed=\"false\">😔</button>\n              <button class=\"emoji-btn\" aria-label=\"Bad mood, tap to log\" aria-pressed=\"false\">😕</button>\n              <button class=\"emoji-btn\" aria-label=\"Okay mood, tap to log\" aria-pressed=\"false\">😐</button>\n              <button class=\"emoji-btn selected\" aria-label=\"Good mood, tap to log\" aria-pressed=\"true\">🙂</button>\n              <button class=\"emoji-btn\" aria-label=\"Great mood, tap to log\" aria-pressed=\"false\">😊</button>\n            </div>\n\n            <!-- Note field -->\n            <div class=\"mt-4\">\n              <textarea class=\"w-full min-h-[56px] px-4 py-3 bg-misty-border/50 rounded-xl text-sm text-graphite placeholder-stone resize-none transition-shadow duration-200 focus:outline-none focus:ring-2 focus:ring-lavender/30\"\n                data-flutter=\"text-field\"\n                placeholder=\"Add a note (optional, max 200 characters)\"\n                aria-label=\"Mood note\"></textarea>\n            </div>\n          </div>\n        </section>\n\n        <!-- Section 2: Mood Trend Chart -->\n        <section class=\"mb-6 animate-section\" style=\"animation-delay: 50ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4\">\n            <!-- Header with toggle chips -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n              <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Mood Trend</h3>\n              <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1\">\n                <button class=\"chip-tap px-3 py-1.5 rounded-full 