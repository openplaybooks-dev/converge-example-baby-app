ackground: #E8E8E8;\n      display: flex;\n      justify-content: center;\n      padding: 32px 16px;\n      min-height: 100vh;\n    }\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n    }\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n    .card-shadow {\n      box-shadow: 0 4px 16px rgba(0,0,0,0.08);\n    }\n    .card-tap:active {\n      transform: scale(0.98);\n      transition: transform 200ms ease-out;\n    }\n    .badge-pill {\n      padding: 4px 10px;\n      border-radius: 999px;\n      font-size: 11px;\n      font-weight: 600;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n\n    <!-- Scaffold -->\n    <div data-flutter=\"scaffold\" class=\"flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- AppBar -->\n      <header data-flutter=\"app-bar\" class=\"flex items-center h-14 px-4 bg-lavender-tint\">\n        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n          <svg class=\"w-6 h-6 text-graphite\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"/>\n          </svg>\n        </button>\n        <h1 class=\"flex-1 text-xl font-semibold text-graphite text-center pr-12\">Mindfulness</h1>\n      </header>\n\n      <!-- Body - ListView with sections -->\n      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto px-4 pb-6\">\n\n        <!-- Section 1: Breathing Exercises -->\n        <section class=\"mt-6 mb-6\">\n          <h2 class=\"text-[22px] font-semibold text-graphite mb-4\" style=\"line-height: 28px;\">Breathing Exercises</h2>\n\n          <div data-flutter=\"column\" data-spacing=\"sm\" class=\"flex flex-col gap-3\">\n\n            <!-- Card 1: Box Breathing -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Box Breathing</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">2 min</p>\n                  <span class=\"badge-pill bg-mint/20 text-lavender\">Beginner</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n            <!-- Card 2: Deep Breathing -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Deep Breathing</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">3 min</p>\n                  <span class=\"badge-pill bg-mint/20 text-lavender\">Beginner</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n            <!-- Card 3: 4-7-8 Technique -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">4-7-8 Technique</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">4 min</p>\n                  <span class=\"badge-pill bg-blush/30 text-graphite\">Intermediate</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n            <!-- Card 4: Energizing Breath -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Energizing Breath</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">2 min</p>\n                  <span class=\"badge-pill bg-blush/30 text-graphite\">Intermediate</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n          </div>\n        </section>\n\n        <!-- Section 2: Stretching & Self-Care -->\n        <section class=\"mb-6\">\n          <h2 class=\"text-[22px] font-semibold text-graphite mb-4\" style=\"line-height: 28px;\">Stretching & Self-Care</h2>\n\n          <div data-flutter=\"column\" data-spacing=\"sm\" class=\"flex flex-col gap-3\">\n\n            <!-- Card 1: Neck & Shoulders -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Neck & Shoulders</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">5 min</p>\n                  <span class=\"badge-pill bg-blush text-graphite\">All Trimester</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n            <!-- Card 2: Hip Opener -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Hip Opener</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">10 min</p>\n                  <span class=\"badge-pill bg-blush text-graphite\">2nd/3rd Tri</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n            <!-- Card 3: Standing Stretch -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Standing Stretch</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">8 min</p>\n                  <span class=\"badge-pill bg-blush text-graphite\">1st/2nd Tri</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n            <!-- Card 4: Floor Relaxation -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Floor Relaxation</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">15 min</p>\n                  <span class=\"badge-pill bg-blush text-graphite\">All Trimester</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n          </div>\n        </section>\n\n      </main>\n    </div>\n  </div>\n</body>\n</html>","numLines":228,"s