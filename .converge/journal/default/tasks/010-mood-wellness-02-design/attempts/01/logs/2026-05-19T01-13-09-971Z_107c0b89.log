d: #E8E8E8;\n      display: flex;\n      justify-content: center;\n      padding: 32px 16px;\n      min-height: 100vh;\n    }\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n    }\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n    .card-shadow {\n      box-shadow: 0 4px 16px rgba(0,0,0,0.08);\n    }\n    .card-tap:active {\n      transform: scale(0.98);\n      transition: transform 200ms ease-out;\n    }\n    .emoji-btn {\n      width: 56px;\n      height: 56px;\n      border-radius: 50%;\n      border: 2px solid var(--color-border);\n      background: var(--color-surface);\n      font-size: 28px;\n      cursor: pointer;\n      transition: transform 200ms ease-out, border-color 200ms ease-out, background 200ms ease-out;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n    .emoji-btn:hover {\n      border-color: #7C3AED;\n      transform: scale(1.1);\n    }\n    .emoji-btn.selected {\n      border-color: #F9A8D4;\n      border-width: 3px;\n      background: rgba(249, 168, 212, 0.2);\n      transform: scale(1.05);\n    }\n    .chip-tap:active {\n      opacity: 0.8;\n      transition: opacity 150ms ease-out;\n    }\n    .badge-pill {\n      padding: 4px 10px;\n      border-radius: 999px;\n      font-size: 11px;\n      font-weight: 600;\n    }\n    @keyframes fade-in-up {\n      from { opacity: 0; transform: translateY(12px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n    .animate-section {\n      animation: fade-in-up 300ms ease-out backwards;\n    }\n    .chart-dot {\n      transition: transform 200ms ease-out;\n    }\n    .chart-dot:hover {\n      transform: scale(1.5);\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n\n    <!-- Scaffold -->\n    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- AppBar -->\n      <header data-flutter=\"app-bar\" class=\"flex items-center h-14 px-4 bg-lavender-tint\">\n        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n          <svg class=\"icon w-6 h-6 text-graphite\" data-name=\"arrow_back\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n            <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n          </svg>\n        </button>\n        <h1 class=\"flex-1 text-xl font-semibold text-graphite text-center pr-12\">Mood & Wellness</h1>\n      </header>\n\n      <!-- Body - CustomScrollView with sections -->\n      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto px-4 pb-6\">\n\n        <!-- Section 1: Today's Mood Card (SliverAppBar expanded child) -->\n        <section class=\"mt-6 mb-6 animate-section\" style=\"animation-delay: 0ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n            <!-- Header row -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n              <div>\n                <h2 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">How are you feeling today?</h2>\n                <p class=\"text-sm text-stone\" style=\"line-height: 20px;\">May 19, 2026</p>\n              </div>\n              <span class=\"badge-pill bg-mint/20 text-graphite\">Today</span>\n            </div>\n\n            <!-- Emoji row -->\n            <div data-flutter=\"row\" data-main-axis=\"space-evenly\" data-spacing=\"sm\" class=\"flex justify-between items-center gap-2 mb-4\">\n              <button class=\"emoji-btn\" aria-label=\"Terrible mood, tap to log\" aria-pressed=\"false\">😔</button>\n              <button class=\"emoji-btn\" aria-label=\"Bad mood, tap to log\" aria-pressed=\"false\">😕</button>\n              <button class=\"emoji-btn\" aria-label=\"Okay mood, tap to log\" aria-pressed=\"false\">😐</button>\n              <button class=\"emoji-btn selected\" aria-label=\"Good mood, tap to log\" aria-pressed=\"true\">🙂</button>\n              <button class=\"emoji-btn\" aria-label=\"Great mood, tap to log\" aria-pressed=\"false\">😊</button>\n            </div>\n\n            <!-- Note field -->\n            <div class=\"mt-4\">\n              <textarea class=\"w-full min-h-[56px] px-4 py-3 bg-misty-border/50 rounded-xl text-sm text-graphite placeholder-stone resize-none transition-shadow duration-200 focus:outline-none focus:ring-2 focus:ring-lavender/30\"\n                data-flutter=\"text-field\"\n                placeholder=\"Add a note (optional, max 200 characters)\"\n                aria-label=\"Mood note\"></textarea>\n            </div>\n          </div>\n        </section>\n\n        <!-- Section 2: Mood Trend Chart -->\n        <section class=\"mb-6 animate-section\" style=\"animation-delay: 50ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4\">\n            <!-- Header with toggle chips -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n              <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Mood Trend</h3>\n              <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1\">\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-lavender text-white\" data-flutter=\"chip\" data-color=\"primary\">1W</button>\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">1M</button>\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">All</button>\n              </div>\n            </div>\n\n            <!-- Chart area -->\n            <div class=\"relative h-[160px]\">\n              <svg data-flutter=\"custom-paint\" class=\"w-full h-full\" viewBox=\"0 0 300 140\" preserveAspectRatio=\"xMidYMid meet\">\n                <!-- Grid lines -->\n                <line x1=\"0\" y1=\"20\" x2=\"300\" y2=\"20\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"50\" x2=\"300\" y2=\"50\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"80\" x2=\"300\" y2=\"80\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"110\" x2=\"300\" y2=\"110\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n\n                <!-- Y-axis labels -->\n                <text x=\"8\" y=\"24\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😊</text>\n                <text x=\"8\" y=\"54\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">🙂</text>\n                <text x=\"8\" y=\"84\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😐</text>\n                <text x=\"8\" y=\"114\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😢</text>\n\n                <!-- Area fill -->\n                <path d=\"M0 85 Q37.5 80 75 70 T150 55 T225 45 T300 35 L300 120 L0 120 Z\" fill=\"url(#moodAreaGrad)\"/>\n\n                <!-- Line -->\n                <path d=\"M0 85 Q37.5 80 75 70 T150 55 T225 45 T300 35\" fill=\"none\" stroke=\"#7C3AED\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n\n                <!-- Data points -->\n                <circle class=\"chart-dot\" cx=\"0\" cy=\"85\" r=\"5\" fill=\"#7C3AED\" data-point=\"Mon\"/>\n                <circle class=\"chart-dot\" cx=\"50\" cy=\"78\" r=\"5\" fill=\"#7C3AED\" data-point=\"Tue\"/>\n                <circle class=\"chart-dot\" cx=\"100\" cy=\"65\" r=\"5\" fill=\"#7C3AED\" data-point=\"Wed\"/>\n                <circle class=\"chart-dot\" cx=\"150\" cy=\"55\" r=\"5\" fill=\"#7C3AED\" data-point=\"Thu\"/>\n                <circle class=\"chart-dot\" cx=\"200\" cy=\"48\" r=\"5\" fill=\"#7C3AED\" data-point=\"Fri\"/>\n                <circle class=\"chart-dot\" cx=\"250\" cy=\"40\" r=\"5\" fill=\"#7C3AED\" data-point=\"Sat\"/>\n                <circle class=\"chart-dot\" cx=\"300\" cy=\"35\" r=\"5\" fill=\"#7C3AED\" data-point=\"Sun\"/>\n\n                <!-- X-axis labels -->\n                <text x=\"0\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Mon</text>\n                <text x=\"50\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Tue</text>\n                <text x=\"100\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Wed</text>\n                <text x=\"150\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Thu</text>\n                <text x=\"200\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Fri</text>\n                <text x=\"250\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sat</text>\n                <text x=\"300\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sun</text>\n\n                <!-- Gradient def -->\n                <defs>\n                  <linearGradient id=\"moodAreaGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stop-color=\"#7C3AED\" stop-opacity=\"0.2\"/>\n                    <stop offset=\"100%\" stop-color=\"#7C3AED\" stop-opacity=\"0\"/>\n                  </linearGradient>\n                </defs>\n              </svg>\n            </div>\n\n            <!-- Legend -->\n            <div data-flutter=\"row\" data-spacing=\"xs\" data-main-axis=\"start\" class=\"flex items-center gap-2 mt-3\">\n              <span class=\"text-xs text-stone\">Score</span>\n              <div class=\"w-2 h-2 rounded-full bg-lavender\"></div>\n              <span class=\"text-xs text-stone\">Mood</span>\n            </div>\n          </div>\n        </section>\n\n        <!-- Section 3: Energy Trend Chart -->\n        <section class=\"mb-6 animate-section\" style=\"animation-delay: 100ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4\">\n            <!-- Header with toggle chips -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n              <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Energy Trend</h3>\n              <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1\">\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-mint text-graphite\" data-flutter=\"chip\" data-color=\"tertiary\">1W</button>\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">1M</button>\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">All</button>\n              </div>\n            </div>\n\n            <!-- Chart area -->\n            <div class=\"relative h-[160px]\">\n              <svg data-flutter=\"custom-paint\" class=\"w-full h-full\" viewBox=\"0 0 300 140\" preserveAspectRatio=\"xMidYMid meet\">\n                <!-- Grid lines -->\n                <line x1=\"0\" y1=\"20\" x2=\"300\" y2=\"20\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"50\" x2=\"300\" y2=\"50\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"80\" x2=\"300\" y2=\"80\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"110\" x2=\"300\" y2=\"110\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n\n                <!-- Y-axis labels -->\n                <text x=\"8\" y=\"24\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">High</text>\n                <text x=\"8\" y=\"54\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">Med</text>\n                <text x=\"8\" y=\"84\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">Low</text>\n                <text x=\"8\" y=\"114\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">VLow</text>\n\n                <!-- Area fill -->\n                <path d=\"M0 90 Q37.5 75 75 80 T150 60 T225 45 T300 50 L300 120 L0 120 Z\" fill=\"url(#energyAreaGrad)\"/>\n\n                <!-- Line -->\n                <path d=\"M0 90 Q37.5 75 75 80 T150 60 T225 45 T300 50\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n\n                <!-- Data points -->\n                <circle class=\"chart-dot\" cx=\"0\" cy=\"90\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Mon\"/>\n                <circle class=\"chart-dot\" cx=\"50\" cy=\"80\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Tue\"/>\n                <circle class=\"chart-dot\" cx=\"100\" cy=\"75\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Wed\"/>\n                <circle class=\"chart-dot\" cx=\"150\" cy=\"60\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Thu\"/>\n                <circle class=\"chart-dot\" cx=\"200\" cy=\"50\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Fri\"/>\n                <circle class=\"chart-dot\" cx=\"250\" cy=\"55\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Sat\"/>\n                <circle class=\"chart-dot\" cx=\"300\" cy=\"50\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Sun\"/>\n\n                <!-- X-axis labels -->\n                <text x=\"0\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Mon</text>\n                <text x=\"50\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Tue</text>\n                <text x=\"100\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Wed</text>\n                <text x=\"150\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Thu</text>\n                <text x=\"200\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Fri</text>\n                <text x=\"250\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sat</text>\n                <text x=\"300\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sun</text>\n\n                <!-- Gradient def -->\n                <defs>\n                  <linearGradient id=\"energyAreaGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stop-color=\"#6EE7B7\" stop-opacity=\"0.2\"/>\n                    <stop offset=\"100%\" stop-color=\"#6EE7B7\" stop-opacity=\"0\"/>\n                  </linearGradient>\n                </defs>\n              </svg>\n            </div>\n\n            <!-- Legend -->\n            <div data-flutter=\"row\" data-spacing=\"xs\" data-main-axis=\"start\" class=\"flex items-center gap-2 mt-3\">\n              <span class=\"text-xs text-stone\">Level</span>\n              <div class=\"w-2 h-2 rounded-full bg-mint\"></div>\n              <span class=\"text-xs text-stone\">Energy</span>\n            </div>\n          </div>\n        </section>\n\n        <!-- Section 4: Wellness Tip -->\n        <section class=\"mb-6 animate-section\" style=\"animation-delay: 150ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" data-expandable=\"true\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n            <!-- Header row -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-3\">\n              <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex items-center gap-2\">\n                <svg class=\"icon w-5 h-5 text-lavender\" data-name=\"lightbulb\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                  <path d=\"M9 21h6M12 3a6 6 0 0 0-6 6c0 2.22 1.21 4.16 3 5.19V17a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1v-2.81c1.79-1.03 3-2.97 3-5.19a6 6 0 0 0-6-6z\"/>\n                </svg>\n                <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Wellness Tip</h3>\n              </div>\n              <span class=\"badge-pill bg-lavender/10 text-lavender\" data-flutter=\"chip\" data-color=\"primary\">Mood</span>\n            </div>\n\n            <!-- Tip text -->\n            <p class=\"text-sm text-stone\" style=\"line-height: 20px;\">\n              Your energy is improving! Try adding a 10-minute walk after meals to maintain this positive trend.\n            </p>\n\n            <!-- Expand indicator -->\n            <div class=\"flex justify-center mt-3\">\n              <svg class=\"icon w-4 h-4 text-stone\" data-name=\"expand_more\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M6 9l6 6 6-6\"/>\n              </svg>\n            </div>\n          </div>\n        </section>\n\n      </main>\n\n    </div>\n  </div>\n</body>\n</html>","structuredPatch":[],"originalFile":null,"userModified":false}}
