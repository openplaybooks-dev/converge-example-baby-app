(--color-background);\n56\t      border-radius: 40px;\n57\t      overflow: hidden;\n58\t      position: relative;\n59\t      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n60\t    }\n61\t\n62\t    .status-bar {\n63\t      height: 44px;\n64\t      background: var(--color-background);\n65\t      display: flex;\n66\t      justify-content: space-between;\n67\t      align-items: center;\n68\t      padding: 0 24px;\n69\t      font-size: 14px;\n70\t      font-weight: 600;\n71\t      color: var(--color-text-primary);\n72\t    }\n73\t\n74\t    .status-bar-icons {\n75\t      display: flex;\n76\t      gap: 6px;\n77\t      align-items: center;\n78\t    }\n79\t\n80\t    .status-bar-icons svg {\n81\t      width: 18px;\n82\t      height: 18px;\n83\t    }\n84\t\n85\t    .app-bar {\n86\t      height: 56px;\n87\t      display: flex;\n88\t      align-items: center;\n89\t      padding: 0 8px;\n90\t      background: var(--color-background);\n91\t    }\n92\t\n93\t    .back-btn {\n94\t      width: 48px;\n95\t      height: 48px;\n96\t      display: flex;\n97\t      align-items: center;\n98\t      justify-content: center;\n99\t      border: none;\n100\t      background: none;\n101\t      cursor: pointer;\n102\t      border-radius: 50%;\n103\t      transition: background 200ms ease-out;\n104\t    }\n105\t\n106\t    .back-btn:hover {\n107\t      background: var(--color-border);\n108\t    }\n109\t\n110\t    .back-btn svg {\n111\t      width: 24px;\n112\t      height: 24px;\n113\t      color: var(--color-text-primary);\n114\t    }\n115\t\n116\t    .app-bar-title {\n117\t      flex: 1;\n118\t      font-size: 20px;\n119\t      font-weight: 600;\n120\t      color: var(--color-text-primary);\n121\t      text-align: center;\n122\t      margin-right: 48px;\n123\t    }\n124\t\n125\t    .content {\n126\t      padding: 0 16px 100px;\n127\t      overflow-y: auto;\n128\t    }\n129\t\n130\t    .section {\n131\t      margin-bottom: 24px;\n132\t    }\n133\t\n134\t    .card {\n135\t      background: var(-