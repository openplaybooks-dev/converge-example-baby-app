ite mb-4\" style=\"line-height: 28px;\">Stretching & Self-Care</h2>\n\n          <div data-flutter=\"column\" data-spacing=\"sm\" class=\"flex flex-col gap-3\">\n\n            <!-- Card 1: Neck & Shoulders -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Neck & Shoulders</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">5 min</p>\n                  <span class=\"badge-pill bg-blush text-graphite\">All Trimester</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n            <!-- Card 2: Hip Opener -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Hip Opener</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">10 min</p>\n                  <span class=\"badge-pill bg-blush text-graphite\">2nd/3rd Tri</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n     