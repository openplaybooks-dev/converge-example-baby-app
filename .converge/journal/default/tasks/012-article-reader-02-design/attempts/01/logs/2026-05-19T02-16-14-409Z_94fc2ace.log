t-graphite\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n107\t            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"/>\n108\t          </svg>\n109\t        </button>\n110\t        <h1 class=\"flex-1 text-xl font-semibold text-graphite text-center pr-12\">Education</h1>\n111\t        <button data-flutter=\"icon-btn\" aria-label=\"Search articles\" class=\"icon-btn w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n112\t          <svg class=\"w-6 h-6 text-graphite\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n113\t            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"/>\n114\t          </svg>\n115\t        </button>\n116\t      </header>\n117\t\n118\t      <!-- Body - scrollable content -->\n119\t      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto pb-24\">\n120\t\n121\t        <!-- Section 1: Featured Article Hero -->\n122\t        <section class=\"px-4 mt-6\">\n123\t          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow overflow-hidden cursor-pointer animate-fade-in\" style=\"animation-delay: 0ms;\" data-route=\"/article-reader/featured-1\">\n124\t            <!-- Hero image area -->\n125\t            <div class=\"relative h-[180px] bg-gradient-to-br from-lavender to-lavender-light rounded-t-card overflow-hidden\">\n126\t              <!-- Topic badge -->\n127\t              <div class=\"absolute top-3 left-3\" data-flutter=\"chip\" data-color=\"primary\" data-selected=\"true\">\n128\t                <span class=\"bg-lavender text-white text-xs font-semibold px-3 py-1 rounded-full\">Nutrition</span>\n129\t              </div>\n130\t              <!-- Bookmark icon -->\n131\t              <button data-flutter=\"icon-btn\" aria-label=\"Bookmark article\" class=\"absolute top-3 right-3 w-10 h-1