kground: var(--color-background);\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .status-bar {\n      height: 44px;\n      background: var(--color-background);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 0 16px;\n      background: var(--color-background);\n    }\n\n    .app-bar-title {\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .avatar-btn {\n      width: 48px;\n      height: 48px;\n      border: none;\n      background: none;\n      cursor: pointer;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      border-radius: 50%;\n      transition: background 200ms ease-out;\n    }\n\n    .avatar-btn:hover {\n      background: var(--color-border);\n    }\n\n    .avatar {\n      width: 36px;\n      height: 36px;\n      border-radius: 50%;\n      background: linear-gradient(135deg, var(--color-secondary), var(--color-primary));\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .avatar svg {\n      width: 20px;\n      height: 20px;\n      color: var(--color-white);\n    }\n\n    .content {\n      padding: 0 16px 100px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-bottom: 24px;\n    }\n\n    /* Week Banner Card */\n    .week-banner {\n      background: var(--color-surface);\n      border-radius: var(--radius-card);\n      padding: 24px;\n      text-align: center;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .week-badge {\n      display: inline-block;\n      background: var(--color-primary);\n      color: var(--color-white);\n      font-size: 12px;\n      font-weight: 600;\n      padding: 6px 16px;\n      border-radius: 20px;\n      margin-bottom: 16px;\n    }\n\n    .week-number {\n      font-size: 72px;\n      font-weight: 700;\n      color: var(--color-primary);\n      line-height: 80px;\n      letter-spacing: -2px;\n    }\n\n    .week-label {\n      font-size: 16px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n      margin-top: -4px;\n    }\n\n    .due-date {\n      font-size: 14px;\n      color: var(--color-text-secondary);\n      margin-top: 8px;\n    }\n\n    .countdown {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-primary);\n      margin-top: 8px;\n    }\n\n    .fruit-chip {\n      display: inline-flex;\n      align-items: center;\n      gap: 8px;\n      background: rgba(249, 168, 212, 0.2);\n      padding: 8px 16px;\n      border-radius: 20px;\n      margin-top: 12px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .fruit-icon {\n      width: 24px;\n      height: 24px;\n    }\n\n    /* Card */\n    .card {\n      background: var(--color-white);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .card-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      margin-bottom: 12px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n    }\n\n    .progress-badge {\n      font-size: 12px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n      background: var(--color-surface);\n      padding: 4px 8px;\n      border-radius: 8px;\n    }\n\n    /* Mood Buttons */\n    .mood-selector {\n      display: flex;\n      justify-content: space-between;\n      gap: 8px;\n    }\n\n    .mood-btn {\n      width: 56px;\n      height: 56px;\n      border-radius: 50%;\n      border: 2px solid var(--color-border);\n      background: var(--color-surface);\n      font-size: 28px;\n      cursor: pointer;\n      transition: transform 200ms ease-out, border-color 200ms ease-out, background 200ms ease-out;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      gap: 2px;\n    }\n\n    .mood-btn:hover, .mood-btn:focus {\n      border-color: var(--color-primary);\n      transform: scale(1.1);\n    }\n\n    .mood-btn:focus {\n      outline: none;\n      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.2);\n    }\n\n    .mood-btn.selected {\n      border-color: var(--color-primary);\n      background: rgba(124, 58, 237, 0.1);\n    }\n\n    .mood-label {\n      font-size: 9px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n      opacity: 0;\n      transition: opacity 200ms ease-out;\n    }\n\n    .mood-btn.selected .mood-label {\n      opacity: 1;\n      color: var(--color-primary);\n    }\n\n    /* Checklist Chips */\n    .checklist-scroll {\n      display: flex;\n      gap: 8px;\n      overflow-x: auto;\n      padding-bottom: 4px;\n      -webkit-overflow-scrolling: touch;\n    }\n\n    .checklist-scroll::-webkit-scrollbar {\n      display: none;\n    }\n\n    .checklist-chip {\n      display: inline-flex;\n      align-items: center;\n      gap: 8px;\n      padding: 10px 16px;\n      border-radius: var(--radius-chip);\n      font-size: 14px;\n      font-weight: 600;\n      white-space: nowrap;\n      cursor: pointer;\n      transition: transform 200ms ease-out, background 200ms ease-out;\n      min-height: 48px;\n      border: none;\n    }\n\n    .checklist-chip.completed {\n      background: rgba(110, 231, 183, 0.2);\n      color: var(--color-text-primary);\n    }\n\n    .checklist-chip.completed svg {\n      color: var(--color-mint);\n    }\n\n    .checklist-chip.uncompleted {\n      background: var(--color-surface);\n      border: 1px solid var(--color-border);\n      color: var(--color-text-primary);\n    }\n\n    .checklist-chip.uncompleted svg {\n      color: var(--color-text-secondary);\n    }\n\n    .checklist-chip:active {\n      transform: scale(0.97);\n    }\n\n    .checklist-chip svg {\n      width: 18px;\n      height: 18px;\n      flex-shrink: 0;\n    }\n\n    /* Quick Actions Grid */\n    .quick-actions {\n      display: grid;\n      grid-template-columns: repeat(2, 1fr);\n      gap: 12px;\n    }\n\n    .action-btn {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      gap: 10px;\n      padding: 20px 16px;\n      border: none;\n      border-radius: var(--radius-card);\n      cursor: pointer;\n      transition: transform 200ms ease-out;\n      min-height: 88px;\n    }\n\n    .action-btn:active {\n      transform: scale(0.95);\n    }\n\n    .action-btn.primary {\n      background: var(--color-primary);\n      color: var(--color-white);\n    }\n\n    .action-btn.secondary {\n      background: var(--color-white);\n      color: var(--color-text-primary);\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n      border: 1px solid var(--color-border);\n    }\n\n    .action-btn svg {\n      width: 32px;\n      height: 32px;\n    }\n\n    .action-btn.primary svg {\n      color: var(--color-white);\n    }\n\n    .action-btn.secondary svg {\n      color: var(--color-text-primary);\n    }\n\n    .action-btn span {\n      font-size: 14px;\n      font-weight: 600;\n      line-height: 20px;\n    }\n\n    /* Weekly Tip Card */\n    .tip-card {\n      background: linear-gradient(135deg, var(--color-primary), #9F67FF);\n      border-radius: var(--radius-card);\n      padding: 20px;\n      color: var(--color-white);\n    }\n\n    .tip-header {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n      margin-bottom: 12px;\n    }\n\n    .tip-icon {\n      width: 40px;\n      height: 40px;\n      border-radius: 50%;\n      background: rgba(255, 255, 255, 0.2);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .tip-icon svg {\n      width: 20px;\n      height: 20px;\n      color: var(--color-white);\n    }\n\n    .tip-label {\n      font-size: 12px;\n      font-weight: 500;\n      letter-spacing: 0.4pt;\n      text-transform: uppercase;\n      opacity: 0.9;\n    }\n\n    .tip-title {\n      font-size: 16px;\n      font-weight: 600;\n      margin-bottom: 8px;\n      line-height: 24px;\n    }\n\n    .tip-body {\n      font-size: 14px;\n      font-weight: 400;\n      line-height: 20px;\n      opacity: 0.9;\n    }\n\n    /* Bottom Navigation */\n    .bottom-nav {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      height: 80px;\n      background: var(--color-white);\n      display: flex;\n      justify-content: space-around;\n      align-items: flex-start;\n      padding-top: 8px;\n      border-top: 1px solid var(--color-border);\n    }\n\n    .nav-item {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 4px;\n      padding: 8px 16px;\n      border: none;\n      background: none;\n      cursor: pointer;\n      position: relative;\n      min-width: 64px;\n      min-height: 48px;\n    }\n\n    .nav-item.active::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      width: 40px;\n      height: 4px;\n      background: var(--color-primary);\n      border-radius: 2px;\n      opacity: 0.15;\n    }\n\n    .nav-item svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active svg {\n      color: var(--color-primary);\n    }\n\n    .nav-item span {\n      font-size: 11px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active span {\n      font-weight: 600;\n      color: var(--color-primary);\n    }\n\n    .home-indicator {\n      position: absolute;\n      bottom: 8px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 134px;\n      height: 5px;\n      background: var(--color-text-primary);\n      border-radius: 3px;\n      opacity: 0.2;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\" data-flutter=\"scaffold\">\n\n    <div class=\"status-bar\">\n      <span>9:41</span>\n      <div class=\"status-bar-icons\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n          <rect x=\"4\" y=\"9\" width=\"14\" height=\"6\" rx=\"1\" fill=\"currentColor\"/>\n        </svg>\n      </div>\n    </div>\n\n    <header class=\"app-bar\" data-flutter=\"app-bar\">\n      <h1 class=\"app-bar-title\">Baby Bump</h1>\n      <button class=\"avatar-btn\" aria-label=\"Profile\" data-flutter=\"nav-destination\">\n        <div class=\"avatar\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n            <circle cx=\"12\" cy=\"8\" r=\"4\"/>\n            <path d=\"M4 20c0-4 4-6 8-6s8 2 8 6\"/>\n          </svg>\n        </div>\n      </button>\n    </header>\n\n    <main class=\"content\" data-flutter=\"custom-scroll\">\n      <section class=\"section\">\n        <div class=\"week-banner\">\n          <span class=\"week-badge\">Week 24</span>\n          <div class=\"week-number\">24</div>\n          <div class=\"week-label\">weeks pregnant</div>\n          <div class=\"due-date\">Due December 15, 2026</div>\n          <div class=\"countdown\">112 days to go</div>\n          <div class=\"fruit-chip\">\n            <svg class=\"fruit-icon\" viewBox=\"0 0 24 24\" fill=\"none\">\n              <ellipse cx=\"12\" cy=\"14\" rx=\"8\" ry=\"9\" fill=\"#F9A8D4\"/>\n              <ellipse cx=\"12\" cy=\"14\" rx=\"6\" ry=\"7\" fill=\"#FBC4E0\"/>\n              <path d=\"M12 5c0-2 1-3 3-3\" stroke=\"#6EE7B7\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n            </svg>\n            Papaya size\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"card\">\n          <h2 class=\"card-title\">How are you feeling today?</h2>\n          <div class=\"mood-selector\" role=\"group\" aria-label=\"Mood check-in\">\n            <button class=\"mood-btn\" aria-label=\"Terrible\" aria-pressed=\"false\">\n              😢\n              <span class=\"mood-label\">Terrible</span>\n            </button>\n            <button class=\"mood-btn\" aria-label=\"Bad\" aria-pressed=\"false\">\n              😕\n              <span class=\"mood-label\">Bad</span>\n            </button>\n            <button class=\"mood-btn\" aria-label=\"Okay\" aria-pressed=\"false\">\n              😐\n              <span class=\"mood-label\">Okay</span>\n            </button>\n            <button class=\"mood-btn selected\" aria-label=\"Good\" aria-pressed=\"true\">\n              🙂\n              <span class=\"mood-label\">Good</span>\n            </button>\n            <button class=\"mood-btn\" aria-label=\"Great\" aria-pressed=\"false\">\n              😊\n              <span class=\"mood-label\">Great</span>\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"card\">\n          <h2 class=\"card-title\">\n            Today's Checklist\n            <span class=\"progress-badge\">2 of 4 done</span>\n          </h2>\n          <div class=\"checklist-scroll\">\n            <button class=\"checklist-chip completed\" aria-label=\"Weight logged, completed, double tap to toggle\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M20 6L9 17l-5-5\"/>\n              </svg>\n              Weight\n            </button>\n            <button class=\"checklist-chip completed\" aria-label=\"Mood checked, completed, double tap to toggle\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M20 6L9 17l-5-5\"/>\n              </svg>\n              Mood\n            </button>\n            <button class=\"checklist-chip uncompleted\" aria-label=\"Log symptoms, not completed, double tap to toggle\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n              </svg>\n              Log symptoms\n            </button>\n            <button class=\"checklist-chip uncompleted\" aria-label=\"Drink water, not completed, double tap to toggle\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z\"/>\n              </svg>\n              Drink water\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <h2 class=\"card-title\" style=\"margin-bottom: 12px;\">Quick Actions</h2>\n        <div class=\"quick-actions\">\n          <button class=\"action-btn primary\" aria-label=\"Log Weight, double tap to navigate to weight nutrition\" data-route=\"/weight-nutrition\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M12 3v18M3 12h18\"/>\n              <circle cx=\"12\" cy=\"12\" r=\"9\"/>\n            </svg>\n            <span>Log Weight</span>\n          </button>\n          <button class=\"action-btn primary\" style=\"background: var(--color-secondary);\" aria-label=\"Log Mood, double tap to navigate to mood wellness\" data-route=\"/mood-wellness\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n              <path d=\"M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01\"/>\n            </svg>\n            <span>Log Mood</span>\n          </button>\n          <button class=\"action-btn secondary\" aria-label=\"Log Symptoms, double tap to open symptom form\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/>\n            </svg>\n            <span>Log Symptoms</span>\n          </button>\n          <button class=\"action-btn secondary\" aria-label=\"View Education, double tap to navigate to education\" data-route=\"/education\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M4 19.5A2.5 2.5 0 0 1 6.5 17H20\"/>\n              <path d=\"M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z\"/>\n            </svg>\n            <span>Education</span>\n          </button>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"tip-card\" data-animate=\"fade-in\">\n          <div class=\"tip-header\">\n            <div class=\"tip-icon\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n                <path d=\"M12 16v-4M12 8h.01\"/>\n              </svg>\n            </div>\n            <span class=\"tip-label\">Weekly Tip</span>\n          </div>\n          <div class=\"tip-title\">Stay Hydrated This Week</div>\n          <div class=\"tip-body\">Your body is working hard to support your growing baby. Aim for 8-10 glasses of water daily to maintain healthy amniotic fluid levels.</div>\n        </div>\n      </section>\n    </main>\n\n    <nav class=\"bottom-nav\" data-flutter=\"bottom-nav\" role=\"navigation\" aria-label=\"Main navigation\">\n      <button class=\"nav-item active\" aria-current=\"page\" data-flutter=\"nav-destination\" data-icon=\"home\" data-label=\"Home\" data-selected=\"true\">\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <path d=\"M12 3L4 9v12h5v-7h6v7h5V9z\"/>\n        </svg>\n        <span>Home</span>\n      </button>\n      <button class=\"nav-item\" data-flutter=\"nav-destination\" data-icon=\"search\" data-label=\"Browse\" data-selected=\"false\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"11\" cy=\"11\" r=\"8\"/>\n          <path d=\"M21 21l-4.35-4.35\"/>\n        </svg>\n        <span>Browse</span>\n      </button>\n      <button class=\"nav-item\" data-flutter=\"nav-destination\" data-icon=\"library\" data-label=\"Library\" data-selected=\"false\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z\"/>\n        </svg>\n        <span>Library</span>\n      </button>\n      <button class=\"nav-item\" data-flutter=\"nav-destination\" data-icon=\"profile\" data-label=\"Profile\" data-selected=\"false\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"12\" cy=\"8\" r=\"4\"/>\n          <path d=\"M4 20c0-4 4-6 8-6s8 2 8 6\"/>\n        </svg>\n        <span>Profile</span>\n      </button>\n    </nav>\n\n    <div class=\"home-indicator\"></div>\n  </div>\n</body>\n</html>"}}],"usage":{"input_tokens":1816,"output_tokens":6014,"cache_creation_input_tokens":0,"cache_read_input_tokens":54813},"stop_reason":"tool_use","base_resp":{"status_code":0,"status_msg":"success"},"context_management":null},"parent_tool_use_id":null,"session_id":"4c8e097a