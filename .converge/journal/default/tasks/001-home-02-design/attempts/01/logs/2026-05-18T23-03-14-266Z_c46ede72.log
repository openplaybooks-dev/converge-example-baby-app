<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=375, initial-scale=1.0\" />\n  <title>Home — Baby Bump Design</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\" />\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          colors: {\n            'lavender': '#7C3AED',\n            'lavender-light': '#A78BFA',\n            'lavender-tint': '#F5F3FF',\n            'blush': '#F9A8D4',\n            'mint': '#6EE7B7',\n            'mist': '#FAFAFA',\n            'graphite': '#1F2937',\n            'stone': '#6B7280',\n            'misty-border': '#E5E7EB',\n            'coral': '#EF4444',\n            'warm-white': '#FFFFFF',\n          },\n          fontFamily: {\n            'nunito': ['Nunito', 'system-ui', 'sans-serif'],\n          },\n          borderRadius: {\n            'card': '16px',\n            'sheet': '28px',\n            'pill': '999px',\n          }\n        }\n      }\n    }\n  </script>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      font-family: 'Nunito', system-ui, sans-serif;\n      background: #E8E8E8;\n      display: flex;\n      justify-content: center;\n      padding: 32px 16px;\n      min-height: 100vh;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n\n    /* SliverAppBar collapsed gradient */\n    .sliver-bg {\n      background: linear-gradient(180deg, #F5F3FF 0%, #F5F3FF 100%);\n    }\n\n    /* Card shadow */\n    .card-shadow {\n      box-shadow: 0 8px 24px rgba(0,0,0,0.08);\n    }\n\n    /* Chip tap */\n    .chip-tap:active {\n      transform: scale(0.97);\n      transition: transform 200ms ease-out;\n    }\n\n    /* Bottom nav active indicator */\n    .nav-indicator {\n      background: rgba(124, 58, 237, 0.15);\n      border-radius: 999px;\n    }\n\n    /* Shimmer loading effect */\n    @keyframes shimmer {\n      0% { background-position: -200% 0; }\n      100% { background-position: 200% 0; }\n    }\n    .shimmer {\n      background: linear-gradient(90deg, #F0F0F0 25%, #E0E0E0 50%, #F0F0F0 75%);\n      background-size: 200% 100%;\n      animation: shimmer 1.5s infinite;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <!-- Scaffold with CustomScrollView / SliverAppBar -->\n    <div data-flutter=\"scaffold\" data-bg=\"lavenderTint\" class=\"flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- SliverAppBar - collapses to show week badge -->\n      <header data-flutter=\"sliver-app-bar\" data-expanded-height=\"280\" data-pinned=\"true\"\n              class=\"sliver-bg relative overflow-hidden\">\n\n        <!-- Expanded content (shown when scrolled to top) -->\n        <div class=\"absolute inset-0 flex flex-col items-center justify-center pt-12 pb-6\">\n          <!-- Week badge -->\n          <div class=\"bg-lavender text-white px-4 py-1.5 rounded-full text-sm font-semibold mb-4\" data-flutter=\"chip\">\n            Week 24\n          </div>\n\n          <!-- Main week banner card -->\n          <div class=\"bg-warm-white rounded-card card-shadow mx-4 p-6 w-full max-w-[343px]\">\n            <div class=\"text-center\">\n              <!-- Fruit size visual -->\n              <div class=\"w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-br from-blush to-lavender-light flex items-center justify-center\">\n                <span class=\"text-4xl\">🍈</span>\n              </div>\n\n              <!-- Week and countdown -->\n              <h1 class=\"text-3xl font-bold text-graphite mb-1\">Week 24</h1>\n              <p class=\"text-stone text-sm mb-2\">Due date: Dec 15, 2026</p>\n              <p class=\"text-lavender font-semibold text-sm\">112 days to go</p>\n\n              <!-- Fruit size comparison -->\n              <div class=\"mt-4 flex items-center justify-center gap-2\">\n                <span class=\"text-xs text-stone\">Baby is the size of</span>\n                <span class=\"bg-blush/20 text-lavender px-3 py-1 rounded-full text-sm font-semibold\">Papaya</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Collapsed title (shows when scrolled) -->\n        <div data-flutter=\"sliver-app-bar-title\" class=\"absolute top-0 left-0 right-0 h-14 flex items-center justify-center\">\n          <span class=\"text-xl font-semibold text-graphite\">Baby Bump</span>\n        </div>\n\n        <!-- AppBar actions -->\n        <div class=\"absolute top-0 right-0 h-14 flex items-center pr-4\">\n          <button data-flutter=\"icon-btn\" aria-label=\"Profile\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n            <div class=\"w-8 h-8 rounded-full bg-gradient-to-br from-lavender to-blush\"></div>\n          </button>\n        </div>\n      </header>\n\n      <!-- Body - scrollable content -->\n      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto pb-20\">\n\n        <!-- Section 1: Mood Check-In Card -->\n        <div class=\"px-4 mt-6\">\n          <div class=\"bg-warm-white rounded-card card-shadow p-5\">\n            <div class=\"flex justify-between items-center mb-4\">\n              <h2 class=\"text-lg font-semibold text-graphite\">How are you feeling today?</h2>\n              <span class=\"text-xs text-stone\">May 18</span>\n            </div>\n\n            <!-- Mood emoji selector -->\n            <div data-flutter=\"row\" data-spacing=\"md\" data-main-axis=\"space-around\" class=\"flex justify-around\">\n              <!-- Mood options: terrible, bad, okay, good, great -->\n              <button data-flutter=\"icon-btn\" aria-label=\"Terrible\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-red-50 transition-colors\">\n                <span class=\"text-3xl\">😢</span>\n                <span class=\"text-xs text-stone\">Terrible</span>\n              </button>\n              <button data-flutter=\"icon-btn\" aria-label=\"Bad\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-orange-50 transition-colors\">\n                <span class=\"text-3xl\">😔</span>\n                <span class=\"text-xs text-stone\">Bad</span>\n              </button>\n              <button data-flutter=\"icon-btn\" aria-label=\"Okay\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-yellow-50 transition-colors\">\n                <span class=\"text-3xl\">😐</span>\n                <span class=\"text-xs text-stone\">Okay</span>\n              </button>\n              <button data-flutter=\"icon-btn\" aria-label=\"Good\" data-selected=\"true\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl bg-lavender/10 ring-2 ring-lavender\">\n                <span class=\"text-3xl\">🙂</span>\n                <span class=\"text-xs text-lavender font-semibold\">Good</span>\n              </button>\n              <button data-flutter=\"icon-btn\" aria-label=\"Great\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-green-50 transition-colors\">\n                <span class=\"text-3xl\">😊</span>\n                <span class=\"text-xs text-stone\">Great</span>\n              </button>\n            </div>\n          </div>\n        </div>\n\n        <!-- Section 2: Today's Checklist - horizontal scroll chips -->\n        <div class=\"mt-6\">\n          <div class=\"flex justify-between items-center px-4 mb-3\">\n            <h2 class=\"text-lg font-semibold text-graphite\">Today's Checklist</h2>\n            <span class=\"text-sm text-lavender font-medium\">2 of 4 done</span>\n          </div>\n\n          <div data-flutter=\"horizontal-scroll\" class=\"overflow-x-auto\">\n            <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex px-4\">\n              <!-- Checklist chips -->\n              <div data-flutter=\"chip\" data-selected=\"true\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-mint/20 border border-mint/30 shrink-0 cursor-pointer\">\n                <svg class=\"w-5 h-5 text-mint\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"/>\n                </svg>\n                <span class=\"text-sm font-medium text-graphite\">Weight logged</span>\n              </div>\n              <div data-flutter=\"chip\" data-selected=\"true\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-mint/20 border border-mint/30 shrink-0 cursor-pointer\">\n                <svg class=\"w-5 h-5 text-mint\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"/>\n                </svg>\n                <span class=\"text-sm font-medium text-graphite\">Mood checked</span>\n              </div>\n              <div data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-stone/10 border border-misty-border shrink-0 cursor-pointer\">\n                <div class=\"w-5 h-5 rounded-full border-2 border-stone/30\"></div>\n                <span class=\"text-sm font-medium text-stone\">Log symptoms</span>\n              </div>\n              <div data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-stone/10 border border-misty-border shrink-0 cursor-pointer\">\n                <div class=\"w-5 h-5 rounded-full border-2 border-stone/30\"></div>\n                <span class=\"text-sm font-medium text-stone\">Drink water</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Section 3: Quick Actions - 4 primary buttons -->\n        <div class=\"mt-6 px-4\">\n          <h2 class=\"text-lg font-semibold text-graphite mb-3\">Quick Actions</h2>\n\n          <div data-flutter=\"grid\" data-columns=\"2\" data-spacing=\"sm\" class=\"grid grid-cols-2 gap-3\">\n            <!-- Log Weight -->\n            <button data-flutter=\"elevated-btn\" class=\"bg-lavender text-white rounded-2xl p-4 flex flex-col items-center gap-2 min-h-[88px] active:scale-95 transition-transform\">\n              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3\"/>\n              </svg>\n              <span class=\"text-sm font-semibold\">Log Weight</span>\n            </button>\n\n            <!-- Log Mood -->\n            <button data-flutter=\"elevated-btn\" class=\"bg-blush text-white rounded-2xl p-4 flex flex-col items-center gap-2 min-h-[88px] active:scale-95 transition-transform\">\n              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n              </svg>\n              <span class=\"text-sm font-semibold\">Log Mood</span>\n            </button>\n\n            <!-- Log Symptoms -->\n            <button data-flutter=\"elevated-btn\" class=\"bg-warm-white text-graphite rounded-2xl p-4 flex flex-col items-center gap-2 min-h-[88px] border-2 border-misty-border active:scale-95 transition-transform\">\n              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01\"/>\n              </svg>\n              <span class=\"text-sm font-semibold text-graphite\">Log Symptoms</span>\n            </button>\n\n            <!-- View Education -->\n            <button data-flutter=\"elevated-btn\" class=\"bg-warm-white text-graphite rounded-2xl p-4 flex flex-col items-center gap-2 min-h-[88px] border-2 border-misty-border active:scale-95 transition-transform\">\n              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253\"/>\n              </svg>\n              <span class=\"text-sm font-semibold text-graphite\">View Education</span>\n            </button>\n          </div>\n        </div>\n\n        <!-- Section 4: Weekly Tip -->\n        <div class=\"mt-6 px-4 mb-6\">\n          <div class=\"bg-gradient-to-br from-lavender to-lavender-light rounded-card p-5\">\n            <div class=\"flex items-start gap-3\">\n              <div class=\"w-10 h-10 rounded-full bg-white/20 flex items-center justify-center shrink-0\">\n                <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 16h-1v-