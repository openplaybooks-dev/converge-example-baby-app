t Color(0xFF6B7280),\n            ),\n          ),\n        ],\n      ),\n    );\n  }\n}\n\nclass _ChecklistItem {\n  final String label;\n  final bool isCompleted;\n\n  _ChecklistItem(this.label, this.isCompleted);\n}\n","structuredPatch":[{"oldStart":37,"oldLines":7,"newStart":37,"newLines":7,"lines":["                     minWidth: 48,","                     minHeight: 48,","                   ),","-                  child: Container(","+                  icon: Container(","                     width: 32,","                     height: 32,","                     decoration: BoxDecoration("]}],"userModified":false,"replaceAll":false}}
