data-selected=\"true\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-mint/20 border border-mint/30 shrink-0 cursor-pointer\">\n207\t                <svg class=\"w-5 h-5 text-mint\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n208\t                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"/>\n209\t                </svg>\n210\t                <span class=\"text-sm font-medium text-graphite\">Mood checked</span>\n211\t              </div>\n212\t              <div data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-stone/10 border border-misty-border shrink-0 cursor-pointer\">\n213\t                <div class=\"w-5 h-5 rounded-full border-2 border-stone/30\"></div>\n214\t                <span class=\"text-sm font-medium text-stone\">Log symptoms</span>\n215\t              </div>\n216\t              <div data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-stone/10 border border-misty-border shrink-0 cursor-pointer\">\n217\t                <div class=\"w-5 h-5 rounded-full border-2 border-stone/30\"></div>\n218\t                <span class=\"text-sm font-medium text-stone\">Drink water</span>\n219\t              </div>\n220\t            </div>\n221\t          </div>\n222\t        </div>\n223\t\n224\t        <!-- Section 3: Quick Actions - 4 primary buttons -->\n225\t        <div class=\"mt-6 px-4\">\n226\t          <h2 class=\"text-lg font-semibold text-graphite mb-3\">Quick Actions</h2>\n227\t\n228\t          <div data-flutter=\"grid\" data-columns=\"2\" data-spacing=\"sm\" class=\"grid grid-cols-2 gap-3\">\n229\t            <!-- Log Weight -->\n230\t            <button data-flutter=\"elevated-btn\" data-color=\"primary\" class=\"bg-lavender text-white rounded-2xl p-4 flex flex-col items-center gap-2 min-h-[88px] active:scale-95 transition-transform\">\