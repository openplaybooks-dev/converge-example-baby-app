122	                <span class="text-4xl">🍈</span>
123	              </div>
124	
125	              <!-- Week and countdown -->
126	              <h1 class="text-3xl font-bold text-graphite mb-1">Week 24</h1>
127	              <p class="text-stone text-sm mb-2">Due date: Dec 15, 2026</p>
