622	  Widget _buildNavDestination(IconData icon, String label, bool isActive) {
623	    return Container(
624	      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
625	      decoration: isActive
626	          ? BoxDecoration(
627	              color: const Color(0xFF7C3AED).withValues(alpha: 0.15),
628	              borderRadius: BorderRadius.circular(9999),
629	            )
630	          : null,
631	      child: Column(
632	        mainAxisSize: MainAxisSize.min,
633	        children: [
634	          Icon(
635	            icon,
636	            size: 24,
637	            color: isActive ? const Color(0xFF7C3AED) : const Color(0xFF6B7280),
638	          ),
639	          const SizedBox(height: 4),
640	          Text(
641	            label,
642	            style: TextStyle(
643	              fontSize: 12,
644	              fontWeight: isActive ? FontWeight.w600 : FontWeight.w500,
645	              color: isActive
646	                  ? const Color(0xFF7C3AED)
647	                  : const Color(0xFF6B7280),
648	            ),
649	          ),
650	        ],
651	      ),
652	    );
653	  }
654	}
