- title: "Mindfulness"
- route: "/mindfulness"
- description: "Guided breathing exercises, light stretching guides, and mindful activity suggestions"
- features: ["breathing-exercises", "stretching-self-care", "overlay-trigger"]
- navType: "push"
- priority: 1

