lass=\"card-icon-container\">\n              <!-- mood_outlined -->\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n                <path d=\"M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01\"/>\n              </svg>\n            </div>\n            <div class=\"card-text\">\n              <h2 class=\"card-title\">Mood & Wellness</h2>\n              <p class=\"card-description\">Log moods, track energy levels</p>\n            </div>\n            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <polyline points=\"9 18 15 12 9 6\"/>\n            </svg>\n          </div>\n        </div>\n\n        <!-- Education Card -->\n        <div class=\"card card-education\"\n             role=\"link\"\n             tabindex=\"0\"\n             aria-label=\"Education, double tap to open education screen\"\n             data-route=\"/education\">\n          <div class=\"card-row\">\n            <div class=\"card-icon-container\">\n              <!-- school_outlined -->\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M22 10v6M2 10l10-5 10 5-10 5z\"/>\n                <path d=\"M6 12v5c3 3 9 3 12 0v-5\"/>\n              </svg>\n            </div>\n            <div class=\"card-text\">\n              <h2 class=\"card-title\">Education</h2>\n              <p class=\"card-description\">Browse articles and trusted health info</p>\n            </div>\n            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <polyline points=\"9 18 15 12 9 6\"/>\n            </svg>\n          </div>\n        </div>\n      </section>\n    </main>\n\n    <nav class=\"bottom-nav\" role=\"navigation\" aria-label=\"Main navigation\">\n      <button class=\"nav-item\" aria-label=\"Home