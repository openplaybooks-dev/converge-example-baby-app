x 8px rgba(0, 0, 0, 0.08);\n      cursor: pointer;\n      transition: transform 200ms ease-out;\n      border: 1px solid var(--color-border);\n    }\n\n    .card:hover {\n      transform: scale(0.98);\n    }\n\n    .card:active {\n      transform: scale(0.98);\n    }\n\n    .card-row {\n      display: flex;\n      align-items: center;\n      gap: 16px;\n    }\n\n    .card-icon-container {\n      width: 48px;\n      height: 48px;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      flex-shrink: 0;\n    }\n\n    .card-icon-container svg {\n      width: 24px;\n      height: 24px;\n    }\n\n    .card-text {\n      flex: 1;\n      min-width: 0;\n    }\n\n    .card-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      margin-bottom: 4px;\n    }\n\n    .card-description {\n      font-size: 14px;\n      font-weight: 400;\n      color: var(--color-text-secondary);\n      white-space: nowrap;\n      overflow: hidden;\n      text-overflow: ellipsis;\n    }\n\n    .card-chevron {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-secondary);\n      flex-shrink: 0;\n    }\n\n    .card-health-log .card-icon-container {\n      background: rgba(124, 58, 237, 0.15);\n    }\n\n    .card-health-log .card-icon-container svg {\n      color: var(--color-primary);\n    }\n\n    .card-mood .card-icon-container {\n      background: rgba(249, 168, 212, 0.2);\n    }\n\n    .card-mood .card-icon-container svg {\n      color: var(--color-secondary);\n    }\n\n    .card-education .card-icon-container {\n      background: rgba(110, 231, 183, 0.2);\n    }\n\n    .card-education .card-icon-container svg {\n      color: var(--color-tertiary);\n    }\n\n    .bottom-nav {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      height: 80px;\n      background: var(--color-white);\n      display: flex;\n      justify-content: space-around;\n 