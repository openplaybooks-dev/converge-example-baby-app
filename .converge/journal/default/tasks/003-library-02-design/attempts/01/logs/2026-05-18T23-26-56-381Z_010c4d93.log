tline -->\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/>\n              </svg>\n            </div>\n            <div class=\"card-text\">\n              <h2 class=\"card-title\">Health Log</h2>\n              <p class=\"card-description\">Track symptoms, doctor visits, reminders</p>\n            </div>\n            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <polyline points=\"9 18 15 12 9 6\"/>\n            </svg>\n          </div>\n        </div>\n\n        <!-- Mood & Wellness Card -->\n        <div class=\"card card-mood\"\n             role=\"link\"\n             tabindex=\"0\"\n             aria-label=\"Mood and Wellness, double tap to open mood and wellness screen\"\n             data-route=\"/mood-wellness\">\n          <div class=\"card-row\">\n            <div class=\"card-icon-container\">\n              <!-- mood_outlined -->\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n                <path d=\"M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01\"/>\n              </svg>\n            </div>\n            <div class=\"card-text\">\n              <h2 class=\"card-title\">Mood & Wellness</h2>\n              <p class=\"card-description\">Log moods, track energy levels</p>\n            </div>\n            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <polyline points=\"9 18 15 12 9 6\"/>\n            </svg>\n          </div>\n        </div>\n\n        <!-- Education Card -->\n        <div class=\"card card-education\"\n             role=\"link\"\n             tabindex=\"0\"\n             aria-label=\"Education, double tap to open education screen\"\n             data-route=\"/education\">\n          <div class=\"card-row\">\n            <div class=\"card-icon-container\">\n              <!-- school_outlined -->\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M22 10v6M2 10l10-5 10 5-10 5z\"/>\n                <path d=\"M6 12v5c3 3 9 3 12 0v-5\"/>\n              </svg>\n            </div>\n            <div class=\"card-text\">\n              <h2 class=\"card-title\">Education</h2>\n              <p class=\"card-description\">Browse articles and trusted health info</p>\n            </div>\n            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <polyline points=\"9 18 15 12 9 6\"/>\n            </svg>\n          </div>\n        </div>\n      </section>\n    </main>\n\n    <nav class=\"bottom-nav\" role=\"navigation\" aria-label=\"Main navigation\">\n      <button class=\"nav-item\" aria-label=\"Home\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/>\n          <polyline points=\"9 22 9 12 15 12 15 22\"/>\n        </svg>\n        <span>Home</span>\n      </button>\n      <button class=\"nav-item\" aria-label=\"Browse\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"11\" cy=\"11\" r=\"8\"/>\n          <path d=\"M21 21l-4.35-4.35\"/>\n        </svg>\n        <span>Browse</span>\n      </button>\n      <button class=\"nav-item active\" aria-current=\"page\" aria-label=\"Library\">\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <path d=\"M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z\"/>\n        </svg>\n        <span>Library</span>\n      </button>\n      <button class=\"nav-item\" aria-labe