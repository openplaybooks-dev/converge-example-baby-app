er\">\n335\t              <!-- favorite_outline -->\n336\t              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n337\t                <path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/>\n338\t              </svg>\n339\t            </div>\n340\t            <div class=\"card-text\">\n341\t              <h2 class=\"card-title\">Health Log</h2>\n342\t              <p class=\"card-description\">Track symptoms, doctor visits, reminders</p>\n343\t            </div>\n344\t            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n345\t              <polyline points=\"9 18 15 12 9 6\"/>\n346\t            </svg>\n347\t          </div>\n348\t        </div>\n349\t\n350\t        <!-- Mood & Wellness Card -->\n351\t        <div class=\"card card-mood\"\n352\t             role=\"link\"\n353\t             tabindex=\"0\"\n354\t             aria-label=\"Mood and Wellness, double tap to open mood and wellness screen\"\n355\t             data-route=\"/mood-wellness\">\n356\t          <div class=\"card-row\">\n357\t            <div class=\"card-icon-container\">\n358\t              <!-- mood_outlined -->\n359\t              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n360\t                <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n361\t                <path d=\"M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01\"/>\n362\t              </svg>\n363\t            </div>\n364\t            <div class=\"card-text\">\n365\t              <h2 class=\"card-title\">Mood & Wellness</h2>\n366\t              <p class=\"card-description\">Log moods, track energy levels</p>\n367\t            </div>\n368\t            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n369\t              <polyline points=\"9 18 15 12 9 