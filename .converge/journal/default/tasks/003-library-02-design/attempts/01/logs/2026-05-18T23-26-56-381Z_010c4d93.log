: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .status-bar {\n      height: 44px;\n      background: var(--color-background);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 0 16px;\n      background: var(--color-background);\n    }\n\n    .app-bar-title {\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .content {\n      padding: 0 16px 100px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-bottom: 24px;\n    }\n\n    .card {\n      background: var(--color-surface);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n      cursor: pointer;\n      transition: transform 200ms ease-out;\n    }\n\n    .card:hover {\n      transform: scale(0.98);\n    }\n\n    .card:active {\n      transform: scale(0.98);\n    }\n\n    .card-row {\n      display: flex;\n      align-items: center;\n      gap: 16px;\n    }\n\n    .card-icon-container {\n      width: 48px;\n      height: 48px;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      flex-shrink: 0;\n    }\n\n    .card-icon-container svg {\n      width: 24px;\n      height: 24px;\n    }\n\n    .card-text {\n      flex: 1;\n      min-width: 0;\n    }\n\n    .card-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      margin-bottom: 4px;\n    }\n\n    .card-description {\n      font-size: 14px;\n      font-weight: 400;\n      color: var(--color-text-secondary);\n      white-space: nowrap;\n      overflow: hidden;\n      text-overflow: ellipsis;\n    }\n\n    .card-chevron {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-secondary);\n      flex-shrink: 0;\n    }\n\n    .card-health-log .card-icon-container {\n      background: rgba(124, 58, 237, 0.15);\n    }\n\n    .card-health-log .card-icon-container svg {\n      color: var(--color-primary);\n    }\n\n    .card-mood .card-icon-container {\n      background: rgba(249, 168, 212, 0.2);\n    }\n\n    .card-mood .card-icon-container svg {\n      color: var(--color-secondary);\n    }\n\n    .card-education .card-icon-container {\n      background: rgba(110, 231, 183, 0.2);\n    }\n\n    .card-education .card-icon-container svg {\n      color: var(--color-tertiary);\n    }\n\n    .bottom-nav {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      height: 80px;\n      background: var(--color-white);\n      display: flex;\n      justify-content: space-around;\n      align-items: flex-start;\n      padding-top: 8px;\n      border-top: 1px solid var(--color-border);\n    }\n\n    .nav-item {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 4px;\n      padding: 8px 16px;\n      border: none;\n      background: none;\n      cursor: pointer;\n      position: relative;\n    }\n\n    .nav-item.active::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      width: 40px;\n      height: 4px;\n      background: var(--color-primary);\n      border-radius: 2px;\n      opacity: 0.15;\n    }\n\n    .nav-item svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active svg {\n      color: var(--color-primary);\n    }\n\n    .nav-item span {\n      font-size: 11px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active span {\n      font-weight: 600;\n      color: var(--color-primary);\n    }\n\n    .home-indicator {\n      position: absolute;\n      bottom: 8px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 134px;\n      height: 5px;\n      background: var(--color-text-primary);\n      border-radius: 3px;\n      opacity: 0.2;\n    }\n\n    /* Animation keyframes */\n    @keyframes fade-in {\n      from {\n        opacity: 0;\n        transform: translateY(8px);\n      }\n      to {\n        opacity: 1;\n        transform: translateY(0);\n      }\n    }\n\n    .card {\n      opacity: 0;\n      animation: fade-in 300ms ease-out forwards;\n    }\n\n    .card:nth-child(1) {\n      animation-delay: 0ms;\n    }\n\n    .card:nth-child(2) {\n      animation-delay: 100ms;\n    }\n\n    .card:nth-child(3) {\n      animation-delay: 200ms;\n    }\n\n    /* Screen fade-in */\n    .phone {\n      opacity: 0;\n      animation: fade-in 300ms ease-out forwards;\n      animation-delay: 0ms;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <div class=\"status-bar\">\n      <span>9:41</span>\n      <div class=\"status-bar-icons\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n          <rect x=\"4\" y=\"9\" width=\"14\" height=\"6\" rx=\"1\" fill=\"currentColor\"/>\n        </svg>\n      </div>\n    </div>\n\n    <header class=\"app-bar\">\n      <h1 class=\"app-bar-title\">Library</h1>\n    </header>\n\n    <main class=\"content\" role=\"main\" aria-label=\"Library screen\">\n      <section class=\"section\" aria-label=\"Navigation cards\">\n        <!-- Health Log Card -->\n        <div class=\"card card-health-log\"\n             role=\"link\"\n             tabindex=\"0\"\n             aria-label=\"Health Log, double tap to open health log screen\"\n             data-route=\"/health-log\">\n          <div class=\"card-row\">\n            <div class=\"card-icon-container\">\n              <!-- favorite_outline -->\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/>\n              </svg>\n            </div>\n            <div class=\"card-text\">\n              <h2 class=\"card-title\">Health Log</h2>\n              <p class=\"card-description\">Track symptoms, doctor visits, reminders</p>\n            </div>\n            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <polyline points=\"9 18 15 12 9 6\"/>\n            </svg>\n          </div>\n        </div>\n\n        <!-- Mood & Wellness Card -->\n        <div class=\"card card-mood\"\n             role=\"link\"\n             tabindex=\"0\"\n             aria-label=\"Mood and Wellness, double tap to open mood and wellness screen\"\n             data-route=\"/mood-wellness\">\n          <div class=\"card-row\">\n            <div class=\"card-icon-container\">\n              <!-- mood_outlined -->\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n                <path d=\"M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01\"/>\n              </svg>\n            </div>\n            <div class=\"card-text\">\n              <h2 class=\"card-title\">Mood & Wellness</h2>\n              <p class=\"card-description\">Log moods, track energy levels</p>\n            </div>\n            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <polyline points=\"9 18 15 12 9 6\"/>\n            </svg>\n          </div>\n        </div>\n\n        <!-- Education Card -->\n        <div class=\"card card-education\"\n             role=\"link\"\n             tabindex=\"0\"\n             aria-label=\"Education, double tap to open education screen\"\n             data-route=\"/education\">\n          <div class=\"card-row\">\n            <div class=\"card-icon-container\">\n              <!-- school_outlined -->\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M22 10v6M2 10l10-5 10 5-10 5z\"/>\n                <path d=\"M6 12v5c3 3 9 3 12 0v-5\"/>\n              </svg>\n            </div>\n            <div class=\"card-text\">\n              <h2 class=\"card-title\">Education</h2>\n              <p class=\"card-description\">Browse articles and trusted health info</p>\n            </div>\n            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <polyline points=\"9 18 15 12 9 6\"/>\n            </svg>\n          </div>\n        </div>\n      </section>\n    </main>\n\n    <nav class=\"bottom-nav\" role=\"navigation\" aria-label=\"Main navigation\">\n      <button class=\"nav-item\" aria-label=\"Home\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/>\n          <polyline points=\"9 22 9 12 15 12 15 22\"/>\n        </svg>\n        <span>Home</span>\n      </button>\n      <button class=\"nav-item\" aria-label=\"Browse\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"11\" cy=\"11\" r=\"8\"/>\n          <path d=\"M21 21l-4.35-4.35\"/>\n        </svg>\n        <span>Browse</span>\n      </button>\n      <button class=\"nav-item active\" aria-current=\"page\" aria-label=\"Library\">\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <path d=\"M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z\"/>\n        </svg>\n        <span>Library</span>\n      </button>\n      <button class=\"nav-item\" aria-label=\"Profile\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"12\" cy=\"8\" r=\"4\"/>\n          <path d=\"M4 20c0-4 4-6 8-6s8 2 8 6\"/>\n        </svg>\n        <span>Profile</span>\n      </button>\n    </nav>\n\n    <div class=\"home-indicator\"></div>\n  </div>\n</body>\n</html>"}}],"model":"MiniMax-M2.7","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":33953,"output_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"416afcf3-a126-4a1b-8d05-d25586a70067","uuid":"aadda20c-5833-439e-a91e-18548f369f81"}
