ration(\n164\t                    color: AppTheme.lavenderBloom.withValues(alpha: 0.15),\n165\t                    shape: BoxShape.circle,\n166\t                  ),\n167\t                  child: Icon(\n168\t                    Icons.checklist,\n169\t                    size: 20,\n170\t                    color: AppTheme.lavenderBloom,\n171\t                  ),\n172\t                ),\n173\t                Column(\n174\t                  crossAxisAlignment: CrossAxisAlignment.start,\n175\t                  children: [\n176\t                    Text(\n177\t                      '3',\n178\t                      style: textTheme.titleMedium,\n179\t                    ),\n180\t                    Text(\n181\t                      'symptoms this week',\n182\t                      style: textTheme.labelSmall,\n183\t                    ),\n184\t                  ],\n185\t                ),\n186\t              ],\n187\t            ),\n188\t            // Divider\n189\t            Container(\n190\t              width: 1,\n191\t              height: 40,\n192\t              color: AppTheme.mistyBorder,\n193\t            ),\n194\t            // Next reminder\n195\t            Row(\n196\t              spacing: AppTheme.spaceXs,\n197\t              children: [\n198\t                Container(\n199\t                  width: 40,\n200\t                  height: 40,\n201\t                  decoration: BoxDecoration(\n202\t                    color: AppTheme.softMint.withValues(alpha: 0.2),\n203\t                    shape: BoxShape.circle,\n204\t                  ),\n205\t                  child: Icon(\n206\t                    Icons.calendar_today,\n207\t                    size: 20,\n208\t                    color: AppTheme.softMint,\n209\t                  ),\n210\t                ),\n211\t                Column(\n212\t                  crossAxisAlignment: CrossAxisAlignment.start,\n213\t                  children: [\n214\t                    Text(\n215\t                      'N