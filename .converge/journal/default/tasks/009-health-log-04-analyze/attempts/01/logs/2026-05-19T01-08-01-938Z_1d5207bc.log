oneGrey,\n53\t              letterSpacing: 0.4,\n54\t            ),\n55\t          ),\n56\t          const SizedBox(height: AppTheme.spaceSm),\n57\t\n58\t          // Today entries\n59\t          _HealthEntryCard(\n60\t            title: 'Headache',\n61\t            subtitle: 'Felt dizzy after standing up quickly',\n62\t            time: '2:30 PM',\n63\t            severity: 2,\n64\t            entryType: _EntryType.symptom,\n65\t          ),\n66\t          const SizedBox(height: AppTheme.spaceSm),\n67\t          _HealthEntryCard(\n68\t            title: 'Dr. Sarah Chen',\n69\t            subtitle: 'Regular prenatal checkup, everything looks good',\n70\t            time: '10:00 AM',\n71\t            badgeText: 'Next: May 29',\n72\t            badgeColor: AppTheme.softMint.withValues(alpha: 0.2),\n73\t            entryType: _EntryType.doctorVisit,\n74\t          ),\n75\t\n76\t          const SizedBox(height: AppTheme.spaceLg),\n77\t\n78\t          // Yesterday header\n79\t          Text(\n80\t            'Yesterday',\n81\t            style: textTheme.labelSmall?.copyWith(\n82\t              color: AppTheme.stoneGrey,\n83\t              letterSpacing: 0.4,\n84\t            ),\n85\t          ),\n86\t          const SizedBox(height: AppTheme.spaceSm),\n87\t\n88\t          _HealthEntryCard(\n89\t            title: 'Nausea',\n90\t            subtitle: 'Morning sickness, took ginger tea',\n91\t            time: '8:15 AM',\n92\t            severity: 1,\n93\t            entryType: _EntryType.symptom,\n94\t          ),\n95\t          const SizedBox(height: AppTheme.spaceSm),\n96\t          _HealthEntryCard(\n97\t            title: 'Take Prenatal Vitamins',\n98\t            subtitle: null,\n99\t            time: '7:00 AM',\n100\t            badgeText: 'Medication',\n101\t            badgeColor: AppTheme.blushRose.withValues(alpha: 0.2),\n102\t            enabledText: 'Enabled',\n103\t            enabledColor: AppTheme.softMint,\n104\t            entryType: _EntryType.reminder,\n105\t          ),\n106\t\n107\t          const SizedBox(height: AppTheme.spaceLg),\n108\t\n109\t          // May 15, 2026 header\n110\t          Text(\n111\t            'May 15, 2026',\n112\t            style: textTheme.labelSmall?.copyWith(\n113\t              color: AppTheme.stoneGrey,\n114\t              letterSpacing: 0.4,\n115\t            ),\n116\t          ),\n117\t          const SizedBox(height: AppTheme.spaceSm),\n118\t\n119\t          _HealthEntryCard(\n120\t            title: 'Dr. Emily Watson',\n121\t            subtitle: '22-week ultrasound scan',\n122\t            time: '11:30 AM',\n123\t            badgeText: 'Next: Jun 12',\n124\t            badgeColor: AppTheme.softMint.withValues(alpha: 0.2),\n125\t            entryType: _EntryType.doctorVisit,\n126\t          ),\n127\t\n128\t          // Bottom padding for FAB\n129\t          const SizedBox(height: 100),\n130\t        ],\n131\t      ),\n132\t      floatingActionButton: _AddEntryFab(),\n133\t    );\n134\t  }\n135\t}\n136\t\n137\tenum _EntryType { symptom, doctorVisit, reminder }\n138\t\n139\tclass _SummaryStatsCard extends StatelessWidget {\n140\t  @override\n141\t  Widget build(BuildContext context) {\n142\t    final theme = Theme.of(context);\n143\t    final textTheme = theme.textTheme;\n144\t\n145\t    return Card(\n146\t      color: AppTheme.morningMist,\n147\t      elevation: 0,\n148\t      shape: RoundedRectangleBorder(\n149\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n150\t      ),\n151\t      child: Padding(\n152\t        padding: const EdgeInsets.all(AppTheme.spaceMd),\n153\t        child: Row(\n154\t          mainAxisAlignment: MainAxisAlignment.spaceAround,\n155\t          children: [\n156\t            // Symptom count\n157\t            Row(\n158\t              spacing: AppTheme.spaceXs,\n159\t              children: [\n160\t                Container(\n161\t                  width: 40,\n162\t                  height: 40,\n163\t                  decoration: BoxDecoration(\n164\t                    color: AppTheme.lavenderBloom.withValues(alpha: 0.15),\n165\t                    shape: BoxShape.circle,\n166\t                  ),\n167\t                  child: Icon(\n168\t                    Icons.checklist,\n169\t                    size: 20,\n170\t                    color: AppTheme.lavenderBloom,\n171\t                  ),\n172\t                ),\n173\t                Column(\n174\t                  crossAxisAlignment: CrossAxisAlignment.start,\n175\t                  children: [\n176\t                    Text(\n177\t                      '3',\n178\t                      style: textTheme.titleMedium,\n179\t                    ),\n180\t                    Text(\n181\t                      'symptoms this week',\n182\t                      style: textTheme.labelSmall,\n183\t                    ),\n184\t                  ],\n185\t                ),\n186\t              ],\n187\t            ),\n188\t            // Divider\n189\t            Container(\n190\t              width: 1,\n191\t              height: 40,\n192\t              color: AppTheme.mistyBorder,\n193\t            ),\n194\t            // Next reminder\n195\t            Row(\n196\t              spacing: AppTheme.spaceXs,\n197\t              children: [\n198\t                Container(\n199\t                  width: 40,\n200\t                  height: 40,\n201\t                  decoration: BoxDecoration(\n202\t                    color: AppTheme.softMint.withValues(alpha: 0.2),\n203\t                    shape: BoxShape.circle,\n204\t                  ),\n205\t                  child: Icon(\n206\t                    Icons.calendar_today,\n207\t                    size: 20,\n208\t                    color: AppTheme.softMint,\n209\t                  ),\n210\t                ),\n211\t                Column(\n212\t                  crossAxisAlignment: CrossAxisAlignment.start,\n213\t                  children: [\n214\t                    Text(\n215\t                      'Next',\n216\t                      style: textTheme.labelSmall,\n217\t                    ),\n218\t                    Text(\n219\t                      'Prenatal on May 22',\n220\t                      style: textTheme.titleSmall,\n221\t                    ),\n222\t                  ],\n223\t                ),\n224\t              ],\n225\t            ),\n226\t          ],\n227\t        ),\n228\t      ),\n229\t    ).animate().fadeIn(duration: 200.ms);\n230\t  }\n231\t}\n232\t\n233\tclass _HealthEntryCard extends StatelessWidget {\n234\t  final String title;\n235\t  final String? subtitle;\n236\t  final String time;\n237\t  final int? severity;\n238\t  final String? badgeText;\n239\t  final Color? badgeColor;\n240\t  final String? enabledText;\n241\t  final Color? enabledColor;\n242\t  final _EntryType entryType;\n243\t\n244\t  const _HealthEntryCard({\n245\t    required this.title,\n246\t    required this.subtitle,\n247\t    required this.time,\n248\t    this.severity,\n249\t    this.badgeText,\n250\t    this.badgeColor,\n251\t    this.enabledText,\n252\t    this.enabledColor,\n253\t    required this.entryType,\n254\t  });\n255\t\n256\t  Color get _borderColor {\n257\t    switch (entryType) {\n258\t      case _EntryType.symptom:\n259\t        return AppTheme.lavenderBloom;\n260\t      case _EntryType.doctorVisit:\n261\t        return AppTheme.blushRose;\n262\t      case _EntryType.reminder:\n263\t        return AppTheme.softMint;\n264\t    }\n265\t  }\n266\t\n267\t  @override\n268\t  Widget build(BuildContext context) {\n269\t    final theme = Theme.of(context);\n270\t    final textTheme = theme.textTheme;\n271\t\n272\t    return Container(\n273\t      decoration: BoxDecoration(\n274\t        color: AppTheme.morningMist,\n275\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n276\t        border: Border(\n277\t          left: BorderSide(color: _borderColor, width: 4),\n278\t        ),\n279\t      ),\n280\t      child: Material(\n281\t        color: App