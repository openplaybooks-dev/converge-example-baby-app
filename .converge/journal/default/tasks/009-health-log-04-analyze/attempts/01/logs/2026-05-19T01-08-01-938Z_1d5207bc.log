233	class _HealthEntryCard extends StatelessWidget {
234	  final String title;
235	  final String? subtitle;
236	  final String time;
237	  final int? severity;
238	  final String? badgeText;
239	  final Color? badgeColor;
240	  final String? enabledText;
241	  final Color? enabledColor;
242	  final _EntryType entryType;
243	
244	  const _HealthEntryCard({
245	    required this.title,
246	    required this.subtitle,
247	    required this.time,
248	    this.severity,
249	    this.badgeText,
250	    this.badgeColor,
251	    this.enabledText,
252	    this.enabledColor,
253	    required this.entryType,
254	  });
255	
256	  Color get _borderColor {
257	    switch (entryType) {
258	      case _EntryType.symptom:
259	        return AppTheme.lavenderBloom;
260	      case _EntryType.doctorVisit:
261	        return AppTheme.blushRose;
262	      case _EntryType.reminder:
263	        return AppTheme.softMint;
264	    }
265	  }
266	
267	  @override
268	  Widget build(BuildContext context) {
269	    final theme = Theme.of(context);
270	    final textTheme = theme.textTheme;
271	
272	    return Container(
273	      decoration: BoxDecoration(
274	        color: AppTheme.morningMist,
275	        borderRadius: BorderRadius.circular(AppTheme.radiusLg),
276	        border: Border(
277	          left: BorderSide(color: _borderColor, width: 4),
278	        ),
279	      ),
280	      child: Material(
281	        color: AppTheme.transparent,
282	        child: InkWell(
283	          borderRadius: BorderRadius.circular(AppTheme.radiusLg),
284	          onTap: () {
285	            // Entry detail bottom sheet
286	          },
287	          child: Padding(
288	            padding: const EdgeInsets.all(AppTheme.spaceMd),
289	            child: Row(
290	              crossAxisAlignment: CrossAxisAlignment.start,
291	              children: [
292	                Expanded(
293	                  child: Column(
294	                    crossAxisAlignment: CrossAxisAlignment.start,
295	                    children: [
296	                      Text(
297	                        title,
298	                        style: textTheme.titleMedium,
299	                      ),
300	                      if (severity != null) ...[
301	                        const SizedBox(height: AppTheme.spaceXxs),
302	                        Row(
303	                          spacing: AppTheme.spaceXxs,
304	                          children: [
305	                            ...List.generate(
306	                              3,
307	                              (index) => Container(
308	                                width: 8,
309	                                height: 8,
310	                                decoration: BoxDecoration(
311	                                  color: index < severity!
312	                                      ? AppTheme.lavenderBloom
313	                                      : AppTheme.stoneGrey.withValues(alpha: 0.3),
314	                                  shape: BoxShape.circle,
315	                                ),
316	                              ),
317	                            ),
318	                            const SizedBox(width: AppTheme.spaceXxs),
319	                            Text(
320	                              severity == 1
321	                                  ? 'Mild'
322	                                  : severity == 2
323	                                      ? 'Moderate'
324	                                      : 'Severe',
325	                              style: textTheme.labelSmall,
326	                            ),
327	                          ],
328	                        ),
329	                      ],
330	                      if (subtitle != null) ...[
331	                        const SizedBox(height: AppTheme.spaceXxs),
332	                        Text(
333	                          subtitle!,
334	                          style: textTheme.bodyMedium,
335	                          maxLines: 1,
336	                          overflow: TextOverflow.ellipsis,
337	                        ),
338	                      ],
339	                      if (badgeText != null) ...[
340	                        const SizedBox(height: AppTheme.spaceXs),
341	                        Container(
342	                          padding: const EdgeInsets.symmetric(
343	                            horizontal: AppTheme.spaceXs,
344	                            vertical: AppTheme.spaceXxs,
345	                          ),
346	                          decoration: BoxDecoration(
347	                            color: badgeColor,
348	                            borderRadius: BorderRadius.circular(AppTheme.radiusPill),
349	                          ),
350	                          child: Text(
351	                            badgeText!,
352	                            style: textTheme.labelSmall,
353	                          ),
354	                        ),
355	                      ],
356	                      if (enabledText != null) ...[
357	                        const SizedBox(height: AppTheme.spaceXs),
358	                        Row(
359	                          spacing: AppTheme.spaceXxs,
360	                          children: [
361	                            Container(
362	                              width: 8,
363	                              height: 8,
364	                              decoration: BoxDecoration(
365	                                color: enabledColor,
366	                                shape: BoxShape.circle,
367	                              ),
368	                            ),
369	                            Text(
370	                              enabledText!,
371	                              style: textTheme.labelSmall?.copyWith(
372	                                color: enabledColor,
373	                                fontWeight: FontWeight.w600,
374	                              ),
375	                            ),
376	                          ],
377	                        ),
378	                      ],
379	                    ],
380	                  ),
381	                ),
382	                const SizedBox(width: AppTheme.spaceSm),
383	                Text(
384	                  time,
385	                  style: textTheme.labelSmall,
386	                ),
387	              ],
388	            ),
389	          ),
390	        ),
391	      ),
392	    ).animate().fadeIn(duration: 200.ms).slideY(begin: 0.05, end: 0);
393	  }
394	}
