button>\n            <button class=\"mood-btn\" aria-label=\"Neutral\" aria-pressed=\"false\">😐</button>\n            <button class=\"mood-btn\" aria-label=\"Happy\" aria-pressed=\"false\">🙂</button>\n            <button class=\"mood-btn\" aria-label=\"Very happy\" aria-pressed=\"false\">😊</button>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"card\">\n          <h2 class=\"card-title\">Today's Checklist</h2>\n          <div class=\"checklist-chips\">\n            <button class=\"chip\" aria-label=\"Log weight\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M12 3v18M3 12h18M5.6 5.6l12.8 12.8M18.4 5.6L5.6 18.4\"/>\n              </svg>\n              Weight\n            </button>\n            <button class=\"chip\" aria-label=\"Log water intake\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z\"/>\n              </svg>\n              Water\n            </button>\n            <button class=\"chip\" aria-label=\"Log mood\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n                <path d=\"M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01\"/>\n              </svg>\n              Mood\n            </button>\n            <button class=\"chip\" aria-label=\"Log symptoms\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/>\n              </svg>\n              Symptoms\n            </button>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <h2 class=\"card-title\">Quick Actions</h2>\n        <div class=\"quick-actions\">\n          <button class=\"action-btn\" aria-label=\"Log Weight\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n              <path d=\"M12 6v6l4 2\"/>\n            </svg>\n            <span>Log Weight</span>\n          </button>\n          <button class=\"action-btn\" aria-label=\"Log Mood\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n              <path d=\"M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01\"/>\n            </svg>\n            <span>Log Mood</span>\n          </button>\n          <button class=\"action-btn\" aria-label=\"Log Symptoms\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/>\n            </svg>\n            <span>Log Symptoms</span>\n          </button>\n          <button class=\"action-btn\" aria-label=\"View Education\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M4 19.5A2.5 2.5 0 0 1 6.5 17H20\"/>\n              <path d=\"M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z\"/>\n            </svg>\n            <span>Education</span>\n          </button>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"tip-card\">\n          <div class=\"tip-label\">Weekly Tip</div>\n          <p class=\"tip-text\">Stay hydrated! Aim for 8-10 glasses of water daily. Your body is working hard to support your growing baby.</p>\n        </div>\n      </section>\n    </main>\n\n    <nav class=\"bottom-nav\" role=\"navigation\" aria-label=\"Main navigation\">\n      <button class=\"nav-item active\" aria-current=\"page\" aria-label=\"Home\">\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <path d=\"M12 3L4 9v12h5v-7h6v7h5V9z\"/>\n  