       <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Box Breathing</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">2 min</p>\n                  <span class=\"badge-pill bg-mint/20 text-lavender\">Beginner</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n            <!-- Card 2: Deep Breathing -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Deep Breathing</h3>\n                  <p class=\"text-sm text-stone mb-2\" style=\"line-height: 20px;\">3 min</p>\n                  <span class=\"badge-pill bg-mint/20 text-lavender\">Beginner</span>\n                </div>\n                <svg class=\"w-5 h-5 text-stone shrink-0 ml-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n                </svg>\n              </div>\n            </div>\n\n            <!-- Card 3: 4-7-8 Technique -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n              <div class=\"flex items-center justify-between\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">4-7-8 Technique</h3>\n                  <p class=\"text