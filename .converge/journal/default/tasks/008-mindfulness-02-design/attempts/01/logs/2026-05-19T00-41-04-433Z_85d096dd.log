ckground);\n56\t      border-radius: 40px;\n57\t      overflow: hidden;\n58\t      position: relative;\n59\t      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n60\t    }\n61\t\n62\t    .status-bar {\n63\t      height: 44px;\n64\t      background: var(--color-background);\n65\t      display: flex;\n66\t      justify-content: space-between;\n67\t      align-items: center;\n68\t      padding: 0 24px;\n69\t      font-size: 14px;\n70\t      font-weight: 600;\n71\t      color: var(--color-text-primary);\n72\t    }\n73\t\n74\t    .status-bar-icons {\n75\t      display: flex;\n76\t      gap: 6px;\n77\t      align-items: center;\n78\t    }\n79\t\n80\t    .status-bar-icons svg {\n81\t      width: 18px;\n82\t      height: 18px;\n83\t    }\n84\t\n85\t    .app-bar {\n86\t      height: 56px;\n87\t      display: flex;\n88\t      align-items: center;\n89\t      justify-content: space-between;\n90\t      padding: 0 16px;\n91\t      background: var(--color-background);\n92\t    }\n93\t\n94\t    .app-bar-title {\n95\t      font-size: 20px;\n96\t      font-weight: 600;\n97\t      color: var(--color-text-primary);\n98\t    }\n99\t\n100\t    .avatar {\n101\t      width: 36px;\n102\t      height: 36px;\n103\t      border-radius: 50%;\n104\t      background: linear-gradient(135deg, var(--color-secondary), var(--color-primary));\n105\t      display: flex;\n106\t      align-items: center;\n107\t      justify-content: center;\n108\t    }\n109\t\n110\t    .avatar svg {\n111\t      width: 20px;\n112\t      height: 20px;\n113\t      color: var(--color-white);\n114\t    }\n115\t\n116\t    .content {\n117\t      padding: 0 16px 100px;\n118\t      overflow-y: auto;\n119\t    }\n120\t\n121\t    .section {\n122\t      margin-bottom: 24px;\n123\t    }\n124\t\n125\t    .week-banner {\n126\t      background: var(--color-white);\n127\t      border-radius: var(--radius-card);\n128\t      padding: 24px;\n129\t      text-align: center;\n130\t      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n131\t    }\