in-bottom: 4px;\n281\t    }\n282\t\n283\t    .tip-text {\n284\t      font-size: 14px;\n285\t      font-weight: 500;\n286\t      line-height: 20px;\n287\t    }\n288\t\n289\t    .state-indicator {\n290\t      position: absolute;\n291\t      top: 60px;\n292\t      right: 16px;\n293\t      padding: 4px 12px;\n294\t      border-radius: 12px;\n295\t      font-size: 11px;\n296\t      font-weight: 600;\n297\t      text-transform: uppercase;\n298\t      letter-spacing: 0.5pt;\n299\t    }\n300\t\n301\t    .state-indicator.empty {\n302\t      background: var(--color-border);\n303\t      color: var(--color-text-secondary);\n304\t    }\n305\t\n306\t    .state-indicator.filling {\n307\t      background: var(--color-secondary);\n308\t      opacity: 0.3;\n309\t      color: var(--color-text-primary);\n310\t    }\n311\t\n312\t    .state-indicator.complete {\n313\t      background: var(--color-tertiary);\n314\t      color: var(--color-text-primary);\n315\t    }\n316\t\n317\t    .bottom-nav {\n318\t      position: absolute;\n319\t      bottom: 0;\n320\t      left: 0;\n321\t      right: 0;\n322\t      height: 80px;\n323\t      background: var(--color-white);\n324\t      display: flex;\n325\t      justify-content: space-around;\n326\t      align-items: flex-start;\n327\t      padding-top: 8px;\n328\t      border-top: 1px solid var(--color-border);\n329\t    }\n330\t\n331\t    .nav-item {\n332\t      display: flex;\n333\t      flex-direction: column;\n334\t      align-items: center;\n335\t      gap: 4px;\n336\t      padding: 8px 16px;\n337\t      border: none;\n338\t      background: none;\n339\t      cursor: pointer;\n340\t      position: relative;\n341\t    }\n342\t\n343\t    .nav-item.active::before {\n344\t      content: '';\n345\t      position: absolute;\n346\t      top: 0;\n347\t      width: 40px;\n348\t      height: 4px;\n349\t      background: var(--color-primary);\n350\t      border-radius: 2px;\n351\t      opacity: 0.15;\n352\t    }\n353\t\n354\t    .nav-item svg {\n355\t      width: 24px;\n356\t      height: 24px;\n357\t      color: var(--color-text-secondary);\n358\t    }\n359\t\n360\t    .nav-item.active svg {\n361\t      color: var(--color-primary);\n362\t    }\n363\t\n364\t    .nav-item span {\n365\t      font-size: 11px;\n366\t      font-weight: 500;\n367\t      color: var(--color-text-secondary);\n368\t    }\n369\t\n370\t    .nav-item.active span {\n371\t      font-weight: 600;\n372\t      color: var(--color-primary);\n373\t    }\n374\t\n375\t    .home-indicator {\n376\t      position: absolute;\n377\t      bottom: 8px;\n378\t      left: 50%;\n379\t      transform: translateX(-50%);\n380\t      width: 134px;\n381\t      height: 5px;\n382\t      background: var(--color-text-primary);\n383\t      border-radius: 3px;\n384\t      opacity: 0.2;\n385\t    }\n386\t  </style>\n387\t</head>\n388\t<body>\n389\t  <div class=\"phone\">\n390\t    <div class=\"status-bar\">\n391\t      <span>9:41</span>\n392\t      <div class=\"status-bar-icons\">\n393\t        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n394\t          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n395\t        </svg>\n396\t        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n397\t          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n398\t          <rect x=\"4\" y=\"9\" width=\"14\" height=\"6\" rx=\"1\" fill=\"currentColor\"/>\n399\t        </svg>\n400\t      </div>\n401\t    </div>\n402\t\n403\t    <header class=\"app-bar\">\n404\t      <button class=\"back-btn\" aria-label=\"Go back\">\n405\t        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n406\t          <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n407\t        </svg>\n408\t      </button>\n409\t      <h1 class=\"app-bar-title\">Mood & Wellness</h1>\n410\t      <span class=\"state-indicator complete\">7 days</span>\n411\t    </header>\n412\t\n413\t    <main class=\"content\">\n414\t      <section class=\"section\">\n415\t        <div class=\"card\">\n416\t          <h2 class=\"card-title\">How are you feeling today?</h2>\n417\t          <div class=\"emoji-selector\" role=\"group\" aria-label=\"Mood selection\">\n418\t            <button class=\"emoji-btn\" aria-label=\"Very sad\" aria-pressed=\"false\">😢</button>\n419\t            <button class=\"emoji-btn\" aria-label=\"Sad\" aria-pressed=\"false\">😕</button>\n420\t            <button class=\"emoji-btn selected\" aria-label=\"Neutral\" aria-pressed=\"true\">😐</button>\n421\t            <button class=\"emoji-btn\" aria-label=\"Happy\" aria-pressed=\"false\">🙂</button>\n422\t            <button class=\"emoji-btn\" aria-label=\"Very happy\" aria-pressed=\"false\">😊</button>\n423\t          </div>\n424\t          <div class=\"note-field\">\n425\t            <textarea class=\"note-input\" placeholder=\"Add a note (optional)\" aria-label=\"Mood note\"></textarea>\n426\t          </div>\n427\t        </div>\n428\t      </section>\n429\t\n430\t      <section class=\"section\">\n431\t        <div class=\"chart-card\">\n432\t          <div class=\"chart-header\">\n433\t            <h3 class=\"chart-title\">Mood Trend</h3>\n434\t            <span class=\"chart-badge\">Last 7 days</span>\n435\t          </div>\n436\t          <div class=\"chart-area\">\n437\t            <svg class=\"chart-svg\" viewBox=\"0 0 300 120\" preserveAspectRatio=\"none\">\n438\t              <defs>\n439\t                <linearGradient id=\"moodGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n440\t                  <stop offset=\"0%\" stop-color=\"#7C3AED\" stop-opacity=\"0.3\"/>\n441\t                  <stop offset=\"100%\" stop-color=\"#7C3AED\" stop-opacity=\"0\"/>\n442\t                </linearGradient>\n443\t              </defs>\n444\t              <path d=\"M0 90 Q25 85 50 75 T100 65 T150 55 T200 45 T250 40 T300 35 L300 120 L0 120 Z\" fill=\"url(#moodGradient)\"/>\n445\t              <path d=\"M0 90 Q25 85 50 75 T100 65 T150 55 T200 45 T250 40 T300 35\" fill=\"none\" stroke=\"#7C3AED\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n446\t              <circle cx=\"0\" cy=\"90\" r=\"4\" fill=\"#7C3AED\"/>\n447\t              <circle cx=\"50\" cy=\"75\" r=\"4\" fill=\"#7C3AED\"/>\n448\t              <circle cx=\"100\" cy=\"65\" r=\"4\" fill=\"#7C3AED\"/>\n449\t              <circle cx=\"150\" cy=\"55\" r=\"4\" fill=\"#7C3AED\"/>\n450\t              <circle cx=\"200\" cy=\"45\" r=\"4\" fill=\"#7C3AED\"/>\n451\t              <circle cx=\"250\" cy=\"40\" r=\"4\" fill=\"#7C3AED\"/>\n452\t              <circle cx=\"300\" cy=\"35\" r=\"4\" fill=\"#7C3AED\"/>\n453\t              <text x=\"0\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Mon</text>\n454\t              <text x=\"50\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Tue</text>\n455\t              <text x=\"100\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Wed</text>\n456\t              <text x=\"150\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Thu</text>\n457\t              <text x=\"200\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Fri</text>\n458\t              <text x=\"250\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sat</text>\n459\t              <text x=\"300\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sun</text>\n460\t            </svg>\n461\t          </div>\n462\t        </div>\n463\t      </section>\n464\t\n465\t      <section class=\"section\">\n466\t        <div class=\"chart-card\">\n467\t          <div class=\"chart-header\">\n468\t            <h3 class=\"chart-title\">Energy Level</h3>\n469\t            <span class=\"chart-badge\">Last 7 days</span>\n470\t          </div>\n471\t          <div class=\"chart-area\">\n472\t            <svg class=\"chart-svg\" viewBox=\"0 0 300 120\" preserveAspectRatio=\"none\">\n473\t              <defs>\n474\t                <linearGradient id=\"energyGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n475\t                  <stop offset=\"0%\" stop-color=\"#6EE7B7\" stop-opacity=\"0.3\"/>\n476\t                  <stop offset=\"100%\" stop-color=\"#6EE7B7\" stop-opacity=\"0\"/>\n477\t                </linearGradient>\n478\t              </defs>\n479\t              <path d=\"M0 70 Q25 60 50 65 T100 50 T150 55 T200 35 T250 30 T300 40 L300 120 L0 120 Z\" fill=\"url(#energyGradient)\"/>\n480\t              <path d=\"M0 70 Q25 60 50 65 T100 50 T150 55 T200 35 T250 30 T300 40\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n481\t              <circle cx=\"0\" cy=\"70\" r=\"4\" fill=\"#6EE7B7\"/>\n482\t              <circle cx=\"50\" cy=\"65\" r=\"4\" fill=\"#6EE7B7\"/>\n483\t              <circle cx=\"100\" cy=\"50\" r=\"4\" fill=\"#6EE7B7\"/>\n484\t              <circle cx=\"150\" cy=\"55\" r=\"4\" fill=\"#6EE7B7\"/>\n485\t              <circle cx=\"200\" cy=\"35\" r=\"4\" fill=\"#6EE7B7\"/>\n486\t              <circle cx=\"250\" cy=\"30\" r=\"4\" fill=\"#6EE7B7\"/>\n487\t              <circle cx=\"300\" cy=\"40\" r=\"4\" fill=\"#6EE7B7\"/>\n488\t              <text x=\"0\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Mon</text>\n489\t              <text x=\"50\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Tue</text>\n490\t              <text x=\"100\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Wed</text>\n491\t              <text x=\"150\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Thu</text>\n492\t              <text x=\"200\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Fri</text>\n493\t              <text x=\"250\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sat</text>\n494\t              <text x=\"300\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sun</text>\n495\t            </svg>\n496\t          </div>\n497\t        </div>\n498\t      </section>\n499\t\n500\t      <section class=\"section\">\n501\t        <div class=\"wellness-tip\">\n502\t          <div class=\"tip-label\">Wellness Tip</div>\n503\t          <p class=\"tip-text\">Your energy is improving! Try adding a 10-minute walk after meals to maintain this positive trend.</p>\n504\t        </div>\n505\t      </section>\n506\t    </main>\n507\t\n508\t    <nav class=\"bottom-nav\" role=\"navigation\" aria-label=\"Main navigation\">\n509\t      <button class=\"nav-item\" aria-label=\"Home\">\n510\t        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n511\t          <path d=\"M12 3L4 9v12h5v-7h6v7h5V9z\"/>\n512\t        </svg>\n513\t        <span>Home</span>\n514\t      </button>\n515\t      <button class=\"nav-item\" aria-label=\"Browse\">\n516\t        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n517\t          <circle cx=\"11\" cy=\"11\" r=\"8\"/>\n518\t          <path d=\"M21 21l-4.35-4.35\"/>\n519\t        </svg>\n520\t        <span>Browse</span>\n521\t      </button>\n522\t      <button class=\"nav-item\" aria-label=\"Library\">\n523\t        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n524\t          <path d=\"M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z\"/>\n525\t        </svg>\n526\t        <span>Library</span>\n527\t      </button>\n528\t      <button class=\"nav-item active\" aria-current=\"page\" aria-label=\"Profile\">\n529\t        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n530\t          <circle cx=\"12\" cy=\"8\" r=\"4\"/>\n531\t          <path d=\"M4 20c0-4 4-6 8-6s8 2 8 6\"/>\n532\t        </svg>\n533\t        <span>Profile</span>\n534\t      </button>\n535\t    </nav>\n536\t\n537\t    <div class=\"home-indicator\"></div>\n538\t  </div>\n539\t</body>\n540\t</html>"}]},"parent_tool_use_id":null,"session_id":"0af1fd99-22fd-4f17-9f64-ae468b87fb8e","uuid":"9cd1a483-2529-4a7a-9250-d255a38d8205","timestamp":"2026-05-19T00:41:38.703Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/minh/Documents/openplayboosks/examples/baby-app/.stitch/system/multi-state-screen.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Baby Bump - Mood & Wellness</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root {\n      --color-primary: #7C3AED;\n      --color-secondary: #F9A8D4;\n      --color-tertiary: #6EE7B7;\n      --color-background: #F5F3FF;\n      --color-surface: #FAFAFA;\n      --color-text-primary: #1F2937;\n      --color-text-secondary: #6B7280;\n      --color-border: #E5E7EB;\n      --color-error: #EF4444;\n      --color-white: #FFFFFF;\n      --radius-card: 16px;\n      --radius-button: 24px;\n      --spacing-unit: 8px;\n      --font-family: 'Nunito', sans-serif;\n    }\n\n    *, *::before, *::after {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        animation-iteration-count: 1 !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n\n    body {\n      font-family: var(--font-family);\n      background: #1E1B2E;\n      min-height: 100vh;\n      display: flex;\n      justify-content: center;\n      align-items: flex-start;\n      padding: 20px 0;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      background: var(--color-background);\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .status-bar {\n      height: 44px;\n      background: var(--color-background);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      padding: 0 8px;\n      background: var(--color-background);\n    }\n\n    .back-btn {\n      width: 48px;\n      height: 48px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      border: none;\n      background: none;\n      cursor: pointer;\n      border-radius: 50%;\n      transition: background 200ms ease-out;\n    }\n\n    .back-btn:hover {\n      background: var(--color-border);\n    }\n\n    .back-btn svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-primary);\n    }\n\n    .app-bar-title {\n      flex: 1;\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      text-align: center;\n      margin-right: 48px;\n    }\n\n    .content {\n      padding: 0 16px 100px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-bottom: 24px;\n    }\n\n    .card {\n      background: var(--color-white);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .card-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      margin-bottom: 12px;\n    }\n\n    .emoji-selector {\n      display: flex;\n      justify-content: space-between;\n      gap: 8px;\n    }\n\n    .emoji-btn {\n      width: 56px;\n      height: 56px;\n      border-radius: 50%;\n      border: 2px solid var(--color-border);\n      background: var(--color-surface);\n      font-size: 32px;\n      cursor: pointer;\n      transition: transform 200ms ease-out, border-color 200ms ease-out, background 200ms ease-out;\n    }\n\n    .emoji-btn:hover, .emoji-btn:focus {\n      border-color: var(--color-primary);\n      transform: scale(1.1);\n    }\n\n    .emoji-btn.selected {\n      border-color: var(--color-primary);\n      background: rgba(124, 58, 237, 0.1);\n    }\n\n    .emoji-btn:focus {\n      outline: none;\n      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.2);\n    }\n\n    .note-field {\n      margin-top: 16px;\n    }\n\n    .note-input {\n      width: 100%;\n      min-height: 56px;\n      padding: 12px 16px;\n      border: none;\n      border-radius: 12px;\n      background: var(--color-surface);\n      font-family: var(--font-family);\n      font-size: 14px;\n      color: var(--color-text-primary);\n      resize: none;\n      transition: box-shadow 200ms ease-out;\n    }\n\n    .note-input::placeholder {\n      color: var(--color-text-secondary);\n    }\n\n    .note-input:focus {\n      outline: none;\n      box-shadow: 0 0 0 2px var(--color-primary);\n    }\n\n    .chart-card {\n      background: var(--color-white);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .chart-header {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      margin-bottom: 16px;\n    }\n\n    .chart-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .chart-badge {\n      font-size: 11px;\n      font-weight: 500;\n      padding: 4px 8px;\n      border-radius: 8px;\n      background: var(--color-secondary);\n      opacity: 0.3;\n      color: var(--color-text-primary);\n    }\n\n    .chart-area {\n      height: 120px;\n      position: relative;\n    }\n\n    .chart-svg {\n      width: 100%;\n      height: 100%;\n    }\n\n    .chart-empty {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      height: 120px;\n      color: var(--color-text-secondary);\n    }\n\n    .chart-empty svg {\n      width: 48px;\n      height: 48px;\n      margin-bottom: 8px;\n      opacity: 0.5;\n    }\n\n    .chart-empty span {\n      font-size: 14px;\n    }\n\n    .wellness-tip {\n      background: linear-gradient(135deg, var(--color-tertiary), #34D399);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      color: var(--color-text-primary);\n    }\n\n    .tip-label {\n      font-size: 11px;\n      font-weight: 500;\n      letter-spacing: 0.4pt;\n      text-transform: uppercase;\n      opacity: 0.7;\n      margin-bottom: 4px;\n    }\n\n    .tip-text {\n      font-size: 14px;\n      font-weight: 500;\n      line-height: 20px;\n    }\n\n    .state-indicator {\n      position: absolute;\n      top: 60px;\n      right: 16px;\n      padding: 4px 12px;\n      border-radius: 12px;\n      font-size: 11px;\n      font-weight: 600;\n      text-transform: uppercase;\n      letter-spacing: 0.5pt;\n    }\n\n    .state-indicator.empty {\n      background: var(--color-border);\n      color: var(--color-text-secondary);\n    }\n\n    .state-indicator.filling {\n      background: var(--color-secondary);\n      opacity: 0.3;\n      color: var(--color-text-primary);\n    }\n\n    .state-indicator.complete {\n      background: var(--color-tertiary);\n      color: var(--color-text-primary);\n    }\n\n    .bottom-nav {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      height: 80px;\n      background: var(--color-white);\n      display: flex;\n      justify-content: space-around;\n      align-items: flex-start;\n      padding-top: 8px;\n      border-top: 1px solid var(--color-border);\n    }\n\n    .nav-item {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 4px;\n      padding: 8px 16px;\n      border: none;\n      background: none;\n      cursor: pointer;\n      position: relative;\n    }\n\n    .nav-item.active::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      width: 40px;\n      height: 4px;\n      background: var(--color-primary);\n      border-radius: 2px;\n      opacity: 0.15;\n    }\n\n    .nav-item svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active svg {\n      color: var(--color-primary);\n    }\n\n    .nav-item span {\n      font-size: 11px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active span {\n      font-weight: 600;\n      color: var(--color-primary);\n    }\n\n    .home-indicator {\n      position: absolute;\n      bottom: 8px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 134px;\n      height: 5px;\n      background: var(--color-text-primary);\n      border-radius: 3px;\n      opacity: 0.2;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <div class=\"status-bar\">\n      <span>9:41</span>\n      <div class=\"status-bar-icons\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n          <rect x=\"4\" y=\"9\" width=\"14\" height=\"6\" rx=\"1\" fill=\"currentColor\"/>\n        </svg>\n      </div>\n    </div>\n\n    <header class=\"app-bar\">\n      <button class=\"back-btn\" aria-label=\"Go back\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n        </svg>\n      </button>\n      <h1 class=\"app-bar-title\">Mood & Wellness</h1>\n      <span class=\"state-indicator complete\">7 days</span>\n    </header>\n\n    <main class=\"content\">\n      <section class=\"section\">\n        <div class=\"card\">\n          <h2 class=\"card-title\">How are you feeling today?</h2>\n          <div class=\"emoji-selector\" role=\"group\" aria-label=\"Mood selection\">\n            <button class=\"emoji-btn\" aria-label=\"Very sad\" aria-pressed=\"false\">😢</button>\n            <button class=\"emoji-btn\" aria-label=\"Sad\" aria-pressed=\"false\">😕</button>\n            <button class=\"emoji-btn selected\" aria-label=\"Neutral\" aria-pressed=\"true\">😐</button>\n            <button class=\"emoji-btn\" aria-label=\"Happy\" aria-pressed=\"false\">🙂</button>\n            <button class=\"emoji-btn\" aria-label=\"Very happy\" aria-pressed=\"false\">😊</button>\n          </div>\n          <div class=\"note-field\">\n            <textarea class=\"note-input\" placeholder=\"Add a note (optional)\" aria-label=\"Mood note\"></textarea>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"chart-card\">\n          <div class=\"chart-header\">\n            <h3 class=\"chart-title\">Mood Trend</h3>\n            <span class=\"chart-badge\">Last 7 days</span>\n          </div>\n          <div class=\"chart-area\">\n            <svg class=\"chart-svg\" viewBox=\"0 0 300 120\" preserveAspectRatio=\"none\">\n              <defs>\n                <linearGradient id=\"moodGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                  <stop offset=\"0%\" stop-color=\"#7C3AED\" stop-opacity=\"0.3\"/>\n                  <stop offset=\"100%\" stop-color=\"#7C3AED\" stop-opacity=\"0\"/>\n                </linearGradient>\n              </defs>\n              <path d=\"M0 90 Q25 85 50 75 