m-textarea {\n      width: 100%;\n      min-height: 56px;\n      padding: 12px 16px;\n      background: var(--color-surface);\n      border: 1px solid var(--color-border);\n      border-radius: var(--radius-md);\n      font-size: 16px;\n      font-family: var(--font-family);\n      color: var(--color-text-primary);\n      resize: vertical;\n    }\n\n    .toggle-row {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 12px 0;\n    }\n\n    .toggle-label {\n      font-size: 16px;\n      font-weight: 500;\n      color: var(--color-text-primary);\n    }\n\n    .toggle {\n      width: 52px;\n      height: 32px;\n      background: var(--color-border);\n      border-radius: 16px;\n      position: relative;\n      cursor: pointer;\n      transition: background 200ms ease;\n    }\n\n    .toggle.active {\n      background: var(--color-primary);\n    }\n\n    .toggle::after {\n      content: '';\n      position: absolute;\n      top: 4px;\n      left: 4px;\n      width: 24px;\n      height: 24px;\n      background: var(--color-white);\n      border-radius: 50%;\n      transition: transform 200ms ease;\n    }\n\n    .toggle.active::after {\n      transform: translateX(20px);\n    }\n\n    .sheet-actions {\n      display: flex;\n      gap: var(--spacing-sm);\n      margin-top: var(--spacing-lg);\n    }\n\n    .btn-cancel {\n      flex: 1;\n      padding: 14px;\n      background: none;\n      border: none;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-secondary);\n      cursor: pointer;\n    }\n\n    .btn-save {\n      flex: 2;\n      padding: 14px;\n      background: var(--color-primary);\n      border: none;\n      border-radius: var(--radius-pill);\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-white);\n      cursor: pointer;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <div class=\"status-bar\">\n      <span>9:41</span>\n      <div class=\"status-bar-icons\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n          <rect x=\"4\" y=\"9\" width=\"14\" height=\"6\" rx=\"1\" fill=\"currentColor\"/>\n        </svg>\n      </div>\n    </div>\n\n    <header class=\"app-bar\">\n      <button class=\"back-btn\" aria-label=\"Back to Browse\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M15 18l-6-6 6-6\"/>\n        </svg>\n      </button>\n      <h1 class=\"app-bar-title\">Cycle Tracking</h1>\n    </header>\n\n    <main class=\"content\">\n      <section class=\"section\" aria-label=\"Current Cycle\">\n        <div class=\"current-cycle-card\">\n          <div class=\"cycle-day-badge\">Day 14</div>\n          <div class=\"days-counter\">14</div>\n          <div class=\"days-label\">days since last period</div>\n\n          <div class=\"next-period-row\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/>\n              <path d=\"M16 2v4M8 2v4M3 10h18\"/>\n            </svg>\n            <span>Next period expected: May 28, 2026</span>\n          </div>\n\n          <div class=\"fertile-window\" role=\"button\" tabindex=\"0\" aria-label=\"Tap to learn about your fertile window\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\">\n              <circle cx=\"12\" cy=\"12\" r=\"8\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n              <circle cx=\"12\" cy=\"12\" r=\"4\" fill=\"currentColor\"/>\n            </svg>\n            <span>Fertile window: May 19 - May 23</span>\n          </div>\n\n          <div class=\"cycle-progress\" role=\"progressbar\" aria-valuenow=\"50\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-label=\"Cycle progress\">\n            <div class=\"cycle-progress-fill\"></div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\" aria-label=\"Cycle History\">\n        <h2 class=\"history-header\">Cycle History</h2>\n\n        <article class=\"history-item\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from April 1 to April 28, 2026, 28 days\">\n          <div class=\"history-item-header\">\n            <span class=\"history-date\">Apr 1 - Apr 28, 2026</span>\n            <span class=\"history-length-badge\">28 days</span>\n          </div>\n          <div class=\"history-bar\">\n            <div class=\"history-bar-fill\" style=\"width: 100%\"></div>\n          </div>\n          <span class=\"history-notes\">Regular cycle this month</span>\n        </article>\n\n        <article class=\"history-item\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from March 4 to March 31, 2026, 27 days\">\n          <div class=\"history-item-header\">\n            <span class=\"history-date\">Mar 4 - Mar 31, 2026</span>\n            <span class=\"history-length-badge\">27 days</span>\n          </div>\n          <div class=\"history-bar\">\n            <div class=\"history-bar-fill\" style=\"width: 96%\"></div>\n          </div>\n          <span class=\"history-notes\">Shorter than usual</span>\n        </article>\n\n        <article class=\"history-item\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from February 5 to March 4, 2026, 27 days, irregular\">\n          <div class=\"history-item-header\">\n            <span class=\"history-date\">Feb 5 - Mar 4, 2026</span>\n            <span class=\"history-length-badge\">27 days</span>\n          </div>\n          <div class=\"history-bar\">\n            <div class=\"history-bar-fill\" style=\"width: 96%\"></div>\n          </div>\n          <span class=\"history-notes\">Had stress this month</span>\n          <span class=\"history-irregular\" aria-label=\"Irregular cycle indicator\"></span>\n        </article>\n\n        <div class=\"empty-state\" style=\"display: none;\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\">\n            <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/>\n            <path d=\"M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4\"/>\n          </svg>\n          <p class=\"empty-state-title\">No cycles logged yet</p>\n          <p class=\"empty-state-subtitle\">Tap + to add your first cycle</p>\n        </div>\n      </section>\n    </main>\n\n    <button class=\"fab\" aria-label=\"Add new cycle entry, double tap to open form\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n        <path d=\"M12 5v14M5 12h14\"/>\n      </svg>\n    </button>\n\n    <!-- Bottom Sheet Preview (triggered by FAB) -->\n    <div class=\"bottom-sheet\" id=\"bottomSheet\" style=\"display: none;\">\n      <div class=\"sheet-handle\"></div>\n      <h2 class=\"sheet-title\">Log Cycle</h2>\n\n      <div class=\"form-field\">\n        <label class=\"form-label\" for=\"periodDate\">Period Started</label>\n        <input type=\"date\" class=\"form-input\" id=\"periodDate\" value=\"2026-05-15\">\n      </div>\n\n      <div class=\"form-field\">\n        <label class=\"form-label\" for=\"cycleLength\">Cycle Length (days)</label>\n        <input type=\"number\" class=\"form-input\" id=\"cycleLength\" value=\"28\" placeholder=\"28\">\n      </div>\n\n      <div class=\"form-field\">\n        <label class=\"form-label\" for=\"notes\">Notes</label>\n        <textarea class=\"form-textarea\" id=\"notes\" placeholder=\"Add notes...\"></textarea>\n      </div>\n\n      <div class=\"toggle-row\">\n        <span class=\"toggle-label\">Irregular cycle</span>\n        <div class=\"toggle\" id=\"irregularToggle\" role=\"switch\" aria-checked=\"false\" tabindex=\"0\"></div>\n      </div>\n\n      <div class=\"sheet-actions\">\n        <button class=\"btn-cancel\" id=\"cancelBtn\">Cancel</button>\n        <button class=\"btn-save\" id=\"saveBtn\">Save</button>\n      </div>\n    </div>\n\n    <div class=\"home-indicator\"></div>\n  </div>\n\n  <script>\n    const fab = document.querySelector('.fab');\n    const bottomSheet = document.getElementById('bottomSheet');\n    const cancelBtn = document.getElementById('cancelBtn');\n    const toggle = document.getElementById('irregularToggle');\n\n    fab.addEventListener('click', () => {\n      bottomSheet.style.display = 'block';\n    });\n\n    cancelBtn.addEventListener('click', () => {\n      bottomSheet.style.display = 'none';\n    });\n\n    toggle.addEventListener('click', () => {\n      toggle.classList.toggle('active');\n      toggle.setAttribute('aria-checked', toggle.classList.contains('active'));\n    });\n  </script>\n</body>\n</html>"}}],"model":"MiniMax-M2.7","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":23301,"output_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"c41fb445-b236-431a-88b9-d9375f2ed5cf","uuid":"2d8c1cf6-51bb-410e-911a-2978fea74bb3"}
