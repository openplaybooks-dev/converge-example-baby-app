ht: 500;\n202\t      color: var(--color-text-primary);\n203\t    }\n204\t\n205\t    .cycle-progress {\n206\t      height: 8px;\n207\t      background: var(--color-border);\n208\t      border-radius: 4px;\n209\t      overflow: hidden;\n210\t    }\n211\t\n212\t    .cycle-progress-fill {\n213\t      height: 100%;\n214\t      width: 65%;\n215\t      background: var(--color-primary);\n216\t      border-radius: 4px;\n217\t    }\n218\t\n219\t    /* Cycle History */\n220\t    .history-header {\n221\t      font-size: 24px;\n222\t      font-weight: 700;\n223\t      color: var(--color-text-primary);\n224\t      margin-bottom: var(--spacing-md);\n225\t    }\n226\t\n227\t    .history-item {\n228\t      background: var(--color-surface);\n229\t      border-radius: var(--radius-md);\n230\t      padding: var(--spacing-md);\n231\t      margin-bottom: var(--spacing-sm);\n232\t      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n233\t    }\n234\t\n235\t    .history-item-header {\n236\t      display: flex;\n237\t      align-items: center;\n238\t      justify-content: space-between;\n239\t      margin-bottom: var(--spacing-xs);\n240\t    }\n241\t\n242\t    .history-date {\n243\t      font-size: 16px;\n244\t      font-weight: 600;\n245\t      color: var(--color-text-primary);\n246\t    }\n247\t\n248\t    .history-length-badge {\n249\t      display: inline-flex;\n250\t      padding: var(--spacing-xxs) var(--spacing-xs);\n251\t      background: var(--color-primary-tint);\n252\t      border-radius: var(--radius-sm);\n253\t      font-size: 12px;\n254\t      font-weight: 500;\n255\t      color: var(--color-primary);\n256\t    }\n257\t\n258\t    .history-bar {\n259\t      height: 6px;\n260\t      background: var(--color-border);\n261\t      border-radius: 3px;\n262\t      overflow: hidden;\n263\t      margin-bottom: var(--spacing-xs);\n264\t    }\n265\t\n266\t    .history-bar-fill {\n267\t      height: 100%;\n268\t      background: var(--color-primary);\n269\t      border-radius: 3px;\n270\t    }\n271\t\n272\t    .history-notes {\n273\t      font-size: 14px;\n274\t      color: var(--color-text-secondary);\n275\t    }\n276\t\n277\t    .history-irregular {\n278\t      display: inline-block;\n279\t      width: 8px;\n280\t      height: 8px;\n281\t      background: var(--color-secondary);\n282\t      border-radius: 50%;\n283\t      margin-left: var(--spacing-xs);\n284\t    }\n285\t\n286\t    /* Empty State */\n287\t    .empty-state {\n288\t      text-align: center;\n289\t      padding: var(--spacing-xl) var(--spacing-md);\n290\t    }\n291\t\n292\t    .empty-state svg {\n293\t      width: 64px;\n294\t      height: 64px;\n295\t      color: var(--color-border);\n296\t      margin-bottom: var(--spacing-md);\n297\t    }\n298\t\n299\t    .empty-state-title {\n300\t      font-size: 16px;\n301\t      font-weight: 600;\n302\t      color: var(--color-text-primary);\n303\t      margin-bottom: var(--spacing-xs);\n304\t    }\n305\t\n306\t    .empty-state-subtitle {\n307\t      font-size: 14px;\n308\t      color: var(--color-text-secondary);\n309\t    }\n310\t\n311\t    /* FAB */\n312\t    .fab {\n313\t      position: absolute;\n314\t      bottom: 24px;\n315\t      right: 16px;\n316\t      width: 56px;\n317\t      height: 56px;\n318\t      background: var(--color-primary);\n319\t      border: none;\n320\t      border-radius: 50%;\n321\t      display: flex;\n322\t      align-items: center;\n323\t      justify-content: center;\n324\t      box-shadow: 0 4px 12px rgba(124, 58, 237, 0.4);\n325\t      cursor: pointer;\n326\t      transition: transform 200ms ease-out, box-shadow 200ms ease-out;\n327\t    }\n328\t\n329\t    .fab:hover {\n330\t      transform: scale(0.95);\n331\t      box-shadow: 0 6px 16px rgba(124, 58, 237, 0.5);\n332\t    }\n333\t\n334\t    .fab:active {\n335\t      transform: scale(0.9);\n336\t    }\n337\t\n338\t    .fab svg {\n339\t      width: 24px;\n340\t      height: 24px;\n341\t      color: var(--color-white);\n342\t    }\n343\t\n344\t    .home-indicator {\n345\t      position: absolute;\n346\t      bottom: 8px;\n347\t      left: 50%;\n348\t      transform: translateX(-50%);\n349\t      width: 134px;\n350\t      height: 5px;\n351\t      background: var(--color-text-primary);\n352\t      border-radius: 3px;\n353\t      opacity: 0.2;\n354\t    }\n355\t\n356\t    /* Bottom Sheet (modal preview) */\n357\t    .bottom-sheet {\n358\t      position: absolute;\n359\t      bottom: 0;\n360\t      left: 0;\n361\t      right: 0;\n362\t      background: var(--color-white);\n363\t      border-radius: 28px 28px 0 0;\n364\t      padding: 12px 16px 32px;\n365\t      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);\n366\t    }\n367\t\n368\t    .sheet-handle {\n369\t      width: 40px;\n370\t      height: 4px;\n371\t      background: var(--color-border);\n372\t      border-radius: 2px;\n373\t      margin: 0 auto 16px;\n374\t    }\n375\t\n376\t    .sheet-title {\n377\t      font-size: 20px;\n378\t      font-weight: 600;\n379\t      color: var(--color-text-primary);\n380\t      margin-bottom: var(--spacing-md);\n381\t    }\n382\t\n383\t    .form-field {\n384\t      margin-bottom: var(--spacing-md);\n385\t    }\n386\t\n387\t    .form-label {\n388\t      font-size: 14px;\n389\t      font-weight: 500;\n390\t      color: var(--color-text-secondary);\n391\t      margin-bottom: var(--spacing-xs);\n392\t    }\n393\t\n394\t    .form-input {\n395\t      width: 100%;\n396\t      padding: 12px 16px;\n397\t      background: var(--color-surface);\n398\t      border: 1px solid var(--color-border);\n399\t      border-radius: var(--radius-md);\n400\t      font-size: 16px;\n401\t      font-family: var(--font-family);\n402\t      color: var(--color-text-primary);\n403\t    }\n404\t\n405\t    .form-textarea {\n406\t      width: 100%;\n407\t      min-height: 56px;\n408\t      padding: 12px 16px;\n409\t      background: var(--color-surface);\n410\t      border: 1px solid var(--color-border);\n411\t      border-radius: var(--radius-md);\n412\t      font-size: 16px;\n413\t      font-family: var(--font-family);\n414\t      color: var(--color-text-primary);\n415\t      resize: vertical;\n416\t    }\n417\t\n418\t    .toggle-row {\n419\t      display: flex;\n420\t      align-items: center;\n421\t      justify-content: space-between;\n422\t      padding: 12px 0;\n423\t    }\n424\t\n425\t    .toggle-label {\n426\t      font-size: 16px;\n427\t      font-weight: 500;\n428\t      color: var(--color-text-primary);\n429\t    }\n430\t\n431\t    .toggle {\n432\t      width: 52px;\n433\t      height: 32px;\n434\t      background: var(--color-border);\n435\t      border-radius: 16px;\n436\t      position: relative;\n437\t      cursor: pointer;\n438\t      transition: background 200ms ease;\n439\t    }\n440\t\n441\t    .toggle.active {\n442\t      background: var(--color-primary);\n443\t    }\n444\t\n445\t    .toggle::after {\n446\t      content: '';\n447\t      position: absolute;\n448\t      top: 4px;\n449\t      left: 4px;\n450\t      width: 24px;\n451\t      height: 24px;\n452\t      background: var(--color-white);\n453\t      border-radius: 50%;\n454\t      transition: transform 200ms ease;\n455\t    }\n456\t\n457\t    .toggle.active::after {\n458\t      transform: translateX(20px);\n459\t    }\n460\t\n461\t    .sheet-actions {\n462\t      display: flex;\n463\t      gap: var(--spacing-sm);\n464\t      margin-top: var(--spacing-lg);\n465\t    }\n466\t\n467\t    .btn-cancel {\n468\t      flex: 1;\n469\t      padding: 14px;\n470\t      background: none;\n471\t      border: none;\n472\t      font-size: 14px;\n473\t      font-weight: 600;\n474\t      color: var(--color-text-secondary);\n475\t      cursor: pointer;\n476\t    }\n477\t\n478\t    .btn-save {\n479\t      flex: 2;\n480\t      padding: 14px;\n481\t      background: var(--color-primary);\n482\t      border: none;\n483\t      border-radius: var(--radius-pill);\n484\t      font-size: 14px;\n485\t      font-weight: 600;\n486\t      color: var(--color-white);\n487\t      cursor: pointer;\n488\t    }\n489\t  </style>\n490\t</head>\n491\t<body>\n492\t  <div class=\"phone\">\n493\t    <div class=\"status-bar\">\n494\t      <span>9:41</span>\n495\t      <div class=\"status-bar-icons\">\n496\t        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n497\t          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n498\t        </svg>\n499\t        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n500\t          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n501\t          <rect x=\"4\" y=\"9\" width=\"14\" height=\"6\" rx=\"1\" fill=\"currentColor\"/>\n502\t        </svg>\n503\t      </div>\n504\t    </div>\n505\t\n506\t    <header class=\"app-bar\">\n507\t      <button class=\"back-btn\" aria-label=\"Back to Browse\">\n508\t        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n509\t          <path d=\"M15 18l-6-6 6-6\"/>\n510\t        </svg>\n511\t      </button>\n512\t      <h1 class=\"app-bar-title\">Cycle Tracking</h1>\n513\t    </header>\n514\t\n515\t    <main class=\"content\">\n516\t      <section class=\"section\" aria-label=\"Current Cycle\">\n517\t        <div class=\"current-cycle-card\">\n518\t          <div class=\"cycle-day-badge\">Day 14</div>\n519\t          <div class=\"days-counter\">14</div>\n520\t          <div class=\"days-label\">days since last period</div>\n521\t\n522\t          <div class=\"next-period-row\">\n523\t            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n524\t              <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/>\n525\t              <path d=\"M16 2v4M8 2v4M3 10h18\"/>\n526\t            </svg>\n527\t            <span>Next period expected: May 28, 2026</span>\n528\t          </div>\n529\t\n530\t          <div class=\"fertile-window\" role=\"button\" tabindex=\"0\" aria-label=\"Tap to learn about your fertile window\">\n531\t            <svg viewBox=\"0 0 24 24\" fill=\"none\">\n532\t              <circle cx=\"12\" cy=\"12\" r=\"8\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n533\t              <circle cx=\"12\" cy=\"12\" r=\"4\" fill=\"currentColor\"/>\n534\t            </svg>\n535\t            <span>Fertile window: May 19 - May 23</span>\n536\t          </div>\n537\t\n538\t          <div class=\"cycle-progress\" role=\"progressbar\" aria-valuenow=\"50\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-label=\"Cycle progress\">\n539\t            <div class=\"cycle-progress-fill\"></div>\n540\t          </div>\n541\t        </div>\n542\t      </section>\n543\t\n544\t      <section class=\"section\" aria-label=\"Cycle History\">\n545\t        <h2 class=\"history-header\">Cycle History</h2>\n546\t\n547\t        <article class=\"history-item\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from April 1 to April 28, 2026, 28 days\">\n548\t          <div class=\"history-item-header\">\n549\t            <span class=\"history-date\">Apr 1 - Apr 28, 2026</span>\n550\t            <span class=\"history-length-badge\">28 days</span>\n551\t          </div>\n552\t          <div class=\"history-bar\">\n553\t            <div class=\"history-bar-fill\" style=\"width: 100%\"></div>\n554\t          </div>\n555\t          <span class=\"history-notes\">Regular cycle this month</span>\n556\t        </article>\n557\t\n558\t        <article class=\"history-item\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from March 4 to March 31, 2026, 27 days\">\n559\t          <div class=\"history-item-header\">\n560\t            <span class=\"history-date\">Mar 4 - Mar 31, 2026</span>\n561\t            <span class=\"history-length-badge\">27 days</span>\n562\t          </div>\n563\t          <div class=\"history-bar\">\n564\t            <div class=\"history-bar-fill\" style=\"width: 96%\"></div>\n565\t          </div>\n566\t          <span class=\"history-notes\">Shorter than usual</span>\n567\t        </article>\n568\t\n569\t        <article class=\"history-item\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from February 5 to March 4, 2026, 27 days, irregular\">\n570\t          <div class=\"history-item-header\">\n571\t            <span class=\"history-date\">Feb 5 - Mar 4, 2026</span>\n572\t            <span class=\"history-length-badge\">27 days</span>\n573\t          </div>\n574\t          <div class=\"history-bar\">\n575\t            <div class=\"history-bar-fill\" style=\"width: 96%\"></div>\n576\t          </div>\n577\t          <span class=\"history-notes\">Had stress this month</span>\n578\t          <span class=\"history-irregular\" aria-label=\"Irregular cycle indicator\"></span>\n579\t        </article>\n580\t\n581\t        <div class=\"empty-state\" style=\"display: none;\">\n582\t          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\">\n583\t            <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/>\n584\t            <path d=\"M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4\"/>\n585\t          </svg>\n586\t          <p class=\"empty-state-title\">No cycles logged yet</p>\n587\t          <p class=\"empty-state-subtitle\">Tap + to add your first cycle</p>\n588\t        </div>\n589\t      </section>\n590\t    </main>\n591\t\n592\t    <button class=\"fab\" aria-label=\"Add new cycle entry, double tap to open form\">\n593\t      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n594\t        <path d=\"M12 5v14M5 12h14\"/>\n595\t      </svg>\n596\t    </button>\n597\t\n598\t    <!-- Bottom Sheet Preview (triggered by FAB) -->\n599\t    <div class=\"bottom-sheet\" id=\"bottomSheet\" style=\"display: none;\">\n600\t      <div class=\"sheet-handle\"></div>\n601\t      <h2 class=\"sheet-title\">Log Cycle</h2>\n602\t\n603\t      <div class=\"form-field\">\n604\t        <label class=\"form-label\" for=\"periodDate\">Period Started</label>\n605\t        <input type=\"date\" class=\"form-input\" id=\"periodDate\" value=\"2026-05-15\">\n606\t      </div>\n607\t\n608\t      <div class=\"form-field\">\n609\t        <label class=\"form-label\" for=\"cycleLength\">Cycle Length (days)</label>\n610\t        <input type=\"number\" class=\"form-input\" id=\"cycleLength\" value=\"28\" placeholder=\"28\">\n611\t      </div>\n612\t\n613\t      <div class=\"form-field\">\n614\t        <label class=\"form-label\" for=\"notes\">Notes</label>\n615\t        <textarea class=\"form-textarea\" id=\"notes\" placeholder=\"Add notes...\"></textarea>\n616\t      </div>\n617\t\n618\t      <div class=\"toggle-row\">\n619\t        <span class=\"toggle-label\">Irregular cycle</span>\n620\t        <div class=\"toggle\" id=\"irregularToggle\" role=\"switch\" aria-checked=\"false\" tabindex=\"0\"></div>\n621\t      </div>\n622\t\n623\t      <div class=\"sheet-actions\">\n624\t        <button class=\"btn-cancel\" id=\"cancelBtn\">Cancel</button>\n625\t        <button class=\"btn-save\" id=\"saveBtn\">Save</button>\n626\t      </div>\n627\t    </div>\n628\t\n629\t    <div class=\"home-indicator\"></div>\n630\t  </div>\n631\t\n632\t  <script>\n633\t    const fab = document.querySelector('.fab');\n634\t    const bottomSheet = document.getElementById('bottomSheet');\n635\t    const cancelBtn = document.getElementById('cancelBtn');\n636\t    const toggle = document.getElementById('irregularToggle');\n637\t\n638\t    fab.addEventListener('click', () => {\n639\t      bottomSheet.style.display = 'block';\n640\t    });\n641\t\n642\t    cancelBtn.addEventListener('click', () => {\n643\t      bottomSheet.style.display = 'none';\n644\t    });\n645\t\n646\t    toggle.addEventListener('click', () => {\n647\t      toggle.classList.toggle('active');\n648\t      toggle.setAttribute('aria-checked', toggle.classList.contains('active'));\n649\t    });\n650\t  </script>\n651\t</body>\n652\t</html>"}]},"parent_tool_use_id":null,"session_id":"646ef3a5-9221-4d37-8f83-7525abe1aec0","uuid":"d5166a15-6440-4b9b-a327-ed96164cda24","timestamp":"2026-05-18T23:44:43.035Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/minh/Documents/openplayboosks/examples/baby-app/.stitch/designs/cycle-tracking/design.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Cycle Tracking</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root {\n      --color-primary: #7C3AED;\n      --color-primary-tint: #F5F3FF;\n      --color-secondary: #F9A8D4;\n      --color-success: #6EE7B7;\n      --color-surface: #FAFAFA;\n      --color-text-primary: #1F2937;\n      --color-text-secondary: #6B7280;\n      --color-border: #E5E7EB;\n      --color-error: #EF4444;\n      --color-white: #FFFFFF;\n      --radius-sm: 8px;\n      --radius-md: 12px;\n      --radius-card: 16px;\n      --radius-pill: 999dp;\n      --spacing-xxs: 4dp;\n      --spacing-xs: 8dp;\n      --spacing-sm: 12dp;\n      --spacing-md: 16dp;\n      --spacing-lg: 24dp;\n      --spacing-xl: 32dp;\n      --spacing-xxl: 48dp;\n      --font-family: 'Nunito', sans-serif;\n    }\n\n    *, *::before, *::after {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        animation-iteration-count: 1 !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n\n    body {\n      font-family: var(--font-family);\n      background: #1E1B2E;\n      min-height: 100vh;\n      display: flex;\n      justify-content: center;\n      align-items: flex-start;\n      padding: 20px 0;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      background: var(--color-primary-tint);\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .status-bar {\n      height: 44px;\n      background: var(--color-primary);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-white);\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      padding: 0 8px;\n      background: var(--color-primary);\n    }\n\n    .back-btn {\n      width: 48px;\n      height: 48px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: none;\n      border: none;\n      cursor: pointer;\n      color: var(--color-white);\n    }\n\n    .back-btn svg {\n      width: 24px;\n      height: 24px;\n    }\n\n    .app-bar-title {\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-white);\n      margin-left: 8px;\n    }\n\n    .content {\n      padding: 24px 16px 100px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-bottom: var(--spacing-lg);\n    }\n\n    /* Current Cycle Card */\n    .current-cycle-card {\n      background: var(--color-surface);\n      border-radius: var(--radius-card);\n      padding: var(--spacing-md);\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .cycle-day-badge {\n      display: inline-flex;\n      align-items: center;\n      padding: var(--spacing-xs) var(--spacing-sm);\n      background: var(--color-primary);\n      color: var(--color-white);\n      border-radius: var(--radius-pill);\n      font-size: 14px;\n      font-weight: 600;\n      margin-bottom: var(--spacing-sm);\n    }\n\n    .days-counter {\n      font-size: 32px;\n      font-weight: 700;\n      color: var(--color-text-primary);\n      line-height: 40px;\n    }\n\n    .days-label {\n      font-size: 14px;\n      color: var(--color-text-secondary);\n      margin-bottom: var(--spacing-md);\n    }\n\n    .next-period-row {\n      display: flex;\n      align-items: center;\n      gap: var(--spacing-xs);\n      font-size: 14px;\n      color: var(--color-text-secondary);\n      margin-bottom: var(--spacing-sm);\n    }\n\n    .next-period-row svg {\n      width: 16px;\n      height: 16px;\n      color: var(--color-primary);\n    }\n\n    .fertile-window {\n      display: flex;\n      align-items: center;\n      gap: var(--spacing-xs);\n      padding: var(--spacing-xs) var(--spacing-sm);\n      background: rgba(249, 168, 212, 0.2);\n      border-radius: var(--radius-sm);\n      margin-bottom: var(--spacing-md);\n      cursor: pointer;\n    }\n\n    .fertile-window svg {\n      width: 16px;\n      height: 16px;\n      color: var(--color-secondary);\n    }\n\n    .fertile-window span {\n      font-size: 14px;\n      font-weight: 500;\n      color: var(--color-text-primary);\n    }\n\n    .cycle-progress {\n      height: 8px;\n      background: var(--color-border);\n      border-radius: 4px;\n      overflow: hidden;\n    }\n\n    .cycle-progress-fill {\n      height: 100%;\n      width: 65%;\n      background: var(--color-primary);\n      border-radius: 4px;\n    }\n\n    /* Cycle History */\n    .history-header {\n      font-size: 24px;\n      font-weight: 700;\n      color: var(--color-text-primary);\n      margin-bottom: var(--spacing-md);\n    }\n\n    .history-item {\n      background: var(--color-surface);\n      border-radius: var(--radius-md);\n      padding: var(--spacing-md);\n      margin-bottom: var(--spacing-sm);\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .history-item-header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      margin-bottom: var(--spacing-xs);\n    }\n\n    .history-date {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .history-length-badge {\n      display: inline-flex;\n      padding: var(--spacing-xxs) var(--spacing-xs);\n      background: var(--color-primary-tint);\n      border-radius: var(--radius-sm);\n      font-size: 12px;\n      font-weight: 500;\n      color: var(--color-primary);\n    }\n\n    .history-bar {\n      height: 6px;\n      background: var(--color-border);\n      border-radius: 3px;\n      overflow: hidden;\n      margin-bottom: var(--spacing-xs);\n    }\n\n    .history-bar-fill {\n      height: 100%;\n      background: var(--color-primary);\n      border-radius: 3px;\n    }\n\n    .history-notes {\n      font-size: 14px;\n      color: var(--color-text-secondary);\n    }\n\n    .history-irregular {\n      display: inline-block;\n      width: 8px;\n      height: 8px;\n      background: var(--color-secondary);\n      border-radius: 50%;\n      margin-left: var(--spacing-xs);\n    }\n\n    /* Empty State */\n    .empty-state {\n      text-align: center;\n      padding: var(--spacing-xl) var(--spacing-md);\n    }\n\n    .empty-state svg {\n      width: 64px;\n      height: 64px;\n      color: var(--color-border);\n      margin-bottom: var(--spacing-md);\n    }\n\n    .empty-state-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      margin-bottom: var(--spacing-xs);\n    }\n\n    .empty-state-subtitle {\n      font-size: 14px;\n      color: var(--color-text-secondary);\n    }\n\n    /* FAB */\n    .fab {\n      position: absolute;\n      bottom: 24px;\n      right: 16px;\n      width: 56px;\n      height: 56px;\n      background: var(--color-primary);\n      border: none;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      box-shadow: 0 4px 12px rgba(124, 58, 237, 0.4);\n      cursor: pointer;\n      transition: transform 200ms ease-out, box-shadow 200ms ease-out;\n    }\n\n    .fab:hover {\n      transform: scale(0.95);\n      box-shadow: 0 6px 16px rgba(124, 58, 237, 0.5);\n    }\n\n    .fab:active {\n      transform: scale(0.9);\n    }\n\n    .fab svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-white);\n    }\n\n    .home-indicator {\n      position: absolute;\n      bottom: 8px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 134px;\n      height: 5px;\n      background: var(--color-text-primary);\n      border-radius: 3px;\n      opacity: 0.2;\n    }\n\n    /* Bottom Sheet (modal preview) */\n    .bottom-sheet {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      background: var(--color-white);\n      border-radius: 28px 28px 0 0;\n      padding: 12px 16px 32px;\n      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);\n    }\n\n    .sheet-handle {\n      width: 40px;\n      height: 4px;\n      background: var(--color-border);\n      border-radius: 2px;\n      margin: 0 auto 16px;\n    }\n\n    .sheet-title {\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      margin-bottom: var(--spacing-md);\n    }\n\n    .form-field {\n      margin-bottom: var(--spacing-md);\n    }\n\n    .form-label {\n      font-size: 14px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n      margin-bottom: var(--spacing-xs);\n    }\n\n    .form-input {\n      width: 100%;\n      padding: 12px 16px;\n      background: var(--color-surface);\n      border: 1px solid var(--color-border);\n      border-radius: var(--radius-md);\n      font-size: 16px;\n      font-family: var(--font-family);\n      color: var(--color-text-primary);\n    }\n\n    .form-textarea {\n      width: 100%;\n      min-height: 56px;\n      padding: 12px 16px;\n      background: var(--color-surface);\n      border: 1px solid var(--color-border);\n      border-radius: var(--radius-md);\n      font-size: 16px;\n      font-family: var(--font-family);\n      color: var(--color-text-primary);\n      resize: vertical;\n    }\n\n    .toggle-row {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 12px 0;\n    }\n\n    .toggle-label {\n      font-size: 16px;\n      font-weight: 500;\n      color: var(--color-text-primary);\n    }\n\n    .toggle {\n      width: 52px;\n      height: 32px;\n      background: var(--color-border);\n      border-radius: 16px;\n      position: relative;\n      cursor: pointer;\n      transition: background 200ms ease;\n    }\n\n    .toggle.active {\n      background: var(--color-primary);\n    }\n\n    .toggle::after {\n      content: '';\n      position: absolute;\n      top: 4px;\n      left: 4px;\n      width: 24px;\n      height: 24px;\n      background: var(--color-white);\n      border-radius: 50%;\n      transition: transform 200ms ease;\n    }\n\n    .toggle.active::after {\n      transform: translateX(20px);\n    }\n\n    .sheet-actions {\n      display: flex;\n      gap: var(--spacing-sm);\n      margin-top: var(--spacing-lg);\n    }\n\n    .btn-cancel {\n      flex: 1;\n      padding: 14px;\n      background: none;\n      border: none;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-secondary);\n      cursor: pointer;\n    }\n\n    .btn-save {\n      flex: 2;\n      padding: 14px;\n      background: var(--color-primary);\n      border: none;\n      border-radius: var(--radius-pill);\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-white);\n      cursor: pointer;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <div class=\"status-bar\">\n      <span>9:41</span>\n      <div class=\"status-bar-icons\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n          <rect x=\"4\" y=\"9\" width=\"14\" height=\"6\" rx=\"1\" fill=\"currentColor\"/>\n        </svg>\n      </div>\n    </div>\n\n    <header class=\"app-bar\">\n      <button class=\"back-btn\" aria-label=\"Back to Browse\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M15 18l-6-6 6-6\"/>\n        </svg>\n      </button>\n      <h1 class=\"app-bar-title\">Cycle Tracking</h1>\n    </header>\n\n    <main class=\"content\">\n      <section class=\"section\" aria-label=\"Current Cycle\">\n        <div class=\"current-cycle-card\">\n          <div class=\"cycle-day-badge\">Day 14</div>\n          <div class=\"days-counter\">14</div>\n          <div class=\"days-label\">days since last period</div>\n\n          <div class=\"next-period-row\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/>\n              <path d=\"M16 2v4M8 2v4M3 10h18\"/>\n            </svg>\n            <span>Next period expected: May 28, 2026</span>\n          </div>\n\n          <div class=\"fertile-window\" role=\"button\" tabindex=\"0\" aria-label=\"Tap to learn about your fertile window\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\">\n              <circle cx=\"12\" cy=\"12\" r=\"8\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n              <circle cx=\"12\" cy=\"12\" r=\"4\" fill=\"currentColor\"/>\n            </svg>\n            <span>Fertile window: May 19 - May 23</span>\n          </div>\n\n          <div class=\"cycle-progress\" role=\"progressbar\" aria-valuenow=\"50\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-label=\"Cycle progress\">\n            <div class=\"cycle-progress-fill\"></div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\" aria-label=\"Cycle History\">\n        <h2 class=\"history-header\">Cycle History</h2>\n\n        <article class=\"history-item\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from April 1 to April 28, 2026, 28 days\">\n          <div class=\"history-item-header\">\n            <span class=\"history-date\">Apr 1 - Apr 28, 2026</span>\n            <span class=\"history-length-badge\">28 days</span>\n          </div>\n          <div class=\"history-bar\">\n            <div class=\"history-bar-fill\" style=\"width: 100%\"></div>\n          </div>\n          <span class=\"history-notes\">Regular cycle this month</span>\n        </article>\n\n        <article class=\"history-item\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from March 4 to March 31, 2026, 27 days\">\n          <div class=\"history-item-header\">\n            <span class=\"history-date\">Mar 4 - Mar 31, 2026</span>\n            <span class=\"history-length-badge\">27 days</span>\n          </div>\n          <div class=\"history-bar\">\n            <div class=\"history-bar-fill\" style=\"width: 96%\"></div>\n          </div>\n          <span class=\"history-notes\">Shorter than usual</span>\n        </article>\n\n        <article class=\"history-item\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from February 5 to March 4, 2026, 27 days, irregular\">\n          <div class=\"history-item-header\">\n            <span class=\"history-date\">Feb 5 - Mar 4, 2026</span>\n            <span class=\"history-length-badge\">27 days</span>\n          </div>\n          <div class=\"history-bar\">\n            <div class=\"history-bar-fill\" style=\"width: 96%\"></div>\n          </div>\n          <span class=\"history-notes\">Had stress this month</span>\n          <span class=\"history-irregular\" aria-label=\"Irregular cycle indicator\"></span>\n        </article>\n\n        <div class=\"empty-state\" style=\"display: none;\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\">\n            <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/>\n            <path d=\"M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4\"/>\n          </svg>\n          <p class=\"empty-state-title\">No cycles logged yet</p>\n          <p class=\"empty-state-subtitle\">Tap + to add your first cycle</p>\n        </div>\n      </section>\n    </main>\n\n    <button class=\"fab\" aria-label=\"Add new cycle entry, double tap to open form\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n        <path d=\"M12 5v14M5 12h14\"/>\n      </svg>\n    </button>\n\n    <!-- Bottom Sheet Preview (triggered by FAB) -->\n    <div class=\"bottom-sheet\" id=\"bottomSheet\" style=\"display: none;\">\n      <div class=\"sheet-handle\"></div>\n      <h2 class=\"sheet-title\">Log Cycle</h2>\n\n      <div class=\"form-field\">\n        <label class=\"form-label\" for=\"periodDate\">Period Started</label>\n        <input type=\"date\" class=\"form-input\" id=\"periodDate\" value=\"2026-05-15\">\n      </div>\n\n      <div class=\"form-field\">\n        <label class=\"form-label\" for=\"cycleLength\">Cycle Length (days)</label>\n        <input type=\"number\" class=\"form-input\" id=\"cycleLength\" value=\"28\" placeholder=\"28\">\n      </div>\n\n      <div class=\"form-field\">\n        <label class=\"form-label\" for=\"notes\">Notes</label>\n        <textarea class=\"form-textarea\" id=\"notes\" placeholder=\"Add notes...\"></textarea>\n      </div>\n\n      <div class=\"toggle-row\">\n        <span class=\"toggle-label\">Irregular cycle</span>\n        <div class=\"toggle\" id=\"irregularToggle\" role=\"switch\" aria-checked=\"false\" tabindex=\"0\"></div>\n      </div>\n\n      <div class=\"sheet-actions\">\n        <button class=\"btn-cancel\" id=\"cancelBtn\">Cancel</button>\n        <button class=\"btn-save\" id=\"saveBtn\">Save</button>\n      </div>\n    </div>\n\n    <div class=\"home-indicator\"></div>\n  </div>\n\n  <script>\n    const fab = document.querySelector('.fab');\n    const bottomSheet = document.getElementById('bottomSheet');\n    const cancelBtn = document.getElementById('cancelBtn');\n    const toggle = document.getElementById('irregularToggle');\n\n    fab.addEventListener('click', () => {\n      bottomSheet.style.display = 'block';\n    });\n\n    cancelBtn.addEventListener('click', () => {\n      bottomSheet.style.display = 'none';\n    });\n\n    toggle.addEventListener('click', () => {\n      toggle.classList.toggle('active');\n      toggle.setAttribute('aria-checked', toggle.classList.contains('active'));\n    });\n  </script>\n</body>\n</html>","numLines":652,"startLine":1,"totalLines":652}}}
