    --color-error: #EF4444;\n      --color-white: #FFFFFF;\n      --radius-sm: 8px;\n      --radius-md: 12px;\n      --radius-card: 16px;\n      --radius-pill: 999dp;\n      --spacing-xxs: 4dp;\n      --spacing-xs: 8dp;\n      --spacing-sm: 12dp;\n      --spacing-md: 16dp;\n      --spacing-lg: 24dp;\n      --spacing-xl: 32dp;\n      --spacing-xxl: 48dp;\n      --font-family: 'Nunito', sans-serif;\n    }\n\n    *, *::before, *::after {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        animation-iteration-count: 1 !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n\n    body {\n      font-family: var(--font-family);\n      background: #1E1B2E;\n      min-height: 100vh;\n      display: flex;\n      justify-content: center;\n      align-items: flex-start;\n      padding: 20px 0;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      background: var(--color-primary-tint);\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .status-bar {\n      height: 44px;\n      background: var(--color-primary);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-white);\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      padding: 0 8px;\n      background: var(--color-primary);\n    }\n\n    .back-btn {\n      width: 48px;\n      height: 48px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: none;\n      border: none;\n      cursor: pointer;\n      color: var(--color-white);\n    }\n\n    .back-btn svg {\n      width: 24px;\n      height: 24px;\n    }\n\n    .app-bar-title {\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-white);\n      margin-left: 8px;\n    }\n\n    .content {\n      padding: 24px 16px 100px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-bottom: var(--spacing-lg);\n    }\n\n    /* Current Cycle Card */\n    .current-cycle-card {\n      background: var(--color-surface);\n      border-radius: var(--radius-card);\n      padding: var(--spacing-md);\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .cycle-day-badge {\n      display: inline-flex;\n      align-items: center;\n      padding: var(--spacing-xs) var(--spacing-sm);\n      background: var(--color-primary);\n      color: var(--color-white);\n      border-radius: var(--radius-pill);\n      font-size: 14px;\n      font-weight: 600;\n      margin-bottom: var(--spacing-sm);\n    }\n\n    .days-counter {\n      font-size: 32px;\n      font-weight: 700;\n      color: var(--color-text-primary);\n      line-height: 40px;\n    }\n\n    .days-label {\n      font-size: 14px;\n      color: var(--color-text-secondary);\n      margin-bottom: var(--spacing-md);\n    }\n\n    .next-period-row {\n      display: flex;\n      align-items: center;\n      gap: var(--spacing-xs);\n      font-size: 14px;\n      color: var(--color-text-secondary);\n      margin-bottom: var(--spacing-sm);\n    }\n\n    .next-period-row svg {\n      width: 16px;\n      height: 16px;\n      color: var(--color-primary);\n    }\n\n    .fertile-window {\n      display: flex;\n      align-items: center;\n      gap: var(--spacing-xs);\n      padding: var(--spacing-xs) var(--spacing-sm);\n      background: rgba(249, 168, 212, 0.2);\n      border-radius: var(--radius-sm);\n      margin-bottom: var(--spacing-md);\n      cursor: pointer;\n    }\n\n    .fertile-window svg {\n      width: 16px;\n      height: 16px;\n      color: var(--color-secondary);\n    }\n\n    .fertile-window span {\n      font-size: 14px;\n      font-weight: 500;\n      color: var(--color-text-primary);\n    }\n\n    .cycle-progress {\n      height: 8px;\n      background: var(--color-border);\n      border-radius: 4px;\n      overflow: hidden;\n    }\n\n    .cycle-progress-fill {\n      height: 100%;\n      width: 65%;\n      background: var(--color-primary);\n      border-radius: 4px;\n    }\n\n    /* Cycle History */\n    .history-header {\n      font-size: 24px;\n      font-weight: 700;\n      color: var(--color-text-primary);\n      margin-bottom: var(--spacing-md);\n    }\n\n    .history-item {\n      background: var(--color-surface);\n      border-radius: var(--radius-md);\n      padding: var(--spacing-md);\n      margin-bottom: var(--spacing-sm);\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .history-item-header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      margin-bottom: var(--spacing-xs);\n    }\n\n    .history-date {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .history-length-badge {\n      display: inline-flex;\n      padding: var(--spacing-xxs) var(--spacing-xs);\n      background: var(--color-primary-tint);\n      border-radius: var(--radius-sm);\n      font-size: 12px;\n      font-weight: 500;\n      color: var(--color-primary);\n    }\n\n    .history-bar {\n      height: 6px;\n      background: var(--color-border);\n      border-radius: 3px;\n      overflow: hidden;\n      margin-bottom: var(--spacing-xs);\n    }\n\n    .history-bar-fill {\n      height: 100%;\n      background: var(--color-primary);\n      border-radius: 3px;\n    }\n\n    .history-notes {\n      font-size: 14px;\n      color: var(--color-text-secondary);\n    }\n\n    .history-irregular {\n      display: inline-block;\n      width