ion: relative;\n57\t      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n58\t    }\n59\t\n60\t    @media (prefers-reduced-motion: reduce) {\n61\t      *, *::before, *::after {\n62\t        animation-duration: 0.01ms !important;\n63\t        transition-duration: 0.01ms !important;\n64\t      }\n65\t    }\n66\t\n67\t    /* SliverAppBar collapsed gradient */\n68\t    .sliver-bg {\n69\t      background: linear-gradient(180deg, #F5F3FF 0%, #F5F3FF 100%);\n70\t    }\n71\t\n72\t    /* Card shadow */\n73\t    .card-shadow {\n74\t      box-shadow: 0 8px 24px rgba(0,0,0,0.08);\n75\t    }\n76\t\n77\t    /* Chip tap */\n78\t    .chip-tap:active {\n79\t      transform: scale(0.97);\n80\t      transition: transform 200ms ease-out;\n81\t    }\n82\t\n83\t    /* Bottom nav active indicator */\n84\t    .nav-indicator {\n85\t      background: rgba(124, 58, 237, 0.15);\n86\t      border-radius: 999px;\n87\t    }\n88\t\n89\t    /* Shimmer loading effect */\n90\t    @keyframes shimmer {\n91\t      0% { background-position: -200% 0; }\n92\t      100% { background-position: 200% 0; }\n93\t    }\n94\t    .shimmer {\n95\t      background: linear-gradient(90deg, #F0F0F0 25%, #E0E0E0 50%, #F0F0F0 75%);\n96\t      background-size: 200% 100%;\n97\t      animation: shimmer 1.5s infinite;\n98\t    }\n99\t  </style>\n100\t</head>\n101\t<body>\n102\t  <div class=\"phone\">\n103\t    <!-- Scaffold with CustomScrollView / SliverAppBar -->\n104\t    <div data-flutter=\"scaffold\" data-bg=\"lavenderTint\" class=\"flex flex-col min-h-screen bg-lavender-tint\">\n105\t\n106\t      <!-- SliverAppBar - collapses to show week badge -->\n107\t      <header data-flutter=\"sliver-app-bar\" data-expanded-height=\"280\" data-pinned=\"true\"\n108\t              class=\"sliver-bg relative overflow-hidden\">\n109\t\n110\t        <!-- Expanded content (shown when scrolled to top) -->\n111\t        <div class=\"absolute inset-0 flex flex-col items-center justify-center pt-12 pb-6\">\n112\t          <!-- Week badge -->\n113\t          <div class=\"bg-lavender text-white px-4 py-1.5 rounded-full text-sm font-semibold mb-4\" data-flutter=\"chip\">\n114\t            Week 24\n115\t          </div>\n116\t\n117\t          <!-- Main week banner card -->\n118\t          <div class=\"bg-warm-white rounded-card card-shadow mx-4 p-6 w-full max-w-[343px]\">\n119\t            <div class=\"text-center\">\n120\t              <!-- Fruit size visual -->\n121\t              <div class=\"w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-br from-blush to-lavender-light flex items-center justify-center\">\n122\t                <span class=\"text-4xl\">🍈</span>\n123\t              </div>\n124\t\n125\t              <!-- Week and countdown -->\n126\t              <h1 class=\"text-3xl font-bold text-graphite mb-1\">Week 24</h1>\n127\t              <p class=\"text-stone text-sm mb-2\">Due date: Dec 15, 2026</p>\n128\t              <p class=\"text-lavender font-semibold text-sm\">112 days to go</p>\n129\t\n130\t              <!-- Fruit size comparison -->\n131\t              <div class=\"mt-4 flex items-center justify-center gap-2\">\n132\t                <span class=\"text-xs text-stone\">Baby is the size of</span>\n133\t                <span class=\"bg-blush/20 text-lavender px-3 py-1 rounded-full text-sm font-semibold\">Papaya</span>\n134\t              </div>\n135\t            </div>\n136\t          </div>\n137\t        </div>\n138\t\n139\t        <!-- Collapsed title (shows when scrolled) -->\n140\t        <div data-flutter=\"sliver-app-bar-title\" class=\"absolute top-0 left-0 right-0 h-14 flex items-center justify-center\">\n141\t          <span class=\"text-xl font-semibold text-graphite\">Baby Bump</span>\n142\t        </div>\n143\t\n144\t        <!-- AppBar actions -->\n145\t        <div class=\"absolute top-0 right-0 h-14 flex items-center pr-4\">\n146\t          <button data-flutter=\"icon-btn\" aria-label=\"Profile\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n147\t            <div class=\"w-8 h-8 rounded-full bg-gradient-to-br from-lavender to-blush\"></div>\n148\t          </button>\n149\t        </div>\n150\t      </header>\n151\t\n152\t      <!-- Body - scrollable content -->\n153\t      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto pb-20\">\n154\t\n155\t        <!-- Section 1: Mood Check-In Card -->\n156\t        <div class=\"px-4 mt-6\">\n157\t          <div class=\"bg-warm-white rounded-card card-shadow p-5\">\n158\t            <div class=\"flex justify-between items-center mb-4\">\n159\t              <h2 class=\"text-lg font-semibold text-graphite\">How are you feeling today?</h2>\n160\t              <span class=\"text-xs text-stone\">May 18</span>\n161\t            </div>\n162\t\n163\t            <!-- Mood emoji selector -->\n164\t            <div data-flutter=\"row\" data-spacing=\"md\" data-main-axis=\"space-around\" class=\"flex justify-around\">\n165\t              <!-- Mood options: terrible, bad, okay, good, great -->\n166\t              <button data-flutter=\"icon-btn\" aria-label=\"Terrible\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-red-50 transition-colors\">\n167\t                <span class=\"text-3xl\">😢</span>\n168\t                <span class=\"text-xs text-stone\">Terrible</span>\n169\t              </button>\n170\t              <button data-flutter=\"icon-btn\" aria-label=\"Bad\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-orange-50 transition-colors\">\n171\t                <span class=\"text-3xl\">😔</span>\n172\t                <span class=\"text-xs text-stone\">Bad</span>\n173\t              </button>\n174\t              <button data-flutter=\"icon-btn\" aria-label=\"Okay\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-yellow-50 transition-colors\">\n175\t                <span class=\"text-3xl\">😐</span>\n176\t                <span class=\"text-xs text-stone\">Okay</span>\n177\t              </button>\n178\t              <button data-flutter=\"icon-btn\" aria-label=\"Good\" data-selected=\"true\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl bg-lavender/10 ring-2 ring-lavender\">\n179\t                <span class=\"text-3xl\">🙂</span>\n180\t                <span class=\"text-xs text-lavender font-semibold\">Good</span>\n181\t              </button>\n182\t              <button data-flutter=\"icon-btn\" aria-label=\"Great\" class=\"flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-green-50 transition-colors\">\n183\t                <span class=\"text-3xl\">😊</span>\n184\t                <span class=\"text-xs text-stone\">Great</span>\n185\t              </button>\n186\t            </div>\n187\t          </div>\n188\t        </div>\n189\t\n190\t        <!-- Section 2: Today's Checklist - horizontal scroll chips -->\n191\t        <div class=\"mt-6\">\n192\t          <div class=\"flex justify-between items-center px-4 mb-3\">\n193\t            <h2 class=\"text-lg font-semibold text-graphite\">Today's Checklist</h2>\n194\t            <span class=\"text-sm text-lavender font-medium\">2 of 4 done</span>\n195\t          </div>\n196\t\n197\t          <div data-flutter=\"horizontal-scroll\" class=\"overflow-x-auto\">\n198\t            <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex px-4\">\n199\t              <!-- Checklist chips -->\n200\t              <div data-flutter=\"chip\" data-selected=\"true\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-mint/20 border border-mint/30 shrink-0 cursor-pointer\">\n201\t                <svg class=\"w-5 h-5 text-mint\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n202\t                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"/>\n203\t                </svg>\n204\t                <span class=\"text-sm font-medium text-graphite\">Weight logged</span>\n205\t              </div>\n206\t              <div data-flutter=\"chip\" data-selected=\"true\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-mint/20 border border-mint/30 shrink-0 cursor-pointer\">\n207\t                <svg class=\"w-5 h-5 text-mint\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n208\t                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"/>\n209\t                </svg>\n210\t                <span class=\"text-sm font-medium text-graphite\">Mood checked</span>\n211\t              </div>\n212\t              <div data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-stone/10 border border-misty-border shrink-0 cursor-pointer\">\n213\t                <div class=\"w-5 h-5 rounded-full border-2 border-stone/30\"></div>\n214\t                <span class=\"text-sm font-medium text-stone\">Log symptoms</span>\n215\t              </div>\n216\t              <div data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap flex items-center gap-2 px-4 py-2.5 rounded-full bg-stone/10 border border-misty-border shrink-0 cursor-pointer\">\n217\t                <div class=\"w-5 h-5 rounded-full border-2 border-stone/30\"></div>\n218\t                <span class=\"text-sm font-medium text-stone\">Drink water</span>\n219\t              </div>\n220\t            </div>\n221\t          </div>\n222\t        </div>\n223\t\n224\t        <!-- Section 3: Quick Actions - 4 primary buttons -->\n225\t        <div class=\"mt-6 px-4\">\n226\t          <h2 class=\"text-lg font-semibold text-graphite mb-3\">Quick Actions</h2>\n227\t\n228\t          <div data-flutter=\"grid\" data-columns=\"2\" data-spacing=\"sm\" class=\"grid grid-cols-2 gap-3\">\n229\t            <!-- Log Weight -->\n230\t            <button data-flutter=\"elevated-btn\" data-color=\"primary\" class=\"bg-lavender text-white rounded-2xl p-4 flex flex-col items-center gap-2 min-h-[88px] active:scale-95 transition-transform\">\n231\t              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n232\t                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3\"/>\n233\t              </svg>\n234\t              <span class=\"text-sm font-semibold\">Log Weight</span>\n235\t            </button>\n236\t\n237\t            <!-- Log Mood -->\n238\t            <button data-flutter=\"elevated-btn\" class=\"bg-blush text-white rounded-2xl p-4 flex flex-col items-center gap-2 min-h-[88px] active:scale-95 transition-transform\">\n239\t              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n240\t                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n241\t              </svg>\n242\t              <span class=\"text-sm font-semibold\">Log Mood</span>\n243\t            </button>\n244\t\n245\t            <!-- Log Symptoms -->\n246\t            <button data-flutter=\"elevated-btn\" class=\"bg-warm-white text-graphite rounded-2xl p-4 flex flex-col items-center gap-2 min-h-[88px] border-2 border-misty-border active:scale-95 transition-transform\">\n247\t              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n248\t                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01\"/>\n249\t              </svg>\n250\t              <span class=\"text-sm font-semibold text-graphite\">Log Symptoms</span>\n251\t            </button>\n252\t\n253\t            <!-- View Education -->\n254\t            <button data-flutter=\"elevated-btn\" class=\"bg-warm-white text-graphite rounded-2xl p-4 flex flex-col items-center gap-2 min-h-[88px] border-2 border-misty-border active:scale-95 transition-transform\">\n255\t              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n256\t                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253\"/>\n257\t              </svg>\n258\t              <span class=\"text-sm font-semibold text-graphite\">View Education</span>\n259\t            </button>\n260\t          </div>\n261\t        </div>\n262\t\n263\t        <!-- Section 4: Weekly Tip -->\n264\t        <div class=\"mt-6 px-4 mb-6\">\n265\t          <div class=\"bg-gradient-to-br from-lavender to-lavender-light rounded-card p-5\">\n266\t            <div class=\"flex items-start gap-3\">\n267\t              <div class=\"w-10 h-10 rounded-full bg-white/20 flex items-center justify-center shrink-0\">\n268\t                <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n269\t                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n270\t                </svg>\n271\t              </div>\n272\t              <div class=\"flex-1\">\n273\t                <span class=\"text-xs text-white/70 font-medium uppercase tracking-wide\">Weekly Tip</span>\n274\t                <h3 class=\"text-white font-semibold mt-1 mb-1\">Stay Hydrated</h3>\n275\t                <p class=\"text-sm text-white/80 leading-relaxed\">Aim for 8-10 glasses of water daily. Staying hydrated helps prevent UTIs and constipation, common during pregnancy.</p>\n276\t              </div>\n277\t            </div>\n278\t          </div>\n279\t        </div>\n280\t\n281\t      </main>\n282\t\n283\t      <!-- Bottom Navigation Bar -->\n284\t      <nav data-flutter=\"bottom-nav\" class=\"absolute bottom-0 left-0 right-0 h-[80px] bg-warm-white border-t border-misty-border px-2 flex justify-around items-center\">\n285\t        <!-- Home - active -->\n286\t        <button data-flutter=\"nav-destination\" data-icon=\"home\" data-label=\"Home\" data-selected=\"true\"\n287\t                class=\"flex flex-col items-center gap-1 py-2 px-4 rounded-xl nav-indicator min-w-[64px]\">\n288\t          <svg class=\"w-6 h-6 text-lavender\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n289\t            <path d=\"M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z\"/>\n290\t          </svg>\n291\t          <span class=\"text-xs font-semibold text-lavender\">Home</span>\n292\t        </button>\n293\t\n294\t        <!-- Browse -->\n295\t        <button data-flutter=\"nav-destination\" data-icon=\"search\" data-label=\"Browse\" data-selected=\"false\"\n296\t                class=\"flex flex-col items-center gap-1 py-2 px-4 rounded-xl min-w-[64px]\">\n297\t          <svg class=\"w-6 h-6 text-stone\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n298\t            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"/>\n299\t          </svg>\n300\t          <span class=\"text-xs font-medium text-stone\">Browse</span>\n301\t        </button>\n302\t\n303\t        <!-- Library -->\n304\t        <button data-flutter=\"nav-destination\" data-icon=\"bookmark\" data-label=\"Library\" data-selected=\"false\"\n305\t                class=\"flex flex-col items-center gap-1 py-2 px-4 rounded-xl min-w-[64px]\">\n306\t          <svg class=\"w-6 h-6 text-stone\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n307\t            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z\"/>\n308\t          </svg>\n309\t          <span class=\"text-xs font-medium text-stone\">Library</span>\n310\t        </button>\n311\t\n312\t        <!-- Profile -->\n313\t        <button data-flutter=\"nav-destination\" data-icon=\"person\" data-label=\"Profile\" data-selected=\"false\"\n314\t                class=\"flex flex-col items-center gap-1 py-2 px-4 rounded-xl min-w-[64px]\">\n315\t          <svg class=\"w-6 h-6 text-stone\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n316\t            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z\"/>\n317\t          </svg>\n318\t          <span class=\"text-xs font-medium text-stone\">Profile</span>\n319\t        </button>\n320\t      </nav>\n321\t\n322\t    </div>\n323\t  </div>\n324\t</body>\n325\t</html>"}]},"parent_tool_use_id":null,"session_id":"646ef3a5-9221-4d37-8f83-7525abe1aec0","uuid":"1acf0180-c2f2-48bd-9325-414e3b270ac0","timestamp":"2026-05-18T23:45:14.968Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/minh/Documents/openplayboosks/examples/baby-app/.stitch/designs/home/design.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=375, initial-scale=1.0\" />\n  <title>Home — Baby Bump Design</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\" />\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          colors: {\n            'lavender': '#7C3AED',\n            'lavender-light': '#A78BFA',\n            'lavender-tint': '#F5F3FF',\n            'blush': '#F9A8D4',\n            'mint': '#6EE7B7',\n            'mist': '#FAFAFA',\n            'graphite': '#1F2937',\n            'stone': '#6B7280',\n            'misty-border': '#E5E7EB',\n            'coral': '#EF4444',\n            'warm-white': '#FFFFFF',\n          },\n          fontFamily: {\n            'nunito': ['Nunito', 'system-ui', 'sans-serif'],\n          },\n          borderRadius: {\n            'card': '16px',\n            'sheet': '28px',\n            'pill': '999px',\n          }\n        }\n      }\n    }\n  </script>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      font-family: 'Nunito', system-ui, sans-serif;\n      background: #E8E8E8;\n      display: flex;\n      justify-content: center;\n      padding: 32px 16px;\n      min-height: 100vh;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n\n    /* SliverAppBar collapsed gradient */\n    .sliver-bg {\n      background: linear-gradient(180deg, #F5F3FF 0%, #F5F3FF 100%);\n    }\n\n    /* Card shadow */\n    .card-shadow {\n      box-shadow: 0 8px 24px rgba(0,0,0,0.08);\n    }\n\n    /* Chip tap */\n    .chip-tap:active {\n      transform: scale(0.97);\n      transition: transform 200ms ease-out;\n    }\n\n    /* Bottom nav active indicator */\n    .nav-indicator {\n      background: rgba(124, 58, 237, 0.15);\n      border-radius: 999px;\n    }\n\n    /* Shimmer loading effect */\n    @keyframes shimmer {\n      0% { background-position: -200% 0; }\n      100% { background-position: 200% 0; }\n    }\n    .shimmer {\n      background: linear-gradient(90deg, #F0F0F0 25%, #E0E0E0 50%, #F0F0F0 75%);\n      background-size: 200% 100%;\n      animation: shimmer 1.5s infinite;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <!-- Scaffold with CustomScrollView / SliverAppBar -->\n    <div data-flutter=\"scaffold\" data-bg=\"lavenderTint\" class=\"flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- SliverAppBar - collapses to show week badge -->\n      <header data-flutter=\"sliver-app-bar\" data-expanded-height=\"280\" data-pinned=\"true\"\n              class=\"sliver-bg relative overflow-hidden\">\n\n        <!-- Expanded content (shown when scrolled to top) -->\n        <div class=\"absolute inset-0 flex flex-col items-center justify-center pt-12 pb-6\">\n          <!-- Week badge -->\n          <div class=\"bg-lavender text-white px-4 py-1.5 rounded-full text-sm font-semibold mb-4\" data-flutter=\"chip\">\n            Week 24\n          </div>\n\n          <!-- Main week banner card -->\n          <div class=\"bg-warm-white rounded-card card-shadow mx-4 p-6 w-full max-w-[343px]\">\n            <div class=\"text-center\">\n              <!-- Fruit size visual -->\n              <div class=\"w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-br from-blush to-lavender-light flex items-center justify-center\">\n                <span class=\"text-4xl\">🍈</span>\n              </div>\n\n              <!-- Week and countdown -->\n              <h1 class=\"text-3xl font-bold text-graphite mb-1\">Week 24</h1>\n              <p class=\"text-stone text-sm mb-2\">Due date: Dec 15, 2026</p>\n              <p class=\"text-lavender font-semibold text-sm\">112 days to go</p>\n\n              <!-- Fruit size comparison -->\n              <div class=\"mt-4 flex items-center justify-center gap-2\">\n                <span class=\"text-xs text-stone\">Baby is the size of</span>\n                <span class=\"bg-blush/20 text-lavender px-3 py-1 rounded-full text-sm font-semibold\">Papaya</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Collapsed title (shows when scrolled) -->\n        