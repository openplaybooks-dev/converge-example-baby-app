Cycle from March 4 to March 31, 2026, 27 days\">","+            <div class=\"flex items-center justify-between mb-2\">","+              <span class=\"text-base font-semibold text-graphite\">Mar 4 - Mar 31, 2026</span>","+              <span class=\"px-2 py-0.5 bg-lavender-tint text-lavender text-xs font-medium rounded-lg\">27 days</span>","+            </div>","+            <div class=\"h-1.5 bg-misty-border rounded-full mb-2 overflow-hidden\">","+              <div class=\"h-full bg-lavender rounded-full\" data-color=\"primary\" style=\"width: 96%\"></div>","+            </div>","+            <span class=\"text-sm text-stone\">Shorter than usual</span>","+          </article>"," ","-    .toggle.active {","-      background: var(--color-primary);","-    }","+          <article class=\"bg-mist rounded-xl card-shadow p-4 mb-3 history-press cursor-pointer\" data-flutter=\"card\" data-flutter=\"list-tile\" role=\"button\" tabindex=\"0\" aria-label=\"Cycle from February 5 to March 4, 2026, 27 days, irregular\">","+            <div class=\"flex items-center justify-between mb-2\">","+              <span class=\"text-base font-semibold text-graphite\">Feb 5 - Mar 4, 2026</span>","+              <span class=\"flex items-center gap-2\">","+                <span class=\"px-2 py-0.5 bg-lavender-tint text-lavender text-xs font-medium rounded-lg\">27 days</span>","+                <span class=\"w-2 h-2 bg-blush rounded-full\" data-color=\"secondary\" aria-label=\"Irregular\"></span>","+              </span>","+            </div>","+            <div class=\"h-1.5 bg-misty-border rounded-full mb-2 overflow-hidden\">","+              <div class=\"h-full bg-lavender rounded-full\" data-color=\"primary\" style=\"width: 96%\"></div>","+            </div>","+            <span class=\"text-sm text-stone\">Had stress this month</span>","+          </article>"," ","-    .toggle::after {","-      content: '';","-      position: absolute;","-      top: 4px;","-      left: 4px;","-      widt