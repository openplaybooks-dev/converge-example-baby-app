or=\"cycleLength\">Cycle Length (days)</label>","-        <input type=\"number\" class=\"form-input\" id=\"cycleLength\" value=\"28\" placeholder=\"28\">","+      <!-- Cycle length field -->","+      <div class=\"mb-4\">","+        <label class=\"block text-sm font-medium text-stone mb-1\">Cycle Length (days)</label>","+        <input type=\"number\" class=\"w-full px-4 py-3 bg-mist border border-misty-border rounded-xl text-graphite font-medium\" data-flutter=\"text-field\" value=\"28\" placeholder=\"28\">","       </div>"," ","-      <div class=\"form-field\">","-        <label class=\"form-label\" for=\"notes\">Notes</label>","-        <textarea class=\"form-textarea\" id=\"notes\" placeholder=\"Add notes...\"></textarea>","+      <!-- Notes field -->","+      <div class=\"mb-4\">","+        <label class=\"block text-sm font-medium text-stone mb-1\">Notes</label>","+        <textarea class=\"w-full px-4 py-3 bg-mist border border-misty-border rounded-xl text-graphite font-medium min-h-[56px] resize-none\" data-flutter=\"text-field\" placeholder=\"Add notes...\"></textarea>","       </div>"," ","-      <div class=\"toggle-row\">","-        <span class=\"toggle-label\">Irregular cycle</span>","-        <div class=\"toggle\" id=\"irregularToggle\" role=\"switch\" aria-checked=\"false\" tabindex=\"0\"></div>","+      <!-- Irregular toggle -->","+      <div class=\"flex items-center justify-between py-3 mb-6\">","+        <span class=\"text-base font-medium text-graphite\">Irregular cycle</span>","+        <div class=\"w-13 h-8 bg-misty-border rounded-full relative cursor-pointer\" data-flutter=\"switch\" role=\"switch\" aria-checked=\"false\" tabindex=\"0\">","+          <div class=\"absolute top-1 left-1 w-6 h-6 bg-white rounded-full shadow transition-transform duration-200\"></div>","+        </div>","       </div>"," ","-      <div class=\"sheet-actions\">","-        <button class=\"btn-cancel\" id=\"cancelBtn\">Cancel</button>","-        <button class=\"btn-save\