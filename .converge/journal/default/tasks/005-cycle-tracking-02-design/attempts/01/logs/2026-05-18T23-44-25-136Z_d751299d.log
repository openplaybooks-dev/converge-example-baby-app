x-shadow: 0 24px 64px rgba(0,0,0,0.2);\n    }\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n    /* Card shadow */\n    .card-shadow {\n      box-shadow: 0 8px 24px rgba(0,0,0,0.08);\n    }\n    /* FAB press feedback */\n    .fab-press:active {\n      transform: scale(0.9);\n    }\n    /* History item press */\n    .history-press:active {\n      transform: scale(0.98);\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n\n    <!-- Scaffold root with AppBar -->\n    <div data-flutter=\"scaffold\" class=\"flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- AppBar: lavender primary, title + back button -->\n      <header data-flutter=\"app-bar\" data-color=\"primary\" class=\"bg-lavender h-14 flex items-center px-2\">\n        <button data-flutter=\"icon-btn\" aria-label=\"Back to Browse\" class=\"w-12 h-12 flex items-center justify-center rounded-full\">\n          <svg class=\"icon w-6 h-6 text-white\" data-name=\"arrow_back\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n            <path d=\"M15 18l-6-6 6-6\"/>\n          </svg>\n        </button>\n        <h1 class=\"text-xl font-semibold text-white ml-2\">Cycle Tracking</h1>\n      </header>\n\n      <!-- Body: ListView with content padding -->\n      <main class=\"flex-1 overflow-y-auto px-4 pt-6 pb-24\">\n\n        <!-- Section 1: Current Cycle Card -->\n        <section class=\"mb-6\">\n          <div class=\"bg-mist rounded-card card-shadow p-4\" data-flutter=\"card\">\n            <!-- Cycle day badge -->\n            <div class=\"inline-flex items-center px-3 py-1.5 bg-lavender text-white rounded-full text-sm font-semibold mb-3\" data-flutter=\"chip\" data-color=\"primary\">\n              Day 14\n            </div>\n\n            <!-- Days counter -->\n            <div class=\"text-4xl font-bold text-graphite leading-tight mb-1\">14</div>\n            <div class=\"text-sm text-stone mb-4\">days since last period</div>\n\n            <!-- Next period row -->\n            <div class=\"flex items-center gap-2 text-sm text-stone mb-3\">\n              <svg class=\"icon w-4 h-4 text-lavender\" data-name=\"calendar_today\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/>\n                <path d=\"M16 2v4M8 2v4M3 10h18\"/>\n              </svg>\n              <span>Next period expected: May 28, 2026</span>\n            </div>\n\n            <!-- Fertile window row -->\n            <div class=\"flex items-center gap-2 px-3 py-2 bg-blush/20 rounded-lg mb-4 cursor-pointer\" data-flutter=\"ink-well\" role=\"button\" tabindex=\"0\" aria-label=\"Tap to learn about your fertile window\">\n              <svg class=\"icon w-4 h-4 text-blush\" data-name=\"egg_alt\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <circle cx=\"12\" cy=\"12\" r=\"8\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n                <circle cx=\"12\" cy=\"12\" r=\"4\" fill=\"currentColor\"/>\n              </svg>\n              <span class=\"text-sm font-medium text-graphite\">Fertile window: May 19 - May 23</span>\n            </div>\n\n            <!-- Cycle progress bar -->\n            <div class=\"h-2 bg-misty-border rounded-full overflow-hidden\" data-flutter=\"progress-bar\" role=\"progressbar\" aria-valuenow=\"50\" aria-valuemin=\"0\" aria-valuemax=\"100\">\n              <div class=\"h-full bg-lavender rounded-full\" data-color=\"primary\" style=\"width: 50%\"></div>\n            </div>\n          </div>\n        </section>\n\n        <!-- Section 2: Cycle History -->\n        <section>\n          <h2 class=\"text-2xl font-bold text-graphite mb-4\">Cycle History</h2>\n\n          <!-- History items -->\n          <article class=\"bg-m