xtTheme,\n299\t    required this.colorScheme,\n300\t  });\n301\t\n302\t  @override\n303\t  Widget build(BuildContext context) {\n304\t    return Container(\n305\t      decoration: BoxDecoration(\n306\t        color: AppTheme.morningMist,\n307\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n308\t        boxShadow: const [\n309\t          BoxShadow(\n310\t            color: AppTheme.shadow,\n311\t            blurRadius: 16,\n312\t            offset: Offset(0, 4),\n313\t          ),\n314\t        ],\n315\t      ),\n316\t      child: Padding(\n317\t        padding: const EdgeInsets.all(AppTheme.spaceMd),\n318\t        child: Column(\n319\t          crossAxisAlignment: CrossAxisAlignment.start,\n320\t          children: [\n321\t            Row(\n322\t              mainAxisAlignment: MainAxisAlignment.spaceBetween,\n323\t              crossAxisAlignment: CrossAxisAlignment.center,\n324\t              children: [\n325\t                Text(\n326\t                  'Mood Trend',\n327\t                  style: textTheme.titleMedium?.copyWith(\n328\t                    color: colorScheme.onSurface,\n329\t                  ),\n330\t                ),\n331\t                Row(\n332\t                  children: [\n333\t                    _ChartChip(\n334\t                      label: '1W',\n335\t                      isSelected: true,\n336\t                      colorScheme: colorScheme,\n337\t                      textTheme: textTheme,\n338\t                    ),\n339\t                    const SizedBox(width: AppTheme.spaceXxs),\n340\t                    _ChartChip(\n341\t                      label: '1M',\n342\t                      isSelected: false,\n343\t                      colorScheme: colorScheme,\n344\t                      textTheme: textTheme,\n345\t                    ),\n346\t                    const SizedBox(width: AppTheme.spaceXxs),\n347\t                    _ChartChip(\n348\t                      label: 'All',\n349\t                      isSelected: false,\n350\t                      colorScheme: colorScheme,\n351\t                      textTheme: textTheme,\n352\t                    ),\n353\t                  ],\n354\t                ),\n355\t              ],\n356\t            ),\n357\t            const SizedBox(height: AppTheme.spaceSm),\n358\t            SizedBox(\n359\t              height: 160,\n360\t              child: Semantics(\n361\t                label: 'Mood trend chart showing 7 day history',\n362\t                child: CustomPaint(\n363\t                  size: const Size(double.infinity, 160),\n364\t                  painter: _MoodChartPainter(),\n365\t                ),\n366\t              ),\n367\t            ),\n368\t            const SizedBox(height: AppTheme.spaceXs),\n369\t            Row(\n370\t              children: [\n371\t                Text(\n372\t                  'Score',\n373\t                  style: textTheme.labelSmall?.copyWith(\n374\t                    color: AppTheme.stoneGrey,\n375\t                  ),\n376\t                ),\n377\t                const SizedBox(width: AppTheme.spaceXxs),\n378\t                Container(\n379\t                  width: 8,\n380\t                  height: 8,\n381\t                  decoration: const BoxDecoration(\n382\t                    shape: BoxShape.circle,\n383\t                    color: AppTheme.lavenderBloom,\n384\t                  ),\n385\t                ),\n386\t                const SizedBox(width: AppTheme.spaceXxs),\n387\t                Text(\n388\t                  'Mood',\n389\t                  style: textTheme.labelSmall?.copyWith(\n390\t                    color: AppTheme.stoneGrey,\n391\t                  ),\n392\t                ),\n393\t              ],\n394\t            ),\n395\t          ],\n396\t        ),\n397\t      ),\n398\t    ).animate().fadeIn(duration: 300.ms, delay: 50.ms).slideY(begin: 0.1, end: 0);\n399\t  }\n400\t}\n401\t\n402\tclass _MoodChartPainter extends CustomPainter {\n403\t  @override\n404\t  void paint(Canvas canvas, Size size) {\n405\t    final gridPaint = Paint()\n406\t      ..color = AppTheme.mistyBorder\n407\t      ..strokeWidth = 1;\n408\t\n409\t    // Draw grid lines\n410\t    for (var i = 0; i < 4; i++) {\n411\t      final y = 20.0 + (i * 30);\n412\t      canvas.drawLine(Offset(0, y), Offset(size.width, y), gridPaint);\n413\t    }\n414\t\n415\t    // Y-axis labels\n416\t    final labelStyle = TextStyle(\n417\t      fontSize: 10,\n418\t      color: AppTheme.stoneGrey,\n419\t      fontFamily: 'Nunito',\n420\t    );\n421\t\n422\t    _drawText(canvas, '\\u{1F60A}', Offset(4, 16), labelStyle); // 😊\n423\t    _drawText(canvas, '\\u{1F642}', Offset(4, 46), labelStyle); // 🙂\n424\t    _drawText(canvas, '\\u{1F610}', Offset(4, 76), labelStyle); // 😐\n425\t    _drawText(canvas, '\\u{1F622}', Offset(4, 106), labelStyle); // 😢\n426\t\n427\t    // Line paint\n428\t    final linePaint = Paint()\n429\t      ..color = AppTheme.lavenderBloom\n430\t      ..strokeWidth = 2.5\n431\t      ..style = PaintingStyle.stroke\n432\t      ..strokeCap = StrokeCap.round;\n433\t\n434\t    // Data points\n435\t    final pointPaint = Paint()\n436\t      ..color = AppTheme.lavenderBloom\n437\t      ..style = PaintingStyle.fill;\n438\t\n439\t    // Draw mood line (sample data)\n440\t    final points = [\n441\t      Offset(0, 85),\n442\t      Offset(50, 78),\n443\t      Offset(100, 65),\n444\t      Offset(150, 55),\n445\t      Offset(200, 48),\n446\t      Offset(250, 40),\n447\t      Offset(300, 35),\n448\t    ];\n449\t\n450\t    final path = Path();\n451\t    path.moveTo(points[0].dx, points[0].dy);\n452\t    for (var i = 1; i < points.length; i++) {\n453\t      final p0 = points[i - 1];\n454\t      final p1 = points[i];\n455\t      final cpX = (p0.dx + p1.dx) / 2;\n456\t      path.quadraticBezierTo(cpX, p0.dy, cpX, (p0.dy + p1.dy) / 2);\n457\t      path.quadraticBezierTo(cpX, p1.dy, p1.dx, p1.dy);\n458\t    }\n459\t    canvas.drawPath(path, linePaint);\n460\t\n461\t    // Draw data points\n462\t    for (final point in points) {\n463\t      canvas.drawCircle(point, 5, pointPaint);\n464\t    }\n465\t\n466\t    // X-axis labels\n467\t    final days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];\n468\t    for (var i = 0; i < days.length; i++) {\n469\t      _drawText(\n470\t        canvas,\n471\t        days[i],\n472\t        Offset(i * 50.0, 125),\n473\t        labelStyle,\n474\t      );\n475\t    }\n476\t  }\n477\t\n478\t  void _drawText(Canvas canvas, String text, Offset offset, TextStyle style) {\n479\t    final textSpan = TextSpan(text: text, style: style);\n480\t    final textPainter = TextPainter(\n481\t      text: textSpan,\n482\t      textDirection: TextDirection.ltr,\n483\t    );\n484\t    textPainter.layout();\n485\t    textPainter.paint(canvas, offset);\n486\t  }\n487\t\n488\t  @override\n489\t  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;\n490\t}\n491\t\n492\tclass _EnergyTrendChart extends StatelessWidget {\n493\t  final TextTheme textTheme;\n494\t  final ColorScheme colorScheme;\n495\t\n496\t  const _EnergyTrendChart({\n497\t    required this.textTheme,\n498\t    required this.colorScheme,\n499\t  });\n500\t\n501\t  @override\n502\t  Widget build(BuildContext context) {\n503\t    return Container(\n504\t      decoration: BoxDecoration(\n505\t        color: AppTheme.morningMist,\n506\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n507\t        boxShadow: const [\n508\t          BoxShadow(\n509\t            color: AppTheme.shadow,\n510\t            blurRadius: 16,\n511\t            offset: Offset(0, 4),\n512\t          ),\n513\t        ],\n514\t      ),\n515\t      child: Padding(\n516\t        padding: const EdgeInsets.all(AppTheme.spaceMd),\n517\t        child: Column(\n518\t          crossAxisAlignment: CrossAxisAlignment.start,\n519\t          children: [\n520\t            Row(\n521\t              mainAxisAlignment: MainAxisAlignment.spaceBetween,\n522\t              crossAxisAlignment: CrossAxisAlignment.center,\n523\t              children: [\n524\t                Text(\n525\t                  'Energy Trend',\n526\t                  style: textTheme.titleMedium?.copyWith(\n527\t                    color: colorScheme.onSurface,\n528\t                  ),\n529\t                ),\n530\t                Row(\n531\t                  children: [\n532\t                    _ChartChip(\n533\t                      label: '1W',\n534\t                      isSelected: true,\n535\t                      colorScheme: colorScheme,\n536\t                      textTheme: textTheme,\n537\t                    ),\n538\t                    const SizedBox(width: AppTheme.spaceXxs),\n539\t                    _ChartChip(\n540\t                      label: '1M',\n541\t                      isSelected: false,\n542\t                      colorScheme: colorScheme,\n543\t                      textTheme: textTheme,\n544\t                    ),\n545\t                    const SizedBox(width: AppTheme.spaceXxs),\n546\t                    _ChartChip(\n547\t                      label: 'All',\n548\t                      isSelected: false,\n549\t                      colorScheme: colorScheme,\n550\t                      textTheme: textTheme,\n551\t                    ),\n552\t                  ],\n553\t                ),\n554\t              ],\n555\t            ),\n556\t            const SizedBox(height: AppTheme.spaceSm),\n557\t            SizedBox(\n558\t              height: 160,\n559\t              child: Semantics(\n560\t                label: 'Energy trend chart showing 7 day history',\n561\t                child: CustomPaint(\n562\t                  size: const Size(double.infinity, 160),\n563\t                  painter: _EnergyChartPainter(),\n564\t                ),\n565\t              ),\n566\t            ),\n567\t            const SizedBox(height: AppTheme.spaceXs),\n568\t            Row(\n569\t              children: [\n570\t                Text(\n571\t                  'Level',\n572\t                  style: textTheme.labelSmall?.copyWith(\n573\t                    color: AppTheme.stoneGrey,\n574\t                  ),\n575\t                ),\n576\t                const SizedBox(width: AppTheme.spaceXxs),\n577\t                Container(\n578\t                  width: 8,\n579\t                  height: 8,\n580\t                  decoration: const BoxDecoration(\n581\t                    shape: BoxShape.circle,\n582\t                    color: AppTheme.softMint,\n583\t                  ),\n584\t                ),\n585\t                const SizedBox(width: AppTheme.spaceXxs),\n586\t                Text(\n587\t                  'Energy',\n588\t                  style: textTheme.labelSmall?.copyWith(\n589\t                    color: AppTheme.stoneGrey,\n590\t                  ),\n591\t                ),\n592\t              ],\n593\t            ),\n594\t          ],\n595\t        ),\n596\t      ),\n597\t    ).animate().fadeIn(duration: 300.ms, delay: 100.ms).slideY(begin: 0.1, end: 0);\n598\t  }\n599\t}\n600\t\n601\tclass _EnergyChartPainter extends CustomPainter {\n602\t  @override\n603\t  void paint(Canvas canvas, Size size) {\n604\t    final gridPaint = Paint()\n605\t      ..color = AppTheme.mistyBorder\n606\t      ..strokeWidth = 1;\n607\t\n608\t    // Draw grid lines\n609\t    for (var i = 0; i < 4; i++) {\n610\t      final y = 20.0 + (i * 30);\n611\t      canvas.drawLine(Offset(0, y), Offset(size.width, y), gridPaint);\n612\t    }\n613\t\n614\t    // Y-axis labels\n615\t    final labelStyle = TextStyle(\n616\t      fontSize: 10,\n617\t      color: AppTheme.stoneGrey,\n618\t      fontFamily: 'Nunito',\n619\t    );\n620\t\n621\t    _drawText(canvas, 'High', Offset(4, 16), labelStyle);\n622\t    _drawText(canvas, 'Med', Offset(4, 46), labelStyle);\n623\t    _drawText(canvas, 'Low', Offset(4, 76), labelStyle);\n624\t    _drawText(canvas, 'VLow', Offset(4, 106), labelStyle);\n625\t\n626\t    // Line paint\n627\t    final linePaint = Paint()\n628\t      ..color = AppTheme.softMint\n629\t      ..strokeWidth = 2.5\n630\t      ..style = PaintingStyle.stroke\n631\t      ..strokeCap = StrokeCap.round;\n632\t\n633\t    // Data points\n634\t    final pointPaint = Paint()\n635\t      ..color = AppTheme.softMint\n636\t      ..style = PaintingStyle.fill;\n637\t\n638\t    // Draw energy line (sample data)\n639\t    final points = [\n640\t      Offset(0, 90),\n641\t      Offset(50, 80),\n642\t      Offset(100, 75),\n643\t      Offset(150, 60),\n644\t      Offset(200, 50),\n645\t      Offset(250, 55),\n646\t      Offset(300, 50),\n647\t    ];\n648\t\n649\t    final path = Path();\n650\t    path.moveTo(points[0].dx, points[0].dy);\n651\t    for (var i = 1; i < points.length; i++) {\n652\t      final p0 = points[i - 1];\n653\t      final p1 = points[i];\n654\t      final cpX = (p0.dx + p1.dx) / 2;\n655\t      path.quadraticBezierTo(cpX, p0.dy, cpX, (p0.dy + p1.dy) / 2);\n656\t      path.quadraticBezierTo(cpX, p1.dy, p1.dx, p1.dy);\n657\t    }\n658\t    canvas.drawPath(path, linePaint);\n659\t\n660\t    // Draw data points\n661\t    for (final point in points) {\n662\t      canvas.drawCircle(point, 5, pointPaint);\n663\t    }\n664\t\n665\t    // X-axis labels\n666\t    final days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];\n667\t    for (var i = 0; i < days.length; i++) {\n668\t      _drawText(\n669\t        canvas,\n670\t        days[i],\n671\t        Offset(i * 50.0, 125),\n672\t        labelStyle,\n673\t      );\n674\t    }\n675\t  }\n676\t\n677\t  void _drawText(Canvas canvas, String text, Offset offset, TextStyle style) {\n678\t    final textSpan = TextSpan(text: text, style: style);\n679\t    final textPainter = TextPainter(\n680\t      text: textSpan,\n681\t      textDirection: TextDirection.ltr,\n682\t    );\n683\t    textPainter.layout();\n684\t    textPainter.paint(canvas, offset);\n685\t  }\n686\t\n687\t  @override\n688\t  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;\n689\t}\n690\t\n691\tclass _WellnessTipCard extends StatefulWidget {\n692\t  final TextTheme textTheme;\n693\t  final ColorScheme colorScheme;\n694\t\n695\t  const _WellnessTipCard({\n696\t    required this.textTheme,\n697\t    required this.colorScheme,\n698\t  });\n699\t\n700\t  @override\n701\t  State<_WellnessTipCard> createState() => _WellnessTipCardState();\n702\t}\n703\t\n704\tclass _WellnessTipCardState extends State<_WellnessTipCard> {\n705\t  bool _isExpanded = false;\n706\t\n707\t  // TODO: Replace with MoodEntryProvider data\n708\t  String get _tipText {\n709\t    return 'Your energy is improving! Try adding a 10-minute walk after meals to maintain this positive trend.';\n710\t  }\n711\t\n712\t  String get _tipCategory => 'Mood';\n713\t\n714\t  @override\n715\t  Widget build(BuildContext context) {\n716\t    final colorScheme = widget.colorScheme;\n717\t    final textTheme = widget.textTheme;\n718\t\n719\t    return Container(\n720\t      decoration: BoxDecoration(\n721\t        color: AppTheme.morningMist,\n722\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n723\t        boxShadow: const [\n724\t          BoxShadow(\n725\t            color: AppTheme.shadow,\n726\t            blurRadius: 16,\n727\t            offset: Offset(0, 4),\n728\t          ),\n729\t        ],\n730\t      ),\n731\t      child: Material(\n732\t        color: AppTheme.transparent,\n733\t        child: InkWell(\n734\t          onTap: () => setState(() => _isExpanded = !_isExpanded),\n735\t          borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n736\t          child: Semantics(\n737\t            label: 'Wellness tip: $_tipText',\n738\t            child: AnimatedContainer(\n739\t              duration: const Duration(milliseconds: 250),\n740\t              curve: Curves.easeInOut,\n741\t              padding: const EdgeInsets.all(AppTheme.spaceMd),\n742\t              child: Column(\n743\t                crossAxisAlignment: CrossAxisAlignment.start,\n744\t                children: [\n745\t                  Row(\n746\t                    mainAxisAlignment: MainAxisAlignment.spaceBetween,\n747\t                    crossAxisAlignment: CrossAxisAlignment.center,\n748\t                    children: [\n749\t                      Row(\n750\t                        children: [\n751\t                          Icon(\n752\t                            Icons.lightbulb_outline,\n753\t                            size: 20,\n754\t                            color: colorScheme.primary,\n755\t                          ),\n756\t                          const SizedBox(width: AppTheme.spaceSm),\n757\t                          Text(\n758\t                            'Wellness Tip',\n759\t                            style: textTheme.titleMedium?.copyWith(\n760\t                              color: colorScheme.onSurface,\n761\t                            ),\n762\t                          ),\n763\t                        ],\n764\t                      ),\n765\t                      Container(\n766\t                        padding: const EdgeInsets.symmetric(\n767\t                          horizontal: 10,\n768\t                          vertical: 4,\n769\t                        ),\n770\t                        decoration: BoxDecoration(\n771\t                          color: colorScheme.primary.withValues(alpha: 0.1),\n772\t                          borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n773\t                        ),\n774\t                        child: Text(\n775\t                          _tipCategory,\n776\t                          style: textTheme.labelSmall?.copyWith(\n777\t                            fontWeight: FontWeight.w600,\n778\t                            color: colorScheme.primary,\n779\t                          ),\n780\t                        ),\n781\t                      ),\n782\t                    ],\n783\t                  ),\n784\t                  const SizedBox(height: AppTheme.spaceXs),\n785\t                  AnimatedCrossFade(\n786\t                    firstChild: Text(\n787\t                      _tipText,\n788\t                      style: textTheme.bodyMedium?.copyWith(\n789\t                        color: AppTheme.stoneGrey,\n790\t                      ),\n791\t                      maxLines: 2,\n792\t                      overflow: TextOverflow.ellipsis,\n793\t                    ),\n794\t                    secondChild: Text(\n795\t                      _tipText,\n796\t                      style: textTheme.bodyMedium?.copyWith(\n797\t                        color: AppTheme.stoneGrey,\n798\t                      ),\n799\t                    ),\n800\t                    crossFadeState: _isExpanded\n801\t                        ? CrossFadeState.showSecond\n802\t                        : CrossFadeState.showFirst,\n803\t                    duration: const Duration(milliseconds: 250),\n804\t                  ),\n805\t                  const SizedBox(height: AppTheme.spaceXs),\n806\t                  Center(\n807\t                    child: AnimatedRotation(\n808\t                      turns: _isExpanded ? 0.5 : 0,\n809\t                      duration: const Duration(milliseconds: 200),\n810\t                      child: Icon(\n811\t                        Icons.expand_more,\n812\t                        size: 16,\n813\t                        color: AppTheme.stoneGrey,\n814\t                      ),\n815\t                    ),\n816\t                  ),\n817\t                ],\n818\t              ),\n819\t            ),\n820\t          ),\n821\t        ),\n822\t      ),\n823\t    ).animate().fadeIn(duration: 300.ms, delay: 150.ms).slideY(begin: 0.1, end: 0);\n824\t  }\n825\t}\n826\t\n827\tclass _ChartChip extends StatelessWidget {\n828\t  final String label;\n829\t  final bool isSelected;\n830\t  final ColorScheme colorScheme;\n831\t  final TextTheme textTheme;\n832\t\n833\t  const _ChartChip({\n834\t    required this.label,\n835\t    required this.isSelected,\n836\t    required this.colorScheme,\n837\t    required this.textTheme,\n838\t  });\n839\t\n840\t  @override\n841\t  Widget build(BuildContext context) {\n842\t    return GestureDetector(\n843\t      onTap: () {\n844\t        // TODO: Toggle chart time range\n845\t      },\n846\t      child: AnimatedContainer(\n847\t        duration: const Duration(milliseconds: 150),\n848\t        curve: Curves.easeInOut,\n849\t        padding: const EdgeInsets.symmetric(\n850\t          horizontal: 12,\n851\t          vertical: 6,\n852\t        ),\n853\t        decoration: BoxDecoration(\n854\t          color: isSelected\n855\t              ? colorScheme.primary.withValues(alpha: 0.15)\n856\t              : AppTheme.mistyBorder,\n857\t          borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n858\t        ),\n859\t        child: Text(\n860\t          label,\n861\t          style: textTheme.labelSmall?.copyWith(\n862\t            fontWeight: FontWeight.w600,\n863\t            color: isSelected ? colorScheme.primary : colorScheme.onSurface,\n864\t          ),\n865\t        ),\n866\t      ),\n867\t    );\n868\t  }\n869\t}"}]},"parent_tool_use_id":null,"session_id":"fb05e17d-f35c-48db-806c-472c3e5dcf5b","uuid":"7e0b802d-e353-4f52-b9fc-7979d4c9f3ae","timestamp":"2026-05-19T01:30:42.426Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/minh/Documents/openplayboosks/examples/baby-app/lib/screens/mood_wellness/mood_wellness_screen.dart","content":"import 'package:flutter/material.dart';\nimport 'package:flutter_animate/flutter_animate.dart';\n\nimport '../../theme/app_theme.dart';\n\nclass MoodWellnessScreen extends StatelessWidget {\n  const MoodWellnessScreen({super.key});\n\n  @override\n  Widget build(BuildContext context) {\n    final theme = Theme.of(context);\n    final colorScheme = theme.colorScheme;\n    final textTheme = theme.textTheme;\n\n    return Scaffold(\n      backgroundColor: colorScheme.surfaceContainer,\n      appBar: AppBar(\n        backgroundColor: colorScheme.surfaceContainer,\n        elevation: 0,\n        leading: IconButton(\n          onPressed: () => Navigator.of(context).pop(),\n          icon: const Icon(Icons.arrow_back_ios, size: 24),\n          padding: EdgeInsets.zero,\n          constraints: const BoxConstraints(minWidth: 48, minHeight: 48),\n          tooltip: 'Go back',\n        ),\n        title: Text(\n          'Mood & Wellness',\n          style: textTheme.headlineSmall?.copyWith(\n            color: colorScheme.onSurface,\n          ),\n        ),\n        centerTitle: true,\n      ),\n      body: CustomScrollView(\n        slivers: [\n          SliverToBoxAdapter(\n            child: Padding(\n              padding: const EdgeInsets.symmetric(horizontal: AppTheme.spaceMd),\n              child: Column(\n                crossAxisAlignment: CrossAxisAlignment.stretch,\n                children: [\n                  const SizedBox(height: AppTheme.spaceXs),\n                  _TodaysMoodCard(\n                    textTheme: textTheme,\n                    colorScheme: colorScheme,\n                  ),\n                  const SizedBox(height: AppTheme.spaceLg),\n                  _MoodTrendChart(\n                    textTheme: textTheme,\n                    colorScheme: colorScheme,\n                  ),\n                  const SizedBox(height: AppTheme.spaceLg),\n                  _EnergyTrendChart(\n                    textTheme: textTheme,\n                    colorScheme: colorScheme,\n                  ),\n                  const SizedBox(height: AppTheme.spaceLg),\n                  _WellnessTipCard(\n                    textTheme: textTheme,\n                    colorScheme: colorScheme,\n                  ),\n                  const SizedBox(height: AppTheme.spaceLg),\n                ],\n              ),\n            ),\n          ),\n        ],\n      ),\n    );\n  }\n}\n\nclass _TodaysMoodCard extends StatelessWidget {\n  final TextTheme textTheme;\n  final ColorScheme colorScheme;\n\n  const _TodaysMoodCard({\n    required this.textTheme,\n    required this.colorScheme,\n  });\n\n  @override\n  Widget build(BuildContext context) {\n    // TODO: Integrate with MoodEntryProvider\n    const selectedMood = 4; // 1-5 scale, null if not logged today\n\n    return Container(\n      decoration: BoxDecoration(\n        color: AppTheme.morningMist,\n        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n        boxShadow: const [\n          BoxShadow(\n            color: AppTheme.shadow,\n            blurRadius: 16,\n            offset: Offset(0, 4),\n          ),\n        ],\n      ),\n      child: Material(\n        color: AppTheme.transparent,\n        child: InkWell(\n          onTap: () {\n            // TODO: Focus note field if needed\n          },\n          borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n          child: Padding(\n            padding: const EdgeInsets.all(AppTheme.spaceMd),\n            child: Column(\n              crossAxisAlignment: CrossAxisAlignment.start,\n              children: [\n                Row(\n                  mainAxisAlignment: MainAxisAlignment.spaceBetween,\n                  crossAxisAlignment: CrossAxisAlignment.center,\n                  children: [\n                    Column(\n                      crossAxisAlignment: CrossAxisAlignment.start,\n                      children: [\n                        Text(\n                          'How are you feeling today?',\n                          style: textTheme.titleMedium?.copyWith(\n                            color: colorScheme.onSurface,\n                          ),\n                        ),\n                        const SizedBox(height: AppTheme.spaceXxs),\n                        Text(\n                          'May 19, 2026',\n                          style: textTheme.bodyMedium?.copyWith(\n                            color: AppTheme.stoneGrey,\n                          ),\n                        ),\n                      ],\n                    ),\n                    Container(\n                      padding: const EdgeInsets.symmetric(\n                        horizontal: 10,\n                        vertical: 4,\n                      ),\n                      decoration: BoxDecoration(\n                        color: AppTheme.softMint.withValues(alpha: 0.2),\n                        borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n                      ),\n                      child: Text(\n                        'Today',\n                        style: textTheme.labelSmall?.copyWith(\n                          fontWeight: FontWeight.w600,\n                          color: colorScheme.onSurface,\n                        ),\n                      ),\n                    ),\n                  ],\n                ),\n                const SizedBox(height: AppTheme.spaceMd),\n                Row(\n                  mainAxisAlignment: MainAxisAlignment.spaceEvenly,\n                  children: [\n                    _MoodEmoji(\n                      emoji: '\\u{1F614}', // 😔\n                      score: 1,\n                      label: 'Terrible',\n                      isSelected: selectedMood == 1,\n                      colorScheme: colorScheme,\n                      textTheme: textTheme,\n                    ),\n                    _MoodEmoji(\n                      emoji: '\\u{1F615}', // 😕\n                      score: 2,\n                      label: 'Bad',\n                      isSelected: selectedMood == 2,\n                      colorScheme: colorScheme,\n                      textTheme: textTheme,\n                    ),\n                    _MoodEmoji(\n                      emoji: '\\u{1F610}', // 😐\n                      score: 3,\n                      label: 'Okay',\n                      isSelected: selectedMood == 3,\n                      colorScheme: colorScheme,\n                      textTheme: textTheme,\n                    ),\n                    _MoodEmoji(\n                      emoji: '\\u{1F642}', // 🙂\n                      score: 4,\n                      label: 'Good',\n                      isSelected: selectedMood == 4,\n                      colorScheme: colorScheme,\n                      textTheme: textTheme,\n                    ),\n                    _MoodEmoji(\n                      emoji: '\\u{1F60A}', // 😊\n                      score: 5,\n                      label: 'Great',\n                      isSelected: selectedMood == 5,\n                      colorScheme: colorScheme,\n                      textTheme: textTheme,\n                    ),\n                  ],\n                ),\n                const SizedBox(height: AppTheme.spaceMd),\n                TextField(\n                  maxLength: 200,\n                  maxLines: 3,\n                  minLines: 2,\n                  decoration: InputDecoration(\n                    hintText: 'Add a note (optional, max 200 characters)',\n                    hintStyle: textTheme.bodyMedium?.copyWith(\n                      color: AppTheme.stoneGrey,\n                    ),\n                    filled: true,\n                    fillColor: AppTheme.mistyBorder.withValues(alpha: 0.5),\n                    border: OutlineInputBorder(\n                      borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n                      borderSide: BorderSide.none,\n                    ),\n                    focusedBorder: OutlineInputBorder(\n                      borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n                      borderSide: BorderSide(\n                        color: colorScheme.primary.withValues(alpha: 0.3),\n                        width: 2,\n                      ),\n                    ),\n                    counterStyle: textTheme.labelSmall?.copyWith(\n                      color: AppTheme.stoneGrey,\n                    ),\n                    contentPadding: const EdgeInsets.all(AppTheme.spaceSm),\n                  ),\n                  style: textTheme.bodyMedium?.copyWith(\n                    color: colorScheme.onSurface,\n                  ),\n                ),\n              ],\n            ),\n          ),\n        ),\n      ),\n    ).animate().fadeIn(duration: 300.ms).slideY(begin: 0.1, end: 0);\n  }\n}\n\nclass _MoodEmoji extends StatelessWidget {\n  final String emoji;\n  final int score;\n  final String label;\n  final bool isSelected;\n  final ColorScheme colorScheme;\n  final TextTheme textTheme;\n\n  const _MoodEmoji({\n    required this.emoji,\n    required this.score,\n    required this.label,\n    required this.isSelected,\n    required this.colorScheme,\n    required this.textTheme,\n  });\n\n  @override\n  Widget build(BuildContext context) {\n    return Semantics(\n      label: '$label mood, tap to log',\n      button: true,\n      child: GestureDetector(\n        onTap: () {\n          // TODO: MoodEntryProvider.logMood(score)\n        },\n        child: AnimatedContainer(\n          duration: const Duration(milliseconds: 200),\n          curve: Curves.easeOut,\n          width: 56,\n          height: 56,\n          decoration: BoxDecoration(\n            shape: BoxShape.circle,\n            color: isSelected\n                ? AppTheme.blushRose.withValues(alpha: 0.2)\n                : AppTheme.morningMist,\n            border: Border.all(\n              color: isSelected ? AppTheme.blushRose : AppTheme.mistyBorder,\n              width: isSelected ? 3 : 2,\n            ),\n          ),\n          child: Center(\n            child: Text(\n              emoji,\n              style: const TextStyle(fontSize: 28),\n            ),\n          ),\n        ),\n      ),\n    );\n  }\n}\n\nclass _MoodTrendChart extends StatelessWidget {\n  final TextTheme textTheme;\n  final ColorScheme colorScheme;\n\n  const _MoodTrendChart({\n    required this.textTheme,\n    required this.colorScheme,\n  });\n\n  @override\n  Widget build(BuildContext context) {\n    return Container(\n      decoration: BoxDecoration(\n        color: AppTheme.morningMist,\n        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n        boxShadow: const [\n          BoxShadow(\n            color: AppTheme.shadow,\n            blurRadius: 16,\n            offset: Offset(0, 4),\n          ),\n        ],\n      ),\n      child: Padding(\n        padding: const EdgeInsets.all(AppTheme.spaceMd),\n        child: Column(\n          crossAxisAlignment: CrossAxisAlignment.start,\n          children: [\n            Row(\n              mainAxisAlignment: MainAxisAlignment.spaceBetween,\n              crossAxisAlignment: CrossAxisAlignment.center,\n              children: [\n                Text(\n                  'Mood Trend',\n                  style: textTheme.titleMedium?.copyWith(\n                    color: colorScheme.onSurface,\n                  ),\n                ),\n                Row(\n                  children: [\n                    _ChartChip(\n                      label: '1W',\n                      isSelected: true,\n                      colorScheme: colorScheme,\n                      textTheme: textTheme,\n                    ),\n                    const SizedBox(width: AppTheme.spaceXxs),\n                    _ChartChip(\n                      label: '1M',\n                      isSelected: false,\n                      colorScheme: colorScheme,\n                      textTheme: textTheme,\n                    ),\n                    const SizedBox(width: AppTheme.spaceXxs),\n                    _ChartChip(\n                      label: 'All',\n                      isSelected: false,\n                      colorScheme: colorScheme,\n                      textTheme: textTheme,\n                    ),\n                  ],\n                ),\n              ],\n            ),\n            const SizedBox(height: AppTheme.spaceSm),\n            SizedBox(\n              height: 160,\n              child: Semantics(\n                label: 'Mood trend chart showing 7 day history',\n                child: CustomPaint(\n                  size: const Size(double.infinity, 160),\n                  painter: _MoodChartPainter(),\n                ),\n              ),\n            ),\n            const SizedBox(height: AppTheme.spaceXs),\n            Row(\n              children: [\n                Text(\n                  'Score',\n                  style: textTheme.labelSmall?.copyWith(\n                    color: AppTheme.stoneGrey,\n                  ),\n                ),\n                const SizedBox(width: AppTheme.spaceXxs),\n                Container(\n                  width: 8,\n                  height: 8,\n                  decoration: const BoxDecoration(\n                    shape: BoxShape.circle,\n                    color: AppTheme.lavenderBloom,\n                  ),\n                ),\n                const SizedBox(width: AppTheme.spaceXxs),\n                Text(\n                  'Mood',\n                  style: textTheme.labelSmall?.copyWith(\n                    color: AppTheme.stoneGrey,\n                  ),\n                ),\n              ],\n            ),\n          ],\n        ),\n      ),\n    ).animate().fadeIn(duration: 300.ms, delay: 50.ms).slideY(begin: 0.1, end: 0);\n  }\n}\n\nclass _MoodChartPainter extends CustomPainter {\n  @override\n  void paint(Canvas canvas, Size size) {\n    final gridPaint = Paint()\n      ..color = AppTheme.mistyBorder\n      ..strokeWidth = 1;\n\n    // Draw grid lines\n    for (var i = 0; i < 4; i++) {\n      final y = 20.0 + (i * 30);\n      canvas.drawLine(Offset(0, y), Offset(size.width, y), gridPaint);\n    }\n\n    // Y-axis labels\n    final labelStyle = TextStyle(\n      fontSize: 10,\n      color: AppTheme.stoneGrey,\n      fontFamily: 'Nunito',\n    );\n\n    _drawText(canvas, '\\u{1F60A}', Offset(4, 16), labelStyle); // 😊\n    _drawText(canvas, '\\u{1F642}', Offset(4, 46), labelStyle); // 🙂\n    _drawText(canvas, '\\u{1F610}', Offset(4, 76), labelStyle); // 😐\n    _drawText(canvas, '\\u{1F622}', Offset(4, 106), labelStyle); // 😢\n\n    // Line paint\n    final linePaint = Paint()\n      ..color = AppTheme.lavenderBloom\n      ..strokeWidth = 2.5\n      ..style = PaintingStyle.stroke\n      ..strokeCap = StrokeCap.round;\n\n    // Data points\n    final pointPaint = Paint()\n      ..color = AppTheme.lavenderBloom\n      ..style = PaintingStyle.fill;\n\n    // Draw mood line (sample data)\n    final points = [\n      Offset(0, 85),\n      Offset(50, 78),\n      Offset(100, 65),\n      Offset(150, 55),\n      Offset(200, 48),\n      Offset(250, 40),\n      Offset(300, 35),\n    ];\n\n    final path = Path();\n    path.moveTo(points[0].dx, points[0].dy);\n    for (var i = 1; i < points.length; i++) {\n      final p0 = points[i - 1];\n      final p1 = points[i];\n      final cpX = (p0.dx + p1.dx) / 2;\n      path.quadraticBezierTo(cpX, p0.dy, cpX, (p0.dy + p1.dy) / 2);\n      path.quadraticBezierTo(cpX, p1.dy, p1.dx, p1.dy);\n    }\n    canvas.drawPath(path, linePaint);\n\n    // Draw data points\n    for (final point in points) {\n      canvas.drawCircle(point, 5, pointPaint);\n    }\n\n    // X-axis labels\n    final days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];\n    for (var i = 0; i < days.length; i++) {\n      _drawText(\n        canvas,\n        days[i],\n        Offset(i * 50.0, 125),\n        labelStyle,\n      );\n    }\n  }\n\n  void _drawText(Canvas canvas, String text, Offset offset, TextStyle style) {\n    final textSpan = TextSpan(text: text, style: style);\n    final textPainter = TextPainter(\n      text: textSpan,\n      textDirection: TextDirection.ltr,\n    );\n    textPainter.layout();\n    textPainter.paint(canvas, offset);\n  }\n\n  @override\n  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;\n}\n\nclass _EnergyTrendChart extends StatelessWidget {\n  final TextTheme textTheme;\n