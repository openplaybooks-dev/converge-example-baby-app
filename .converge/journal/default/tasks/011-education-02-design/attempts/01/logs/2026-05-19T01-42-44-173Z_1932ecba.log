e</span>\n200\t            </div>\n201\t\n202\t            <!-- Mental Health -->\n203\t            <div data-flutter=\"card\" data-color=\"secondary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer stagger-item flex flex-col items-center gap-3\" style=\"animation-delay: 250ms;\" data-route=\"/education/mental-health\">\n204\t              <div class=\"w-12 h-12 rounded-full bg-blush/20 flex items-center justify-center\">\n205\t                <svg class=\"w-6 h-6 text-blush\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n206\t                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z\"/>\n207\t                </svg>\n208\t              </div>\n209\t              <span class=\"text-base font-semibold text-graphite\">Mental Health</span>\n210\t            </div>\n211\t\n212\t          </div>\n213\t        </section>\n214\t\n215\t        <!-- Section 3: Recent Articles -->\n216\t        <section class=\"mt-8\">\n217\t          <div class=\"flex justify-between items-center px-4 mb-4\">\n218\t            <h2 class=\"text-lg font-semibold text-graphite\">Recent Articles</h2>\n219\t          </div>\n220\t\n221\t          <div data-flutter=\"horizontal-scroll\" class=\"overflow-x-auto\">\n222\t            <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex px-4\">\n223\t\n224\t              <!-- Article Card 1 -->\n225\t              <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow w-[160px] shrink-0 cursor-pointer slide-in overflow-hidden\" style=\"animation-delay: 300ms;\" data-route=\"/article-reader/art-1\">\n226\t                <!-- Image area -->\n227\t                <div class=\"h-20 bg-lavender/10 rounded-t-card flex items-center justify-center\">\n228\t                  <svg class=\"w-8 h-8 text-lavender/40\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n229\t                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253\"/>\n230\t                  </svg>\n231\t                </div>\n232\t                <div class=\"p-3\">\n233\t                  <h3 class=\"text-sm font-semibold text-graphite mb-1 line-clamp-2\" style=\"line-height: 20px;\">Morning Sickness Remedies That Work</h3>\n234\t                  <span class=\"text-[11px] font-medium text-lavender bg-lavender/10 px-2 py-0.5 rounded-full\">Nutrition</span>\n235\t                  <div class=\"flex items-center gap-1 mt-2 text-stone\">\n236\t                    <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n237\t                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n238\t                    </svg>\n239\t                    <span class=\"text-[11px]\">4 min</span>\n240\t                  </div>\n241\t                </div>\n242\t              </div>\n243\t\n244\t              <!-- Article Card 2 -->\n245\t              <div data-flutter=\"card\" data-color=\"secondary\" class=\"card-tap bg-mist rounded-card card-shadow w-[160px] shrink-0 cursor-pointer slide-in overflow-hidden\" style=\"animation-delay: 350ms;\" data-route=\"/article-reader/art-2\">\n246\t                <div class=\"h-20 bg-blush/10 rounded-t-card flex items-center justify-center\">\n247\t                  <svg class=\"w-8 h-8 text-blush/40\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n248\t                    <path s