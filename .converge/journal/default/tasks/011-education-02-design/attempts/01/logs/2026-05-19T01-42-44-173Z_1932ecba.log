elative;\n57\t      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n58\t    }\n59\t\n60\t    @media (prefers-reduced-motion: reduce) {\n61\t      *, *::before, *::after {\n62\t        animation-duration: 0.01ms !important;\n63\t        transition-duration: 0.01ms !important;\n64\t      }\n65\t    }\n66\t\n67\t    /* SliverAppBar collapsed gradient */\n68\t    .sliver-bg {\n69\t      background: linear-gradient(180deg, #F5F3FF 0%, #F5F3FF 100%);\n70\t    }\n71\t\n72\t    /* Card shadow */\n73\t    .card-shadow {\n74\t      box-shadow: 0 8px 24px rgba(0,0,0,0.08);\n75\t    }\n76\t\n77\t    /* Chip tap */\n78\t    .chip-tap:active {\n79\t      transform: scale(0.97);\n80\t      transition: transform 200ms ease-out;\n81\t    }\n82\t\n83\t    /* Bottom nav active indicator */\n84\t    .nav-indicator {\n85\t      background: rgba(124, 58, 237, 0.15);\n86\t      border-radius: 999px;\n87\t    }\n88\t\n89\t    /* Shimmer loading effect */\n90\t    @keyframes shimmer {\n91\t      0% { background-position: -200% 0; }\n92\t      100% { background-position: 200% 0; }\n93\t    }\n94\t    .shimmer {\n95\t      background: linear-gradient(90deg, #F0F0F0 25%, #E0E0E0 50%, #F0F0F0 75%);\n96\t      background-size: 200% 100%;\n97\t      animation: shimmer 1.5s infinite;\n98\t    }\n99\t  </style>\n100\t</head>\n101\t<body>\n102\t  <div class=\"phone\">\n103\t    <!-- Scaffold with CustomScrollView / SliverAppBar -->\n104\t    <div data-flutter=\"scaffold\" data-bg=\"lavenderTint\" class=\"flex flex-col min-h-screen bg-lavender-tint\">\n105\t\n106\t      <!-- SliverAppBar - collapses to show week badge -->\n107\t      <header data-flutter=\"sliver-app-bar\" data-expanded-height=\"280\" data-pinned=\"true\"\n108\t              class=\"sliver-bg relative overflow-hidden\">\n109\t\n110\t        <!-- Expanded content (shown when scrolled to top) -->\n111\t        <div class=\"absolute inset-0 flex flex-col items-center justify-center pt-12 pb-6\">\n112\t          <!-- Week badge -->\n113\t     