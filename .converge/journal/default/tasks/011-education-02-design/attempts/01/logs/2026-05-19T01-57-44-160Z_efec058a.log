ith CustomScrollView -->\n    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- AppBar -->\n      <header data-flutter=\"app-bar\" class=\"flex items-center h-14 px-4 bg-lavender-tint\">\n        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"icon-btn w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n          <svg class=\"w-6 h-6 text-graphite\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"/>\n          </svg>\n        </button>\n        <h1 class=\"flex-1 text-xl font-semibold text-graphite text-center pr-12\">Education</h1>\n        <button data-flutter=\"icon-btn\" aria-label=\"Search articles\" class=\"icon-btn w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n          <svg class=\"w-6 h-6 text-graphite\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"/>\n          </svg>\n        </button>\n      </header>\n\n      <!-- Body - scrollable content -->\n      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto pb-24\">\n\n        <!-- Section 1: Featured Article Hero -->\n        <section class=\"px-4 mt-6\">\n          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow overflow-hidden cursor-pointer animate-fade-in\" style=\"animation-delay: 0ms;\" data-route=\"/article-reader/featured-1\">\n            <!-- Hero image area -->\n            <div class=\"relative h-[180px] bg-gradient-to-br from-lavender to-lavender-light rounded-t-card overflow-hidden\">\n              <!-- Topic badge -->\n              <div class=\"absolute top-3 left-3\" data-flutter=\"chip\" data-color=\"primary\" dat