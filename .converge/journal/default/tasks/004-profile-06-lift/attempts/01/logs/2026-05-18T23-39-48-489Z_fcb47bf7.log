[2026-05-18T23:40:21.401Z] [TOOL_RESULT] 1	# Task: 004-profile-06-lift
2	
3	# Lift: Profile
4	
5	Lift each widget in `lib/screens/profile/_widgets/` marked `shared: true` in `.stitch/designs/profile/widgets.jsonl` to `lib/widgets/` — one spawn per shared widget.
6	
7	```bash
8	TEMPLATES=".converge/playbooks/default/templates"
9	WIDGETS=".stitch/designs/profile/widgets.jsonl"
10	LOCAL_DIR="lib/screens/profile/_widgets"
11	SCREEN_PATH="lib/screens/profile/profile_screen.dart"
12	SID="profile"
13	TITLE="Profile"
14	
15	[ -f "${WIDGETS}" ] || exit 0
16	
17	I=0
18	while IFS= read -r W; do
19	  [ -z "${W}" ] && continue
20	  SHARED=$(echo "${W}" | jq -r '.shared // false')
21	  [ "${SHARED}" = "true" ] || continue
22	  I=$((I + 1))
23	  P=$(printf '%03d' "${I}")
24	  WID=$(echo "${W}"   | jq -r '.id // .name')
25	  WNAME=$(echo "${W}" | jq -r '.name // .id')
26	  LOCAL_FILE="${LOCAL_DIR}/${WNAME}.dart"
27	  SHARED_FILE="lib/widgets/${WNAME}.dart"
28	  converge spawn template \
29	    --path "${TEMPLATES}/screen-widget-lift/TASK.md" \
30	    --id "${SID}-lift-${P}-${WID}" \
31	    --var "screenId=${SID}" \
32	    --var "screenTitle=${TITLE}" \
33	    --var "screenPath=${SCREEN_PATH}" \
34	    --var "widgetId=${WID}" \
35	    --var "widgetName=${WNAME}" \
36	    --var "localFile=${LOCAL_FILE}" \
37	    --var "sharedFile=${SHARED_FILE}"
38	done < "${WIDGETS}"
39	```
40	
41	If no widgets are shared (or the file is missing/empty), exit with no spawns.
