           <div class=\"card-icon-container\">\n336\t              <!-- favorite_outline -->\n337\t              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n338\t                <path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/>\n339\t              </svg>\n340\t            </div>\n341\t            <div class=\"card-text\">\n342\t              <h2 class=\"card-title\">Health Log</h2>\n343\t              <p class=\"card-description\">Track symptoms, doctor visits, reminders</p>\n344\t            </div>\n345\t            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n346\t              <polyline points=\"9 18 15 12 9 6\"/>\n347\t            </svg>\n348\t          </div>\n349\t        </div>\n350\t\n351\t        <!-- Mood & Wellness Card -->\n352\t        <div class=\"card card-mood\"\n353\t             role=\"link\"\n354\t             tabindex=\"0\"\n355\t             aria-label=\"Mood and Wellness, double tap to open mood and wellness screen\"\n356\t             data-flutter=\"card\"\n357\t             data-route=\"/mood-wellness\">\n358\t          <div class=\"card-row\">\n359\t            <div class=\"card-icon-container\">\n360\t              <!-- mood_outlined -->\n361\t              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n362\t                <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n363\t                <path d=\"M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01\"/>\n364\t              </svg>\n365\t            </div>\n366\t            <div class=\"card-text\">\n367\t              <h2 class=\"card-title\">Mood & Wellness</h2>\n368\t              <p class=\"card-description\">Log moods, track energy levels</p>\n369\t            </div>\n370\t            <svg class=\"card-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"curre