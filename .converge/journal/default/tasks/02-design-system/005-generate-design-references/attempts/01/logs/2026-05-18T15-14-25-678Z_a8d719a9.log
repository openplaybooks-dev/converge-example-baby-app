Q25 60 50 65 T100 50 T150 55 T200 35 T250 30 T300 40 L300 120 L0 120 Z\" fill=\"url(#energyGradient)\"/>\n              <path d=\"M0 70 Q25 60 50 65 T100 50 T150 55 T200 35 T250 30 T300 40\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n              <circle cx=\"0\" cy=\"70\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"50\" cy=\"65\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"100\" cy=\"50\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"150\" cy=\"55\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"200\" cy=\"35\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"250\" cy=\"30\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"300\" cy=\"40\" r=\"4\" fill=\"#6EE7B7\"/>\n              <text x=\"0\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Mon</text>\n              <text x=\"50\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Tue</text>\n              <text x=\"100\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Wed</text>\n              <text x=\"150\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Thu</text>\n              <text x=\"200\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Fri</text>\n              <text x=\"250\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sat</text>\n              <text x=\"300\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sun</text>\n            </svg>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"wellness-tip\">\n          <div class=\"tip-label\">Wellness Tip</div>\n          <p class=\"tip-text\">Your energy is improving! Try adding a 10-minute walk after meals to maintain this positive trend.</p>\n        </div>\n      </section>\n    </main>\n\n    <nav class=\"bottom-nav\" role=\"navigation\" aria-label=\"Main navigation\">\n   