{"type":"assistant","message":{"id":"065a603eb0e0ef9735bf248ff56cc033","type":"message","role":"assistant","model":"MiniMax-M2.7","content":[{"type":"tool_use","id":"call_function_aicz6u75qnwg_2","name":"Write","input":{"file_path":"/Users/minh/Documents/openplayboosks/examples/baby-app/.stitch/system/multi-state-screen.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Baby Bump - Mood & Wellness</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root {\n      --color-primary: #7C3AED;\n      --color-secondary: #F9A8D4;\n      --color-tertiary: #6EE7B7;\n      --color-background: #F5F3FF;\n      --color-surface: #FAFAFA;\n      --color-text-primary: #1F2937;\n      --color-text-secondary: #6B7280;\n      --color-border: #E5E7EB;\n      --color-error: #EF4444;\n      --color-white: #FFFFFF;\n      --radius-card: 16px;\n      --radius-button: 24px;\n      --spacing-unit: 8px;\n      --font-family: 'Nunito', sans-serif;\n    }\n\n    *, *::before, *::after {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        animation-iteration-count: 1 !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n\n    body {\n      font-family: var(--font-family);\n      background: #1E1B2E;\n      min-height: 100vh;\n      display: flex;\n      justify-content: center;\n      align-items: flex-start;\n      padding: 20px 0;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      background: var(--color-background);\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .status-bar {\n      height: 44px;\n      background: var(--color-background);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      padding: 0 8px;\n      background: var(--color-background);\n    }\n\n    .back-btn {\n      width: 48px;\n      height: 48px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      border: none;\n      background: none;\n      cursor: pointer;\n      border-radius: 50%;\n      transition: background 200ms ease-out;\n    }\n\n    .back-btn:hover {\n      background: var(--color-border);\n    }\n\n    .back-btn svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-primary);\n    }\n\n    .app-bar-title {\n      flex: 1;\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      text-align: center;\n      margin-right: 48px;\n    }\n\n    .content {\n      padding: 0 16px 100px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-bottom: 24px;\n    }\n\n    .card {\n      background: var(--color-white);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .card-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      margin-bottom: 12px;\n    }\n\n    .emoji-selector {\n      display: flex;\n      justify-content: space-between;\n      gap: 8px;\n    }\n\n    .emoji-btn {\n      width: 56px;\n      height: 56px;\n      border-radius: 50%;\n      border: 2px solid var(--color-border);\n      background: var(--color-surface);\n      font-size: 32px;\n      cursor: pointer;\n      transition: transform 200ms ease-out, border-color 200ms ease-out, background 200ms ease-out;\n    }\n\n    .emoji-btn:hover, .emoji-btn:focus {\n      border-color: var(--color-primary);\n      transform: scale(1.1);\n    }\n\n    .emoji-btn.selected {\n      border-color: var(--color-primary);\n      background: rgba(124, 58, 237, 0.1);\n    }\n\n    .emoji-btn:focus {\n      outline: none;\n      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.2);\n    }\n\n    .note-field {\n      margin-top: 16px;\n    }\n\n    .note-input {\n      width: 100%;\n      min-height: 56px;\n      padding: 12px 16px;\n      border: none;\n      border-radius: 12px;\n      background: var(--color-surface);\n      font-family: var(--font-family);\n      font-size: 14px;\n      color: var(--color-text-primary);\n      resize: none;\n      transition: box-shadow 200ms ease-out;\n    }\n\n    .note-input::placeholder {\n      color: var(--color-text-secondary);\n    }\n\n    .note-input:focus {\n      outline: none;\n      box-shadow: 0 0 0 2px var(--color-primary);\n    }\n\n    .chart-card {\n      background: var(--color-white);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .chart-header {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      margin-bottom: 16px;\n    }\n\n    .chart-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .chart-badge {\n      font-size: 11px;\n      font-weight: 500;\n      padding: 4px 8px;\n      border-radius: 8px;\n      background: var(--color-secondary);\n      opacity: 0.3;\n      color: var(--color-text-primary);\n    }\n\n    .chart-area {\n      height: 120px;\n      position: relative;\n    }\n\n    .chart-svg {\n      width: 100%;\n      height: 100%;\n    }\n\n    .chart-empty {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      height: 120px;\n      color: var(--color-text-secondary);\n    }\n\n    .chart-empty svg {\n      width: 48px;\n      height: 48px;\n      margin-bottom: 8px;\n      opacity: 0.5;\n    }\n\n    .chart-empty span {\n      font-size: 14px;\n    }\n\n    .wellness-tip {\n      background: linear-gradient(135deg, var(--color-tertiary), #34D399);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      color: var(--color-text-primary);\n    }\n\n    .tip-label {\n      font-size: 11px;\n      font-weight: 500;\n      letter-spacing: 0.4pt;\n      text-transform: uppercase;\n      opacity: 0.7;\n      margin-bottom: 4px;\n    }\n\n    .tip-text {\n      font-size: 14px;\n      font-weight: 500;\n      line-height: 20px;\n    }\n\n    .state-indicator {\n      position: absolute;\n      top: 60px;\n      right: 16px;\n      padding: 4px 12px;\n      border-radius: 12px;\n      font-size: 11px;\n      font-weight: 600;\n      text-transform: uppercase;\n      letter-spacing: 0.5pt;\n    }\n\n    .state-indicator.empty {\n      background: var(--color-border);\n      color: var(--color-text-secondary);\n    }\n\n    .state-indicator.filling {\n      background: var(--color-secondary);\n      opacity: 0.3;\n      color: var(--color-text-primary);\n    }\n\n    .state-indicator.complete {\n      background: var(--color-tertiary);\n      color: var(--color-text-primary);\n    }\n\n    .bottom-nav {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      height: 80px;\n      background: var(--color-white);\n      display: flex;\n      justify-content: space-around;\n      align-items: flex-start;\n      padding-top: 8px;\n      border-top: 1px solid var(--color-border);\n    }\n\n    .nav-item {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 4px;\n      padding: 8px 16px;\n      border: none;\n      background: none;\n      cursor: pointer;\n      position: relative;\n    }\n\n    .nav-item.active::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      width: 40px;\n      height: 4px;\n      background: var(--color-primary);\n      border-radius: 2px;\n      opacity: 0.15;\n    }\n\n    .nav-item svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active svg {\n      color: var(--color-primary);\n    }\n\n    .nav-item span {\n      font-size: 11px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active span {\n      font-weight: 600;\n      color: var(--color-primary);\n    }\n\n    .home-indicator {\n      position: absolute;\n      bottom: 8px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 134px;\n      height: 5px;\n      background: var(--color-text-primary);\n      border-radius: 3px;\n      opacity: 0.2;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <div class=\"status-bar\">\n      <span>9:41</span>\n      <div class=\"status-bar-icons\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n          <rect x=\"4\" y=\"9\" width=\"14\" height=\"6\" rx=\"1\" fill=\"currentColor\"/>\n        </svg>\n      </div>\n    </div>\n\n    <header class=\"app-bar\">\n      <button class=\"back-btn\" aria-label=\"Go back\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n        </svg>\n      </button>\n      <h1 class=\"app-bar-title\">Mood & Wellness</h1>\n      <span class=\"state-indicator complete\">7 days</span>\n    </header>\n\n    <main class=\"content\">\n      <section class=\"section\">\n        <div class=\"card\">\n          <h2 class=\"card-title\">How are you feeling today?</h2>\n          <div class=\"emoji-selector\" role=\"group\" aria-label=\"Mood selection\">\n            <button class=\"emoji-btn\" aria-label=\"Very sad\" aria-pressed=\"false\">😢</button>\n            <button class=\"emoji-btn\" aria-label=\"Sad\" aria-pressed=\"false\">😕</button>\n            <button class=\"emoji-btn selected\" aria-label=\"Neutral\" aria-pressed=\"true\">😐</button>\n            <button class=\"emoji-btn\" aria-label=\"Happy\" aria-pressed=\"false\">🙂</button>\n            <button class=\"emoji-btn\" aria-label=\"Very happy\" aria-pressed=\"false\">😊</button>\n          </div>\n          <div class=\"note-field\">\n            <textarea class=\"note-input\" placeholder=\"Add a note (optional)\" aria-label=\"Mood note\"></textarea>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"chart-card\">\n          <div class=\"chart-header\">\n            <h3 class=\"chart-title\">Mood Trend</h3>\n            <span class=\"chart-badge\">Last 7 days</span>\n          </div>\n          <div class=\"chart-area\">\n            <svg class=\"chart-svg\" viewBox=\"0 0 300 120\" preserveAspectRatio=\"none\">\n              <defs>\n                <linearGradient id=\"moodGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                  <stop offset=\"0%\" stop-color=\"#7C3AED\" stop-opacity=\"0.3\"/>\n                  <stop offset=\"100%\" stop-color=\"#7C3AED\" stop-opacity=\"0\"/>\n                </linearGradient>\n              </defs>\n              <path d=\"M0 90 Q25 85 50 75 T100 65 T150 55 T200 45 T250 40 T300 35 L300 120 L0 120 Z\" fill=\"url(#moodGradient)\"/>\n              <path d=\"M0 90 Q25 85 50 75 T100 65 T150 55 T200 45 T250 40 T300 35\" fill=\"none\" stroke=\"#7C3AED\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n              <circle cx=\"0\" cy=\"90\" r=\"4\" fill=\"#7C3AED\"/>\n              <circle cx=\"50\" cy=\"75\" r=\"4\" fill=\"#7C3AED\"/>\n              <circle cx=\"100\" cy=\"65\" r=\"4\" fill=\"#7C3AED\"/>\n              <circle cx=\"150\" cy=\"55\" r=\"4\" fill=\"#7C3AED\"/>\n              <circle cx=\"200\" cy=\"45\" r=\"4\" fill=\"#7C3AED\"/>\n              <circle cx=\"250\" cy=\"40\" r=\"4\" fill=\"#7C3AED\"/>\n              <circle cx=\"300\" cy=\"35\" r=\"4\" fill=\"#7C3AED\"/>\n              <text x=\"0\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Mon</text>\n              <text x=\"50\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Tue</text>\n              <text x=\"100\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Wed</text>\n              <text x=\"150\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Thu</text>\n              <text x=\"200\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Fri</text>\n              <text x=\"250\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sat</text>\n              <text x=\"300\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sun</text>\n            </svg>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"chart-card\">\n          <div class=\"chart-header\">\n            <h3 class=\"chart-title\">Energy Level</h3>\n            <span class=\"chart-badge\">Last 7 days</span>\n          </div>\n          <div class=\"chart-area\">\n            <svg class=\"chart-svg\" viewBox=\"0 0 300 120\" preserveAspectRatio=\"none\">\n              <defs>\n                <linearGradient id=\"energyGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                  <stop offset=\"0%\" stop-color=\"#6EE7B7\" stop-opacity=\"0.3\"/>\n                  <stop offset=\"100%\" stop-color=\"#6EE7B7\" stop-opacity=\"0\"/>\n                </linearGradient>\n              </defs>\n              <path d=\"M0 70 Q25 60 50 65 T100 50 T150 55 T200 35 T250 30 T300 40 L300 120 L0 120 Z\" fill=\"url(#energyGradient)\"/>\n              <path d=\"M0 70 Q25 60 50 65 T100 50 T150 55 T200 35 T250 30 T300 40\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n              <circle cx=\"0\" cy=\"70\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"50\" cy=\"65\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"100\" cy=\"50\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"150\" cy=\"55\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"200\" cy=\"35\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"250\" cy=\"30\" r=\"4\" fill=\"#6EE7B7\"/>\n              <circle cx=\"300\" cy=\"40\" r=\"4\" fill=\"#6EE7B7\"/>\n              <text x=\"0\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Mon</text>\n              <text x=\"50\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Tue</text>\n              <text x=\"100\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Wed</text>\n              <text x=\"150\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Thu</text>\n              <text x=\"200\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Fri</text>\n              <text x=\"250\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sat</text>\n              <text x=\"300\" y=\"110\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\">Sun</text>\n            </svg>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"wellness-tip\">\n          <div class=\"tip-label\">Wellness Tip</div>\n          <p class=\"tip-text\">Your energy is improving! Try adding a 10-minute walk after meals to maintain this positive trend.</p>\n        </div>\n      </section>\n    </main>\n\n    <nav class=\"bottom-nav\" role=\"navigation\" aria-label=\"Main navigation\">\n      <button class=\"nav-item\" aria-label=\"Home\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M12 3L4 9v12h5v-7h6v7h5V9z\"/>\n        </svg>\n        <span>Home</span>\n      </button>\n      <button class=\"nav-item\" aria-label=\"Browse\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"11\" cy=\"11\" r=\"8\"/>\n          <path d=\"M21 21l-4.35-4.35\"/>\n        </svg>\n        <span>Browse</span>\n      </button>\n      <button class=\"nav-item\" aria-label=\"Library\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z\"/>\n        </svg>\n        <span>Library</span>\n      </button>\n      <button class=\"nav-item active\" aria-current=\"page\" aria-label=\"Profile\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"12\" cy=\"8\" r=\"4\"/>\n          <path d=\"M4 20c0-4 4-6 8-6s8 2 8 6\"/>\n        </svg>\n        <span>Profile</span>\n      </button>\n    </nav>\n\n    <div class=\"home-indicator\"></div>\n  </div>\n</body>\n</html>"}}],"usage":{"input_tokens":1296,"output_tokens":15769,"cache_creation_input_tokens":0,"cache_read_input_tokens":38983},"stop_reason":"tool_use","base_resp":{"status_code":0,"status_msg":"success"},"context_management":null},"parent_tool_use_id":null,"session_id":"c90e9e73-2ac5-4b2b-94b7-796b4c632644","uuid":"4d03d608-d174-4eac-bd7a-000000000002"}
{"type":"assistant","message":{"id":"065a603eb0e0ef9735bf248ff56cc033","type":"message","role":"assistant","model":"MiniMax-M2.7","content":[{"type":"tool_use","id":"call_function_aicz6u75qnwg_3","name":"Write","input":{"file_path":"/Users/minh/Documents/openplayboosks/examples/baby-app/.stitch/system/celebration-screen.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Baby Bump - Pregnancy Progress</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root {\n      --color-primary: #7C3AED;\n      --color-secondary: #F9A8D4;\n      --color-tertiary: #6EE7B7;\n      --color-background: #F5F3FF;\n      --color-surface: #FAFAFA;\n      --color-text-primary: #1F2937;\n      --color-text-secondary: #6B7280;\n      --color-border: #E5E7EB;\n      --color-error: #EF4444;\n      --color-white: #FFFFFF;\n      --radius-card: 16px;\n      --radius-button: 24px;\n      --spacing-unit: 8px;\n      --font-family: 'Nunito', sans-serif;\n    }\n\n    *, *::before, *::after {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        animation-iteration-count: 1 !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n\n    body {\n      font-family: var(--font-family);\n      background: #1E1B2E;\n      min-height: 100vh;\n      display: flex;\n      justify-content: center;\n      align-items: flex-start;\n      padding: 20px 0;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      background: var(--color-background);\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .confetti {\n      position: absolute;\n      top: 0;\n      left: 0;\n      right: 0;\n      height: 200px;\n      pointer-events: none;\n      overflow: hidden;\n    }\n\n    .confetti-piece {\n      position: absolute;\n      width: 8px;\n      height: 8px;\n      border-radius: 2px;\n      animation: confettiFall 3s ease-out forwards;\n    }\n\n    @keyframes confettiFall {\n      0% {\n        transform: translateY(-20px) rotate(0deg);\n        opacity: 1;\n      }\n      100% {\n        transform: translateY(200px) rotate(720deg);\n        opacity: 0;\n      }\n    }\n\n    .status-bar {\n      height: 44px;\n      background: transparent;\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      position: relative;\n      z-index: 10;\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      padding: 0 8px;\n      background: transparent;\n      position: relative;\n      z-index: 10;\n    }\n\n    .back-btn {\n      width: 48px;\n      height: 48px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      border: none;\n      background: rgba(255, 255, 255, 0.8);\n      backdrop-filter: blur(8px);\n      cursor: pointer;\n      border-radius: 50%;\n      transition: background 200ms ease-out;\n    }\n\n    .back-btn:hover {\n      background: var(--color-white);\n    }\n\n    .back-btn svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-primary);\n    }\n\n    .app-bar-title {\n      flex: 1;\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      text-align: center;\n      margin-right: 48px;\n    }\n\n    .content {\n      padding: 0 16px 100px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-bottom: 24px;\n    }\n\n    .hero-card {\n      background: linear-gradient(180deg, var(--color-secondary) 0%, var(--color-white) 100%);\n      border-radius: var(--radius-card);\n      padding: 32px 24px;\n      text-align: center;\n      position: relative;\n      overflow: hidden;\n    }\n\n    .hero-sparkles {\n      position: absolute;\n      top: 0;\n      left: 0;\n      right: 0;\n      bottom: 0;\n      pointer-events: none;\n    }\n\n    .sparkle {\n      position: absolute;\n      animation: sparkle 2s ease-in-out infinite;\n    }\n\n    @keyframes sparkle {\n      0%, 100% { opacity: 0.3; transform: scale(0.8); }\n      50% { opacity: 1; transform: scale(1.2); }\n    }\n\n    .week-hero {\n      position: relative;\n      z-index: 1;\n    }\n\n    .week-number {\n      font-size: 72px;\n      font-weight: 700;\n      color: var(--color-primary);\n      line-height: 80px;\n      letter-spacing: -2px;\n    }\n\n    .week-label {\n      font-size: 18px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n      margin-top: -4px;\n    }\n\n    .fruit-comparison {\n      display: inline-flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 8px;\n      margin-top: 16px;\n    }\n\n    .fruit-illustration {\n      width: 80px;\n      height: 80px;\n    }\n\n    .fruit-name {\n      font-size: 18px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .page-dots {\n      display: flex;\n      justify-content: center;\n      gap: 8px;\n      margin-top: 24px;\n    }\n\n    .page-dot {\n      width: 8px;\n      height: 8px;\n      border-radius: 50%;\n      background: var(--color-border);\n    }\n\n    .page-dot.active {\n      background: var(--color-primary);\n      width: 24px;\n      border-radius: 4px;\n    }\n\n    .card {\n      background: var(--color-white);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .card-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      margin-bottom: 12px;\n      display: flex;\n      align-items: center;\n      gap: 8px;\n    }\n\n    .card-title svg {\n      width: 20px;\n      height: 20px;\n      color: var(--color-primary);\n    }\n\n    .body-changes {\n      list-style: none;\n    }\n\n    .body-changes li {\n      display: flex;\n      align-items: flex-start;\n      gap: 8px;\n      padding: 8px 0;\n      border-bottom: 1px solid var(--color-border);\n      font-size: 14px;\n      line-height: 20px;\n      color: var(--color-text-primary);\n    }\n\n    .body-changes li:last-child {\n      border-bottom: none;\n    }\n\n    .body-changes li::before {\n      content: '';\n      width: 6px;\n      height: 6px;\n      border-radius: 50%;\n      background: var(--color-secondary);\n      margin-top: 7px;\n      flex-shrink: 0;\n    }\n\n    .baby-dev-text {\n      font-size: 14px;\n      line-height: 20px;\n      color: var(--color-text-primary);\n    }\n\n    .tips-list {\n      list-style: none;\n    }\n\n    .tips-list li {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n      padding: 12px 0;\n      border-bottom: 1px solid var(--color-border);\n    }\n\n    .tips-list li:last-child {\n      border-bottom: none;\n    }\n\n    .tip-number {\n      width: 28px;\n      height: 28px;\n      border-radius: 50%;\n      background: var(--color-primary);\n      color: var(--color-white);\n      font-size: 14px;\n      font-weight: 600;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      flex-shrink: 0;\n    }\n\n    .tip-text {\n      font-size: 14px;\n      line-height: 20px;\n      color: var(--color-text-primary);\n    }\n\n    .due-summary {\n      background: linear-gradient(135deg, var(--color-primary), #9F67FF);\n      border-radius: var(--radius-card);\n      padding: 20px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n    }\n\n    .due-info {\n      color: var(--color-white);\n    }\n\n    .due-label {\n      font-size: 11px;\n      font-weight: 500;\n      letter-spacing: 0.4pt;\n      text-transform: uppercase;\n      opacity: 0.8;\n      margin-bottom: 4px;\n    }\n\n    .due-date {\n      font-size: 16px;\n      font-weight: 600;\n    }\n\n    .due-countdown {\n      font-size: 32px;\n      font-weight: 700;\n      color: var(--color-white);\n    }\n\n    .due-days {\n      font-size: 12px;\n      font-weight: 500;\n      opacity: 0.8;\n    }\n\n    .trimester-badge {\n      display: inline-flex;\n      align-items: center;\n      gap: 4px;\n      padding: 6px 12px;\n      background: rgba(255, 255, 255, 0.2);\n      border-radius: 20px;\n      font-size: 12px;\n      font-weight: 600;\n      color: var(--color-white);\n      margin-top: 8px;\n    }\n\n    .trimester-badge svg {\n      width: 14px;\n      height: 14px;\n    }\n\n    .bottom-nav {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      height: 80px;\n      background: var(--color-white);\n      display: flex;\n      justify-content: space-around;\n      align-items: flex-start;\n      padding-top: 8px;\n      border-top: 1px solid var(--color-border);\n    }\n\n    .nav-item {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 4px;\n      padding: 8px 16px;\n      border: none;\n      background: none;\n      cursor: pointer;\n      position: relative;\n    }\n\n    .nav-item.active::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      width: 40px;\n      height: 4px;\n      background: var(--color-primary);\n      border-radius: 2px;\n      opacity: 0.15;\n    }\n\n    .nav-item svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active svg {\n      color: var(--color-primary);\n    }\n\n    .nav-item span {\n      font-size: 11px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active span {\n      font-weight: 600;\n      color: var(--color-primary);\n    }\n\n    .home-indicator {\n      position: absolute;\n      bottom: 8px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 134px;\n      height: 5px;\n      background: var(--color-text-primary);\n      border-radius: 3px;\n      opacity: 0.2;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <div class=\"confetti\" aria-hidden=\"true\">\n      <div class=\"confetti-piece\" style=\"left: 10%; background: #7C3AED; animation-delay: 0s;\"></div>\n      <div class=\"confetti-piece\" style=\"left: 20%; background: #F9A8D4; animation-delay: 0.2s;\"></div>\n      <div class=\"confetti-piece\" style=\"left: 30%; background: #6EE7B7; animation-delay: 0.4s;\"></div>\n      <div class=\"confetti-piece\" style=\"left: 40%; background: #7C3AED; animation-delay: 0.1s;\"></div>\n      <div class=\"confetti-piece\" style=\"left: 50%; background: #F9A8D4; animation-delay: 0.3s;\"></div>\n      <div class=\"confetti-piece\" style=\"left: 60%; background: #6EE7B7; animation-delay: 0.5s;\"></div>\n      <div class=\"confetti-piece\" style=\"left: 70%; background: #7C3AED; animation-delay: 0.15s;\"></div>\n      <div class=\"confetti-piece\" style=\"left: 80%; background: #F9A8D4; animation-delay: 0.35s;\"></div>\n      <div class=\"confetti-piece\" style=\"left: 90%; background: #6EE7B7; animation-delay: 0.25s;\"></div>\n    </div>\n\n    <div class=\"status-bar\">\n      <span>9:41</span>\n      <div class=\"status-bar-icons\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/>\n          <rect x=\"4\" y=\"9\" width=\"14\" height=\"6\" rx=\"1\" fill=\"currentColor\"/>\n        </svg>\n      </div>\n    </div>\n\n    <header class=\"app-bar\">\n      <button class=\"back-btn\" aria-label=\"Go back\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n        </svg>\n      </button>\n      <h1 class=\"app-bar-title\">My Pregnancy</h1>\n    </header>\n\n    <main class=\"content\">\n      <section class=\"section\">\n        <div class=\"hero-card\">\n          <div class=\"hero-sparkles\" aria-hidden=\"true\">\n            <svg class=\"sparkle\" style=\"top: 20%; left: 15%;\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"#7C3AED\">\n              <path d=\"M12 0L14.5 9.5L24 12L14.5 14.5L12 24L9.5 14.5L0 12L9.5 9.5L12 0Z\"/>\n            </svg>\n            <svg class=\"sparkle\" style=\"top: 30%; right: 20%; animation-delay: 0.5s;\" width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"#F9A8D4\">\n              <path d=\"M12 0L14.5 9.5L24 12L14.5 14.5L12 24L9.5 14.5L0 12L9.5 9.5L12 0Z\"/>\n            </svg>\n            <svg class=\"sparkle\" style=\"top: 50%; left: 10%; animation-delay: 1s;\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"#6EE7B7\">\n              <path d=\"M12 0L14.5 9.5L24 12L14.5 14.5L12 24L9.5 14.5L0 12L9.5 9.5L12 0Z\"/>\n            </svg>\n            <svg class=\"sparkle\" style=\"top: 15%; right: 30%; animation-delay: 0.3s;\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#7C3AED\">\n              <path d=\"M12 0L14.5 9.5L24 12L14.5 14.5L12 24L9.5 14.5L0 12L9.5 9.5L12 0Z\"/>\n            </svg>\n          </div>\n          <div class=\"week-hero\">\n            <div class=\"week-number\">24</div>\n            <div class=\"week-label\">weeks pregnant</div>\n            <div class=\"fruit-comparison\">\n              <svg class=\"fruit-illustration\" viewBox=\"0 0 80 80\" fill=\"none\">\n                <ellipse cx=\"40\" cy=\"45\" rx=\"32\" ry=\"30\" fill=\"#FBC4E0\"/>\n                <ellipse cx=\"40\" cy=\"45\" rx=\"26\" ry=\"24\" fill=\"#F9A8D4\"/>\n                <ellipse cx=\"35\" cy=\"40\" rx=\"8\" ry=\"6\" fill=\"#fff\" opacity=\"0.3\"/>\n                <path d=\"M40 15C40 15 45 20 50 20C55 20 55 15 55 15\" stroke=\"#6EE7B7\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n                <ellipse cx=\"52\" cy=\"18\" rx=\"6\" ry=\"4\" fill=\"#6EE7B7\" transform=\"rotate(-30 52 18)\"/>\n              </svg>\n              <span class=\"fruit-name\">Papaya</span>\n            </div>\n          </div>\n          <div class=\"page-dots\" aria-label=\"Week navigation indicator\">\n            <span class=\"page-dot\"></span>\n            <span class=\"page-dot\"></span>\n            <span class=\"page-dot active\"></span>\n            <span class=\"page-dot\"></span>\n            <span class=\"page-dot\"></span>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"card\">\n          <h2 class=\"card-title\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/>\n            </svg>\n            Body Changes This Week\n          </h2>\n          <ul class=\"body-changes\">\n            <li>Your uterus is now about the size of a soccer ball</li>\n            <li>You may experience more frequent urination as baby presses on your bladder</li>\n            <li>Leg cramps and swelling may increase</li>\n            <li>Stretch marks may appear on your belly and breasts</li>\n          </ul>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"card\">\n          <h2 class=\"card-title\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n              <path d=\"M12 16v-4M12 8h.01\"/>\n            </svg>\n            Baby's Development\n          </h2>\n          <p class=\"baby-dev-text\">\n            Your baby is now about 11 inches long and weighs around 1.3 pounds. The senses are developing rapidly — your little one can now hear sounds from the outside world. Fingernails are fully formed and baby is starting to develop a sleep pattern.\n          </p>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"card\">\n          <h2 class=\"card-title\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z\"/>\n              <path d=\"M12 8v4l3 3\"/>\n            </svg>\n            Self-Care Tips\n          </h2>\n          <ul class=\"tips-list\">\n            <li>\n              <span class=\"tip-number\">1</span>\n              <span class=\"tip-text\">Stay hydrated with at least 8-10 glasses of water daily</span>\n            </li>\n            <li>\n              <span class=\"tip-number\">2</span>\n              <span class=\"tip-text\">Try sleeping on your left side to improve circulation</span>\n            </li>\n            <li>\n              <span class=\"tip-number\">3</span>\n              <span class=\"tip-text\">Gentle stretching can help with leg cramps and discomfort</span>\n            </li>\n          </ul>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"due-summary\">\n          <div class=\"due-info\">\n            <div class=\"due-label\">Due Date</div>\n     