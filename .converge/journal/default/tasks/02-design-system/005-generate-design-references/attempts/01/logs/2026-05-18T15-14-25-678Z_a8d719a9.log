lor\" stroke-width=\"2\">\n          <circle cx=\"12\" cy=\"8\" r=\"4\"/>\n          <path d=\"M4 20c0-4 4-6 8-6s8 2 8 6\"/>\n        </svg>\n        <span>Profile</span>\n      </button>\n    </nav>\n\n    <div class=\"home-indicator\"></div>\n  </div>\n</body>\n</html>","structuredPatch":[],"originalFile":null,"userModified":false}}
