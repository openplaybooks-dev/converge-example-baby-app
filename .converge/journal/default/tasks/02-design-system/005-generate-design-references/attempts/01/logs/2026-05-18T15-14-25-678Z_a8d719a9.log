0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <circle cx=\"12\" cy=\"12\" r=\"10\"/>\n              <path d=\"M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01\"/>\n            </svg>\n            <span>Log Mood</span>\n          </button>\n          <button class=\"action-btn\" aria-label=\"Log Symptoms\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/>\n            </svg>\n            <span>Log Symptoms</span>\n          </button>\n          <button class=\"action-btn\" aria-label=\"View Education\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M4 19.5A2.5 2.5 0 0 1 6.5 17H20\"/>\n              <path d=\"M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z\"/>\n            </svg>\n            <span>Education</span>\n          </button>\n        </div>\n      </section>\n\n      <section class=\"section\">\n        <div class=\"tip-card\">\n          <div class=\"tip-label\">Weekly Tip</div>\n          <p class=\"tip-text\">Stay hydrated! Aim for 8-10 glasses of water daily. Your body is working hard to support your growing baby.</p>\n        </div>\n      </section>\n    </main>\n\n    <nav class=\"bottom-nav\" role=\"navigation\" aria-label=\"Main navigation\">\n      <button class=\"nav-item active\" aria-current=\"page\" aria-label=\"Home\">\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <path d=\"M12 3L4 9v12h5v-7h6v7h5V9z\"/>\n        </svg>\n        <span>Home</span>\n      </button>\n      <button class=\"nav-item\" aria-label=\"Browse\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <circle cx=\"11\" cy=\"11\" r=\"8\"/>\n          <path d=\"M21 21l-4.35-4.35\"/>\n        </svg>\n        <span>Browse</span>\n      </button>\n      <button class=\"nav-item\" ar