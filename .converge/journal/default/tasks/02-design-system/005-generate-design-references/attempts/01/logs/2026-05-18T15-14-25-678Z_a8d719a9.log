 {\n      font-family: var(--font-family);\n      background: #1E1B2E;\n      min-height: 100vh;\n      display: flex;\n      justify-content: center;\n      align-items: flex-start;\n      padding: 20px 0;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      background: var(--color-background);\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);\n    }\n\n    .status-bar {\n      height: 44px;\n      background: var(--color-background);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 0 24px;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .status-bar-icons {\n      display: flex;\n      gap: 6px;\n      align-items: center;\n    }\n\n    .status-bar-icons svg {\n      width: 18px;\n      height: 18px;\n    }\n\n    .app-bar {\n      height: 56px;\n      display: flex;\n      align-items: center;\n      padding: 0 8px;\n      background: var(--color-background);\n    }\n\n    .back-btn {\n      width: 48px;\n      height: 48px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      border: none;\n      background: none;\n      cursor: pointer;\n      border-radius: 50%;\n      transition: background 200ms ease-out;\n    }\n\n    .back-btn:hover {\n      background: var(--color-border);\n    }\n\n    .back-btn svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-primary);\n    }\n\n    .app-bar-title {\n      flex: 1;\n      font-size: 20px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      text-align: center;\n      margin-right: 48px;\n    }\n\n    .content {\n      padding: 0 16px 100px;\n      overflow-y: auto;\n    }\n\n    .section {\n      margin-bottom: 24px;\n    }\n\n    .card {\n      background: var(--color-white);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .card-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n      margin-bottom: 12px;\n    }\n\n    .emoji-selector {\n      display: flex;\n      justify-content: space-between;\n      gap: 8px;\n    }\n\n    .emoji-btn {\n      width: 56px;\n      height: 56px;\n      border-radius: 50%;\n      border: 2px solid var(--color-border);\n      background: var(--color-surface);\n      font-size: 32px;\n      cursor: pointer;\n      transition: transform 200ms ease-out, border-color 200ms ease-out, background 200ms ease-out;\n    }\n\n    .emoji-btn:hover, .emoji-btn:focus {\n      border-color: var(--color-primary);\n      transform: scale(1.1);\n    }\n\n    .emoji-btn.selected {\n      border-color: var(--color-primary);\n      background: rgba(124, 58, 237, 0.1);\n    }\n\n    .emoji-btn:focus {\n      outline: none;\n      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.2);\n    }\n\n    .note-field {\n      margin-top: 16px;\n    }\n\n    .note-input {\n      width: 100%;\n      min-height: 56px;\n      padding: 12px 16px;\n      border: none;\n      border-radius: 12px;\n      background: var(--color-surface);\n      font-family: var(--font-family);\n      font-size: 14px;\n      color: var(--color-text-primary);\n      resize: none;\n      transition: box-shadow 200ms ease-out;\n    }\n\n    .note-input::placeholder {\n      color: var(--color-text-secondary);\n    }\n\n    .note-input:focus {\n      outline: none;\n      box-shadow: 0 0 0 2px var(--color-primary);\n    }\n\n    .chart-card {\n      background: var(--color-white);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n\n    .chart-header {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      margin-bottom: 16px;\n    }\n\n    .chart-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--color-text-primary);\n    }\n\n    .chart-badge {\n      font-size: 11px;\n      font-weight: 500;\n      padding: 4px 8px;\n      border-radius: 8px;\n      background: var(--color-secondary);\n      opacity: 0.3;\n      color: var(--color-text-primary);\n    }\n\n    .chart-area {\n      height: 120px;\n      position: relative;\n    }\n\n    .chart-svg {\n      width: 100%;\n      height: 100%;\n    }\n\n    .chart-empty {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      height: 120px;\n      color: var(--color-text-secondary);\n    }\n\n    .chart-empty svg {\n      width: 48px;\n      height: 48px;\n      margin-bottom: 8px;\n      opacity: 0.5;\n    }\n\n    .chart-empty span {\n      font-size: 14px;\n    }\n\n    .wellness-tip {\n      background: linear-gradient(135deg, var(--color-tertiary), #34D399);\n      border-radius: var(--radius-card);\n      padding: 16px;\n      color: var(--color-text-primary);\n    }\n\n    .tip-label {\n      font-size: 11px;\n      font-weight: 500;\n      letter-spacing: 0.4pt;\n      text-transform: uppercase;\n      opacity: 0.7;\n      margin-bottom: 4px;\n    }\n\n    .tip-text {\n      font-size: 14px;\n      font-weight: 500;\n      line-height: 20px;\n    }\n\n    .state-indicator {\n      position: absolute;\n      top: 60px;\n      right: 16px;\n      padding: 4px 12px;\n      border-radius: 12px;\n      font-size: 11px;\n      font-weight: 600;\n      text-transform: uppercase;\n      letter-spacing: 0.5pt;\n    }\n\n    .state-indicator.empty {\n      background: var(--color-border);\n      color: var(--color-text-secondary);\n    }\n\n    .state-indicator.filling {\n      background: var(--color-secondary);\n      opacity: 0.3;\n      color: var(--color-text-primary);\n    }\n\n    .state-indicator.complete {\n      background: var(--color-tertiary);\n      color: var(--color-text-primary);\n    }\