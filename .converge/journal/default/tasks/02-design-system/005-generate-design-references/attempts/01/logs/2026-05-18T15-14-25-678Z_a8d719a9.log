    }\n\n    .bottom-nav {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      right: 0;\n      height: 80px;\n      background: var(--color-white);\n      display: flex;\n      justify-content: space-around;\n      align-items: flex-start;\n      padding-top: 8px;\n      border-top: 1px solid var(--color-border);\n    }\n\n    .nav-item {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 4px;\n      padding: 8px 16px;\n      border: none;\n      background: none;\n      cursor: pointer;\n      position: relative;\n    }\n\n    .nav-item.active::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      width: 40px;\n      height: 4px;\n      background: var(--color-primary);\n      border-radius: 2px;\n      opacity: 0.15;\n    }\n\n    .nav-item svg {\n      width: 24px;\n      height: 24px;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active svg {\n      color: var(--color-primary);\n    }\n\n    .nav-item span {\n      font-size: 11px;\n      font-weight: 500;\n      color: var(--color-text-secondary);\n    }\n\n    .nav-item.active span {\n      font-weight: 600;\n      color: var(--color-primary);\n    }\n\n    .home-indicator {\n      position: absolute;\n      bottom: 8px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 134px;\n      height: 5px;\n      background: var(--color-text-primary);\n      border-radius: 3px;\n      opacity: 0.2;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <div class=\"status-bar\">\n      <span>9:41</span>\n      <div class=\"status-bar-icons\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n          <path d=\"M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n          <rect x=\"2\" y=\"7\" width=\"18\" height=\"10\" rx=\"