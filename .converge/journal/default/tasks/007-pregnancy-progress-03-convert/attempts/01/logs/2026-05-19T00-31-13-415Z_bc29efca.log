 0.3),\n236\t              borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n237\t            ),\n238\t            child: Row(\n239\t              mainAxisSize: MainAxisSize.min,\n240\t              children: [\n241\t                Text(\n242\t                  trimester,\n243\t                  style: textTheme.labelLarge?.copyWith(\n244\t                    color: colorScheme.primary,\n245\t                  ),\n246\t                ),\n247\t              ],\n248\t            ),\n249\t          ),\n250\t          const SizedBox(height: AppTheme.spaceXs),\n251\t          Text(\n252\t            '$weeksRemaining weeks to go',\n253\t            style: textTheme.bodyMedium?.copyWith(\n254\t              color: colorScheme.onSurfaceVariant,\n255\t            ),\n256\t          ),\n257\t          const SizedBox(height: AppTheme.spaceXxs),\n258\t          Text(\n259\t            'Due ${dueDate.month}/${dueDate.day}/${dueDate.year}',\n260\t            style: textTheme.labelSmall?.copyWith(\n261\t              color: colorScheme.onSurfaceVariant,\n262\t            ),\n263\t          ),\n264\t        ],\n265\t      ),\n266\t    );\n267\t  }\n268\t}\n269\t\n270\tclass _BodyChangesCard extends StatelessWidget {\n271\t  final int week;\n272\t\n273\t  const _BodyChangesCard({required this.week});\n274\t\n275\t  @override\n276\t  Widget build(BuildContext context) {\n277\t    final theme = Theme.of(context);\n278\t    final colorScheme = theme.colorScheme;\n279\t    final textTheme = theme.textTheme;\n280\t\n281\t    final bodyChanges = _getBodyChanges(week);\n282\t\n283\t    return Container(\n284\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n285\t      decoration: BoxDecoration(\n286\t        color: colorScheme.surface,\n287\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n288\t        boxShadow: [\n289\t          BoxShadow(\n290\t            color: AppTheme.shadow,\n291\t            blurRadius: 24,\n292\t            offset: const Offset(0, 8),\n293\t          ),\n294\t        ],\n295\t      ),\n296\t      child: Column(\n297\t        crossAxisAlignment: CrossAxisAlignment.start,\n298\t        children: [\n299\t          Text(\n300\t            'Body Changes',\n301\t            style: textTheme.titleLarge?.copyWith(\n302\t              color: colorScheme.onSurface,\n303\t            ),\n304\t          ),\n305\t          const SizedBox(height: AppTheme.spaceSm),\n306\t          ...bodyChanges.map((change) => Padding(\n307\t                padding: const EdgeInsets.only(bottom: AppTheme.spaceSm),\n308\t                child: Row(\n309\t                  crossAxisAlignment: CrossAxisAlignment.start,\n310\t                  children: [\n311\t                    Container(\n312\t                      width: 8,\n313\t                      height: 8,\n314\t                      margin: const EdgeInsets.only(top: 6),\n315\t                      decoration: BoxDecoration(\n316\t                        color: colorScheme.tertiary,\n317\t                        shape: BoxShape.circle,\n318\t                      ),\n319\t                    ),\n320\t                    const SizedBox(width: AppTheme.spaceSm),\n321\t                    Expanded(\n322\t                      child: Text(\n323\t                        change,\n324\t                        style: textTheme.bodyMedium?.copyWith(\n325\t                          color: colorScheme.onSurface,\n326\t                        ),\n327\t                      ),\n328\t                    ),\n329\t                  ],\n330\t                ),\n331\t              )),\n332\t        ],\n333\t      ),\n334\t    );\n335\t  }\n336\t\n337\t  List<String> _getBodyChanges(int week) {\n338\t    const changes = {\n339\t      12: [\n340\t        'Your uterus is now about the size of a grapefruit',\n341\t        'You may experience mild cramping or round ligament pain',\n342\t        'Fatigue may continue, but energy often improves this trimester',\n343\t      ],\n344\t      24: [\n345\t        'Your belly is growing noticeably',\n346\t        'You may feel the baby move soon (quickening)',\n347\t        'Leg cramps and swelling may occur',\n348\t      ],\n349\t    };\n350\t    return changes[week] ??\n351\t        [\n352\t          'Your body is adapting to pregnancy',\n353\t          'Hormonal changes may affect your mood',\n354\t          'Stay hydrated and rest when needed',\n355\t        ];\n356\t  }\n357\t}\n358\t\n359\tclass _BabyDevelopmentCard extends StatelessWidget {\n360\t  final int week;\n361\t\n362\t  const _BabyDevelopmentCard({required this.week});\n363\t\n364\t  @override\n365\t  Widget build(BuildContext context) {\n366\t    final theme = Theme.of(context);\n367\t    final colorScheme = theme.colorScheme;\n368\t    final textTheme = theme.textTheme;\n369\t\n370\t    return Container(\n371\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n372\t      decoration: BoxDecoration(\n373\t        color: colorScheme.surface,\n374\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n375\t        boxShadow: [\n376\t          BoxShadow(\n377\t            color: AppTheme.shadow,\n378\t            blurRadius: 24,\n379\t            offset: const Offset(0, 8),\n380\t          ),\n381\t        ],\n382\t      ),\n383\t      child: Column(\n384\t        crossAxisAlignment: CrossAxisAlignment.start,\n385\t        children: [\n386\t          Text(\n387\t            'Baby\\'s Development',\n388\t            style: textTheme.titleLarge?.copyWith(\n389\t              color: colorScheme.onSurface,\n390\t            ),\n391\t          ),\n392\t          const SizedBox(height: AppTheme.spaceSm),\n393\t          Text(\n394\t            _getBabyDevelopment(week),\n395\t            style: textTheme.bodyLarge?.copyWith(\n396\t              color: colorScheme.onSurface,\n397\t            ),\n398\t          ),\n399\t        ],\n400\t      ),\n401\t    );\n402\t  }\n403\t\n404\t  String _getBabyDevelopment(int week) {\n405\t    const developments = {\n406\t      12:\n407\t          'Your baby is now about 2 inches long — the size of a plum! Fingers and toes are fully formed, and tooth buds are appearing beneath the gums. The brain continues to develop rapidly, and your baby may start making small movements you can\\'t feel yet.',\n408\t      24:\n409\t          'Your baby is about 12 inches long — the size of a papaya! The brain is developing rapidly, and the baby can hear your voice. Fat is beginning to accumulate, giving the skin a smoother appearance.',\n410\t    };\n411\t    return developments[week] ??\n412\t        'Your baby is growing and developing. Each week brings new milestones.';\n413\t  }\n414\t}\n415\t\n416\tclass _SelfCareTipsCard extends StatefulWidget {\n417\t  final int week;\n418\t\n419\t  const _SelfCareTipsCard({required this.week});\n420\t\n421\t  @override\n422\t  State<_SelfCareTipsCard> createState() => _SelfCareTipsCardState();\n423\t}\n424\t\n425\tclass _SelfCareTipsCardState extends State<_SelfCareTipsCard> {\n426\t  int _expandedIndex = -1;\n427\t\n428\t  @override\n429\t  Widget build(BuildContext context) {\n430\t    final theme = Theme.of(context);\n431\t    final colorScheme = theme.colorScheme;\n432\t    final textTheme = theme.textTheme;\n433\t\n434\t    final tips = _getSelfCareTips(widget.week);\n435\t\n436\t    return Container(\n437\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n438\t      decoration: BoxDecoration(\n439\t        color: colorScheme.surface,\n440\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n441\t        boxShadow: [\n442\t          BoxShadow(\n443\t            color: AppTheme.shadow,\n444\t            blurRadius: 24,\n445\t            offset: const Offset(0, 8),\n446\t          ),\n447\t        ],\n448\t      ),\n449\t      child: Column(\n450\t        crossAxisAlignment: CrossAxisAlignment.start,\n451\t        children: [\n452\t          Text(\n453\t            'Self-Care Tips',\n454\t            style: textTheme.titleLarge?.copyWith(\n455\t              color: colorScheme.onSurface,\n456\t            ),\n457\t          ),\n458\t          const SizedBox(height: AppTheme.spaceSm),\n459\t          ...List.generate(tips.length, (index) {\n460\t            final tip = tips[index];\n461\t            final isExpanded = _expandedIndex == index;\n462\t            return Padding(\n463\t              padding: const EdgeInsets.only(bottom: AppTheme.spaceSm),\n464\t              child: _ExpandableTipTile(\n465\t                number: index + 1,\n466\t                title: tip['title']!,\n467\t                detail: tip['detail']!,\n468\t                isExpanded: isExpanded,\n469\t                onTap: () {\n470\t                  setState(() {\n471\t                    _expandedIndex = isExpanded ? -1 : index;\n472\t                  });\n473\t                },\n474\t              ),\n475\t            );\n476\t          }),\n477\t        ],\n478\t      ),\n479\t    );\n480\t  }\n481\t\n482\t  List<Map<String, String>> _getSelfCareTips(int week) {\n483\t    const tips = {\n484\t      12: [\n485\t        {\n486\t          'title': 'Stay hydrated',\n487\t          'detail':\n488\t              'Aim for 8-10 glasses of water daily. Staying hydrated helps prevent UTIs and constipation, common during pregnancy.',\n489\t        },\n490\t        {\n491\t          'title': 'Try gentle exercise',\n492\t          'detail':\n493\t              'Walking or prenatal yoga can help with energy levels and prepare your body for labor.',\n494\t        },\n495\t        {\n496\t          'title': 'Schedule your anatomy scan',\n497\t          'detail':\n498\t              'Your 20-week anatomy scan is approaching. This detailed ultrasound checks baby\\'s development and is often covered by insurance.',\n499\t        },\n500\t      ],\n501\t      24: [\n502\t        {\n503\t          'title': 'Practice good posture',\n504\t          'detail':\n505\t              'As your belly grows, focus on