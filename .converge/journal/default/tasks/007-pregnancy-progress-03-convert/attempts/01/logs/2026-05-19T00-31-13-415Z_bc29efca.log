velopmentCard(week: week),\n119\t          const SizedBox(height: AppTheme.spaceMd),\n120\t          _SelfCareTipsCard(week: week),\n121\t        ],\n122\t      ),\n123\t    );\n124\t  }\n125\t\n126\t  String _getTrimester(int week) {\n127\t    if (week <= 13) return 'First Trimester';\n128\t    if (week <= 26) return 'Second Trimester';\n129\t    return 'Third Trimester';\n130\t  }\n131\t\n132\t  String _getFruitEmoji(int week) {\n133\t    const fruits = [\n134\t      ' poppy seed', // 4\n135\t      ' sesame seed', // 5\n136\t      '🫐 blueberry', // 6\n137\t      '🫐 blueberry', // 7\n138\t      '🫐 blueberry', // 8\n139\t      '🫐 blueberry', // 9\n140\t      '🫐 blueberry', // 10\n141\t      '🍒 cherry', // 11\n142\t      '🍒 cherry', // 12\n143\t      '🍒 cherry', // 12\n144\t      '🍅 tomato', // 12\n145\t    ];\n146\t    if (week < 4) return '🌱 seed';\n147\t    if (week > 12) return '🍅 tomato';\n148\t    return fruits[week - 4];\n149\t  }\n150\t\n151\t  String _getFruitSize(int week) {\n152\t    if (week <= 4) return 'poppy seed';\n153\t    if (week <= 6) return 'sesame seed';\n154\t    if (week <= 8) return 'blueberry';\n155\t    if (week <= 11) return 'cherry';\n156\t    if (week <= 13) return 'lime';\n157\t    if (week <= 16) return 'avocado';\n158\t    if (week <= 20) return 'banana';\n159\t    if (week <= 24) return 'papaya';\n160\t    if (week <= 28) return 'cucumber';\n161\t    if (week <= 32) return 'butternut squash';\n162\t    if (week <= 36) return 'honeydew';\n163\t    return 'watermelon';\n164\t  }\n165\t}\n166\t\n167\tclass _WeekHeroCard extends StatelessWidget {\n168\t  final int week;\n169\t  final String trimester;\n170\t  final int weeksRemaining;\n171\t  final DateTime dueDate;\n172\t  final String fruitEmoji;\n173\t\n174\t  const _WeekHeroCard({\n175\t    required this.week,\n176\t    required this.trimester,\n177\t    required this.weeksRemaining,\n178\t    required this.dueDate,\n179\t    required this.fruitEmoji,\n180\t  });\n181\t\n182\t  @over