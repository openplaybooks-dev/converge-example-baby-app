uired this.child,\n376\t  });\n377\t\n378\t  @override\n379\t  State<_SettingsCard> createState() => _SettingsCardState();\n380\t}\n381\t\n382\tclass _SettingsCardState extends State<_SettingsCard> {\n383\t  bool _isPressed = false;\n384\t\n385\t  @override\n386\t  Widget build(BuildContext context) {\n387\t    return GestureDetector(\n388\t      onTapDown: (_) => setState(() => _isPressed = true),\n389\t      onTapUp: (_) => setState(() => _isPressed = false),\n390\t      onTapCancel: () => setState(() => _isPressed = false),\n391\t      child: AnimatedScale(\n392\t        scale: _isPressed ? 0.98 : 1.0,\n393\t        duration: const Duration(milliseconds: 200),\n394\t        curve: Curves.easeOut,\n395\t        child: Container(\n396\t          width: double.infinity,\n397\t          padding: const EdgeInsets.all(AppTheme.spaceMd),\n398\t          decoration: BoxDecoration(\n399\t            color: widget.colorScheme.surface,\n400\t            borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n401\t            boxShadow: const [\n402\t              BoxShadow(\n403\t                color: AppTheme.shadow,\n404\t                blurRadius: 8,\n405\t                offset: Offset(0, 2),\n406\t              ),\n407\t            ],\n408\t          ),\n409\t          child: widget.child,\n410\t        ),\n411\t      ),\n412\t    );\n413\t  }\n414\t}\n415\t\n416\tclass _ListItemRow extends StatelessWidget {\n417\t  final ColorScheme colorScheme;\n418\t  final TextTheme textTheme;\n419\t  final IconData icon;\n420\t  final Color iconColor;\n421\t  final Color iconBackgroundColor;\n422\t  final String title;\n423\t  final String description;\n424\t  final bool showChevron;\n425\t  final VoidCallback onTap;\n426\t\n427\t  const _ListItemRow({\n428\t    required this.colorScheme,\n429\t    required this.textTheme,\n430\t    required this.icon,\n431\t    required this.iconColor,\n432\t    required this.iconBackgroundColor,\n433\t    required this.title,\n434\t    requir