uired this.child,\n376\t  });\n377\t\n378\t  @override\n379\t  State<_SettingsCard> createState() => _SettingsCardState();\n380\t}\n381\t\n382\tclass _SettingsCardState extends State<_SettingsCard> {\n383\t  bool _isPressed = false;\n384\t\n385\t  @override\n386\t  Widget build(BuildContext context) {\n387\t    return GestureDetector(\n388\t      onTapDown: (_) => setState(() => _isPressed = true),\n389\t      onTapUp: (_) => setState(() => _isPressed = false),\n390\t      onTapCancel: () => setState(() => _isPressed = false),\n391\t      child: AnimatedScale(\n392\t        scale: _isPressed ? 0.98 : 1.0,\n393\t        duration: const Duration(milliseconds: 200),\n394\t        curve: Curves.easeOut,\n395\t        child: Container(\n396\t          width: double.infinity,\n397\t          padding: const EdgeInsets.all(AppTheme.spaceMd),\n398\t          decoration: BoxDecoration(\n399\t            color: widget.colorScheme.surface,\n400\t            borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n401\t            boxShadow: const [\n402\t              BoxShadow(\n403\t                color: AppTheme.shadow,\n404\t                blurRadius: 8,\n405\t                offset: Offset(0, 2),\n406\t              ),\n407\t            ],\n408\t          ),\n409\t          child: widget.child,\n410\t        ),\n411\t      ),\n412\t    );\n413\t  }\n414\t}\n415\t\n416\tclass _ListItemRow extends StatelessWidget {\n417\t  final ColorScheme colorScheme;\n418\t  final TextTheme textTheme;\n419\t  final IconData icon;\n420\t  final Color iconColor;\n421\t  final Color iconBackgroundColor;\n422\t  final String title;\n423\t  final String description;\n424\t  final bool showChevron;\n425\t  final VoidCallback onTap;\n426\t\n427\t  const _ListItemRow({\n428\t    required this.colorScheme,\n429\t    required this.textTheme,\n430\t    required this.icon,\n431\t    required this.iconColor,\n432\t    required this.iconBackgroundColor,\n433\t    required this.title,\n434\t    required this.description,\n435\t    this.showChevron = false,\n436\t    required this.onTap,\n437\t  });\n438\t\n439\t  @override\n440\t  Widget build(BuildContext context) {\n441\t    return _InkWellScale(\n442\t      onTap: onTap,\n443\t      child: Container(\n444\t        padding: const EdgeInsets.symmetric(vertical: AppTheme.spaceXs),\n445\t        decoration: BoxDecoration(\n446\t          border: Border(\n447\t            bottom: BorderSide(\n448\t              color: colorScheme.outline,\n449\t            ),\n450\t          ),\n451\t        ),\n452\t        child: Row(\n453\t          children: [\n454\t            Container(\n455\t              width: 40,\n456\t              height: 40,\n457\t              decoration: BoxDecoration(\n458\t                color: iconBackgroundColor,\n459\t                shape: BoxShape.circle,\n460\t              ),\n461\t              child: Icon(\n462\t                icon,\n463\t                size: 20,\n464\t                color: iconColor,\n465\t              ),\n466\t            ),\n467\t            const SizedBox(width: AppTheme.spaceSm + 4),\n468\t            Expanded(\n469\t              child: Column(\n470\t                crossAxisAlignment: CrossAxisAlignment.start,\n471\t                mainAxisSize: MainAxisSize.min,\n472\t                children: [\n473\t                  Text(\n474\t                    title,\n475\t                    style: textTheme.titleSmall?.copyWith(\n476\t                      color: colorScheme.onSurface,\n477\t                    ),\n478\t                  ),\n479\t                  const SizedBox(height: 2),\n480\t                  Text(\n481\t                    description,\n482\t                    style: textTheme.bodyMedium?.copyWith(\n483\t                      color: colorScheme.onSurfaceVariant,\n484\t                    ),\n485\t                  ),\n486\t                ],\n487\t              ),\n488\t            ),\n489\t            if (showChevron)\n490\t              Icon(\n491\t                Icons.chevron_right,\n492\t                size: 20,\n493\t                color: colorScheme.onSurfaceVariant,\n494\t              ),\n495\t          ],\n496\t        ),\n497\t      ),\n498\t    );\n499\t  }\n500\t}\n501\t\n502\tclass _SwitchRow extends StatelessWidget {\n503\t  final ColorScheme colorScheme;\n504\t  final TextTheme textTheme;\n505\t  final String title;\n506\t  final String description;\n507\t  final bool value;\n508\t  final ValueChanged<bool> onChanged;\n509\t  final bool showDivider;\n510\t\n511\t  const _SwitchRow({\n512\t    required this.colorScheme,\n513\t    required this.textTheme,\n514\t    required this.title,\n515\t    required this.description,\n516\t    required this.value,\n517\t    required this.onChanged,\n518\t    this.showDivider = true,\n519\t  });\n520\t\n521\t  @override\n522\t  Widget build(BuildContext context) {\n523\t    return Container(\n524\t      padding: const EdgeInsets.symmetric(vertical: AppTheme.spaceXs),\n525\t      decoration: showDivider\n526\t          ? BoxDecoration(\n527\t              border: Border(\n528\t                bottom: BorderSide(\n529\t                  color: colorScheme.outline,\n530\t                ),\n531\t              ),\n532\t            )\n533\t          : null,\n534\t      child: Row(\n535\t        children: [\n536\t          Expanded(\n537\t            child: Column(\n538\t              crossAxisAlignment: CrossAxisAlignment.start,\n539\t              mainAxisSize: MainAxisSize.min,\n540\t              children: [\n541\t                Text(\n542\t                  title,\n543\t                  style: textTheme.titleSmall?.copyWith(\n544\t                    color: colorScheme.onSurface,\n545\t                  ),\n546\t                ),\n547\t                const SizedBox(height: 2),\n548\t                Text(\n549\t                  description,\n550\t                  style: textTheme.bodyMedium?.copyWith(\n551\t                    color: colorScheme.o