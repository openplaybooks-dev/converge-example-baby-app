BackgroundColor,\n616\t                shape: BoxShape.circle,\n617\t              ),\n618\t              child: Icon(\n619\t                icon,\n620\t                size: 20,\n621\t                color: iconColor,\n622\t              ),\n623\t            ),\n624\t            const SizedBox(width: AppTheme.spaceSm + 4),\n625\t            Expanded(\n626\t              child: Column(\n627\t                crossAxisAlignment: CrossAxisAlignment.start,\n628\t                mainAxisSize: MainAxisSize.min,\n629\t                children: [\n630\t                  Text(\n631\t                    label,\n632\t                    style: textTheme.titleSmall?.copyWith(\n633\t                      color: isDestructive\n634\t                          ? colorScheme.error\n635\t                          : colorScheme.onSurface,\n636\t                    ),\n637\t                  ),\n638\t                  const SizedBox(height: 2),\n639\t                  Text(\n640\t                    description,\n641\t                    style: textTheme.bodyMedium?.copyWith(\n642\t                      color: colorScheme.onSurfaceVariant,\n643\t                    ),\n644\t                  ),\n645\t                ],\n646\t              ),\n647\t            ),\n648\t            Icon(\n649\t              Icons.chevron_right,\n650\t              size: 20,\n651\t              color: colorScheme.onSurfaceVariant,\n652\t            ),\n653\t          ],\n654\t        ),\n655\t      ),\n656\t    );\n657\t  }\n658\t}\n659\t\n660\tclass _AboutRow extends StatelessWidget {\n661\t  final ColorScheme colorScheme;\n662\t  final TextTheme textTheme;\n663\t  final String label;\n664\t  final String value;\n665\t\n666\t  const _AboutRow({\n667\t    required this.colorScheme,\n668\t    required this.textTheme,\n669\t    required this.label,\n670\t    required this.value,\n671\t  });\n672\t\n673\t  @override\n674\t  Widget build(BuildContext context) {\n675\t    return Container(\n676\t      padding: 