9	seed:
10	  mode: cli
11	tags:
12	  - split
13	  - screen-article-reader
14	vars:
15	  screenId: article-reader
16	  title: Article Reader
17	  screenPath: lib/screens/article_reader/article_reader_screen.dart
18	  widgetsJsonPath: .stitch/designs/article-reader/widgets.jsonl
19	  localWidgetsDir: lib/screens/article_reader/_widgets
20	---
21	
22	# Split: Article Reader
23	
24	Extract each widget identified in `.stitch/designs/article-reader/widgets.jsonl` into its own file under `lib/screens/article_reader/_widgets/` — one spawn per widget.
25	
26	```bash
27	TEMPLATES=".converge/playbooks/default/templates"
28	WIDGETS=".stitch/designs/article-reader/widgets.jsonl"
29	LOCAL_DIR="lib/screens/article_reader/_widgets"
30	SCREEN_PATH="lib/screens/article_reader/article_reader_screen.dart"
31	SID="article-reader"
32	TITLE="Article Reader"
33	
34	[ -f "${WIDGETS}" ] || exit 0
35	
36	I=0
37	while IFS= read -r W; do
38	  [ -z "${W}" ] && continue
39	  I=$((I + 1))
40	  P=$(printf '%03d' "${I}")
41	  WID=$(echo "${W}"      | jq -r '.id // .name')
42	  WNAME=$(echo "${W}"    | jq -r '.name // .id')
43	  WIDGET_FILE="${LOCAL_DIR}/${WNAME}.dart"
44	  converge spawn template \
45	    --path "${TEMPLATES}/screen-widget-split/TASK.md" \
46	    --id "${SID}-split-${P}-${WID}" \
47	    --var "screenId=${SID}" \
48	    --var "screenTitle=${TITLE}" \
49	    --var "screenPath=${SCREEN_PATH}" \
50	    --var "widgetId=${WID}" \
51	    --var "widgetName=${WNAME}" \
52	    --var "widgetFile=${WIDGET_FILE}"
53	done < "${WIDGETS}"
54	```
55	
56	If the widgets file is missing or empty, exit with no spawns.
57	
