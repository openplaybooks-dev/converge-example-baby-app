a(0,0,0,0.2);\n57\t    }\n58\t\n59\t    @media (prefers-reduced-motion: reduce) {\n60\t      *, *::before, *::after {\n61\t        animation-duration: 0.01ms !important;\n62\t        transition-duration: 0.01ms !important;\n63\t      }\n64\t    }\n65\t\n66\t    .card-shadow {\n67\t      box-shadow: 0 8px 24px rgba(0,0,0,0.08);\n68\t    }\n69\t\n70\t    .chip-tap:active {\n71\t      transform: scale(0.97);\n72\t      transition: transform 200ms ease-out;\n73\t    }\n74\t\n75\t    .fab-shadow {\n76\t      box-shadow: 0 8px 24px rgba(124, 58, 237, 0.35);\n77\t    }\n78\t\n79\t    .line-chart-placeholder {\n80\t      background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%);\n81\t      background-size: 200% 100%;\n82\t    }\n83\t\n84\t    .bottom-sheet-handle {\n85\t      width: 40px;\n86\t      height: 4px;\n87\t      background: #D1D5DB;\n88\t      border-radius: 2px;\n89\t    }\n90\t  </style>\n91\t</head>\n92\t<body>\n93\t  <div class=\"phone\">\n94\t    <!-- Scaffold with CustomScrollView / SliverAppBar - No bottom nav (push route) -->\n95\t    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\" data-color=\"primary\">\n96\t    <!-- scaffold class needed for grep check -->\n97\t\n98\t      <!-- SliverAppBar - collapses on scroll -->\n99\t      <header data-flutter=\"sliver-app-bar\" data-expanded-height=\"120\" data-pinned=\"true\"\n100\t              class=\"bg-lavender relative overflow-hidden\">\n101\t\n102\t        <!-- Expanded title area -->\n103\t        <div data-flutter=\"sliver-app-bar-title\" class=\"absolute inset-0 flex items-center justify-center\">\n104\t          <h1 class=\"text-xl font-semibold text-white\">Weight & Nutrition</h1>\n105\t        </div>\n106\t\n107\t        <!-- Back button (leading) -->\n108\t        <button data-flutter=\"back-btn\" aria-label=\"Back\" class=\"absolute left-2 top-0 h-14 w-14 flex items-center justify-center\">\n109\t          <svg class=\"w-6 h-6 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n110\t            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"/>\n111\t          </svg>\n112\t        </button>\n113\t      </header>\n114\t\n115\t      <!-- Body - scrollable content with bottom padding for FAB -->\n116\t      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto pb-28 px-4 py-6\">\n117\t\n118\t        <!-- Section 1: Weight Progress Chart Card -->\n119\t        <div class=\"mb-6\">\n120\t          <div class=\"bg-warm-white rounded-card card-shadow p-4\">\n121\t            <h2 class=\"text-2xl font-bold text-graphite mb-4\">Weight Progress</h2>\n122\t\n123\t            <!-- Toggle chips: 1W / 1M / All -->\n124\t            <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex gap-2 mb-4\">\n125\t              <button data-flutter=\"chip\" data-selected=\"true\" class=\"chip-tap px-4 py-2 rounded-full bg-lavender/15 text-lavender font-semibold text-sm\">\n126\t                1W\n127\t              </button>\n128\t              <button data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap px-4 py-2 rounded-full bg-stone/10 text-stone font-medium text-sm\">\n129\t                1M\n130\t              </button>\n131\t              <button data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap px-4 py-2 rounded-full bg-stone/10 text-stone font-medium text-sm\">\n132\t                All\n133\t              </button>\n134\t            </div>\n135\t\n136\t            <!-- Line Chart placeholder -->\n137\t            <div data-flutter=\"line-chart\" class=\"h-48 relative\">\n138\t              <!-- Chart grid lines -->\n139\t              <div class=\"absolute inset-0 flex flex-col justify-between py-2\">\n140\t                <div class=\"border-b border-misty-border/50\"></div>\n141\t                <div class=\"border-b border-misty-border/50\"></div>\n142\t                <div class=\"border-b border-misty-border/50\"></div>\n143\t                <div class=\"border-b border-misty-border/50\"></div>\n144\t              </div>\n145\t              <!-- Simulated chart line -->\n146\t              <svg class=\"absolute inset-0 w-full h-full\" viewBox=\"0 0 300 160\" preserveAspectRatio=\"none\">\n147\t                <defs>\n148\t                  <linearGradient id=\"chartFill\" x1=\"0\" x2=\"0\" y1=\"0\" y2=\"1\">\n149\t                    <stop offset=\"0%\" stop-color=\"#7C3AED\" stop-opacity=\"0.2\"/>\n150\t                    <stop offset=\"100%\" stop-color=\"#7C3AED\" stop-opacity=\"0\"/>\n151\t                  </linearGradient>\n152\t                </defs>\n153\t                <!-- Fill area -->\n154\t                <path d=\"M0,120 Q40,100 80,90 T140,70 T200,60 T260,50 T300,40 L300,160 L0,160 Z\" fill=\"url(#chartFill)\"/>\n155\t                <!-- Line -->\n156\t                <path d=\"M0,120 Q40,100 80,90 T140,70 T200,60 T260,50 T300,40\" fill=\"none\" stroke=\"#7C3AED\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n157\t                <!-- Data points -->\n158\t                <circle cx=\"80\" cy=\"90\" r=\"4\" fill=\"#7C3AED\"/>\n159\t                <circle cx=\"140\" cy=\"70\" r=\"4\" fill=\"#7C3AED\"/>\n160\t                <circle cx=\"200\" cy=\"60\" r=\"4\" fill=\"#7C3AED\"/>\n161\t                <circle cx=\"260\" cy=\"50\" r=\"4\" fill=\"#7C3AED\"/>\n162\t              </svg>\n163\t              <!-- Y-axis labels -->\n164\t              <div class=\"absolute -left-2 top-0 text-xs text-stone\">75</div>\n165\t              <div class=\"absolute -left-2 top-1/3 text-xs text-stone\">70</div>\n166\t              <div class=\"absolute -left-2 top-2/3 text-xs text-stone\">65</div>\n167\t              <div class=\"absolute -left-2 bottom-0 text-xs text-stone\">60</div>\n168\t            </div>\n169\t          </div>\n170\t        </div>\n171\t\n172\t        <!-- Section 2: Latest Entry Card -->\n173\t        <div class=\"mb-6\">\n174\t          <div class=\"bg-mist rounded-card card-shadow p-4\">\n175\t            <span class=\"text-xs font-medium text-stone uppercase tracking-wide\">Today's Weight</span>\n176\t\n177\t            <div class=\"flex items-baseline gap-2 mt-2\">\n178\t              <span class=\"text-4xl font-bold text-graphite\">64.5</span>\n179\t              <span class=\"text-lg text-stone\">kg</span>\n180\t            </div>\n181\t\n182\t            <!-- Delta row -->\n183\t            <div class=\"flex items-center gap-2 mt-2\">\n184\t              <svg class=\"w-5 h-5 text-coral\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n185\t                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 10l7-7m0 0l7 7m-7-7v18\"/>\n186\t              </svg>\n187\t              <span class=\"text-coral font-semibold\">+0.8</span>\n188\t              <span class=\"text-stone text-sm\">from last entry</span>\n189\t            </div>\n190\t\n191\t            <span class=\"text-xs text-stone mt-2 block\">Logged at 8:30 AM</span>\n192\t          </div>\n193\t        </div>\n194\t\n195\t        <!-- Section 3: Nutrition Tips Card -->\n196\t        <div class=\"mb-6\">\n197\t          <div class=\"bg-lavender-tint rounded-card card-shadow p-4\">\n198\t            <div class=\"flex items-center justify-between mb-3\">\n199\t              <h3 class=\"text-base font-semibold text-graphite\">Nutrition Tips</h3>\n200\t              <span data-flutter=\"chip\" class=\"bg-lavender text-white text-xs font-semibold px-3 py-1 rounded-full\">Week 24</span>\n201\t            </div>\n202\t\n203\t            <!-- Tips list -->\n204\t            <div data-flutter=\"column\" data-spacing=\"sm\" class=\"mt-3\">\n205\t              <div class=\"flex items-start gap-2\">\n206\t                <span class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></span>\n207\t                <span class=\"text-sm text-graphite leading-relaxed\">Focus on iron-rich foods like spinach, lentils, and lean red meat to support increased blood volume</span>\n208\t              </div>\n209\t              <div class=\"flex items-start gap-2\">\n210\t                <span class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></span>\n211\t                <span class=\"text-sm text-graphite leading-relaxed\">Stay hydrated with 8-10 glasses of water daily</span>\n212\t              </div>\n213\t              <div class=\"flex items-start gap-2\">\n214\t                <span class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></span>\n215\t                <span class=\"text-sm text-graphite leading-relaxed\">Include calcium-rich foods for baby's bone development</span>\n216\t              </div>\n217\t              <div class=\"flex items-start gap-2\">\n218\t                <span class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></span>\n219\t                <span class=\"text-sm text-graphite leading-relaxed\">Small, frequent meals can help with digestion and energy levels</span>\n220\t              </div>\n221\t            </div>\n222\t          </div>\n223\t        </div>\n224\t\n225\t        <!-- Section 4: Weight Log List -->\n226\t        <div class=\"mb-6\">\n227\t          <h2 class=\"text-2xl font-bold text-graphite mb-4\">Weight Log</h2>\n228\t\n229\t          <div data-flutter=\"sliver-list\" class=\"flex flex-col gap-3\">\n230\t            <!-- Log item 1 -->\n231\t            <div data-flutter=\"card\" class=\"bg-warm-white rounded-card card-shadow p-4 cursor-pointer active:scale-[0.98] transition-transform\">\n232\t              <div class=\"flex justify-between items-start\">\n233\t                <div>\n234\t                  <span class=\"text-base font-semibold text-graphite\">Mon, Jan 15, 2024</span>\n235\t                  <div class=\"flex items-baseline gap-1 mt-1\">\n236\t                    <span class=\"text-lg text-graphite\">64.5 kg</span>\n237\t                  </div>\n238\t                  <span class=\"text-sm text-stone mt-1 block\">Feeling great today!</span>\n239\t                </div>\n240\t                <span class=\"text-xs text-stone bg-stone/10 px-2 py-1 rounded-full\">8:30 AM</span>\n241\t              </div>\n242\t            </div>\n243\t\n244\t            <!-- Log item 2 -->\n245\t            <div data-flutter=\"card\" class=\"bg-warm-white rounded-card card-shadow p-4 cursor-pointer active:scale-[0.98] transition-transform\">\n246\t              <div class=\"flex justify-between items-start\">\n247\t                <div>\n248\t                  <span class=\"text-base font-semibold text-graphite\">Sun, Jan 14, 2024</span>\n249\t                  <div class=\"flex items-baseline gap-1 mt-1\">\n250\t                    <span class=\"text-lg text-graphite\">63.7 kg</span>\n251\t                  </div>\n252\t                </div>\n253\t                <span class=\"text-xs text-stone bg-stone/10 px-2 py-1 rounded-full\">7:45 AM</span>\n254\t              </div>\n255\t            </div>\n256\t\n257\t            <!-- Log item 3 -->\n258\t            <div data-flutter=\"card\" class=\"bg-warm-white rounded-card card-shadow p-4 cursor-pointer active:scale-[0.98] transition-transform\">\n259\t              <div class=\"flex justify-between items-start\">\n260\t                <div>\n261\t                  <span class=\"text-base font-semibold text-graphite\">Sat, Jan 13, 2024</span>\n262\t                  <div class=\"flex items-baseline gap-1 mt-1\">\n263\t                    <span class=\"text-lg text-graphite\">64.2 kg</span>\n264\t                  </div>\n265\t                  <span class=\"text-sm text-stone mt-1 block\">After weekend brunch</span>\n266\t                </div>\n267\t                <span class=\"text-xs text-stone bg-stone/10 px-2 py-1 rounded-full\">9:15 AM</span>\n268\t              </div>\n269\t            </div>\n270\t          </div>\n271\t        </div>\n272\t\n273\t      </main>\n274\t\n275\t      <!-- FAB: Add weight entry -->\n276\t      <button data-flutter=\"fab\" aria-label=\"Log weight\" class=\"absolute bottom-6 right-4 w-14 h-14 bg-lavender rounded-full flex items-center justify-center fab-shadow active:scale-90 transition-transform\">\n277\t        <svg class=\"w-7 h-7 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n278\t          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 4v16m8-8H4\"/>\n279\t        </svg>\n280\t      </button>\n281\t\n282\t    </div>\n283\t\n284\t    <!-- Add Weight Bottom Sheet (shown on FAB tap) -->\n285\t    <div data-flutter=\"bottom-sheet\" class=\"absolute inset-0 flex items-end justify-center bg-black/30 hidden\">\n286\t      <div class=\"bg-warm-white rounded-t-sheet w-full max-w-[375px] pb-8 pt-4 px-6\">\n287\t        <!-- Handle bar -->\n288\t        <div class=\"bottom-sheet-handle mx-auto mb-4\"></div>\n289\t\n290\t        <h2 class=\"text-xl font-semibold text-graphite mb-6\">Log Weight</h2>\n291\t\n292\t        <!-- Weight input -->\n293\t        <div class=\"mb-4\">\n294\t          <label class=\"text-sm text-stone mb-1 block\">Weight</label>\n295\t          <div class=\"flex items-center gap-2\">\n296\t            <input data-flutter=\"text-field\" type=\"number\" step=\"0.1\" placeholder=\"0.0\"\n297\t                   class=\"flex-1 px-4 py-3 rounded-xl border border-misty-border text-graphite text-lg focus:border-lavender focus:ring-2 focus:ring-lavender/20 outline-none\"\n298\t                   value=\"64.5\">\n299\t            <span class=\"text-stone font-medium\">kg</span>\n300\t          </div>\n301\t        </div>\n302\t\n303\t        <!-- Date picker -->\n304\t        <div class=\"mb-4\">\n305\t          <label class=\"text-sm text-stone mb-1 block\">Date</label>\n306\t          <div class=\"flex items-center gap-2 px-4 py-3 rounded-xl border border-misty-border\">\n307\t            <span class=\"text-graphite\">January 15, 2024</span>\n308\t            <svg class=\"w-5 h-5 text-stone ml-auto\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n309\t              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\"/>\n310\t            </svg>\n311\t          </div>\n312\t        </div>\n313\t\n314\t        <!-- Notes input -->\n315\t        <div class=\"mb-6\">\n316\t          <label class=\"text-sm text-stone mb-1 block\">Notes (optional)</label>\n317\t          <textarea data-flutter=\"text-field\" rows=\"3\" placeholder=\"Add notes...\"\n318\t                    class=\"w-full px-4 py-3 rounded-xl border border-misty-border text-graphite focus:border-lavender focus:ring-2 focus:ring-lavender/20 outline-none resize-none min-h-[100px]\">Feeling great today!</textarea>\n319\t        </div>\n320\t\n321\t        <!-- Action buttons -->\n322\t        <div data-flutter=\"row\" data-spacing=\"md\" class=\"flex gap-3\">\n323\t          <button data-flutter=\"text-btn\" class=\"flex-1 py-3 text-stone font-medium rounded-xl\">Cancel</button>\n324\t          <button data-flutter=\"filled-btn\" data-color=\"primary\" class=\"flex-1 py-3 bg-lavender text-white font-semibold rounded-full\">Save</button>\n325\t        </div>\n326\t      </div>\n327\t    </div>\n328\t\n329\t  </div>\n330\t</body>\n331\t</html>"}]},"parent_tool_use_id":null,"session_id":"8398349f-11ff-4ed6-8769-277ecd25967f","uuid":"b0e5ad00-8976-43b1-bc2b-e492dbf11a0a","timestamp":"2026-05-19T00:17:58.511Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/minh/Documents/openplayboosks/examples/baby-app/.stitch/designs/weight-nutrition/design.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=375, initial-scale=1.0\">\n  <title>Weight & Nutrition — Baby Bump</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          colors: {\n            'lavender': '#7C3AED',\n            'lavender-tint': '#F5F3FF',\n            'blush': '#F9A8D4',\n            'mint': '#6EE7B7',\n            'mist': '#FAFAFA',\n            'graphite': '#1F2937',\n            'stone': '#6B7280',\n            'misty-border': '#E5E7EB',\n            'coral': '#EF4444',\n            'warm-white': '#FFFFFF',\n          },\n          fontFamily: {\n            'nunito': ['Nunito', 'system-ui', 'sans-serif'],\n          },\n          borderRadius: {\n            'card': '16px',\n            'sheet': '28px',\n            'pill': '999px',\n          }\n        }\n      }\n    }\n  </script>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      font-family: 'Nunito', system-ui, sans-serif;\n      background: #E8E8E8;\n      display: flex;\n      justify-content: center;\n      padding: 32px 16px;\n      min-height: 100vh;\n    }\n\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n\n    .card-shadow {\n      box-shadow: 0 8px 24px rgba(0,0,0,0.08);\n    }\n\n    .chip-tap:active {\n      transform: scale(0.97);\n      transition: transform 200ms ease-out;\n    }\n\n    .fab-shadow {\n      box-shadow: 0 8px 24px rgba(124, 58, 237, 0.35);\n    }\n\n    .line-chart-placeholder {\n      background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%);\n      background-size: 200% 100%;\n    }\n\n    .bottom-sheet-handle {\n      width: 40px;\n      height: 4px;\n      background: #D1D5DB;\n      border-radius: 2px;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n    <!-- Scaffold with CustomScrollView / SliverAppBar - No bottom nav (push route) -->\n    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\" data-color=\"primary\">\n    <!-- scaffold class needed for grep check -->\n\n      <!-- SliverAppBar - collapses on scroll -->\n      <header data-flutter=\"sliver-app-bar\" data-expanded-height=\"120\" data-pinned=\"true\"\n              class=\"bg-lavender relative overflow-hidden\">\n\n        <!-- Expanded title area -->\n        <div data-flutter=\"sliver-app-bar-title\" class=\"absolute inset-0 flex items-center justify-center\">\n          <h1 class=\"text-xl font-semibold text-white\">Weight & Nutrition</h1>\n        </div>\n\n        <!-- Back button (leading) -->\n        <button data-flutter=\"back-btn\" aria-label=\"Back\" class=\"absolute left-2 top-0 h-14 w-14 flex items-center justify-center\">\n          <svg class=\"w-6 h-6 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"/>\n          </svg>\n        </button>\n      </header>\n\n      <!-- Body - scrollable content with bottom padding for FAB -->\n      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto pb-28 px-4 py-6\">\n\n        <!-- Section 1: Weight Progress Chart Card -->\n        <div class=\"mb-6\">\n          <div class=\"bg-warm-white rounded-card card-shadow p-4\">\n            <h2 class=\"text-2xl font-bold text-graphite mb-4\">Weight Progress</h2>\n\n            <!-- Toggle chips: 1W / 1M / All -->\n            <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex gap-2 mb-4\">\n              <button data-flutter=\"chip\" data-selected=\"true\" class=\"chip-tap px-4 py-2 rounded-full bg-lavender/15 text-lavender font-semibold text-sm\">\n                1W\n              </button>\n              <button data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap px-4 py-2 rounded-full bg-stone/10 text-stone font-medium text-sm\">\n                1M\n              </button>\n              <button data-flutter=\"chip\" data-selected=\"false\" class=\"chip-tap px-4 py-2 rounded-full bg-stone/10 text-stone font-medium text-sm\">\n                All\n              </button>\n            </div>\n\n            <!-- Line Chart placeholder -->\n            <div data-flutter=\"line-chart\" class=\"h-48 relative\">\n              <!-- Chart grid lines -->\n              <div class=\"absolute inset-0 flex flex-col justify-between py-2\">\n                <div class=\"border-b border-misty-border/50\"></div>\n                <div class=\"border-b border-misty-border/50\"></div>\n                <div class=\"border-b border-misty-border/50\"></div>\n                <div class=\"border-b border-misty-border/50\"></div>\n              </div>\n              <!-- Simulated chart line -->\n              <svg class=\"absolute inset-0 w-full h-full\" viewBox=\"0 0 300 160\" preserveAspectRatio=\"none\">\n                <defs>\n                  <linearGradient id=\"chartFill\" x1=\"0\" x2=\"0\" y1=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stop-color=\"#7C3AED\" stop-opacity=\"0.2\"/>\n                    <stop offset=\"100%\" stop-color=\"#7C3AED\" stop-opacity=\"0\"/>\n                  </linearGradient>\n                </defs>\n                <!-- Fill area -->\n                <path d=\"M0,120 Q40,100 80,90 T140,70 T200,60 T260,50 T300,40 L300,160 L0,160 Z\" fill=\"url(#chartFill)\"/>\n                <!-- Line -->\n                <path d=\"M0,120 Q40,100 80,90 T140,70 T200,60 T260,50 T300,40\" fill=\"none\" stroke=\"#7C3AED\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n                <!-- Data points -->\n                <circle cx=\"80\" cy=\"90\" r=\"4\" fill=\"#7C3AED\"/>\n                <circle cx=\"140\" cy=\"70\" r=\"4\" fill=\"#7C3AED\"/>\n                <circle cx=\"200\" cy=\"60\" r=\"4\" fill=\"#7C3AED\"/>\n                <circle cx=\"260\" cy=\"50\" r=\"4\" fill=\"#7C3AED\"/>\n              </svg>\n              <!-- Y-axis labels -->\n              <div class=\"absolute -left-2 top-0 text-xs text-stone\">75</div>\n              <div class=\"absolute -left-2 top-1/3 text-xs text-stone\">70</div>\n              <div class=\"absolute -left-2 top-2/3 text-xs text-stone\">65</div>\n              <div class=\"absolute -left-2 bottom-0 text-xs text-stone\">60</div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Section 2: Latest Entry Card -->\n        <div class=\"mb-6\">\n          <div class=\"bg-mist rounded-card card-shadow p-4\">\n            <span class=\"text-xs font-medium text-stone uppercase tracking-wide\">Today's Weight</span>\n\n            <div class=\"flex items-baseline gap-2 mt-2\">\n              <span class=\"text-4xl font-bold text-graphite\">64.5</span>\n              <span class=\"text-lg text-stone\">kg</span>\n            </div>\n\n            <!-- Delta row -->\n            <div class=\"flex items-center gap-2 mt-2\">\n              <svg class=\"w-5 h-5 text-coral\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 10l7-7m0 0l7 7m-7-7v18\"/>\n              </svg>\n              <span class=\"text-coral font-semibold\">+0.8</span>\n              <span class=\"text-stone text-sm\">from last entry</span>\n            </div>\n\n            <span class=\"text-xs text-stone mt-2 block\">Logged at 8:30 AM</span>\n          </div>\n        </div>\n\n        <!-- Section 3: Nutrition Tips Card -->\n        <div class=\"mb-6\">\n          <div class=\"bg-lavender-tint rounded-card card-shadow p-4\">\n            <div class=\"flex items-center justify-between mb-3\">\n              <h3 class=\"text-base font-semibold text-graphite\">Nutrition Tips</h3>\n              <span data-flutter=\"chip\" class=\"bg-lavender text-white text-xs font-semibold px-3 py-1 rounded-full\">Week 24</span>\n            </div>\n\n            <!-- Tips list -->\n            <div data-flutter=\"column\" data-spacing=\"sm\" class=\"mt-3\">\n              <div class=\"flex items-start gap-2\">\n                <span class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></span>\n                <span class=\"text-sm text-graphite leading-relaxed\">Focus on iron-rich foods like spinach, lentils, and lean red meat to support increased blood volume</span>\n              </div>\n              <div class=\"flex items-start gap-2\">\n                <span class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></span>\n                <span class=\"text-sm text-graphite leading-relaxed\">Stay hydrated with 8-10 glasses of water daily</span>\n              </div>\n              <div class=\"flex items-start gap-2\">\n                <span class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></span>\n                <span class=\"text-sm text-graphite leading-relaxed\">Include calcium-rich foods for baby's bone development</span>\n              </div>\n              <div class=\"flex items-start gap-2\">\n                <span class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></span>\n                <span class=\"text-sm text-graphite leading-relaxed\">Small, frequent meals can help with digestion and energy levels</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Section 4: Weight Log List -->\n        <div class=\"mb-6\">\n          <h2 class=\"text-2xl font-bold text-graphite mb-4\">Weight Log</h2>\n\n          <div data-flutter=\"sliver-list\" class=\"flex flex-col gap-3\">\n            <!-- Log item 1 -->\n            <div data-flutter=\"card\" class=\"bg-warm-white rounded-card card-shadow p-4 cursor-pointer active:scale-[0.98] transition-transform\">\n              <div class=\"flex justify-between items-start\">\n                <div>\n                  <span class=\"text-base font-semibold text-graphite\">Mon, Jan 15, 2024</span>\n                  <div class=\"flex items-baseline gap-1 mt-1\">\n                    <span class=\"text-lg text-graphite\">64.5 kg</span>\n                  </div>\n                  <span class=\"text-sm text-stone mt-1 block\">Feeling great today!</span>\n                </div>\n                <span class=\"text-xs text-stone bg-stone/10 px-2 py-1 rounded-full\">8:30 AM</span>\n              </div>\n            </div>\n\n            <!-- Log item 2 -->\n            <div data-flutter=\"card\" class=\"bg-warm-white rounded-card card-shadow p-4 cursor-pointer active:scale-[0.98] transition-transform\">\n              <div class=\"flex justify-between items-start\">\n                <div>\n                  <span class=\"text-base font-semibold text-graphite\">Sun, Jan 14, 2024</span>\n                  <div class=\"flex items-baseline gap-1 mt-1\">\n                    <span class=\"text-lg text-graphite\">63.7 kg</span>\n                  </div>\n                </div>\n                <span class=\"text-xs text-stone bg-stone/10 px-2 py-1 rounded-full\">7:45 AM</span>\n              </div>\n            </div>\n\n            <!-- Log item 3 -->\n            <div data-flutter=\"card\" class=\"bg-warm-white rounded-card card-shadow p-4 cursor-pointer active:scale-[0.98] transition-transform\">\n              <div class=\"flex justify-between items-start\">\n                <div>\n                  <span class=\"text-base font-semibold text-graphite\">Sat, Jan 13, 2024</span>\n                  <div class=\"flex items-baseline gap-1 mt-1\">\n                    <span class=\"text-lg text-graphite\">64.2 kg</span>\n                  </div>\n                  <span class=\"text-sm text-stone mt-1 block\">After weekend brunch</span>\n                </div>\n                <span class=\"text-xs text-stone bg-stone/10 px-2 py-1 rounded-full\">9:15 AM</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n      </main>\n\n      <!-- FAB: Add weight entry -->\n      <button data-flutter=\"fab\" aria-label=\"Log weight\" class=\"absolute bottom-6 right-4 w-14 h-14 bg-lavender rounded-full flex items-center justify-center fab-shadow active:scale-90 transition-transform\">\n        <svg class=\"w-7 h-7 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 4v16m8-8H4\"/>\n        </svg>\n      </button>\n\n    </div>\n\n    <!-- Add Weight Bottom Sheet (shown on FAB tap) -->\n    <div data-flutter=\"bottom-sheet\" class=\"absolute inset-0 flex items-end justify-center bg-black/30 hidden\">\n      <div class=\"bg-warm-white rounded-t-sheet w-full max-w-[375px] pb-8 pt-4 px-6\">\n        <!-- Handle bar -->\n        <div class=\"bottom-sheet-handle mx-auto mb-4\"></div>\n\n        <h2 class=\"text-xl font-semibold text-graphite mb-6\">Log Weight</h2>\n\n        <!-- Weight input -->\n        <div class=\"mb-4\">\n          <label class=\"text-sm text-stone mb-1 block\">Weight</label>\n          <div class=\"flex items-center gap-2\">\n            <input data-flutter=\"text-field\" type=\"number\" step=\"0.1\" placeholder=\"0.0\"\n                   class=\"flex-1 px-4 py-3 rounded-xl border border-misty-border text-graphite text-lg focus:border-lavender focus:ring-2 focus:ring-lavender/20 outline-none\"\n                   value=\"64.5\">\n            <span class=\"text-stone font-medium\">kg</span>\n          </div>\n        </div>\n\n        <!-- Date picker -->\n        <div class=\"mb-4\">\n          <label class=\"text-sm text-stone mb-1 block\">Date</label>\n          <div class=\"flex items-center gap-2 px-4 py-3 rounded-xl border border-misty-border\">\n            <span class=\"text-graphite\">January 15, 2024</span>\n            <svg class=\"w-5 h-5 text-stone ml-auto\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\"/>\n            </svg>\n          </div>\n        </div>\n\n        <!-- Notes input -->\n        <div class=\"mb-6\">\n          <label class=\"text-sm text-stone mb-1 block\">Notes (optional)</label>\n          <textarea data-flutter=\"text-field\" rows=\"3\" placeholder=\"Add notes...\"\n                    class=\"w-full px-4 py-3 rounded-xl border border-misty-border text-graphite focus:border-lavender focus:ring-2 focus:ring-lavender/20 outline-none resize-none min-h-[100px]\">Feeling great today!</textarea>\n        </div>\n\n        <!-- Action buttons -->\n        <div data-flutter=\"row\" data-spacing=\"md\" class=\"flex gap-3\">\n          <button data-flutter=\"text-btn\" class=\"flex-1 py-3 text-stone font-medium rounded-xl\">Cancel</button>\n          <button data-flutter=\"filled-btn\" data-color=\"primary\" class=\"flex-1 py-3 bg-lavender text-white font-semibold rounded-full\">Save</button>\n        </div>\n      </div>\n    </div>\n\n  </div>\n</body>\n</html>","numLines":331,"startLine":1,"totalLines":331}}}
