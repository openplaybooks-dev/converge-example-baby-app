[2026-05-19T00:18:08.499Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_vjhp9awol82c_1","type":"tool_result","content":"1\timport 'package:flutter/material.dart';\n2\timport 'package:gap/gap.dart';\n3\timport 'package:flutter_animate/flutter_animate.dart';\n4\t\n5\timport '../../theme/app_theme.dart';\n6\t\n7\tclass WeightNutritionScreen extends StatelessWidget {\n8\t  const WeightNutritionScreen({super.key});\n9\t\n10\t  @override\n11\t  Widget build(BuildContext context) {\n12\t    return Scaffold(\n13\t      backgroundColor: AppTheme.lavenderTint,\n14\t      appBar: AppBar(\n15\t        backgroundColor: AppTheme.lavenderBloom,\n16\t        leading: IconButton(\n17\t          icon: const Icon(Icons.arrow_back, color: Colors.white),\n18\t          onPressed: () => Navigator.of(context).pop(),\n19\t          tooltip: 'Back to Browse',\n20\t        ),\n21\t        title: const Text(\n22\t          'Weight & Nutrition',\n23\t          style: TextStyle(\n24\t            fontSize: 20,\n25\t            fontWeight: FontWeight.w600,\n26\t            color: Colors.white,\n27\t          ),\n28\t        ),\n29\t        centerTitle: true,\n30\t        elevation: 0,\n31\t      ),\n32\t      body: CustomScrollView(\n33\t        slivers: [\n34\t          SliverToBoxAdapter(\n35\t            child: Padding(\n36\t              padding: const EdgeInsets.symmetric(horizontal: AppTheme.spaceMd),\n37\t              child: Column(\n38\t                crossAxisAlignment: CrossAxisAlignment.start,\n39\t                children: [\n40\t                  const Gap(AppTheme.spaceLg),\n41\t                  _WeightProgressChart(),\n42\t                  const Gap(AppTheme.spaceLg),\n43\t                  _LatestEntryCard(),\n44\t                  const Gap(AppTheme.spaceLg),\n45\t                  _NutritionTipsCard(),\n46\t                  const Gap(AppTheme.spaceLg),\n47\t                  _WeightLogSection(),\n48\t                  const Gap(100),\n49\t                ],\n50\t              ),\n51\t            ),\n52\t          ),\n53\t        ],\n54\t      ),\n55\t      floatingActionButton: FloatingActionButton(\n56\t        onPressed: () => _showAddWeightSheet(context),\n57\t        backgroundColor: AppTheme.lavenderBloom,\n58\t        elevation: 4,\n59\t        child: const Icon(Icons.add, color: Colors.white),\n60\t      ).animate().fade(duration: 200.ms).scale(\n61\t            begin: const Offset(0.95, 0.95),\n62\t            end: const Offset(1, 1),\n63\t            duration: 200.ms,\n64\t          ),\n65\t    );\n66\t  }\n67\t\n68\t  void _showAddWeightSheet(BuildContext context) {\n69\t    showModalBottomSheet(\n70\t      context: context,\n71\t      isScrollControlled: true,\n72\t      backgroundColor: Colors.transparent,\n73\t      builder: (context) => const _AddWeightBottomSheet(),\n74\t    );\n75\t  }\n76\t}\n77\t\n78\t// ============================================================================\n79\t// Section 1: Weight Progress Chart\n80\t// ============================================================================\n81\t\n82\tclass _WeightProgressChart extends StatefulWidget {\n83\t  @override\n84\t  State<_WeightProgressChart> createState() => _WeightProgressChartState();\n85\t}\n86\t\n87\tclass _WeightProgressChartState extends State<_WeightProgressChart> {\n88\t  String _selectedRange = '1W';\n89\t\n90\t  @override\n91\t  Widget build(BuildContext context) {\n92\t    return Container(\n93\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n94\t      decoration: BoxDecoration(\n95\t        color: AppTheme.warmWhite,\n96\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n97\t        boxShadow: const [\n98\t          BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n99\t        ],\n100\t      ),\n101\t      child: Column(\n102\t        crossAxisAlignment: CrossAxisAlignment.start,\n103\t        children: [\n104\t          Text(\n105\t            'Weight Progress',\n106\t            style: Theme.of(context).textTheme.headlineMedium,\n107\t          ),\n108\t          const Gap(AppTheme.spaceSm),\n109\t          Row(\n110\t            children: [\n111\t              _buildChip('1W', '1W'),\n112\t              const Gap(AppTheme.spaceXs),\n113\t              _buildChip('1M', '1M'),\n114\t              const Gap(AppTheme.spaceXs),\n115\t              _buildChip('All', 'All'),\n116\t            ],\n117\t          ),\n118\t          const Gap(AppTheme.spaceMd),\n119\t          SizedBox(\n120\t            height: 192,\n121\t            child: _buildChart(),\n122\t          ),\n123\t        ],\n124\t      ),\n125\t    ).animate().fade(duration: 200.ms);\n126\t  }\n127\t\n128\t  Widget _buildChip(String label, String value) {\n129\t    final isSelected = _selectedRange == value;\n130\t    return GestureDetector(\n131\t      onTap: () => setState(() => _selectedRange = value),\n132\t      child: AnimatedContainer(\n133\t        duration: 150.ms,\n134\t        padding: const EdgeInsets.symmetric(\n135\t          horizontal: AppTheme.spaceSm,\n136\t          vertical: AppTheme.spaceXs,\n137\t        ),\n138\t        decoration: BoxDecoration(\n139\t          color: isSelected\n140\t              ? AppTheme.lavenderBloom.withValues(alpha: 0.15)\n141\t              : AppTheme.stoneGrey.withValues(alpha: 0.1),\n142\t          borderRadius: BorderRadius.circular(AppTheme.radiusSm),\n143\t        ),\n144\t        child: Text(\n145\t          label,\n146\t          style: TextStyle(\n147\t            fontSize: 14,\n148\t            fontWeight: FontWeight.w600,\n149\t            color: isSelected ? AppTheme.lavenderBloom : AppTheme.stoneGrey,\n150\t          ),\n151\t        ),\n152\t      ),\n153\t    );\n154\t  }\n155\t\n156\t  Widget _buildChart() {\n157\t    return CustomPaint(\n158\t      size: const Size(double.infinity, 192),\n159\t      painter: _ChartPainter(),\n160\t    );\n161\t  }\n162\t}\n163\t\n164\tclass _ChartPainter extends CustomPainter {\n165\t  @override\n166\t  void paint(Canvas canvas, Size size) {\n167\t    final linePaint = Paint()\n168\t      ..color = AppTheme.lavenderBloom\n169\t      ..strokeWidth = 3\n170\t      ..strokeCap = StrokeCap.round\n171\t      ..style = PaintingStyle.stroke;\n172\t\n173\t    final fillPaint = Paint()\n174\t      ..shader = LinearGradient(\n175\t        begin: Alignment.topCenter,\n176\t        end: Alignment.bottomCenter,\n177\t        colors: [\n178\t          AppTheme.lavenderBloom.withValues(alpha: 0.2),\n179\t          AppTheme.lavenderBloom.withValues(alpha: 0),\n180\t        ],\n181\t      ).createShader(Rect.fromLTWH(0, 0, size.width, size.height))\n182\t      ..style = PaintingStyle.fill;\n183\t\n184\t    final dotPaint = Paint()\n185\t      ..color = AppTheme.lavenderBloom\n186\t      ..style = PaintingStyle.fill;\n187\t\n188\t    final gridPaint = Paint()\n189\t      ..color = AppTheme.mistyBorder.withValues(alpha: 0.5)\n190\t      ..strokeWidth = 1;\n191\t\n192\t    // Draw grid lines\n193\t    for (var i = 0; i < 4; i++) {\n194\t      final y = size.height * (i / 3);\n195\t      canvas.drawLine(Offset(0, y), Offset(size.width, y), gridPaint);\n196\t    }\n197\t\n198\t    // Chart data points\n199\t    final points = [\n200\t      Offset(0, size.height * 0.75),\n201\t      Offset(size.width * 0.25, size.height * 0.55),\n202\t      Offset(size.width * 0.5, size.height * 0.45),\n203\t      Offset(size.width * 0.75, size.height * 0.35),\n204\t      Offset(size.width, size.height * 0.2),\n205\t    ];\n206\t\n207\t    // Draw fill\n208\t    final fillPath = Path()\n209\t      ..moveTo(0, size.height)\n210\t      ..lineTo(points.first.dx, points.first.dy);\n211\t\n212\t    for (final point in points) {\n213\t      fillPath.lineTo(point.dx, point.dy);\n214\t    }\n215\t    fillPath.lineTo(size.width, size.height);\n216\t    fillPath.close();\n217\t    canvas.drawPath(fillPath, fillPaint);\n218\t\n219\t    // Draw line\n220\t    final linePath = Path()..moveTo(points.first.dx, points.first.dy);\n221\t    for (final point in points) {\n222\t      linePath.lineTo(point.dx, point.dy);\n223\t    }\n224\t    canvas.drawPath(linePath, linePaint);\n225\t\n226\t    // Draw dots\n227\t    for (final point in points) {\n228\t      canvas.drawCircle(point, 4, dotPaint);\n229\t    }\n230\t  }\n231\t\n232\t  @override\n233\t  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;\n234\t}\n235\t\n236\t// ============================================================================\n237\t// Section 2: Latest Entry Card\n238\t// ============================================================================\n239\t\n240\tclass _LatestEntryCard extends StatelessWidget {\n241\t  @override\n242\t  Widget build(BuildContext context) {\n243\t    return Container(\n244\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n245\t      decoration: BoxDecoration(\n246\t        color: AppTheme.morningMist,\n247\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n248\t        boxShadow: const [\n249\t          BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n250\t        ],\n251\t      ),\n252\t      child: Column(\n253\t        crossAxisAlignment: CrossAxisAlignment.start,\n254\t        children: [\n255\t          Text(\n256\t            \"Today's Weight\",\n257\t            style: Theme.of(context).textTheme.labelMedium?.copyWith(\n258\t                  color: AppTheme.stoneGrey,\n259\t                  letterSpacing: 0.5,\n260\t                ),\n261\t          ),\n262\t          const Gap(AppTheme.spaceXs),\n263\t          Row(\n264\t            crossAxisAlignment: CrossAxisAlignment.baseline,\n265\t            textBaseline: TextBaseline.alphabetic,\n266\t            children: [\n267\t              Text(\n268\t                '64.5',\n269\t                style: Theme.of(context).textTheme.displayLarge,\n270\t              ),\n271\t              const Gap(AppTheme.spaceXs),\n272\t              Text(\n273\t                'kg',\n274\t                style: Theme.of(context).textTheme.bodyLarge?.copyWith(\n275\t                      color: AppTheme.stoneGrey,\n276\t                    ),\n277\t              ),\n278\t            ],\n279\t          ),\n280\t          const Gap(AppTheme.spaceXs),\n281\t          Row(\n282\t            children: [\n283\t              Icon(\n284\t                Icons.arrow_upward,\n285\t                size: 20,\n286\t                color: AppTheme.softCoral,\n287\t              ),\n288\t              const Gap(AppTheme.spaceXxs),\n289\t              Text(\n290\t                '+0.8',\n291\t                style: Theme.of(context).textTheme.labelLarge?.copyWith(\n292\t                      color: AppTheme.softCoral,\n293\t                    ),\n294\t              ),\n295\t              const Gap(AppTheme.spaceXs),\n296\t              Text(\n297\t                'from last entry',\n298\t                style: Theme.of(context).textTheme.bodyMedium,\n299\t              ),\n300\t            ],\n301\t          ),\n302\t          const Gap(AppTheme.spaceXs),\n303\t          Text(\n304\t            'Logged at 8:30 AM',\n305\t            style: Theme.of(context).textTheme.bodySmall,\n306\t          ),\n307\t        ],\n308\t      ),\n309\t    ).animate().fade(delay: 50.ms, duration: 200.ms);\n310\t  }\n311\t}\n312\t\n313\t// ============================================================================\n314\t// Section 3: Nutrition Tips Card\n315\t// ============================================================================\n316\t\n317\tclass _NutritionTipsCard extends StatelessWidget {\n318\t  @override\n319\t  Widget build(BuildContext context) {\n320\t    final tips = [\n321\t      'Focus on iron-rich foods like spinach, lentils, and lean red meat to support increased blood volume',\n322\t      'Stay hydrated with 8-10 glasses of water daily',\n323\t      'Include calcium-rich foods for baby\\'s bone development',\n324\t      'Small, frequent meals can help with digestion and energy levels',\n325\t    ];\n326\t\n327\t    return Container(\n328\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n329\t      decoration: BoxDecoration(\n330\t        color: AppTheme.lavenderTint,\n331\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n332\t        boxShadow: const [\n333\t          BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n334\t        ],\n335\t      ),\n336\t      child: Column(\n337\t        crossAxisAlignment: CrossAxisAlignment.start,\n338\t        children: [\n339\t          Row(\n340\t            mainAxisAlignment: MainAxisAlignment.spaceBetween,\n341\t            children: [\n342\t              Text(\n343\t                'Nutrition Tips',\n344\t                style: Theme.of(context).textTheme.titleMedium,\n345\t              ),\n346\t              Container(\n347\t                padding: const EdgeInsets.symmetric(\n348\t                  horizontal: AppTheme.spaceSm,\n349\t                  vertical: AppTheme.spaceXxs + 2,\n350\t                ),\n351\t                decoration: BoxDecoration(\n352\t                  color: AppTheme.lavenderBloom,\n353\t                  borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n354\t                ),\n355\t                child: Text(\n356\t                  'Week 24',\n357\t                  style: Theme.of(context).textTheme.labelSmall?.copyWith(\n358\t                        color: Colors.white,\n359\t                        fontWeight: FontWeight.w600,\n360\t                      ),\n361\t                ),\n362\t              ),\n363\t            ],\n364\t          ),\n365\t          const Gap(AppTheme.spaceSm),\n366\t          ...tips.map((tip) => Padding(\n367\t                padding: const EdgeInsets.only(bottom: AppTheme.spaceSm),\n368\t                child: Row(\n369\t                  crossAxisAlignment: CrossAxisAlignment.start,\n370\t                  children: [\n371\t                    Container(\n372\t                      width: 8,\n373\t                      height: 8,\n374\t                      margin: const EdgeInsets.only(top: 6),\n375\t                      decoration: const BoxDecoration(\n376\t                        color: AppTheme.blushRose,\n377\t                        shape: BoxShape.circle,\n378\t                      ),\n379\t                    ),\n380\t                    const Gap(AppTheme.spaceXs),\n381\t                    Expanded(\n382\t                      child: Text(\n383\t                        tip,\n384\t                        style: Theme.of(context).textTheme.bodyMedium,\n385\t                      ),\n386\t                    ),\n387\t                  ],\n388\t                ),\n389\t              )),\n390\t        ],\n391\t      ),\n392\t    ).animate().fade(delay: 100.ms, duration: 200.ms);\n393\t  }\n394\t}\n395\t\n396\t// ============================================================================\n397\t// Section 4: Weight Log List\n398\t// ============================================================================\n399\t\n400\tclass _WeightLogSection extends StatelessWidget {\n401\t  @override\n402\t  Widget build(BuildContext context) {\n403\t    return Column(\n404\t      crossAxisAlignment: CrossAxisAlignment.start,\n405\t      children: [\n406\t        Text(\n407\t          'Weight Log',\n408\t          style: Theme.of(context).textTheme.headlineMedium,\n409\t        ),\n410\t        const Gap(AppTheme.spaceSm),\n411\t        _WeightLogItem(\n412\t          date: 'Mon, Jan 15, 2024',\n413\t          weight: '64.5 kg',\n414\t          note: 'Feeling great today!',\n415\t          time: '8:30 AM',\n416\t        ),\n417\t        _WeightLogItem(\n418\t          date: 'Sun, Jan 14, 2024',\n419\t          weight: '63.7 kg',\n420\t          note: null,\n421\t          time: '7:45 AM',\n422\t        ),\n423\t        _WeightLogItem(\n424\t          date: 'Sat, Jan 13, 2024',\n425\t          weight: '64.2 kg',\n426\t          note: 'After weekend brunch',\n427\t          time: '9:15 AM',\n428\t        ),\n429\t      ],\n430\t    );\n431\t  }\n432\t}\n433\t\n434\tclass _WeightLogItem extends StatelessWidget {\n435\t  final String date;\n436\t  final String weight;\n437\t  final String? note;\n438\t  final String time;\n439\t\n440\t  const _WeightLogItem({\n441\t    required this.date,\n442\t    required this.weight,\n443\t    this.note,\n444\t    required this.time,\n445\t  });\n446\t\n447\t  @override\n448\t  Widget build(BuildContext context) {\n449\t    return GestureDetector(\n450\t      onTap: () => _showEntryDetailSheet(context),\n451\t      onLongPress: () => _showEditSheet(context),\n452\t      child: Container(\n453\t        margin: const EdgeInsets.only(bottom: AppTheme.spaceSm),\n454\t        padding: const EdgeInsets.all(AppTheme.spaceMd),\n455\t        decoration: BoxDecoration(\n456\t          color: AppTheme.warmWhite,\n457\t          borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n458\t          boxShadow: const [\n459\t            BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n460\t          ],\n461\t        ),\n462\t        child: Row(\n463\t          crossAxisAlignment: CrossAxisAlignment.start,\n464\t          children: [\n465\t            Expanded(\n466\t              child: Column(\n467\t                crossAxisAlignment: CrossAxisAlignment.start,\n468\t                children: [\n469\t                  Text(\n470\t                    date,\n471\t                    style: Theme.of(context).textTheme.titleMedium,\n472\t                  ),\n473\t                  const Gap(AppTheme.spaceXxs),\n474\t                  Text(\n475\t                    weight,\n476\t                    style: Theme.of(context).textTheme.bodyLarge,\n477\t                  ),\n478\t                  if (note != null) ...[\n479\t                    const Gap(AppTheme.spaceXxs),\n480\t                    Text(\n481\t                      note!,\n482\t                      style: Theme.of(context).textTheme.bodyMedium,\n483\t                    ),\n484\t                  ],\n485\t                ],\n486\t              ),\n487\t            ),\n488\t            Container(\n489\t              padding: const EdgeInsets.symmetric(\n490\t                horizontal: AppTheme.spaceXs,\n491\t                vertical: 2,\n492\t              ),\n493\t              decoration: BoxDecoration(\n494\t                color: AppTheme.stoneGrey.withValues(alpha: 0.1),\n495\t                borderRadius: BorderRadius.circular(AppTheme.radiusSm),\n496\t              ),\n497\t              child: Text(\n498\t                time,\n499\t                style: Theme.of(context).textTheme.bodySmall,\n500\t              ),\n501\t            ),\n502\t          ],\n503\t        ),\n504\t      ).animate().fade(duration: 200.ms).slideX(\n505\t            begin: 0.1,\n506\t            end: 0,\n507\t            duration: 200.ms,\n508\t            curve: Curves.easeOut,\n509\t          ),\n510\t    );\n511\t  }\n512\t\n513\t  void _showEntryDetailSheet(BuildContext context) {\n514\t    showModalBottomSheet(\n515\t      context: context,\n516\t      backgroundColor: Colors.transparent,\n517\t      builder: (context) => _EntryDetailBottomSheet(date: date, weight: weight),\n518\t    );\n519\t  }\n520\t\n521\t  void _showEditSheet(BuildContext context) {\n522\t    showModalBottomSheet(\n523\t      context: context,\n524\t      isScrollControlled: true,\n525\t      backgroundColor: Colors.transparent,\n526\t      builder: (context) => _AddWeightBottomSheet(\n527\t        initialWeight: weight.split(' ').first,\n528\t        initialDate: date,\n529\t      ),\n530\t    );\n531\t  }\n532\t}\n533\t\n534\t// ============================================================================\n535\t// Section 5: Add Weight Bottom Sheet\n536\t// ============================================================================\n537\t\n538\tclass _AddWeightBottomSheet extends StatefulWidget {\n539\t  final String? initialWeight;\n540\t  final String? initialDate;\n541\t\n542\t  const _AddWeightBottomSheet({\n543\t    this.initialWeight,\n544\t    this.initialDate,\n545\t  });\n546\t\n547\t  @override\n548\t  State<_AddWeightBottomSheet> createState() => _AddWeightBottomSheetState();\n549\t}\n550\t\n551\tclass _AddWeightBottomSheetState extends State<_AddWeightBottomSheet> {\n552\t  final _weightController = TextEditingController();\n553\t  final _notesController = TextEditingController();\n554\t  DateTime _selectedDate = DateTime.now();\n555\t\n556\t  @override\n557\t  void initState() {\n558\t    super.initState();\n559\t    if (widget.initialWeight != null) {\n560\t      _weightController.text = widget.initialWeight!;\n561\t    }\n562\t  }\n563\t\n564\t  @override\n565\t  void dispose() {\n566\t    _weightController.dispose();\n567\t    _notesController.dispose();\n568\t    super.dispose();\n569\t  }\n570\t\n571\t  @override\n572\t  Widget build(BuildContext context) {\n573\t    final theme = Theme.of(context);\n574\t    final textTheme = theme.textTheme;\n575\t\n576\t    return Container(\n577\t      margin: const EdgeInsets.only(top: 100),\n578\t      decoration: BoxDecoration(\n579\t        color: AppTheme.warmWhite,\n580\t        borderRadius: const BorderRadius.vertical(top: Radius.circular(28)),\n581\t      ),\n582\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n583\t      child: Column(\n584\t        mainAxisSize: MainAxisSize.min,\n585\t        children: [\n586\t          Container(\n587\t            width: 40,\n588\t            height: 4,\n589\t            decoration: BoxDecoration(\n590\t              color: AppTheme.mistyBorder,\n591\t              borderRadius: BorderRadius.circular(2),\n592\t            ),\n593\t          ),\n594\t          const Gap(AppTheme.spaceMd),\n595\t          Text('Log Weight', style: textTheme.titleLarge),\n596\t          const Gap(AppTheme.spaceMd),\n597\t          Row(\n598\t            children: [\n599\t              Expanded(\n600\t                flex: 3,\n601\t                child: TextField(\n602\t                  controller: _weightController,\n603\t                  keyboardType: const TextInputType.numberWithOptions(decimal: true),\n604\t                  decoration: InputDecoration(\n605\t                    labelText: 'Weight',\n606\t                    hintText: '0.0',\n607\t                    border: OutlineInputBorder(\n608\t                      borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n609\t                    ),\n610\t                    contentPadding: const EdgeInsets.symmetric(\n611\t                      horizontal: AppTheme.spaceMd,\n612\t                      vertical: AppTheme.spaceSm,\n613\t                    ),\n614\t                  ),\n615\t                ),\n616\t              ),\n617\t              const Gap(AppTheme.spaceSm),\n618\t              Expanded(\n619\t                flex: 1,\n620\t                child: Container(\n621\t                  padding: const EdgeInsets.symmetric(\n622\t                    horizontal: AppTheme.spaceMd,\n623\t                    vertical: AppTheme.spaceMd,\n624\t                  ),\n625\t                  decoration: BoxDecoration(\n626\t                    color: AppTheme.lavenderTint,\n627\t                    borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n628\t                    border: Border.all(color: AppTheme.mistyBorder),\n629\t                  ),\n630\t                  child: Text(\n631\t                    'kg',\n632\t                    style: textTheme.bodyLarge?.copyWith(\n633\t                      color: AppTheme.stoneGrey,\n634\t                    ),\n635\t                    textAlign: TextAlign.center,\n636\t                  ),\n637\t                ),\n638\t              ),\n639\t            ],\n640\t          ),\n641\t          const Gap(AppTheme.spaceMd),\n642\t          GestureDetector(\n643\t            onTap: () => _selectDate(context),\n644\t            child: Container(\n645\t              padding: const EdgeInsets.all(AppTheme.spaceMd),\n646\t              decoration: BoxDecoration(\n647\t                border: Border.all(color: AppTheme.mistyBorder),\n648\t                borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n649\t              ),\n650\t              child: Row(\n651\t                children: [\n652\t                  Text(\n653\t                    'Date',\n654\t                    style: textTheme.bodyMedium,\n655\t                  ),\n656\t                  const Spacer(),\n657\t                  Text(\n658\t                    _formatDate(_selectedDate),\n659\t                    style: textTheme.bodyLarge,\n660\t                  ),\n661\t                  const Gap(AppTheme.spaceXs),\n662\t                  const Icon(\n663\t                    Icons.calendar_today,\n664\t                    size: 20,\n665\t                    color: AppTheme.stoneGrey,\n666\t                  ),\n667\t                ],\n668\t              ),\n669\t            ),\n670\t          ),\n671\t          const Gap(AppTheme.spaceMd),\n672\t          TextField(\n673\t            controller: _notesController,\n674\t            maxLines: 3,\n675\t            minLines: 3,\n676\t            decoration: InputDecoration(\n677\t              labelText: 'Notes (optional)',\n678\t              hintText: 'Add notes...',\n679\t              border: OutlineInputBorder(\n680\t                borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n681\t              ),\n682\t              contentPadding: const EdgeInsets.all(AppTheme.spaceMd),\n683\t            ),\n684\t          ),\n685\t          const Gap(AppTheme.spaceMd),\n686\t          Row(\n687\t            children: [\n688\t              Expanded(\n689\t                child: TextButton(\n690\t                  onPressed: () => Navigator.pop(context),\n691\t                  child: Text(\n692\t                    'Cancel',\n693\t                    style: TextStyle(color: AppTheme.stoneGrey),\n694\t                  ),\n695\t                ),\n696\t              ),\n697\t              const Gap(AppTheme.spaceSm),\n698\t              Expanded(\n699\t                flex: 2,\n700\t                child: ElevatedButton(\n701\t                  onPressed: () {\n702\t                    Navigator.pop(context);\n703\t                    ScaffoldMessenger.of(context).showSnackBar(\n704\t                      const SnackBar(\n705\t                        content: Text('Weight entry saved'),\n706\t                        behavior: SnackBarBehavior.floating,\n707\t                      ),\n708\t                    );\n709\t                  },\n710\t                  style: ElevatedButton.styleFrom(\n711\t                    backgroundColor: AppTheme.lavenderBloom,\n712\t                    foregroundColor: Colors.white,\n713\t                    shape: RoundedRectangleBorder(\n714\t                      borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n715\t                    ),\n716\t                    padding: const EdgeInsets.symmetric(vertical: 14),\n717\t                  ),\n718\t                  child: const Text('Save'),\n719\t                ),\n720\t              ),\n721\t            ],\n722\t          ),\n723\t          SizedBox(height: MediaQuery.of(context).viewInsets.bottom),\n724\t        ],\n725\t      ),\n726\t    );\n727\t  }\n728\t\n729\t  Future<void> _selectDate(BuildContext context) async {\n730\t    final picked = await showDatePicker(\n731\t      context: context,\n732\t      initialDate: _selectedDate,\n733\t      firstDate: DateTime(2020),\n734\t      lastDate: DateTime.now(),\n735\t    );\n736\t    if (picked != null) {\n737\t      setState(() => _selectedDate = picked);\n738\t    }\n739\t  }\n740\t\n741\t  String _formatDate(DateTime date) {\n742\t    const months = [\n743\t      'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',\n744\t      'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'\n745\t    ];\n746\t    return '${months[date.month - 1]} ${date.day}, ${date.year}';\n747\t  }\n748\t}\n749\t\n750\t// ============================================================================\n751\t// Section 6: Entry Detail Bottom Sheet\n752\t// ============================================================================\n753\t\n754\tclass _EntryDetailBottomSheet extends StatelessWidget {\n755\t  final String date;\n756\t  final String weight;\n757\t\n758\t  const _EntryDetailBottomSheet({\n759\t    required this.date,\n760\t    required this.weight,\n761\t  });\n762\t\n763\t  @override\n764\t  Widget build(BuildContext context) {\n765\t    final theme = Theme.of(context);\n766\t    final textTheme = theme.textTheme;\n767\t\n768\t    return Container(\n769\t      margin: const EdgeInsets.only(top: 150),\n770\t      decoration: BoxDecoration(\n771\t        color: AppTheme.warmWhite,\n772\t        borderRadius: const BorderRadius.vertical(top: Radius.circular(28)),\n773\t      ),\n774\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n775\t      child: Column(\n776\t        mainAxisSize: MainAxisSize.min,\n777\t        children: [\n778\t          Container(\n779\t            width: 40,\n780\t            height: 4,\n781\t            decoration: BoxDecoration(\n782\t              color: AppTheme.mistyBorder,\n783\t              borderRadius: BorderRadius.circular(2),\n784\t            ),\n785\t          ),\n786\t          const Gap(AppTheme.spaceMd),\n787\t          Text('Weight Entry', style: textTheme.titleLarge),\n788\t          const Gap(AppTheme.spaceMd),\n789\t          Row(\n790\t            mainAxisAlignment: MainAxisAlignment.spaceBetween,\n791\t            children: [\n792\t              Text(date, style: textTheme.titleMedium),\n793\t              Container(\n794\t                padding: const EdgeInsets.symmetric(\n795\t                  horizontal: AppTheme.spaceXs,\n796\t                  vertical: 2,\n797\t                ),\n798\t                decoration: BoxDecoration(\n799\t                  color: AppTheme.lavenderTint,\n800\t                  borderRadius: BorderRadius.circular(AppTheme.radiusSm),\n801\t                ),\n802\t                child: Text(\n803\t                  weight,\n804\t                  style: textTheme.labelSmall?.copyWith(\n805\t                    color: AppTheme.lavenderBloom,\n806\t                  ),\n807\t                ),\n808\t              ),\n809\t            ],\n810\t          ),\n811\t          const Gap(AppTheme.spaceMd),\n812\t          Container(\n813\t            padding: const EdgeInsets.all(AppTheme.spaceMd),\n814\t            decoration: BoxDecoration(\n815\t              color: AppTheme.morningMist,\n816\t              borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n817\t            ),\n818\t            child: Text(\n819\t              'Feeling great today!',\n820\t              style: textTheme.bodyMedium,\n821\t            ),\n822\t          ),\n823\t          const Gap(AppTheme.spaceMd),\n824\t          Row(\n825\t            children: [\n826\t              Expanded(\n827\t                child: TextButton(\n828\t                  onPressed: () {\n829\t                    Navigator.pop(context);\n830\t                    _showDeleteConfirmation(context);\n831\t                  },\n832\t                  child: Text(\n833\t                    'Delete',\n834\t                    style: TextStyle(color: AppTheme.softCoral),\n835\t                  ),\n836\t                ),\n837\t              ),\n838\t              const Gap(AppTheme.spaceSm),\n839\t              Expanded(\n840\t                flex: 2,\n841\t                child: ElevatedButton(\n842\t                  onPressed: () => Navigator.pop(context),\n843\t                  style: ElevatedButton.styleFrom(\n844\t                    backgroundColor: AppTheme.lavenderBloom,\n845\t                    foregroundColor: Colors.white,\n846\t                    shape: RoundedRectangleBorder(\n847\t                      borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n848\t                    ),\n849\t                    padding: const EdgeInsets.symmetric(vertical: 14),\n850\t                  ),\n851\t                  child: const Text('Save Changes'),\n852\t                ),\n853\t              ),\n854\t            ],\n855\t          ),\n856\t          SizedBox(height: MediaQuery.of(context).viewInsets.bottom),\n857\t        ],\n858\t      ),\n859\t    );\n860\t  }\n861\t\n862\t  void _showDeleteConfirmation(BuildContext context) {\n863\t    showDialog(\n864\t      context: context,\n865\t      builder: (context) => AlertDialog(\n866\t        title: const Text('Delete Entry'),\n867\t        content: const Text('Are you sure you want to delete this weight entry?'),\n868\t        actions: [\n869\t          TextButton(\n870\t            onPressed: () => Navigator.pop(context),\n871\t            child: const Text('Cancel'),\n872\t          ),\n873\t          TextButton(\n874\t            onPressed: () {\n875\t              Navigator.pop(context);\n876\t              Navigator.pop(context);\n877\t              ScaffoldMessenger.of(context).showSnackBar(\n878\t                const SnackBar(\n879\t                  content: Text('Weight entry deleted'),\n880\t                  behavior: SnackBarBehavior.floating,\n881\t                ),\n882\t              );\n883\t            },\n884\t            child: Text(\n885\t              'Delete',\n886\t              style: TextStyle(color: AppTheme.softCoral),\n887\t            ),\n888\t          ),\n889\t        ],\n890\t      ),\n891\t    );\n892\t  }\n893\t}"}]},"parent_tool_use_id":null,"session_id":"8398349f-11ff-4ed6-8769-277ecd25967f","uuid":"c4b57ddf-275b-4c13-9fd8-68f30aab4bea","timestamp":"2026-05-19T00:18:08.498Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/minh/Documents/openplayboosks/examples/baby-app/lib/screens/weight_nutrition/weight_nutrition_screen.dart","content":"import 'package:flutter/material.dart';\nimport 'package:gap/gap.dart';\nimport 'package:flutter_animate/flutter_animate.dart';\n\nimport '../../theme/app_theme.dart';\n\nclass WeightNutritionScreen extends StatelessWidget {\n  const WeightNutritionScreen({super.key});\n\n  @override\n  Widget build(BuildContext context) {\n    return Scaffold(\n      backgroundColor: AppTheme.lavenderTint,\n      appBar: AppBar(\n        backgroundColor: AppTheme.lavenderBloom,\n        leading: IconButton(\n          icon: const Icon(Icons.arrow_back, color: Colors.white),\n          onPressed: () => Navigator.of(context).pop(),\n          tooltip: 'Back to Browse',\n        ),\n        title: const Text(\n          'Weight & Nutrition',\n          style: TextStyle(\n            fontSize: 20,\n            fontWeight: FontWeight.w600,\n            color: Colors.white,\n          ),\n        ),\n        centerTitle: true,\n        elevation: 0,\n      ),\n      body: CustomScrollView(\n        slivers: [\n          SliverToBoxAdapter(\n            child: Padding(\n              padding: const EdgeInsets.symmetric(horizontal: AppTheme.spaceMd),\n              child: Column(\n                crossAxisAlignment: CrossAxisAlignment.start,\n                children: [\n                  const Gap(AppTheme.spaceLg),\n                  _WeightProgressChart(),\n                  const Gap(AppTheme.spaceLg),\n                  _LatestEntryCard(),\n                  const Gap(AppTheme.spaceLg),\n                  _NutritionTipsCard(),\n                  const Gap(AppTheme.spaceLg),\n                  _WeightLogSection(),\n                  const Gap(100),\n                ],\n              ),\n            ),\n          ),\n        ],\n      ),\n      floatingActionButton: FloatingActionButton(\n        onPressed: () => _showAddWeightSheet(context),\n        backgroundColor: AppTheme.lavenderBloom,\n        elevation: 4,\n        child: const Icon(Icons.add, color: Colors.white),\n      ).animate().fade(duration: 200.ms).scale(\n            begin: const Offset(0.95, 0.95),\n            end: const Offset(1, 1),\n            duration: 200.ms,\n          ),\n    );\n  }\n\n  void _showAddWeightSheet(BuildContext context) {\n    showModalBottomSheet(\n      context: context,\n      isScrollControlled: true,\n      backgroundColor: Colors.transparent,\n      builder: (context) => const _AddWeightBottomSheet(),\n    );\n  }\n}\n\n// ============================================================================\n// Section 1: Weight Progress Chart\n// ============================================================================\n\nclass _WeightProgressChart extends StatefulWidget {\n  @override\n  State<_WeightProgressChart> createState() => _WeightProgressChartState();\n}\n\nclass _WeightProgressChartState extends State<_WeightProgressChart> {\n  String _selectedRange = '1W';\n\n  @override\n  Widget build(BuildContext context) {\n    return Container(\n      padding: const EdgeInsets.all(AppTheme.spaceMd),\n      decoration: BoxDecoration(\n        color: AppTheme.warmWhite,\n        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n        boxShadow: const [\n          BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n        ],\n      ),\n      child: Column(\n        crossAxisAlignment: CrossAxisAlignment.start,\n        children: [\n          Text(\n            'Weight Progress',\n            style: Theme.of(context).textTheme.headlineMedium,\n          ),\n          const Gap(AppTheme.spaceSm),\n          Row(\n            children: [\n              _buildChip('1W', '1W'),\n              const Gap(AppTheme.spaceXs),\n              _buildChip('1M', '1M'),\n              const Gap(AppTheme.spaceXs),\n              _buildChip('All', 'All'),\n            ],\n          ),\n          const Gap(AppTheme.spaceMd),\n          SizedBox(\n            height: 192,\n            child: _buildChart(),\n          ),\n        ],\n      ),\n    ).animate().fade(duration: 200.ms);\n  }\n\n  Widget _buildChip(String label, String value) {\n    final isSelected = _selectedRange == value;\n    return GestureDetector(\n      onTap: () => setState(() => _selectedRange = value),\n      child: AnimatedContainer(\n        duration: 150.ms,\n        padding: const EdgeInsets.symmetric(\n          horizontal: AppTheme.spaceSm,\n          vertical: AppTheme.spaceXs,\n        ),\n        decoration: BoxDecoration(\n          color: isSelected\n              ? AppTheme.lavenderBloom.withValues(alpha: 0.15)\n              : AppTheme.stoneGrey.withValues(alpha: 0.1),\n          borderRadius: BorderRadius.circular(AppTheme.radiusSm),\n        ),\n        child: Text(\n          label,\n          style: TextStyle(\n            fontSize: 14,\n            fontWeight: FontWeight.w600,\n            color: isSelected ? AppTheme.lavenderBloom : AppTheme.stoneGrey,\n          ),\n        ),\n      ),\n    );\n  }\n\n  Widget _buildChart() {\n    return CustomPaint(\n      size: const Size(double.infinity, 192),\n      painter: _ChartPainter(),\n    );\n  }\n}\n\nclass _ChartPainter extends CustomPainter {\n  @override\n  void paint(Canvas canvas, Size size) {\n    final linePaint = Paint()\n      ..color = AppTheme.lavenderBloom\n      ..strokeWidth = 3\n      ..strokeCap = StrokeCap.round\n      ..style = PaintingStyle.stroke;\n\n    final fillPaint = Paint()\n      ..shader = LinearGradient(\n        begin: Alignment.topCenter,\n        end: Alignment.bottomCenter,\n        colors: [\n          AppTheme.lavenderBloom.withValues(alpha: 0.2),\n          AppTheme.lavenderBloom.withValues(alpha: 0),\n        ],\n      ).createShader(Rect.fromLTWH(0, 0, size.width, size.height))\n      ..style = PaintingStyle.fill;\n\n    final dotPaint = Paint()\n      ..color = AppTheme.lavenderBloom\n      ..style = PaintingStyle.fill;\n\n    final gridPaint = Paint()\n      ..color = AppTheme.mistyBorder.withValues(alpha: 0.5)\n      ..strokeWidth = 1;\n\n    // Draw grid lines\n    for (var i = 0; i < 4; i++) {\n      final y = size.height * (i / 3);\n      canvas.drawLine(Offset(0, y), Offset(size.width, y), gridPaint);\n    }\n\n    // Chart data points\n    final points = [\n      Offset(0, size.height * 0.75),\n      Offset(size.width * 0.25, size.height * 0.55),\n      Offset(size.width * 0.5, size.height * 0.45),\n      Offset(size.width * 0.75, size.height * 0.35),\n      Offset(size.width, size.height * 0.2),\n    ];\n\n    // Draw fill\n    final fillPath = Path()\n      ..moveTo(0, size.height)\n      ..lineTo(points.first.dx, points.first.dy);\n\n    for (final point in points) {\n      fillPath.lineTo(point.dx, point.dy);\n    }\n    fillPath.lineTo(size.width, size.height);\n    fillPath.close();\n    canvas.drawPath(fillPath, fillPaint);\n\n    // Draw line\n    final linePath = Path()..moveTo(points.first.dx, points.first.dy);\n    for (final point in points) {\n      linePath.lineTo(point.dx, point.dy);\n    }\n    canvas.drawPath(linePath, linePaint);\n\n    // Draw dots\n    for (final point in points) {\n      canvas.drawCircle(point, 4, dotPaint);\n    }\n  }\n\n  @override\n  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;\n}\n\n// ============================================================================\n// Section 2: Latest Entry Card\n// ============================================================================\n\nclass _LatestEntryCard extends StatelessWidget {\n  @override\n  Widget build(BuildContext context) {\n    return Container(\n      padding: const EdgeInsets.all(AppTheme.spaceMd),\n      decoration: BoxDecoration(\n        color: AppTheme.morningMist,\n        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n        boxShadow: const [\n          BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n        ],\n      ),\n      child: Column(\n        crossAxisAlignment: CrossAxisAlignment.start,\n        children: [\n          Text(\n            \"Today's Weight\",\n            style: Theme.of(context).textTheme.labelMedium?.copyWith(\n                  color: AppTheme.stoneGrey,\n                  letterSpacing: 0.5,\n                ),\n          ),\n          const Gap(AppTheme.spaceXs),\n          Row(\n            crossAxisAlignment: CrossAxisAlignment.baseline,\n            textBaseline: TextBaseline.alphabetic,\n            children: [\n              Text(\n                '64.5',\n                style: Theme.of(context).textTheme.displayLarge,\n              ),\n              const Gap(AppTheme.spaceXs),\n              Text(\n                'kg',\n                style: Theme.of(context).textTheme.bodyLarge?.copyWith(\n                      color: AppTheme.stoneGrey,\n                    ),\n              ),\n            ],\n          ),\n          const Gap(AppTheme.spaceXs),\n          Row(\n            children: [\n              Icon(\n                Icons.arrow_upward,\n                size: 20,\n                color: AppTheme.softCoral,\n              ),\n              const Gap(AppTheme.spaceXxs),\n              Text(\n                '+0.8',\n                style: Theme.of(context).textTheme.labelLarge?.copyWith(\n                      color: AppTheme.softCoral,\n                    ),\n              ),\n              const Gap(AppTheme.spaceXs),\n              Text(\n                'from last entry',\n                style: Theme.of(context).textTheme.bodyMedium,\n              ),\n            ],\n          ),\n          const Gap(AppTheme.spaceXs),\n          Text(\n            'Logged at 8:30 AM',\n            style: Theme.of(context).textTheme.bodySmall,\n          ),\n        ],\n      ),\n    ).animate().fade(delay: 50.ms, duration: 200.ms);\n  }\n}\n\n// ============================================================================\n// Section 3: Nutrition Tips Card\n// ============================================================================\n\nclass _NutritionTipsCard extends StatelessWidget {\n  @override\n  Widget build(BuildContext context) {\n    final tips = [\n      'Focus on iron-rich foods like spinach, lentils, and lean red meat to support increased blood volume',\n      'Stay hydrated with 8-10 glasses of water daily',\n      'Include calcium-rich foods for baby\\'s bone development',\n      'Small, frequent meals can help with digestion and energy levels',\n    ];\n\n    return Container(\n      padding: const EdgeInsets.all(AppTheme.spaceMd),\n      decoration: BoxDecoration(\n        color: AppTheme.lavenderTint,\n        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n        boxShadow: const [\n          BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n        ],\n      ),\n      child: Column(\n        crossAxisAlignment: CrossAxisAlignment.start,\n        children: [\n          Row(\n            mainAxisAlignment: MainAxisAlignment.spaceBetween,\n            children: [\n              Text(\n                'Nutrition Tips',\n                style: Theme.of(context).textTheme.titleMedium,\n              ),\n              Container(\n                padding: const EdgeInsets.symmetric(\n                  horizontal: AppTheme.spaceSm,\n                  vertical: AppTheme.spaceXxs + 2,\n                ),\n                decoration: BoxDecoration(\n                  color: AppTheme.lavenderBloom,\n                  borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n                ),\n                child: Text(\n                  'Week 24',\n                  style: Theme.of(context).textTheme.labelSmall?.copyWith(\n                        color: Colors.white,\n                        fontWeight: FontWeight.w600,\n                      ),\n                ),\n              ),\n            ],\n          ),\n          const Gap(AppTheme.spaceSm),\n          ...tips.map((tip) => Padding(\n                padding: const EdgeInsets.only(bottom: AppTheme.spaceSm),\n                child: Row(\n                  crossAxisAlignment: CrossAxisAlignment.start,\n                  children: [\n                    Container(\n                      width: 8,\n                      height: 8,\n                      margin: const EdgeInsets.only(top: 6),\n                      decoration: const BoxDecoration(\n                        color: AppTheme.blushRose,\n                        shape: BoxShape.circle,\n                      ),\n                    ),\n                    const Gap(AppTheme.spaceXs),\n                    Expanded(\n                      child: Text(\n                        tip,\n                        style: Theme.of(context).textTheme.bodyMedium,\n                      ),\n                    ),\n                  ],\n                ),\n              )),\n        ],\n      ),\n    ).animate().fade(delay: 100.ms, duration: 200.ms);\n  }\n}\n\n// ============================================================================\n// Section 4: Weight Log List\n// ============================================================================\n\nclass _WeightLogSection extends StatelessWidget {\n  @override\n  Widget build(BuildContext context) {\n    return Column(\n      crossAxisAlignment: CrossAxisAlignment.start,\n      children: [\n        Text(\n          'Weight Log',\n          style: Theme.of(context).textTheme.headlineMedium,\n        ),\n        const Gap(AppTheme.spaceSm),\n        _WeightLogItem(\n          date: 'Mon, Jan 15, 2024',\n          weight: '64.5 kg',\n          note: 'Feeling great today!',\n          time: '8:30 AM',\n        ),\n        _WeightLogItem(\n          date: 'Sun, Jan 14, 2024',\n          weight: '63.7 kg',\n          note: null,\n          time: '7:45 AM',\n        ),\n        _WeightLogItem(\n          date: 'Sat, Jan 13, 2024',\n          weight: '64.2 kg',\n          note: 'After weekend brunch',\n          time: '9:15 AM',\n        ),\n      ],\n    );\n  }\n}\n\nclass _WeightLogItem extends StatelessWidget {\n  final String date;\n  final String weight;\n  final String? note;\n  final String time;\n\n  const _WeightLogItem({\n    required this.date,\n    required this.weight,\n    this.note,\n    required this.time,\n  });\n\n  @override\n  Widget build(BuildContext context) {\n    return GestureDetector(\n      onTap: () => _showEntryDetailSheet(context),\n      onLongPress: () => _showEditSheet(context),\n      child: Container(\n        margin: const EdgeInsets.only(bottom: AppTheme.spaceSm),\n        padding: const EdgeInsets.all(AppTheme.spaceMd),\n        decoration: BoxDecoration(\n          color: AppTheme.warmWhite,\n          borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n          boxShadow: const [\n            BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n          ],\n        ),\n        child: Row(\n          crossAxisAlignment: CrossAxisAlignment.start,\n          children: [\n            Expanded(\n              child: Column(\n                crossAxisAlignment: CrossAxisAlignment.start,\n                children: [\n                  Text(\n                    date,\n                    style: Theme.of(context).textTheme.titleMedium,\n                  ),\n                  const Gap(AppTheme.spaceXxs),\n                  Text(\n                    weight,\n                    style: Theme.of(context).textTheme.bodyLarge,\n                  ),\n                  if (note != null) ...[\n                    const Gap(AppTheme.spaceXxs),\n                    Text(\n                      note!,\n                      style: Theme.of(context).textTheme.bodyMedium,\n                    ),\n                  ],\n                ],\n              ),\n            ),\n            Container(\n              padding: const EdgeInsets.symmetric(\n                horizontal: AppTheme.spaceXs,\n                vertical: 2,\n              ),\n              decoration: BoxDecoration(\n                color: AppTheme.stoneGrey.withValues(alpha: 0.1),\n                borderRadius: BorderRadius.circular(AppTheme.radiusSm),\n              ),\n              child: Text(\n                time,\n                style: Theme.of(context).textTheme.bodySmall,\n              ),\n            ),\n          ],\n        ),\n      ).animate().fade(duration: 200.ms).slideX(\n            begin: 0.1,\n            end: 0,\n            duration: 200.ms,\n            curve: Curves.easeOut,\n          ),\n    );\n  }\n\n  void _showEntryDetailSheet(BuildContext context) {\n    showModalBottomSheet(\n      context: context,\n      backgroundColor: Colors.transparent,\n      builder: (context) => _EntryDetailBottomSheet(date: date, weight: weight),\n    );\n  }\n\n  void _showEditSheet(BuildContext context) {\n    showModalBottomSheet(\n      context: context,\n      isScrollControlled: true,\n      backgroundColor: Colors.transparent,\n      builder: (context) => _AddWeightBottomSheet(\n        initialWeight: weight.split(' ').first,\n        initialDate: date,\n      ),\n    );\n  }\n}\n\n// ============================================================================\n// Section 5: Add Weight Bottom Sheet\n// ============================================================================\n\nclass _AddWeightBottomSheet extends StatefulWidget {\n  final String? initialWeight;\n  final String? initialDate;\n\n  const _AddWeightBottomSheet({\n    this.initialWeight,\n    this.initialDate,\n  });\n\n  @override\n  State<_AddWeightBottomSheet> createState() => _AddWeightBottomSheetState();\n}\n\nclass _AddWeightBottomSheetState extends State<_AddWeightBottomSheet> {\n  final _weightController = TextEditingController();\n  final _notesController = TextEditingController();\n  DateTime _selectedDate = DateTime.now();\n\n  @override\n  void initState() {\n    super.initState();\n    if (widget.initialWeight != null) {\n      _weightController.text = widget.initialWeight!;\n    }\n  }\n\n  @override\n  void dispose() {\n    _weightController.dispose();\n    _notesController.dispose();\n    super.dispose();\n  }\n\n  @override\n  Widget build(BuildContext context) {\n    final theme = Theme.of(context);\n    final textTheme = theme.textTheme;\n\n    return Container(\n      margin: const EdgeInsets.only(top: 100),\n      decoration: BoxDecoration(\n        color: AppTheme.warmWhite,\n        borderRadius: const BorderRadius.vertical(top: Radius.circular(28)),\n      ),\n      padding: const EdgeInsets.all(AppTheme.spaceMd),\n      child: Column(\n        mainAxisSize: MainAxisSize.min,\n        children: [\n          Container(\n            width: 40,\n            height: 4,\n            decoration: BoxDecoration(\n              color: AppTheme.mistyBorder,\n              borderRadius: BorderRadius.circular(2),\n            ),\n          ),\n          const Gap(AppTheme.spaceMd),\n          Text('Log Weight', style: textTheme.titleLarge),\n          const Gap(AppTheme.spaceMd),\n          Row(\n            children: [\n              Expanded(\n                flex: 3,\n                child: TextField(\n                  controller: _weightController,\n                  keyboardType: const TextInputType.numberWithOptions(decimal: true),\n                  decoration: InputDecoration(\n                    labelText: 'Weight',\n                    hintText: '0.0',\n                    border: OutlineInputBorder(\n                      borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n                    ),\n                    contentPadding: const EdgeInsets.symmetric(\n                      horizontal: AppTheme.spaceMd,\n                      vertical: AppTheme.spaceSm,\n                    ),\n                  ),\n                ),\n              ),\n              const Gap(AppTheme.spaceSm),\n              Expanded(\n                flex: 1,\n                child: Container(\n                  padding: const EdgeInsets.symmetric(\n                    horizontal: AppTheme.spaceMd,\n                    vertical: AppTheme.spaceMd,\n                  ),\n                  decoration: BoxDecoration(\n                    color: AppTheme.lavenderTint,\n                    borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n                    border: Border.all(color: AppTheme.mistyBorder),\n                  ),\n                  child: Text(\n                    'kg',\n                    style: textTheme.bodyLarge?.copyWith(\n                      color: AppTheme.stoneGrey,\n                    ),\n                    textAlign: TextAlign.center,\n                  ),\n                ),\n              ),\n            ],\n          ),\n          const Gap(AppTheme.spaceMd),\n          GestureDetector(\n            onTap: () => _selectDate(context),\n            child: Container(\n              padding: const EdgeInsets.all(AppTheme.spaceMd),\n              decoration: BoxDecoration(\n                border: Border.all(color: AppTheme.mistyBorder),\n                borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n              ),\n              child: Row(\n                children: [\n                  Text(\n                    'Date',\n                    style: textTheme.bodyMedium,\n                  ),\n                  const Spacer(),\n                  Text(\n                    _formatDate(_selectedDate),\n                    style: textTheme.bodyLarge,\n                  ),\n                  const Gap(AppTheme.spaceXs),\n                  const Icon(\n                    Icons.calendar_today,\n                    size: 20,\n                    color: AppTheme.stoneGrey,\n                  ),\n                ],\n              ),\n            ),\n          ),\n          const Gap(AppTheme.spaceMd),\n          TextField(\n            controller: _notesController,\n            maxLines: 3,\n            minLines: 3,\n            decoration: InputDecoration(\n              labelText: 'Notes (optional)',\n              hintText: 'Add notes...',\n              border: OutlineInputBorder(\n                borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n              ),\n              contentPadding: const EdgeInsets.all(AppTheme.spaceMd),\n            ),\n          ),\n          const Gap(AppTheme.spaceMd),\n          Row(\n            children: [\n              Expanded(\n                child: TextButton(\n                  onPressed: () => Navigator.pop(context),\n                  child: Text(\n                    'Cancel',\n                    style: TextStyle(color: AppTheme.stoneGrey),\n                  ),\n                ),\n              ),\n              const Gap(AppTheme.spaceSm),\n              Expanded(\n                flex: 2,\n                child: ElevatedButton(\n                  onPressed: () {\n                    Navigator.pop(context);\n                    ScaffoldMessenger.of(context).showSnackBar(\n                      const SnackBar(\n                        content: Text('Weight entry saved'),\n                        behavior: SnackBarBehavior.floating,\n                      ),\n                    );\n                  },\n                  style: ElevatedButton.styleFrom(\n                    backgroundColor: AppTheme.lavenderBloom,\n                    foregroundColor: Colors.white,\n                    shape: RoundedRectangleBorder(\n                      borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n                    ),\n                    padding: const EdgeInsets.symmetric(vertical: 14),\n                  ),\n                  child: const Text('Save'),\n                ),\n              ),\n            ],\n          ),\n          SizedBox(height: MediaQuery.of(context).viewInsets.bottom),\n        ],\n      ),\n    );\n  }\n\n  Future<void> _selectDate(BuildContext context) async {\n    final picked = await showDatePicker(\n      context: context,\n      initialDate: _selectedDate,\n      firstDate: DateTime(2020),\n      lastDate: DateTime.now(),\n    );\n    if (picked != null) {\n      setState(() => _selectedDate = picked);\n    }\n  }\n\n  String _formatDate(DateTime date) {\n    const months = [\n      'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',\n      'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'\n    ];\n    return '${months[date.month - 1]} ${date.day}, ${date.year}';\n  }\n}\n\n// ============================================================================\n// Section 6: Entry Detail Bottom Sheet\n// ============================================================================\n\nclass _EntryDetailBottomSheet extends StatelessWidget {\n  final String date;\n  final String weight;\n\n  const _EntryDetailBottomSheet({\n    required this.date,\n    required this.weight,\n  });\n\n  @override\n  Widget build(BuildContext context) {\n    final theme = Theme.of(context);\n    final textTheme = theme.textTheme;\n\n    return Container(\n      margin: const EdgeInsets.only(top: 150),\n      decoration: BoxDecoration(\n        color: AppTheme.warmWhite,\n        borderRadius: const BorderRadius.vertical(top: Radius.circular(28)),\n      ),\n      padding: const EdgeInsets.all(AppTheme.spaceMd),\n      child: Column(\n        mainAxisSize: MainAxisSize.min,\n        children: [\n          Container(\n            width: 40,\n            height: 4,\n            decoration: BoxDecoration(\n              color: AppTheme.mistyBorder,\n              borderRadius: BorderRadius.circular(2),\n            ),\n          ),\n          const Gap(AppTheme.spaceMd),\n          Text('Weight Entry', style: textTheme.titleLarge),\n          const Gap(AppTheme.spaceMd),\n          Row(\n            mainAxisAlignment: MainAxisAlignment.spaceBetween,\n            children: [\n              Text(date, style: textTheme.titleMedium),\n              Container(\n                padding: const EdgeInsets.symmetric(\n                  horizontal: AppTheme.spaceXs,\n                  vertical: 2,\n                ),\n                decoration: BoxDecoration(\n                  color: AppTheme.lavenderTint,\n                  borderRadius: BorderRadius.circular(AppTheme.radiusSm),\n                ),\n                child: Text(\n                  weight,\n                  style: textTheme.labelSmall?.copyWith(\n                    color: AppTheme.lavenderBloom,\n                  ),\n                ),\n              ),\n            ],\n          ),\n          const Gap(AppTheme.spaceMd),\n          Container(\n            padding: const EdgeInsets.all(AppTheme.spaceMd),\n            decoration: BoxDecoration(\n              color: AppTheme.morningMist,\n              borderRadius: BorderRadius.circular(AppTheme.radiusMd),\n            ),\n            child: Text(\n              'Feeling great today!',\n              style: textTheme.bodyMedium,\n            ),\n          ),\n          const Gap(AppTheme.spaceMd),\n          Row(\n            children: [\n              Expanded(\n                child: TextButton(\n                  onPressed: () {\n                    Navigator.pop(context);\n                    _showDeleteConfirmation(context);\n                  },\n                  child: Text(\n                    'Delete',\n                    style: TextStyle(color: AppTheme.softCoral),\n                  ),\n                ),\n              ),\n              const Gap(AppTheme.spaceSm),\n              Expanded(\n                flex: 2,\n                child: ElevatedButton(\n                  onPressed: () => Navigator.pop(context),\n                  style: ElevatedButton.styleFrom(\n                    backgroundColor: AppTheme.lavenderBloom,\n                    foregroundColor: Colors.white,\n                    shape: RoundedRectangleBorder(\n                      borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n                    ),\n                    padding: const EdgeInsets.symmetric(vertical: 14),\n                  ),\n                  child: const Text('Save Changes'),\n                ),\n              ),\n            ],\n          ),\n          SizedBox(height: MediaQuery.of(context).viewInsets.bottom),\n        ],\n      ),\n    );\n  }\n\n  void _showDeleteConfirmation(BuildContext context) {\n    showDialog(\n      context: context,\n      builder: (context) => AlertDialog(\n        title: const Text('Delete Entry'),\n        content: const Text('Are you sure you want to delete this weight entry?'),\n        actions: [\n          TextButton(\n            onPressed: () => Navigator.pop(context),\n            child: const Text('Cancel'),\n          ),\n          TextButton(\n            onPressed: () {\n              Navigator.pop(context);\n              Navigator.pop(context);\n              ScaffoldMessenger.of(context).showSnackBar(\n                const SnackBar(\n                  content: Text('Weight entry deleted'),\n                  behavior: SnackBarBehavior.floating,\n                ),\n              );\n            },\n            child: Text(\n              'Delete',\n              style: TextStyle(color: AppTheme.softCoral),\n            ),\n          ),\n        ],\n      ),\n    );\n  }\n}","numLines":893,"startLine":1,"totalLines":893}}}
[2026-05-19T00:18:08.500Z] [STREAM_EVENT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_vjhp9awol82c_1","type":"tool_result","content":"1\timport 'package:flutter/material.dart';\n2\timport 'package:gap/gap.dart';\n3\timport 'package:flutter_animate/flutter_animate.dart';\n4\t\n5\timport '../../theme/app_theme.dart';\n6\t\n7\tclass WeightNutritionScreen extends StatelessWidget {\n8\t  const WeightNutritionScreen({super.key});\n9\t\n10\t  @override\n11\t  Widget build(BuildContext context) {\n12\t    return Scaffold(\n13\t      backgroundColor: AppTheme.lavenderTint,\n14\t      appBar: AppBar(\n15\t        backgroundColor: AppTheme.lavenderBloom,\n16\t        leading: IconButton(\n17\t          icon: const Icon(Icons.arrow_back, color: Colors.white),\n18\t          onPressed: () => Navigator.of(context).pop(),\n19\t          tooltip: 'Back to Browse',\n20\t        ),\n21\t        title: const Text(\n22\t          'Weight & Nutrition',\n23\t          style: TextStyle(\n24\t            fontSize: 20,\n25\t            fontWeight: FontWeight.w600,\n26\t            color: Colors.white,\n27\t          ),\n28\t        ),\n29\t        centerTitle: true,\n30\t        elevation: 0,\n31\t      ),\n32\t      body: CustomScrollView(\n33\t        slivers: [\n34\t          SliverToBoxAdapter(\n35\t            child: Padding(\n36\t              padding: const EdgeInsets.symmetric(horizontal: AppTheme.spaceMd),\n37\t              child: Column(\n38\t                crossAxisAlignment: CrossAxisAlignment.start,\n39\t                children: [\n40\t                  const Gap(AppTheme.spaceLg),\n41\t                  _WeightProgressChart(),\n42\t                  const Gap(AppTheme.spaceLg),\n43\t                  _LatestEntryCard(),\n44\t                  const Gap(AppTheme.spaceLg),\n45\t                  _NutritionTipsCard(),\n46\t                  const Gap(AppTheme.spaceLg),\n47\t                  _WeightLogSection(),\n48\t                  const Gap(100),\n49\t                ],\n50\t              ),\n51\t            ),\n52\t          ),\n53\t        ],\n54\t      ),\n55\t      floatingActionButton: FloatingActionButton(\n56\t        onPressed: () => _showAddWeightSheet(context),\n57\t        backgroundColor: AppTheme.lavenderBloom,\n58\t        elevation: 4,\n59\t        child: const Icon(Icons.add, color: Colors.white),\n60\t      ).animate().fade(duration: 200.ms).scale(\n61\t            begin: const Offset(0.95, 0.95),\n62\t            end: const Offset(1, 1),\n63\t            duration: 200.ms,\n64\t          ),\n65\t    );\n66\t  }\n67\t\n68\t  void _showAddWeightSheet(BuildContext context) {\n69\t    showModalBottomSheet(\n70\t      context: context,\n71\t      isScrollControlled: true,\n72\t      backgroundColor: Colors.transparent,\n73\t      builder: (context) => const _AddWeightBottomSheet(),\n74\t    );\n75\t  }\n76\t}\n77\t\n78\t// ============================================================================\n79\t// Section 1: Weight Progress Chart\n80\t// ============================================================================\n81\t\n82\tclass _WeightProgressChart extends StatefulWidget {\n83\t  @override\n84\t  State<_WeightProgressChart> createState() => _WeightProgressChartState();\n85\t}\n86\t\n87\tclass _WeightProgressChartState extends State<_WeightProgressChart> {\n88\t  String _selectedRange = '1W';\n89\t\n90\t  @override\n91\t  Widget build(BuildContext context) {\n92\t    return Container(\n93\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n94\t      decoration: BoxDecoration(\n95\t        color: AppTheme.warmWhite,\n96\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n97\t        boxShadow: const [\n98\t          BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n99\t        ],\n100\t      ),\n101\t      child: Column(\n102\t        crossAxisAlignment: CrossAxisAlignment.start,\n103\t        children: [\n104\t          Text(\n105\t            'Weight Progress',\n106\t            style: Theme.of(context).textTheme.headlineMedium,\n107\t          ),\n108\t          const Gap(AppTheme.spaceSm),\n109\t          Row(\n110\t            children: [\n111\t              _buildChip('1W', '1W'),\n112\t              const Gap(AppTheme.spaceXs),\n113\t              _buildChip('1M', '1M'),\n114\t              const Gap(AppTheme.spaceXs),\n115\t              _buildChip('All', 'All'),\n116\t            ],\n117\t          ),\n118\t          const Gap(AppTheme.spaceMd),\n119\t          SizedBox(\n120\t            height: 192,\n121\t            child: _buildChart(),\n122\t          ),\n123\t        ],\n124\t      ),\n125\t    ).animate().fade(duration: 200.ms);\n126\t  }\n127\t\n128\t  Widget _buildChip(String label, String value) {\n129\t    final isSelected = _selectedRange == value;\n130\t    return GestureDetector(\n131\t      onTap: () => setState(() => _selectedRange = value),\n132\t      child: AnimatedContainer(\n133\t        duration: 150.ms,\n134\t        padding: const EdgeInsets.symmetric(\n135\t          horizontal: AppTheme.spaceSm,\n136\t          vertical: AppTheme.spaceXs,\n137\t        ),\n138\t        decoration: BoxDecoration(\n139\t          color: isSelected\n140\t              ? AppTheme.lavenderBloom.withValues(alpha: 0.15)\n141\t              : AppTheme.stoneGrey.withValues(alpha: 0.1),\n142\t          borderRadius: BorderRadius.circular(AppTheme.radiusSm),\n143\t        ),\n144\t        child: Text(\n145\t          label,\n146\t          style: TextStyle(\n147\t            fontSize: 14,\n148\t            fontWeight: FontWeight.w600,\n149\t            color: isSelected ? AppTheme.lavenderBloom : AppTheme.stoneGrey,\n150\t          ),\n151\t        ),\n152\t      ),\n153\t    );\n154\t  }\n155\t\n156\t  Widget _buildChart() {\n157\t    return CustomPaint(\n158\t      size: const Size(double.infinity, 192),\n159\t      painter: _ChartPainter(),\n160\t    );\n161\t  }\n162\t}\n163\t\n164\tclass _ChartPainter extends CustomPainter {\n165\t  @override\n166\t  void paint(Canvas canvas, Size size) {\n167\t    final linePaint = Paint()\n168\t      ..color = AppTheme.lavenderBloom\n169\t      ..strokeWidth = 3\n170\t      ..strokeCap = StrokeCap.round\n171\t      ..style = PaintingStyle.stroke;\n172\t\n173\t    final fillPaint = Paint()\n174\t      ..shader = LinearGradient(\n175\t        begin: Alignment.topCenter,\n176\t        end: Alignment.bottomCenter,\n177\t        colors: [\n178\t          AppTheme.lavenderBloom.withValues(alpha: 0.2),\n179\t          AppTheme.lavenderBloom.withValues(alpha: 0),\n180\t        ],\n181\t      ).createShader(Rect.fromLTWH(0, 0, size.width, size.height))\n182\t      ..style = PaintingStyle.fill;\n183\t\n184\t    final dotPaint = Paint()\n185\t      ..color = AppTheme.lavenderBloom\n186\t      ..style = PaintingStyle.fill;\n187\t\n188\t    final gridPaint = Paint()\n189\t      ..color = AppTheme.mistyBorder.withValues(alpha: 0.5)\n190\t      ..strokeWidth = 1;\n191\t\n192\t    // Draw grid lines\n193\t    for (var i = 0; i < 4; i++) {\n194\t      final y = size.height * (i / 3);\n195\t      canvas.drawLine(Offset(0, y), Offset(size.width, y), gridPaint);\n196\t    }\n197\t\n198\t    // Chart data points\n199\t    final points = [\n200\t      Offset(0, size.height * 0.75),\n201\t      Offset(size.width * 0.25, size.height * 0.55),\n202\t      Offset(size.width * 0.5, size.height * 0.45),\n203\t      Offset(size.width * 0.75, size.height * 0.35),\n204\t      Offset(size.width, size.height * 0.2),\n205\t    ];\n206\t\n207\t    // Draw fill\n208\t    final fillPath = Path()\n209\t      ..moveTo(0, size.height)\n210\t      ..lineTo(points.first.dx, points.first.dy);\n211\t\n212\t    for (final point in points) {\n213\t      fillPath.lineTo(point.dx, point.dy);\n214\t    }\n215\t    fillPath.lineTo(size.width, size.height);\n216\t    fillPath.close();\n217\t    canvas.drawPath(fillPath, fillPaint);\n218\t\n219\t    // Draw line\n220\t    final linePath = Path()..moveTo(points.first.dx, points.first.dy);\n221\t    for (final point in points) {\n222\t      linePath.lineTo(point.dx, point.dy);\n223\t    }\n224\t    canvas.drawPath(linePath, linePaint);\n225\t\n226\t    // Draw dots\n227\t    for (final point in points) {\n228\t      canvas.drawCircle(point, 4, dotPaint);\n229\t    }\n230\t  }\n231\t\n232\t  @override\n233\t  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;\n234\t}\n235\t\n236\t// ============================================================================\n237\t// Section 2: Latest Entry Card\n238\t// ============================================================================\n239\t\n240\tclass _LatestEntryCard extends StatelessWidget {\n241\t  @override\n242\t  Widget build(BuildContext context) {\n243\t    return Container(\n244\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n245\t      decoration: BoxDecoration(\n246\t        color: AppTheme.morningMist,\n247\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n248\t        boxShadow: const [\n249\t          BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n250\t        ],\n251\t      ),\n252\t      child: Column(\n253\t        crossAxisAlignment: CrossAxisAlignment.start,\n254\t        children: [\n255\t          Text(\n256\t            \"Today's Weight\",\n257\t            style: Theme.of(context).textTheme.labelMedium?.copyWith(\n258\t                  color: AppTheme.stoneGrey,\n259\t                  letterSpacing: 0.5,\n260\t                ),\n261\t          ),\n262\t          const Gap(AppTheme.spaceXs),\n263\t          Row(\n264\t            crossAxisAlignment: CrossAxisAlignment.baseline,\n265\t            textBaseline: TextBaseline.alphabetic,\n266\t            children: [\n267\t              Text(\n268\t                '64.5',\n269\t                style: Theme.of(context).textTheme.displayLarge,\n270\t              ),\n271\t              const Gap(AppTheme.spaceXs),\n272\t              Text(\n273\t                'kg',\n274\t                style: Theme.of(context).textTheme.bodyLarge?.copyWith(\n275\t                      color: AppTheme.stoneGrey,\n276\t                    ),\n277\t              ),\n278\t            ],\n279\t          ),\n280\t          const Gap(AppTheme.spaceXs),\n281\t          Row(\n282\t            children: [\n283\t              Icon(\n284\t                Icons.arrow_upward,\n285\t                size: 20,\n286\t                color: AppTheme.softCoral,\n287\t              ),\n288\t              const Gap(AppTheme.spaceXxs),\n289\t              Text(\n290\t                '+0.8',\n291\t                style: Theme.of(context).textTheme.labelLarge?.copyWith(\n292\t                      color: AppTheme.softCoral,\n293\t                    ),\n294\t              ),\n295\t              const Gap(AppTheme.spaceXs),\n296\t              Text(\n297\t                'from last entry',\n298\t                style: Theme.of(context).textTheme.bodyMedium,\n299\t              ),\n300\t            ],\n301\t          ),\n302\t          const Gap(AppTheme.spaceXs),\n303\t          Text(\n304\t            'Logged at 8:30 AM',\n305\t            style: Theme.of(context).textTheme.bodySmall,\n306\t          ),\n307\t        ],\n308\t      ),\n309\t    ).animate().fade(delay: 50.ms, duration: 200.ms);\n310\t  }\n311\t}\n312\t\n313\t// ============================================================================\n314\t// Section 3: Nutrition Tips Card\n315\t// ============================================================================\n316\t\n317\tclass _NutritionTipsCard extends StatelessWidget {\n318\t  @override\n319\t  Widget build(BuildContext context) {\n320\t    final tips = [\n321\t      'Focus on iron-rich foods like spinach, lentils, and lean red meat to support increased blood volume',\n322\t      'Stay hydrated with 8-10 glasses of water daily',\n323\t      'Include calcium-rich foods for baby\\'s bone development',\n324\t      'Small, frequent meals can help with digestion and energy levels',\n325\t    ];\n326\t\n327\t    return Container(\n328\t      padding: const EdgeInsets.all(AppTheme.spaceMd),\n329\t      decoration: BoxDecoration(\n330\t        color: AppTheme.lavenderTint,\n331\t        borderRadius: BorderRadius.circular(AppTheme.radiusLg),\n332\t        boxShadow: const [\n333\t          BoxShadow(color: AppTheme.shadow, blurRadius: 24, offset: Offset(0, 8)),\n334\t        ],\n335\t      ),\n336\t      child: Column(\n337\t        crossAxisAlignment: CrossAxisAlignment.start,\n338\t        children: [\n339\t          Row(\n340\t            mainAxisAlignment: MainAxisAlignment.spaceBetween,\n341\t            children: [\n342\t              Text(\n343\t                'Nutrition Tips',\n344\t                style: Theme.of(context).textTheme.titleMedium,\n345\t              ),\n346\t              Container(\n347\t                padding: const EdgeInsets.symmetric(\n348\t                  horizontal: AppTheme.spaceSm,\n349\t                  vertical: AppTheme.spaceXxs + 2,\n350\t                ),\n351\t                decoration: BoxDecoration(\n352\t                  color: AppTheme.lavenderBloom,\n353\t                  borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n354\t                ),\n355\t                child: Text(\n356\t                  'Week 24',\n357\t                  style: Theme.of(context).textTheme.labelSmall?.copyWith(\n358\t                        color: Colors.white,\n359\t                        fontWeight: FontWeight.w600,\n360\t                      ),\n361\t                ),\n362\t              ),\n363\t            ],\n364\t          ),\n365\t          const Gap(AppTheme.spaceSm),\n366\t          ...tips.map((tip) => Padding(\n367\t                padding: const EdgeInsets.only(bottom: AppTheme.spaceSm),\n368\t                child: Row(\n369\t                  crossAxisAlignment: CrossAxisAlignment.