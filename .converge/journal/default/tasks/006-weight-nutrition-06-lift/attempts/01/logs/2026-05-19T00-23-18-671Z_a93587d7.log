21	  localWidgetsDir: lib/screens/weight_nutrition/_widgets
22	---
23	
24	# Lift: Weight & Nutrition
25	
26	Lift each widget in `lib/screens/weight_nutrition/_widgets/` marked `shared: true` in `.stitch/designs/weight-nutrition/widgets.jsonl` to `lib/widgets/` — one spawn per shared widget.
27	
28	```bash
29	TEMPLATES=".converge/playbooks/default/templates"
30	WIDGETS=".stitch/designs/weight-nutrition/widgets.jsonl"
31	LOCAL_DIR="lib/screens/weight_nutrition/_widgets"
32	SCREEN_PATH="lib/screens/weight_nutrition/weight_nutrition_screen.dart"
33	SID="weight-nutrition"
34	TITLE="Weight & Nutrition"
35	
36	[ -f "${WIDGETS}" ] || exit 0
37	
38	I=0
39	while IFS= read -r W; do
40	  [ -z "${W}" ] && continue
41	  SHARED=$(echo "${W}" | jq -r '.shared // false')
42	  [ "${SHARED}" = "true" ] || continue
43	  I=$((I + 1))
44	  P=$(printf '%03d' "${I}")
45	  WID=$(echo "${W}"   | jq -r '.id // .name')
46	  WNAME=$(echo "${W}" | jq -r '.name // .id')
47	  LOCAL_FILE="${LOCAL_DIR}/${WNAME}.dart"
48	  SHARED_FILE="lib/widgets/${WNAME}.dart"
49	  converge spawn template \
50	    --path "${TEMPLATES}/screen-widget-lift/TASK.md" \
51	    --id "${SID}-lift-${P}-${WID}" \
52	    --var "screenId=${SID}" \
53	    --var "screenTitle=${TITLE}" \
54	    --var "screenPath=${SCREEN_PATH}" \
55	    --var "widgetId=${WID}" \
56	    --var "widgetName=${WNAME}" \
57	    --var "localFile=${LOCAL_FILE}" \
58	    --var "sharedFile=${SHARED_FILE}"
59	done < "${WIDGETS}"
60	```
61	
62	If no widgets are shared (or the file is missing/empty), exit with no spawns.
