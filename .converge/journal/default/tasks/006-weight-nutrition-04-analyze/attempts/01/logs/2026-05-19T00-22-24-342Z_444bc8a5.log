163	
164	class _ChartPainter extends CustomPainter {
165	  @override
166	  void paint(Canvas canvas, Size size) {
167	    final linePaint = Paint()
168	      ..color = AppTheme.lavenderBloom
169	      ..strokeWidth = 3
170	      ..strokeCap = StrokeCap.round
171	      ..style = PaintingStyle.stroke;
172	
173	    final fillPaint = Paint()
174	      ..shader = LinearGradient(
175	        begin: Alignment.topCenter,
176	        end: Alignment.bottomCenter,
177	        colors: [
178	          AppTheme.lavenderBloom.withValues(alpha: 0.2),
179	          AppTheme.lavenderBloom.withValues(alpha: 0),
180	        ],
181	      ).createShader(Rect.fromLTWH(0, 0, size.width, size.height))
182	      ..style = PaintingStyle.fill;
183	
184	    final dotPaint = Paint()
185	      ..color = AppTheme.lavenderBloom
186	      ..style = PaintingStyle.fill;
187	
188	    final gridPaint = Paint()
189	      ..color = AppTheme.mistyBorder.withValues(alpha: 0.5)
190	      ..strokeWidth = 1;
191	
192	    // Draw grid lines
193	    for (var i = 0; i < 4; i++) {
194	      final y = size.height * (i / 3);
195	      canvas.drawLine(Offset(0, y), Offset(size.width, y), gridPaint);
196	    }
197	
198	    // Chart data points
199	    final points = [
200	      Offset(0, size.height * 0.75),
201	      Offset(size.width * 0.25, size.height * 0.55),
202	      Offset(size.width * 0.5, size.height * 0.45),
203	      Offset(size.width * 0.75, size.height * 0.35),
204	      Offset(size.width, size.height * 0.2),
205	    ];
206	
207	    // Draw fill
208	    final fillPath = Path()
209	      ..moveTo(0, size.height)
210	      ..lineTo(points.first.dx, points.first.dy);
211	
212	    for (final point in points) {
213	      fillPath.lineTo(point.dx, point.dy);
214	    }
215	    fillPath.lineTo(size.width, size.height);
216	    fillPath.close();
217	    canvas.drawPath(fillPath, fillPaint);
218	
219	    // Draw line
220	    final linePath = Path()..moveTo(points.first.dx, points.first.dy);
221	    for (final point in points) {
222	      linePath.lineTo(point.dx, point.dy);
223	    }
224	    canvas.drawPath(linePath, linePaint);
225	
226	    // Draw dots
227	    for (final point in points) {
228	      canvas.drawCircle(point, 4, dotPaint);
229	    }
230	  }
231	
232	  @override
233	  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;
234	}
