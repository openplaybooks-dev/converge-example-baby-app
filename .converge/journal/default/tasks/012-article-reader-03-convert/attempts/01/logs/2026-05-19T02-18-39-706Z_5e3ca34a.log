inset-0 bg-gradient-to-t from-graphite/70 via-graphite/20 to-transparent\"></div>\n104\t        </div>\n105\t\n106\t        <!-- Header content (collapses on scroll) -->\n107\t        <div class=\"relative z-10 flex flex-col h-full justify-end p-4\">\n108\t          <!-- Topic badge -->\n109\t          <div data-flutter=\"chip\" data-color=\"secondary\" data-selected=\"true\" class=\"self-start mb-2\">\n110\t            <span class=\"bg-blush text-white text-xs font-semibold px-3 py-1 rounded-full\">Nutrition</span>\n111\t          </div>\n112\t          <!-- Title -->\n113\t          <h1 class=\"text-2xl font-semibold text-white leading-tight\" style=\"line-height: 28px; text-shadow: 0 2px 8px rgba(0,0,0,0.3);\">Understanding Iron Needs During Pregnancy</h1>\n114\t          <!-- Metadata row -->\n115\t          <div class=\"flex items-center gap-2 mt-2 text-white/90\">\n116\t            <span class=\"text-xs font-medium\">Dr. Sarah Chen</span>\n117\t            <span class=\"text-xs\">•</span>\n118\t            <span class=\"text-xs\">May 15, 2026</span>\n119\t            <span class=\"text-xs\">•</span>\n120\t            <span class=\"text-xs\">5 min read</span>\n121\t          </div>\n122\t        </div>\n123\t\n124\t        <!-- AppBar Actions overlay (back, bookmark, share) -->\n125\t        <div class=\"absolute top-0 left-0 right-0 flex items-center h-14 px-2\">\n126\t          <!-- Back button -->\n127\t          <button data-flutter=\"icon-btn\" aria-label=\"Navigate back\" class=\"icon-btn w-12 h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm hover:bg-white/30\">\n128\t            <svg class=\"w-6 h-6 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n129\t              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"/>\n130\t            </svg>\n131\t          </button>\n132\t          <div class=\"flex-1\"></div>\n133\t          <!-- Bookmark button -->\n134\t          <button data-flutter=\"icon-btn\" aria-label=\"Bookmark article\" class=\"icon-btn w-12 h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm hover:bg-white/30\">\n135\t            <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n136\t              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z\"/>\n137\t            </svg>\n138\t          </button>\n139\t          <!-- Share button -->\n140\t          <button data-flutter=\"icon-btn\" aria-label=\"Share article\" class=\"icon-btn w-12 h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm hover:bg-white/30\">\n141\t            <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n142\t              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z\"/>\n143\t            </svg>\n144\t          </button>\n145\t        </div>\n146\t      </header>\n147\t\n148\t      <!-- Body - scrollable content -->\n149\t      <main data-flutter=\"sliver-list\" class=\"flex-1 overflow-y-auto pb-24\">\n150\t\n151\t        <!-- Article Content Section -->\n152\t        <section class=\"px-4 py-6\">\n153\t\n154\t          <!-- Section Header -->\n155\t          <h2 class=\"text-xl font-semibold text-lavender mb-4\" style=\"line-height: 28px;\">Why Iron Matters More Than Ever</h2>\n156\t\n157\t          <!-- Paragraph 1 -->\n158\t          <p class=\"text-base text-graphite mb-4 leading-relaxed\" style=\"line-height: 24px; letter-spacing: 0.15pt;\">\n159\t            During pregnancy, your body needs nearly twice as much iron as usual to support the growth of your baby and the expansion of your own blood supply. Iron is essential for making hemoglobin — the protein in red blood cells that carries oxygen to your tissues and your growing baby.\n160\t          </p>\n161\t\n162\t          <!-- Pull Quote -->\n163\t          <div data-flutter=\"card\" class=\"bg-blush/10 border-l-4 border-blush p-4 mb-6 rounded-r-card\">\n164\t            <p class=\"text-base text-graphite italic leading-relaxed\" style=\"line-height: 24px;\">\n165\t              \"Your iron needs jump from 18mg to 27mg daily during pregnancy — that's a 50% increase in just nine months.\"\n166\t            </p>\n167\t          </div>\n168\t\n169\t          <!-- Section Header 2 -->\n170\t          <h2 class=\"text-xl font-semibold text-lavender mb-4\" style=\"line-height: 28px;\">Signs of Iron Deficiency</h2>\n171\t\n172\t          <!-- Paragraph 2 -->\n173\t          <p class=\"text-base text-graphite mb-4 leading-relaxed\" style=\"line-height: 24px; letter-spacing: 0.15pt;\">\n174\t            Many pregnant people don't realize they're low in iron until a blood test reveals the issue. But paying attention to early signs can help you catch deficiency before it becomes problematic.\n175\t          </p>\n176\t\n177\t          <!-- Bullet List -->\n178\t          <div class=\"space-y-3 mb-6\">\n179\t            <div class=\"flex items-start gap-3\">\n180\t              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n181\t              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Unusual fatigue or weakness that doesn't ease with rest</p>\n182\t            </div>\n183\t            <div class=\"flex items-start gap-3\">\n184\t              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n185\t              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Pale skin, especially in the eyelids, nails, or gums</p>\n186\t            </div>\n187\t            <div class=\"flex items-start gap-3\">\n188\t              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n189\t              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Shortness of breath during normal activities</p>\n190\t            </div>\n191\t            <div class=\"flex items-start gap-3\">\n192\t              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n193\t              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Persistent headaches or difficulty concentrating</p>\n194\t            </div>\n195\t            <div class=\"flex items-start gap-3\">\n196\t              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n197\t              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Dizziness or lightheadedness</p>\n198\t            </div>\n199\t          </div>\n200\t\n201\t          <!-- Section Header 3 -->\n202\t          <h2 class=\"text-xl font-semibold text-lavender mb-4\" style=\"line-height: 28px;\">Iron-Rich Foods to Include</h2>\n203\t\n204\t          <!-- Paragraph 3 -->\n205\t          <p class=\"text-base text-graphite mb-4 leading-relaxed\" style=\"line-height: 24px; letter-spacing: 0.15pt;\">\n206\t            The best approach to getting enough iron is through a balanced diet. Both heme iron (from animal sources) and non-heme iron (from plant sources and supplements) contribute to your daily needs, but heme iron is absorbed more efficiently by your body.\n207\t          </p>\n208\t\n209\t          <!-- Pull Quote 2 -->\n210\t          <div data-flutter=\"card\" class=\"bg-blush/10 border-l-4 border-blush p-4 mb-6 rounded-r-card\">\n211\t            <p class=\"text-base text-graphite italic leading-relaxed\" style=\"line-height: 24px;\">\n212\t              \"Pairing iron-rich foods with vitamin C — like orange slices with your spinach salad — can boost absorption by up to 6 times.\"\n213\t            </p>\n214\t          </div>\n215\t\n216\t          <!-- Divider -->\n217\t          <hr class=\"border-misty-border my-6\" />\n218\t\n219\t          <!-- Related Articles Section -->\n220\t          <section class=\"mt-6\">\n221\t            <h3 class=\"text-lg font-semibold text-graphite mb-4\">Related Articles</h3>\n222\t\n223\t            <div data-flutter=\"horizontal-scroll\" class=\"overflow-x-auto -mx-4 px-4\">\n224\t              <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex gap-3\">\n225\t\n226\t                <!-- Related Article Card 1 -->\n227\t                <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow w-[140px] shrink-0 cursor-pointer slide-in overflow-hidden animate-fade-in\" style=\"animation-delay: 0ms;\" data-route=\"/article-reader/rel-1\">\n228\t                  <div class=\"h-20 bg-lavender/10 rounded-t-card flex items-center justify-center\">\n229\t                    <svg class=\"w-8 h-8 text-lavender/40\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n230\t                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253\"/>\n231\t                    </svg>\n232\t                  </div>\n233\t                  <div class=\"p-3\">\n234\t                    <h4 class=\"text-sm font-semibold text-graphite mb-1 line-clamp-2\" style=\"line-height: 18px;\">Best Prenatal Vitamins for Morning Sickness</h4>\n235\t                    <div class=\"flex items-center gap-1 mt-2 text-stone\">\n236\t                      <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n237\t                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n238\t                      </svg>\n239\t                      <span class=\"text-[11px]\">4 min</span>\n240\t                    </div>\n241\t                  </div>\n242\t                </div>\n243\t\n244\t                <!-- Related Article Card 2 -->\n245\t                <div data-flutter=\"card\" data-color=\"secondary\" class=\"card-tap bg-mist rounded-card card-shadow w-[140px] shrink-0 cursor-pointer slide-in overflow-hidden animate-fade-in\" style=\"animation-delay: 50ms;\" data-route=\"/article-reader/rel-2\">\n246\t                  <div class=\"h-20 bg-blush/10 rounded-t-card flex items-center justify-center\">\n247\t                    <svg class=\"w-8 h-8 text-blush/40\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n248\t                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z\"/>\n249\t                    </svg>\n250\t                  </div>\n251\t                  <div class=\"p-3\">\n252\t                    <h4 class=\"text-sm font-semibold text-graphite mb-1 line-clamp-2\" style=\"line-height: 18px;\">Managing Pregnancy Fatigue Naturally</h4>\n253\t                    <div class=\"flex items-center gap-1 mt-2 text-stone\">\n254\t                      <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n255\t                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n256\t                      </svg>\n257\t                      <span class=\"text-[11px]\">5 min</span>\n258\t                    </div>\n259\t                  </div>\n260\t                </div>\n261\t\n262\t                <!-- Related Article Card 3 -->\n263\t                <div data-flutter=\"card\" data-color=\"tertiary\" class=\"card-tap bg-mist rounded-card card-shadow w-[140px] shrink-0 cursor-pointer slide-in overflow-hidden animate-fade-in\" style=\"animation-delay: 100ms;\" data-route=\"/article-reader/rel-3\">\n264\t                  <div class=\"h-20 bg-mint/10 rounded-t-card flex items-center justify-center\">\n265\t                    <svg class=\"w-8 h-8 text-mint/40\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n266\t                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z\"/>\n267\t                    </svg>\n268\t                  </div>\n269\t                  <div class=\"p-3\">\n270\t                    <h4 class=\"text-sm font-semibold text-graphite mb-1 line-clamp-2\" style=\"line-height: 18px;\">Second Trimester Meal Planning</h4>\n271\t                    <div class=\"flex items-center gap-1 mt-2 text-stone\">\n272\t                      <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n273\t                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n274\t                      </svg>\n275\t                      <span class=\"text-[11px]\">6 min</span>\n276\t                    </div>\n277\t                  </div>\n278\t                </div>\n279\t\n280\t              </div>\n281\t            </div>\n282\t          </section>\n283\t\n284\t          <!-- Bottom padding -->\n285\t          <div class=\"h-8\"></div>\n286\t\n287\t        </section>\n288\t\n289\t      </main>\n290\t\n291\t    </div>\n292\t  </div>\n293\t</body>\n294\t</html>"}]},"parent_tool_use_id":null,"session_id":"2f062649-0c01-450d-a85b-f7569af9b4e9","uuid":"3b9f5cf2-3522-4379-b1ed-3326fb8f6fa5","timestamp":"2026-05-19T02:18:49.383Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/minh/Documents/openplayboosks/examples/baby-app/.stitch/designs/article-reader/design.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=375, initial-scale=1.0\">\n  <title>Article Reader — Baby Bump Design</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          colors: {\n            'lavender': '#7C3AED',\n            'lavender-tint': '#F5F3FF',\n            'lavender-light': '#A78BFA',\n            'blush': '#F9A8D4',\n            'mint': '#6EE7B7',\n            'mist': '#FAFAFA',\n            'graphite': '#1F2937',\n            'stone': '#6B7280',\n            'misty-border': '#E5E7EB',\n            'coral': '#EF4444',\n            'warm-white': '#FFFFFF',\n          },\n          fontFamily: {\n            'nunito': ['Nunito', 'system-ui', 'sans-serif'],\n          },\n          borderRadius: {\n            'card': '16px',\n            'sheet': '28px',\n            'pill': '999px',\n          }\n        }\n      }\n    }\n  </script>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body {\n      font-family: 'Nunito', system-ui, sans-serif;\n      background: #E8E8E8;\n      display: flex;\n      justify-content: center;\n      padding: 32px 16px;\n      min-height: 100vh;\n    }\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n    }\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n    .card-shadow {\n      box-shadow: 0 4px 16px rgba(0,0,0,0.08);\n    }\n    .card-tap:active {\n      transform: scale(0.98);\n      transition: transform 200ms ease-out;\n    }\n    .icon-btn:active {\n      transform: scale(0.95);\n      transition: transform 200ms ease-out;\n    }\n    @keyframes fade-in {\n      from { opacity: 0; transform: translateY(8px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n    .animate-fade-in {\n      animation: fade-in 300ms ease-out backwards;\n    }\n    @keyframes slide-in-right {\n      from { opacity: 0; transform: translateX(20px); }\n      to { opacity: 1; transform: translateX(0); }\n    }\n    .slide-in {\n      animation: slide-in-right 300ms ease-out backwards;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n\n    <!-- Scaffold with CustomScrollView + SliverAppBar -->\n    <div data-flutter=\"scaffold\" class=\"scaffold\" style=\"display: flex; flex-direction: column; min-height: 100vh; background-color: #F5F3FF;\">\n\n      <!-- AppBar with collapsing header -->\n      <header data-flutter=\"sliver-app-bar\" data-expanded-height=\"240\" data-pinned=\"true\" class=\"relative bg-lavender-tint\">\n\n        <!-- Hero Image -->\n        <div class=\"absolute inset-0\">\n          <img data-flutter=\"cached-image\" class=\"w-full h-full object-cover\" src=\"https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=750&q=80\" alt=\"Article hero image\" />\n          <!-- Gradient overlay for text readability -->\n          <div class=\"absolute inset-0 bg-gradient-to-t from-graphite/70 via-graphite/20 to-transparent\"></div>\n        </div>\n\n        <!-- Header content (collapses on scroll) -->\n        <div class=\"relative z-10 flex flex-col h-full justify-end p-4\">\n          <!-- Topic badge -->\n          <div data-flutter=\"chip\" data-color=\"secondary\" data-selected=\"true\" class=\"self-start mb-2\">\n            <span class=\"bg-blush text-white text-xs font-semibold px-3 py-1 rounded-full\">Nutrition</span>\n          </div>\n          <!-- Title -->\n          <h1 class=\"text-2xl font-semibold text-white leading-tight\" style=\"line-height: 28px; text-shadow: 0 2px 8px rgba(0,0,0,0.3);\">Understanding Iron Needs During Pregnancy</h1>\n          <!-- Metadata row -->\n          <div class=\"flex items-center gap-2 mt-2 text-white/90\">\n            <span class=\"text-xs font-medium\">Dr. Sarah Chen</span>\n            <span class=\"text-xs\">•</span>\n            <span class=\"text-xs\">May 15, 2026</span>\n            <span class=\"text-xs\">•</span>\n            <span class=\"text-xs\">5 min read</span>\n          </div>\n        </div>\n\n        <!-- AppBar Actions overlay (back, bookmark, share) -->\n        <div class=\"absolute top-0 left-0 right-0 flex items-center h-14 px-2\">\n          <!-- Back button -->\n          <button data-flutter=\"icon-btn\" aria-label=\"Navigate back\" class=\"icon-btn w-12 h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm hover:bg-white/30\">\n            <svg class=\"w-6 h-6 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"/>\n            </svg>\n          </button>\n          <div class=\"flex-1\"></div>\n          <!-- Bookmark button -->\n          <button data-flutter=\"icon-btn\" aria-label=\"Bookmark article\" class=\"icon-btn w-12 h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm hover:bg-white/30\">\n            <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z\"/>\n            </svg>\n          </button>\n          <!-- Share button -->\n          <button data-flutter=\"icon-btn\" aria-label=\"Share article\" class=\"icon-btn w-12 h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm hover:bg-white/30\">\n            <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z\"/>\n            </svg>\n          </button>\n        </div>\n      </header>\n\n      <!-- Body - scrollable content -->\n      <main data-flutter=\"sliver-list\" class=\"flex-1 overflow-y-auto pb-24\">\n\n        <!-- Article Content Section -->\n        <section class=\"px-4 py-6\">\n\n          <!-- Section Header -->\n          <h2 class=\"text-xl font-semibold text-lavender mb-4\" style=\"line-height: 28px;\">Why Iron Matters More Than Ever</h2>\n\n          <!-- Paragraph 1 -->\n          <p class=\"text-base text-graphite mb-4 leading-relaxed\" style=\"line-height: 24px; letter-spacing: 0.15pt;\">\n            During pregnancy, your body needs nearly twice as much iron as usual to support the growth of your baby and the expansion of your own blood supply. Iron is essential for making hemoglobin — the protein in red blood cells that carries oxygen to your tissues and your growing baby.\n          </p>\n\n          <!-- Pull Quote -->\n          <div data-flutter=\"card\" class=\"bg-blush/10 border-l-4 border-blush p-4 mb-6 rounded-r-card\">\n            <p class=\"text-base text-graphite italic leading-relaxed\" style=\"line-height: 24px;\">\n              \"Your iron needs jump from 18mg to 27mg daily during pregnancy — that's a 50% increase in just nine months.\"\n            </p>\n          </div>\n\n          <!-- Section Header 2 -->\n          <h2 class=\"text-xl font-semibold text-lavender mb-4\" style=\"line-height: 28px;\">Signs of Iron Deficiency</h2>\n\n          <!-- Paragraph 2 -->\n          <p class=\"text-base text-graphite mb-4 leading-relaxed\" style=\"line-height: 24px; letter-spacing: 0.15pt;\">\n            Many pregnant people don't realize they're low in iron until a blood test reveals the issue. But paying attention to early signs can help you catch deficiency before it becomes problematic.\n          </p>\n\n          <!-- Bullet List -->\n          <div class=\"space-y-3 mb-6\">\n            <div class=\"flex items-start gap-3\">\n              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Unusual fatigue or weakness that doesn't ease with rest</p>\n            </div>\n            <div class=\"flex items-start gap-3\">\n              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Pale skin, especially in the eyelids, nails, or gums</p>\n            </div>\n            <div class=\"flex items-start gap-3\">\n              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Shortness of breath during normal activities</p>\n            </div>\n            <div class=\"flex items-start gap-3\">\n              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Persistent headaches or difficulty concentrating</p>\n            </div>\n            <div class=\"flex items-start gap-3\">\n              <div class=\"w-2 h-2 rounded-full bg-blush mt-2 shrink-0\"></div>\n              <p class=\"text-base text-graphite leading-relaxed\" style=\"line-height: 24px;\">Dizziness or lightheadedness</p>\n            </div>\n          </div>\n\n          <!-- Section Header 3 -->\n          <h2 class=\"text-xl font-semibold text-lavender mb-4\" style=\"line-height: 28px;\">Iron-Rich Foods to Include</h2>\n\n          <!-- Paragraph 3 -->\n          <p class=\"text-base text-graphite mb-4 leading-relaxed\" style=\"line-height: 24px; letter-spacing: 0.15pt;\">\n            The best approach to getting enough iron is through a balanced diet. Both heme iron (from animal sources) and non-heme iron (from plant sources and supplements) contribute to your daily needs, but heme iron is absorbed more efficiently by your body.\n          </p>\n\n          <!-- Pull Quote 2 -->\n          <div data-flutter=\"card\" class=\"bg-blush/10 border-l-4 border-blush p-4 mb-6 rounded-r-card\">\n            <p class=\"text-base text-graphite italic leading-relaxed\" style=\"line-height: 24px;\">\n              \"Pairing iron-rich foods with vitamin C — like orange slices with your spinach salad — can boost absorption by up to 6 times.\"\n            </p>\n          </div>\n\n          <!-- Divider -->\n          <hr class=\"border-misty-border my-6\" />\n\n          <!-- Related Articles Section -->\n          <section class=\"mt-6\">\n            <h3 class=\"text-lg font-semibold text-graphite mb-4\">Related Articles</h3>\n\n            <div data-flutter=\"horizontal-scroll\" class=\"overflow-x-auto -mx-4 px-4\">\n              <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex gap-3\">\n\n                <!-- Related Article Card 1 -->\n                <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow w-[140px] shrink-0 cursor-pointer slide-in overflow-hidden animate-fade-in\" style=\"animation-delay: 0ms;\" data-route=\"/article-reader/rel-1\">\n                  <div class=\"h-20 bg-lavender/10 rounded-t-card flex items-center justify-center\">\n                    <svg class=\"w-8 h-8 text-lavender/40\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253\"/>\n                    </svg>\n                  </div>\n                  <div class=\"p-3\">\n                    <h4 class=\"text-sm font-semibold text-graphite mb-1 line-clamp-2\" style=\"line-height: 18px;\">Best Prenatal Vitamins for Morning Sickness</h4>\n                    <div class=\"flex items-center gap-1 mt-2 text-stone\">\n                      <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n                      </svg>\n                      <span class=\"text-[11px]\">4 min</span>\n                    </div>\n                  </div>\n                </div>\n\n                <!-- Related Article Card 2 -->\n                <div data-flutter=\"card\" data-color=\"secondary\" class=\"card-tap bg-mist rounded-card card-shadow w-[140px] shrink-0 cursor-pointer slide-in overflow-hidden animate-fade-in\" style=\"animation-delay: 50ms;\" data-route=\"/article-reader/rel-2\">\n                  <div class=\"h-20 bg-blush/10 rounded-t-card flex items-center justify-center\">\n                    <svg class=\"w-8 h-8 text-blush/40\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z\"/>\n                    </svg>\n                  </div>\n                  <div class=\"p-3\">\n                    <h4 class=\"text-sm font-semibold text-graphite mb-1 line-clamp-2\" style=\"line-height: 18px;\">Managing Pregnancy Fatigue Naturally</h4>\n                    <div class=\"flex items-center gap-1 mt-2 text-stone\">\n                      <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n                      </svg>\n                      <span class=\"text-[11px]\">5 min</span>\n                    </div>\n                  </div>\n                </div>\n\n                <!-- Related Article Card 3 -->\n                <div data-flutter=\"card\" data-color=\"tertiary\" class=\"card-tap bg-mist rounded-card card-shadow w-[140px] shrink-0 cursor-pointer slide-in overflow-hidden animate-fade-in\" style=\"animation-delay: 100ms;\" data-route=\"/article-reader/rel-3\">\n                  <div class=\"h-20 bg-mint/10 rounded-t-card flex items-center justify-center\">\n                    <svg class=\"w-8 h-8 text-mint/40\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z\"/>\n                    </svg>\n                  </div>\n                  <div class=\"p-3\">\n                    <h4 class=\"text-sm font-semibold text-graphite mb-1 line-clamp-2\" style=\"line-height: 18px;\">Second Trimester Meal Planning</h4>\n                    <div class=\"flex items-center gap-1 mt-2 text-stone\">\n                      <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n                      </svg>\n                      <span class=\"text-[11px]\">6 min</span>\n                    </div>\n                  </div>\n                </div>\n\n              </div>\n            </div>\n          </section>\n\n          <!-- Bottom padding -->\n          <div class=\"h-8\"></div>\n\n        </section>\n\n      </main>\n\n    </div>\n  </div>\n</body>\n</html>","numLines":294,"startLine":1,"totalLines":294}}}
