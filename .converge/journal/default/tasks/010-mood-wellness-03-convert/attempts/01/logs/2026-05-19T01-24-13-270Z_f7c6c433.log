0.2);\n55\t    }\n56\t    @media (prefers-reduced-motion: reduce) {\n57\t      *, *::before, *::after {\n58\t        animation-duration: 0.01ms !important;\n59\t        transition-duration: 0.01ms !important;\n60\t      }\n61\t    }\n62\t    .card-shadow {\n63\t      box-shadow: 0 4px 16px rgba(0,0,0,0.08);\n64\t    }\n65\t    .card-tap:active {\n66\t      transform: scale(0.98);\n67\t      transition: transform 200ms ease-out;\n68\t    }\n69\t    .emoji-btn {\n70\t      width: 56px;\n71\t      height: 56px;\n72\t      border-radius: 50%;\n73\t      border: 2px solid var(--color-border);\n74\t      background: var(--color-surface);\n75\t      font-size: 28px;\n76\t      cursor: pointer;\n77\t      transition: transform 200ms ease-out, border-color 200ms ease-out, background 200ms ease-out;\n78\t      display: flex;\n79\t      align-items: center;\n80\t      justify-content: center;\n81\t    }\n82\t    .emoji-btn:hover {\n83\t      border-color: #7C3AED;\n84\t      transform: scale(1.1);\n85\t    }\n86\t    .emoji-btn.selected {\n87\t      border-color: #F9A8D4;\n88\t      border-width: 3px;\n89\t      background: rgba(249, 168, 212, 0.2);\n90\t      transform: scale(1.05);\n91\t    }\n92\t    .chip-tap:active {\n93\t      opacity: 0.8;\n94\t      transition: opacity 150ms ease-out;\n95\t    }\n96\t    .badge-pill {\n97\t      padding: 4px 10px;\n98\t      border-radius: 999px;\n99\t      font-size: 11px;\n100\t      font-weight: 600;\n101\t    }\n102\t    @keyframes fade-in-up {\n103\t      from { opacity: 0; transform: translateY(12px); }\n104\t      to { opacity: 1; transform: translateY(0); }\n105\t    }\n106\t    .animate-section {\n107\t      animation: fade-in-up 300ms ease-out backwards;\n108\t    }\n109\t    .chart-dot {\n110\t      transition: transform 200ms ease-out;\n111\t    }\n112\t    .chart-dot:hover {\n113\t      transform: scale(1.5);\n114\t    }\n115\t  </style>\n116\t</head>\n117\t<body>\n118\t  <div class=\"phone\">\n119\t\n120\t    <!-- Scaffold -->\n121\t    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\">\n122\t\n123\t      <!-- AppBar -->\n124\t      <header data-flutter=\"app-bar\" class=\"flex items-center h-14 px-4 bg-lavender-tint\">\n125\t        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n126\t          <svg class=\"icon w-6 h-6 text-graphite\" data-name=\"arrow_back\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n127\t            <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n128\t          </svg>\n129\t        </button>\n130\t        <h1 class=\"flex-1 text-xl font-semibold text-graphite text-center pr-12\">Mood & Wellness</h1>\n131\t      </header>\n132\t\n133\t      <!-- Body - CustomScrollView with sections -->\n134\t      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto px-4 pb-6\">\n135\t\n136\t        <!-- Section 1: Today's Mood Card (SliverAppBar expanded child) -->\n137\t        <section class=\"mt-6 mb-6 animate-section\" style=\"animation-delay: 0ms;\">\n138\t          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n139\t            <!-- Header row -->\n140\t            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n141\t              <div>\n142\t                <h2 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">How are you feeling today?</h2>\n143\t                <p class=\"text-sm text-stone\" style=\"line-height: 20px;\">May 19, 2026</p>\n144\t              </div>\n145\t              <span class=\"badge-pill bg-mint/20 text-graphite\">Today</span>\n146\t            </div>\n147\t\n148\t            <!-- Emoji row -->\n149\t            <div data-flutter=\"row\" data-main-axis=\"space-evenly\" data-spacing=\"sm\" class=\"flex justify-between items-center gap-2 mb-4\">\n150\t              <button class=\"emoji-btn\" aria-label=\"Terrible mood, tap to log\" aria-pressed=\"false\">😔</button>\n151\t              <button class=\"emoji-btn\" aria-label=\"Bad mood, tap to log\" aria-pressed=\"false\">😕</button>\n152\t              <button class=\"emoji-btn\" aria-label=\"Okay mood, tap to log\" aria-pressed=\"false\">😐</button>\n153\t              <button class=\"emoji-btn selected\" aria-label=\"Good mood, tap to log\" aria-pressed=\"true\">🙂</button>\n154\t              <button class=\"emoji-btn\" aria-label=\"Great mood, tap to log\" aria-pressed=\"false\">😊</button>\n155\t            </div>\n156\t\n157\t            <!-- Note field -->\n158\t            <div class=\"mt-4\">\n159\t              <textarea class=\"w-full min-h-[56px] px-4 py-3 bg-misty-border/50 rounded-xl text-sm text-graphite placeholder-stone resize-none transition-shadow duration-200 focus:outline-none focus:ring-2 focus:ring-lavender/30\"\n160\t                data-flutter=\"text-field\"\n161\t                placeholder=\"Add a note (optional, max 200 characters)\"\n162\t                aria-label=\"Mood note\"></textarea>\n163\t            </div>\n164\t          </div>\n165\t        </section>\n166\t\n167\t        <!-- Section 2: Mood Trend Chart -->\n168\t        <section class=\"mb-6 animate-section\" style=\"animation-delay: 50ms;\">\n169\t          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4\">\n170\t            <!-- Header with toggle chips -->\n171\t            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n172\t              <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Mood Trend</h3>\n173\t              <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1\">\n174\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-lavender text-white\" data-flutter=\"chip\" data-color=\"primary\">1W</button>\n175\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">1M</button>\n176\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">All</button>\n177\t              </div>\n178\t            </div>\n179\t\n180\t            <!-- Chart area -->\n181\t            <div class=\"relative h-[160px]\">\n182\t              <svg data-flutter=\"custom-paint\" class=\"w-full h-full\" viewBox=\"0 0 300 140\" preserveAspectRatio=\"xMidYMid meet\">\n183\t                <!-- Grid lines -->\n184\t                <line x1=\"0\" y1=\"20\" x2=\"300\" y2=\"20\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n185\t                <line x1=\"0\" y1=\"50\" x2=\"300\" y2=\"50\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n186\t                <line x1=\"0\" y1=\"80\" x2=\"300\" y2=\"80\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n187\t                <line x1=\"0\" y1=\"110\" x2=\"300\" y2=\"110\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n188\t\n189\t                <!-- Y-axis labels -->\n190\t                <text x=\"8\" y=\"24\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😊</text>\n191\t                <text x=\"8\" y=\"54\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">🙂</text>\n192\t                <text x=\"8\" y=\"84\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😐</text>\n193\t                <text x=\"8\" y=\"114\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😢</text>\n194\t\n195\t                <!-- Area fill -->\n196\t                <path d=\"M0 85 Q37.5 80 75 70 T150 55 T225 45 T300 35 L300 120 L0 120 Z\" fill=\"url(#moodAreaGrad)\"/>\n197\t\n198\t                <!-- Line -->\n199\t                <path d=\"M0 85 Q37.5 80 75 70 T150 55 T225 45 T300 35\" fill=\"none\" stroke=\"#7C3AED\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n200\t\n201\t                <!-- Data points -->\n202\t                <circle class=\"chart-dot\" cx=\"0\" cy=\"85\" r=\"5\" fill=\"#7C3AED\" data-point=\"Mon\"/>\n203\t                <circle class=\"chart-dot\" cx=\"50\" cy=\"78\" r=\"5\" fill=\"#7C3AED\" data-point=\"Tue\"/>\n204\t                <circle class=\"chart-dot\" cx=\"100\" cy=\"65\" r=\"5\" fill=\"#7C3AED\" data-point=\"Wed\"/>\n205\t                <circle class=\"chart-dot\" cx=\"150\" cy=\"55\" r=\"5\" fill=\"#7C3AED\" data-point=\"Thu\"/>\n206\t                <circle class=\"chart-dot\" cx=\"200\" cy=\"48\" r=\"5\" fill=\"#7C3AED\" data-point=\"Fri\"/>\n207\t                <circle class=\"chart-dot\" cx=\"250\" cy=\"40\" r=\"5\" fill=\"#7C3AED\" data-point=\"Sat\"/>\n208\t                <circle class=\"chart-dot\" cx=\"300\" cy=\"35\" r=\"5\" fill=\"#7C3AED\" data-point=\"Sun\"/>\n209\t\n210\t                <!-- X-axis labels -->\n211\t                <text x=\"0\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Mon</text>\n212\t                <text x=\"50\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Tue</text>\n213\t                <text x=\"100\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Wed</text>\n214\t                <text x=\"150\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Thu</text>\n215\t                <text x=\"200\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Fri</text>\n216\t                <text x=\"250\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sat</text>\n217\t                <text x=\"300\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sun</text>\n218\t\n219\t                <!-- Gradient def -->\n220\t                <defs>\n221\t                  <linearGradient id=\"moodAreaGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n222\t                    <stop offset=\"0%\" stop-color=\"#7C3AED\" stop-opacity=\"0.2\"/>\n223\t                    <stop offset=\"100%\" stop-color=\"#7C3AED\" stop-opacity=\"0\"/>\n224\t                  </linearGradient>\n225\t                </defs>\n226\t              </svg>\n227\t            </div>\n228\t\n229\t            <!-- Legend -->\n230\t            <div data-flutter=\"row\" data-spacing=\"xs\" data-main-axis=\"start\" class=\"flex items-center gap-2 mt-3\">\n231\t              <span class=\"text-xs text-stone\">Score</span>\n232\t              <div class=\"w-2 h-2 rounded-full bg-lavender\"></div>\n233\t              <span class=\"text-xs text-stone\">Mood</span>\n234\t            </div>\n235\t          </div>\n236\t        </section>\n237\t\n238\t        <!-- Section 3: Energy Trend Chart -->\n239\t        <section class=\"mb-6 animate-section\" style=\"animation-delay: 100ms;\">\n240\t          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4\">\n241\t            <!-- Header with toggle chips -->\n242\t            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n243\t              <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Energy Trend</h3>\n244\t              <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1\">\n245\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-mint text-graphite\" data-flutter=\"chip\" data-color=\"tertiary\">1W</button>\n246\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">1M</button>\n247\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">All</button>\n248\t              </div>\n249\t            </div>\n250\t\n251\t            <!-- Chart area -->\n252\t            <div class=\"relative h-[160px]\">\n253\t              <svg data-flutter=\"custom-paint\" class=\"w-full h-full\" viewBox=\"0 0 300 140\" preserveAspectRatio=\"xMidYMid meet\">\n254\t                <!-- Grid lines -->\n255\t                <line x1=\"0\" y1=\"20\" x2=\"300\" y2=\"20\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n256\t                <line x1=\"0\" y1=\"50\" x2=\"300\" y2=\"50\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n257\t                <line x1=\"0\" y1=\"80\" x2=\"300\" y2=\"80\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n258\t                <line x1=\"0\" y1=\"110\" x2=\"300\" y2=\"110\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n259\t\n260\t                <!-- Y-axis labels -->\n261\t                <text x=\"8\" y=\"24\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">High</text>\n262\t                <text x=\"8\" y=\"54\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">Med</text>\n263\t                <text x=\"8\" y=\"84\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">Low</text>\n264\t                <text x=\"8\" y=\"114\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">VLow</text>\n265\t\n266\t                <!-- Area fill -->\n267\t                <path d=\"M0 90 Q37.5 75 75 80 T150 60 T225 45 T300 50 L300 120 L0 120 Z\" fill=\"url(#energyAreaGrad)\"/>\n268\t\n269\t                <!-- Line -->\n270\t                <path d=\"M0 90 Q37.5 75 75 80 T150 60 T225 45 T300 50\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n271\t\n272\t                <!-- Data points -->\n273\t                <circle class=\"chart-dot\" cx=\"0\" cy=\"90\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Mon\"/>\n274\t                <circle class=\"chart-dot\" cx=\"50\" cy=\"80\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Tue\"/>\n275\t                <circle class=\"chart-dot\" cx=\"100\" cy=\"75\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Wed\"/>\n276\t                <circle class=\"chart-dot\" cx=\"150\" cy=\"60\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Thu\"/>\n277\t                <circle class=\"chart-dot\" cx=\"200\" cy=\"50\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Fri\"/>\n278\t                <circle class=\"chart-dot\" cx=\"250\" cy=\"55\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Sat\"/>\n279\t                <circle class=\"chart-dot\" cx=\"300\" cy=\"50\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Sun\"/>\n280\t\n281\t                <!-- X-axis labels -->\n282\t                <text x=\"0\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Mon</text>\n283\t                <text x=\"50\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Tue</text>\n284\t                <text x=\"100\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Wed</text>\n285\t                <text x=\"150\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Thu</text>\n286\t                <text x=\"200\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Fri</text>\n287\t                <text x=\"250\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sat</text>\n288\t                <text x=\"300\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sun</text>\n289\t\n290\t                <!-- Gradient def -->\n291\t                <defs>\n292\t                  <linearGradient id=\"energyAreaGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n293\t                    <stop offset=\"0%\" stop-color=\"#6EE7B7\" stop-opacity=\"0.2\"/>\n294\t                    <stop offset=\"100%\" stop-color=\"#6EE7B7\" stop-opacity=\"0\"/>\n295\t                  </linearGradient>\n296\t                </defs>\n297\t              </svg>\n298\t            </div>\n299\t\n300\t            <!-- Legend -->\n301\t            <div data-flutter=\"row\" data-spacing=\"xs\" data-main-axis=\"start\" class=\"flex items-center gap-2 mt-3\">\n302\t              <span class=\"text-xs text-stone\">Level</span>\n303\t              <div class=\"w-2 h-2 rounded-full bg-mint\"></div>\n304\t              <span class=\"text-xs text-stone\">Energy</span>\n305\t            </div>\n306\t          </div>\n307\t        </section>\n308\t\n309\t        <!-- Section 4: Wellness Tip -->\n310\t        <section class=\"mb-6 animate-section\" style=\"animation-delay: 150ms;\">\n311\t          <div data-flutter=\"card\" data-color=\"primary\" data-expandable=\"true\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n312\t            <!-- Header row -->\n313\t            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-3\">\n314\t              <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex items-center gap-2\">\n315\t                <svg class=\"icon w-5 h-5 text-lavender\" data-name=\"lightbulb\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n316\t                  <path d=\"M9 21h6M12 3a6 6 0 0 0-6 6c0 2.22 1.21 4.16 3 5.19V17a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1v-2.81c1.79-1.03 3-2.97 3-5.19a6 6 0 0 0-6-6z\"/>\n317\t                </svg>\n318\t                <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Wellness Tip</h3>\n319\t              </div>\n320\t              <span class=\"badge-pill bg-lavender/10 text-lavender\" data-flutter=\"chip\" data-color=\"primary\">Mood</span>\n321\t            </div>\n322\t\n323\t            <!-- Tip text -->\n324\t            <p class=\"text-sm text-stone\" style=\"line-height: 20px;\">\n325\t              Your energy is improving! Try adding a 10-minute walk after meals to maintain this positive trend.\n326\t            </p>\n327\t\n328\t            <!-- Expand indicator -->\n329\t            <div class=\"flex justify-center mt-3\">\n330\t              <svg class=\"icon w-4 h-4 text-stone\" data-name=\"expand_more\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n331\t                <path d=\"M6 9l6 6 6-6\"/>\n332\t              </svg>\n333\t            </div>\n334\t          </div>\n335\t        </section>\n336\t\n337\t      </main>\n338\t\n339\t    </div>\n340\t  </div>\n341\t</body>\n342\t</html>"}]},"parent_tool_use_id":null,"session_id":"9ef2f4d9-d368-43aa-a2b0-f7f3a2dbe32a","uuid":"1738c449-0ce0-4db5-afdb-ea89972e484f","timestamp":"2026-05-19T01:24:27.476Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/minh/Documents/openplayboosks/examples/baby-app/.stitch/designs/mood-wellness/design.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=375, initial-scale=1.0\">\n  <title>Mood & Wellness — Baby Bump Design</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          colors: {\n            'lavender': '#7C3AED',\n            'lavender-tint': '#F5F3FF',\n            'blush': '#F9A8D4',\n            'mint': '#6EE7B7',\n            'mist': '#FAFAFA',\n            'graphite': '#1F2937',\n            'stone': '#6B7280',\n            'misty-border': '#E5E7EB',\n            'coral': '#EF4444',\n            'warm-white': '#FFFFFF',\n          },\n          fontFamily: {\n            'nunito': ['Nunito', 'system-ui', 'sans-serif'],\n          },\n          borderRadius: {\n            'card': '16px',\n            'sheet': '28px',\n            'pill': '999px',\n          }\n        }\n      }\n    }\n  </script>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body {\n      font-family: 'Nunito', system-ui, sans-serif;\n      background: #E8E8E8;\n      display: flex;\n      justify-content: center;\n      padding: 32px 16px;\n      min-height: 100vh;\n    }\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n    }\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n    .card-shadow {\n      box-shadow: 0 4px 16px rgba(0,0,0,0.08);\n    }\n    .card-tap:active {\n      transform: scale(0.98);\n      transition: transform 200ms ease-out;\n    }\n    .emoji-btn {\n      width: 56px;\n      height: 56px;\n      border-radius: 50%;\n      border: 2px solid var(--color-border);\n      background: var(--color-surface);\n      font-size: 28px;\n      cursor: pointer;\n      transition: transform 200ms ease-out, border-color 200ms ease-out, background 200ms ease-out;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n    .emoji-btn:hover {\n      border-color: #7C3AED;\n      transform: scale(1.1);\n    }\n    .emoji-btn.selected {\n      border-color: #F9A8D4;\n      border-width: 3px;\n      background: rgba(249, 168, 212, 0.2);\n      transform: scale(1.05);\n    }\n    .chip-tap:active {\n      opacity: 0.8;\n      transition: opacity 150ms ease-out;\n    }\n    .badge-pill {\n      padding: 4px 10px;\n      border-radius: 999px;\n      font-size: 11px;\n      font-weight: 600;\n    }\n    @keyframes fade-in-up {\n      from { opacity: 0; transform: translateY(12px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n    .animate-section {\n      animation: fade-in-up 300ms ease-out backwards;\n    }\n    .chart-dot {\n      transition: transform 200ms ease-out;\n    }\n    .chart-dot:hover {\n      transform: scale(1.5);\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n\n    <!-- Scaffold -->\n    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- AppBar -->\n      <header data-flutter=\"app-bar\" class=\"flex items-center h-14 px-4 bg-lavender-tint\">\n        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n          <svg class=\"icon w-6 h-6 text-graphite\" data-name=\"arrow_back\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n            <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n          </svg>\n        </button>\n        <h1 class=\"flex-1 text-xl font-semibold text-graphite text-center pr-12\">Mood & Wellness</h1>\n      </header>\n\n      <!-- Body - CustomScrollView with sections -->\n      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto px-4 pb-6\">\n\n        <!-- Section 1: Today's Mood Card (SliverAppBar expanded child) -->\n        <section class=\"mt-6 mb-6 animate-section\" style=\"animation-delay: 0ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n            <!-- Header row -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n              <div>\n                <h2 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">How are you feeling today?</h2>\n                <p class=\"text-sm text-stone\" style=\"line-height: 20px;\">May 19, 2026</p>\n              </div>\n              <span class=\"badge-pill bg-mint/20 text-graphite\">Today</span>\n            </div>\n\n            <!-- Emoji row -->\n            <div data-flutter=\"row\" data-main-axis=\"space-evenly\" data-spacing=\"sm\" class=\"flex justify-between items-center gap-2 mb-4\">\n              <button class=\"emoji-btn\" aria-label=\"Terrible mood, tap to log\" aria-pressed=\"false\">😔</button>\n              <button class=\"emoji-btn\" aria-label=\"Bad mood, tap to log\" aria-pressed=\"false\">😕</button>\n              <button class=\"emoji-btn\" aria-label=\"Okay mood, tap to log\" aria-pressed=\"false\">😐</button>\n              <button class=\"emoji-btn selected\" aria-label=\"Good mood, tap to log\" aria-pressed=\"true\">🙂</button>\n              <button class=\"emoji-btn\" aria-label=\"Great mood, tap to log\" aria-pressed=\"false\">😊</button>\n            </div>\n\n            <!-- Note field -->\n            <div class=\"mt-4\">\n              <textarea class=\"w-full min-h-[56px] px-4 py-3 bg-misty-border/50 rounded-xl text-sm text-graphite placeholder-stone resize-none transition-shadow duration-200 focus:outline-none focus:ring-2 focus:ring-lavender/30\"\n                data-flutter=\"text-field\"\n                placeholder=\"Add a note (optional, max 200 characters)\"\n                aria-label=\"Mood note\"></textarea>\n            </div>\n          </div>\n        </section>\n\n        <!-- Section 2: Mood Trend Chart -->\n        <section class=\"mb-6 animate-section\" style=\"animation-delay: 50ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4\">\n            <!-- Header with toggle chips -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n              <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Mood Trend</h3>\n              <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1\">\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-lavender text-white\" data-flutter=\"chip\" data-color=\"primary\">1W</button>\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">1M</button>\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">All</button>\n              </div>\n            </div>\n\n            <!-- Chart area -->\n            <div class=\"relative h-[160px]\">\n              <svg data-flutter=\"custom-paint\" class=\"w-full h-full\" viewBox=\"0 0 300 140\" preserveAspectRatio=\"xMidYMid meet\">\n                <!-- Grid lines -->\n                <line x1=\"0\" y1=\"20\" x2=\"300\" y2=\"20\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"50\" x2=\"300\" y2=\"50\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"80\" x2=\"300\" y2=\"80\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"110\" x2=\"300\" y2=\"110\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n\n                <!-- Y-axis labels -->\n                <text x=\"8\" y=\"24\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😊</text>\n                <text x=\"8\" y=\"54\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">🙂</text>\n                <text x=\"8\" y=\"84\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😐</text>\n                <text x=\"8\" y=\"114\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😢</text>\n\n                <!-- Area fill -->\n                <path d=\"M0 85 Q37.5 80 75 70 T150 55 T225 45 T300 35 L300 120 L0 120 Z\" fill=\"url(#moodAreaGrad)\"/>\n\n                <!-- Line -->\n                <path d=\"M0 85 Q37.5 80 75 70 T150 55 T225 45 T300 35\" fill=\"none\" stroke=\"#7C3AED\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n\n                <!-- Data points -->\n                <circle class=\"chart-dot\" cx=\"0\" cy=\"85\" r=\"5\" fill=\"#7C3AED\" data-point=\"Mon\"/>\n                <circle class=\"chart-dot\" cx=\"50\" cy=\"78\" r=\"5\" fill=\"#7C3AED\" data-point=\"Tue\"/>\n                <circle class=\"chart-dot\" cx=\"100\" cy=\"65\" r=\"5\" fill=\"#7C3AED\" data-point=\"Wed\"/>\n                <circle class=\"chart-dot\" cx=\"150\" cy=\"55\" r=\"5\" fill=\"#7C3AED\" data-point=\"Thu\"/>\n                <circle class=\"chart-dot\" cx=\"200\" cy=\"48\" r=\"5\" fill=\"#7C3AED\" data-point=\"Fri\"/>\n                <circle class=\"chart-dot\" cx=\"250\" cy=\"40\" r=\"5\" fill=\"#7C3AED\" data-point=\"Sat\"/>\n                <circle class=\"chart-dot\" cx=\"300\" cy=\"35\" r=\"5\" fill=\"#7C3AED\" data-point=\"Sun\"/>\n\n                <!-- X-axis labels -->\n                <text x=\"0\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Mon</text>\n                <text x=\"50\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Tue</text>\n                <text x=\"100\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Wed</text>\n                <text x=\"150\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Thu</text>\n                <text x=\"200\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Fri</text>\n                <text x=\"250\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sat</text>\n                <text x=\"300\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sun</text>\n\n                <!-- Gradient def -->\n                <defs>\n                  <linearGradient id=\"moodAreaGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stop-color=\"#7C3AED\" stop-opacity=\"0.2\"/>\n                    <stop offset=\"100%\" stop-color=\"#7C3AED\" stop-opacity=\"0\"/>\n                  </linearGradient>\n                </defs>\n              </svg>\n            </div>\n\n            <!-- Legend -->\n            <div data-flutter=\"row\" data-spacing=\"xs\" data-main-axis=\"start\" class=\"flex items-center gap-2 mt-3\">\n              <span class=\"text-xs text-stone\">Score</span>\n              <div class=\"w-2 h-2 rounded-full bg-lavender\"></div>\n              <span class=\"text-xs text-stone\">Mood</span>\n            </div>\n          </div>\n        </section>\n\n        <!-- Section 3: Energy Trend Chart -->\n        <section class=\"mb-6 animate-section\" style=\"animation-delay: 100ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4\">\n            <!-- Header with toggle chips -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n              <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Energy Trend</h3>\n              <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1\">\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-mint text-graphite\" data-flutter=\"chip\" data-color=\"tertiary\">1W</button>\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">1M</button>\n                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">All</button>\n              </div>\n            </div>\n\n            <!-- Chart area -->\n            <div class=\"relative h-[160px]\">\n              <svg data-flutter=\"custom-paint\" class=\"w-full h-full\" viewBox=\"0 0 300 140\" preserveAspectRatio=\"xMidYMid meet\">\n                <!-- Grid lines -->\n                <line x1=\"0\" y1=\"20\" x2=\"300\" y2=\"20\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"50\" x2=\"300\" y2=\"50\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"80\" x2=\"300\" y2=\"80\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n                <line x1=\"0\" y1=\"110\" x2=\"300\" y2=\"110\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n\n                <!-- Y-axis labels -->\n                <text x=\"8\" y=\"24\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">High</text>\n                <text x=\"8\" y=\"54\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">Med</text>\n                <text x=\"8\" y=\"84\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">Low</text>\n                <text x=\"8\" y=\"114\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">VLow</text>\n\n                <!-- Area fill -->\n                <path d=\"M0 90 Q37.5 75 75 80 T150 60 T225 45 T300 50 L300 120 L0 120 Z\" fill=\"url(#energyAreaGrad)\"/>\n\n                <!-- Line -->\n                <path d=\"M0 90 Q37.5 75 75 80 T150 60 T225 45 T300 50\" fill=\"none\" stroke=\"#6EE7B7\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n\n                <!-- Data points -->\n                <circle class=\"chart-dot\" cx=\"0\" cy=\"90\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Mon\"/>\n                <circle class=\"chart-dot\" cx=\"50\" cy=\"80\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Tue\"/>\n                <circle class=\"chart-dot\" cx=\"100\" cy=\"75\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Wed\"/>\n                <circle class=\"chart-dot\" cx=\"150\" cy=\"60\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Thu\"/>\n                <circle class=\"chart-dot\" cx=\"200\" cy=\"50\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Fri\"/>\n                <circle class=\"chart-dot\" cx=\"250\" cy=\"55\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Sat\"/>\n                <circle class=\"chart-dot\" cx=\"300\" cy=\"50\" r=\"5\" fill=\"#6EE7B7\" data-point=\"Sun\"/>\n\n                <!-- X-axis labels -->\n                <text x=\"0\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Mon</text>\n                <text x=\"50\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Tue</text>\n                <text x=\"100\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Wed</text>\n                <text x=\"150\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Thu</text>\n                <text x=\"200\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Fri</text>\n                <text x=\"250\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sat</text>\n                <text x=\"300\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sun</text>\n\n                <!-- Gradient def -->\n                <defs>\n                  <linearGradient id=\"energyAreaGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stop-color=\"#6EE7B7\" stop-opacity=\"0.2\"/>\n                    <stop offset=\"100%\" stop-color=\"#6EE7B7\" stop-opacity=\"0\"/>\n                  </linearGradient>\n                </defs>\n              </svg>\n            </div>\n\n            <!-- Legend -->\n            <div data-flutter=\"row\" data-spacing=\"xs\" data-main-axis=\"start\" class=\"flex items-center gap-2 mt-3\">\n              <span class=\"text-xs text-stone\">Level</span>\n              <div class=\"w-2 h-2 rounded-full bg-mint\"></div>\n              <span class=\"text-xs text-stone\">Energy</span>\n            </div>\n          </div>\n        </section>\n\n        <!-- Section 4: Wellness Tip -->\n        <section class=\"mb-6 animate-section\" style=\"animation-delay: 150ms;\">\n          <div data-flutter=\"card\" data-color=\"primary\" data-expandable=\"true\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n            <!-- Header row -->\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-3\">\n              <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex items-center gap-2\">\n                <svg class=\"icon w-5 h-5 text-lavender\" data-name=\"lightbulb\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                  <path d=\"M9 21h6M12 3a6 6 0 0 0-6 6c0 2.22 1.21 4.16 3 5.19V17a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1v-2.81c1.79-1.03 3-2.97 3-5.19a6 6 0 0 0-6-6z\"/>\n                </svg>\n                <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Wellness Tip</h3>\n              </div>\n              <span class=\"badge-pill bg-lavender/10 text-lavender\" data-flutter=\"chip\" data-color=\"primary\">Mood</span>\n            </div>\n\n            <!-- Tip text -->\n            <p class=\"text-sm text-stone\" style=\"line-height: 20px;\">\n              Your energy is improving! Try adding a 10-minute walk after meals to maintain this positive trend.\n            </p>\n\n            <!-- Expand indicator -->\n            <div class=\"flex justify-center mt-3\">\n              <svg class=\"icon w-4 h-4 text-stone\" data-name=\"expand_more\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path d=\"M6 9l6 6 6-6\"/>\n              </svg>\n            </div>\n          </div>\n        </section>\n\n      </main>\n\n    </div>\n  </div>\n</body>\n</html>","numLines":342,"startLine":1,"totalLines":342}}}
[2026-05-19T01:24:27.478Z] [STREAM_EVENT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_kkeftojp0ra2_1","type":"tool_result","content":"1\t<!DOCTYPE html>\n2\t<html lang=\"en\">\n3\t<head>\n4\t  <meta charset=\"UTF-8\">\n5\t  <meta name=\"viewport\" content=\"width=375, initial-scale=1.0\">\n6\t  <title>Mood & Wellness — Baby Bump Design</title>\n7\t  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n8\t  <link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n9\t  <script src=\"https://cdn.tailwindcss.com\"></script>\n10\t  <script>\n11\t    tailwind.config = {\n12\t      theme: {\n13\t        extend: {\n14\t          colors: {\n15\t            'lavender': '#7C3AED',\n16\t            'lavender-tint': '#F5F3FF',\n17\t            'blush': '#F9A8D4',\n18\t            'mint': '#6EE7B7',\n19\t            'mist': '#FAFAFA',\n20\t            'graphite': '#1F2937',\n21\t            'stone': '#6B7280',\n22\t            'misty-border': '#E5E7EB',\n23\t            'coral': '#EF4444',\n24\t            'warm-white': '#FFFFFF',\n25\t          },\n26\t          fontFamily: {\n27\t            'nunito': ['Nunito', 'system-ui', 'sans-serif'],\n28\t          },\n29\t          borderRadius: {\n30\t            'card': '16px',\n31\t            'sheet': '28px',\n32\t            'pill': '999px',\n33\t          }\n34\t        }\n35\t      }\n36\t    }\n37\t  </script>\n38\t  <style>\n39\t    * { box-sizing: border-box; margin: 0; padding: 0; }\n40\t    body {\n41\t      font-family: 'Nunito', system-ui, sans-serif;\n42\t      background: #E8E8E8;\n43\t      display: flex;\n44\t      justify-content: center;\n45\t      padding: 32px 16px;\n46\t      min-height: 100vh;\n47\t    }\n48\t    .phone {\n49\t      width: 375px;\n50\t      min-height: 812px;\n51\t      border-radius: 40px;\n52\t      overflow: hidden;\n53\t      position: relative;\n54\t      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n55\t    }\n56\t    @media (prefers-reduced-motion: reduce) {\n57\t      *, *::before, *::after {\n58\t        animation-duration: 0.01ms !important;\n59\t        transition-duration: 0.01ms !important;\n60\t      }\n61\t    }\n62\t    .card-shadow {\n63\t      box-shadow: 0 4px 16px rgba(0,0,0,0.08);\n64\t    }\n65\t    .card-tap:active {\n66\t      transform: scale(0.98);\n67\t      transition: transform 200ms ease-out;\n68\t    }\n69\t    .emoji-btn {\n70\t      width: 56px;\n71\t      height: 56px;\n72\t      border-radius: 50%;\n73\t      border: 2px solid var(--color-border);\n74\t      background: var(--color-surface);\n75\t      font-size: 28px;\n76\t      cursor: pointer;\n77\t      transition: transform 200ms ease-out, border-color 200ms ease-out, background 200ms ease-out;\n78\t      display: flex;\n79\t      align-items: center;\n80\t      justify-content: center;\n81\t    }\n82\t    .emoji-btn:hover {\n83\t      border-color: #7C3AED;\n84\t      transform: scale(1.1);\n85\t    }\n86\t    .emoji-btn.selected {\n87\t      border-color: #F9A8D4;\n88\t      border-width: 3px;\n89\t      background: rgba(249, 168, 212, 0.2);\n90\t      transform: scale(1.05);\n91\t    }\n92\t    .chip-tap:active {\n93\t      opacity: 0.8;\n94\t      transition: opacity 150ms ease-out;\n95\t    }\n96\t    .badge-pill {\n97\t      padding: 4px 10px;\n98\t      border-radius: 999px;\n99\t      font-size: 11px;\n100\t      font-weight: 600;\n101\t    }\n102\t    @keyframes fade-in-up {\n103\t      from { opacity: 0; transform: translateY(12px); }\n104\t      to { opacity: 1; transform: translateY(0); }\n105\t    }\n106\t    .animate-section {\n107\t      animation: fade-in-up 300ms ease-out backwards;\n108\t    }\n109\t    .chart-dot {\n110\t      transition: transform 200ms ease-out;\n111\t    }\n112\t    .chart-dot:hover {\n113\t      transform: scale(1.5);\n114\t    }\n115\t  </style>\n116\t</head>\n117\t<body>\n118\t  <div class=\"phone\">\n119\t\n120\t    <!-- Scaffold -->\n121\t    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\">\n122\t\n123\t      <!-- AppBar -->\n124\t      <header data-flutter=\"app-bar\" class=\"flex items-center h-14 px-4 bg-lavender-tint\">\n125\t        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n126\t          <svg class=\"icon w-6 h-6 text-graphite\" data-name=\"arrow_back\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n127\t            <path d=\"M19 12H5M12 19l-7-7 7-7\"/>\n128\t          </svg>\n129\t        </button>\n130\t        <h1 class=\"flex-1 text-xl font-semibold text-graphite text-center pr-12\">Mood & Wellness</h1>\n131\t      </header>\n132\t\n133\t      <!-- Body - CustomScrollView with sections -->\n134\t      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto px-4 pb-6\">\n135\t\n136\t        <!-- Section 1: Today's Mood Card (SliverAppBar expanded child) -->\n137\t        <section class=\"mt-6 mb-6 animate-section\" style=\"animation-delay: 0ms;\">\n138\t          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer\">\n139\t            <!-- Header row -->\n140\t            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n141\t              <div>\n142\t                <h2 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">How are you feeling today?</h2>\n143\t                <p class=\"text-sm text-stone\" style=\"line-height: 20px;\">May 19, 2026</p>\n144\t              </div>\n145\t              <span class=\"badge-pill bg-mint/20 text-graphite\">Today</span>\n146\t            </div>\n147\t\n148\t            <!-- Emoji row -->\n149\t            <div data-flutter=\"row\" data-main-axis=\"space-evenly\" data-spacing=\"sm\" class=\"flex justify-between items-center gap-2 mb-4\">\n150\t              <button class=\"emoji-btn\" aria-label=\"Terrible mood, tap to log\" aria-pressed=\"false\">😔</button>\n151\t              <button class=\"emoji-btn\" aria-label=\"Bad mood, tap to log\" aria-pressed=\"false\">😕</button>\n152\t              <button class=\"emoji-btn\" aria-label=\"Okay mood, tap to log\" aria-pressed=\"false\">😐</button>\n153\t              <button class=\"emoji-btn selected\" aria-label=\"Good mood, tap to log\" aria-pressed=\"true\">🙂</button>\n154\t              <button class=\"emoji-btn\" aria-label=\"Great mood, tap to log\" aria-pressed=\"false\">😊</button>\n155\t            </div>\n156\t\n157\t            <!-- Note field -->\n158\t            <div class=\"mt-4\">\n159\t              <textarea class=\"w-full min-h-[56px] px-4 py-3 bg-misty-border/50 rounded-xl text-sm text-graphite placeholder-stone resize-none transition-shadow duration-200 focus:outline-none focus:ring-2 focus:ring-lavender/30\"\n160\t                data-flutter=\"text-field\"\n161\t                placeholder=\"Add a note (optional, max 200 characters)\"\n162\t                aria-label=\"Mood note\"></textarea>\n163\t            </div>\n164\t          </div>\n165\t        </section>\n166\t\n167\t        <!-- Section 2: Mood Trend Chart -->\n168\t        <section class=\"mb-6 animate-section\" style=\"animation-delay: 50ms;\">\n169\t          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4\">\n170\t            <!-- Header with toggle chips -->\n171\t            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n172\t              <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Mood Trend</h3>\n173\t              <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1\">\n174\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-lavender text-white\" data-flutter=\"chip\" data-color=\"primary\">1W</button>\n175\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">1M</button>\n176\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">All</button>\n177\t              </div>\n178\t            </div>\n179\t\n180\t            <!-- Chart area -->\n181\t            <div class=\"relative h-[160px]\">\n182\t              <svg data-flutter=\"custom-paint\" class=\"w-full h-full\" viewBox=\"0 0 300 140\" preserveAspectRatio=\"xMidYMid meet\">\n183\t                <!-- Grid lines -->\n184\t                <line x1=\"0\" y1=\"20\" x2=\"300\" y2=\"20\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n185\t                <line x1=\"0\" y1=\"50\" x2=\"300\" y2=\"50\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n186\t                <line x1=\"0\" y1=\"80\" x2=\"300\" y2=\"80\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n187\t                <line x1=\"0\" y1=\"110\" x2=\"300\" y2=\"110\" stroke=\"#E5E7EB\" stroke-width=\"1\"/>\n188\t\n189\t                <!-- Y-axis labels -->\n190\t                <text x=\"8\" y=\"24\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😊</text>\n191\t                <text x=\"8\" y=\"54\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">🙂</text>\n192\t                <text x=\"8\" y=\"84\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😐</text>\n193\t                <text x=\"8\" y=\"114\" font-size=\"10\" fill=\"#6B7280\" font-family=\"Nunito\">😢</text>\n194\t\n195\t                <!-- Area fill -->\n196\t                <path d=\"M0 85 Q37.5 80 75 70 T150 55 T225 45 T300 35 L300 120 L0 120 Z\" fill=\"url(#moodAreaGrad)\"/>\n197\t\n198\t                <!-- Line -->\n199\t                <path d=\"M0 85 Q37.5 80 75 70 T150 55 T225 45 T300 35\" fill=\"none\" stroke=\"#7C3AED\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>\n200\t\n201\t                <!-- Data points -->\n202\t                <circle class=\"chart-dot\" cx=\"0\" cy=\"85\" r=\"5\" fill=\"#7C3AED\" data-point=\"Mon\"/>\n203\t                <circle class=\"chart-dot\" cx=\"50\" cy=\"78\" r=\"5\" fill=\"#7C3AED\" data-point=\"Tue\"/>\n204\t                <circle class=\"chart-dot\" cx=\"100\" cy=\"65\" r=\"5\" fill=\"#7C3AED\" data-point=\"Wed\"/>\n205\t                <circle class=\"chart-dot\" cx=\"150\" cy=\"55\" r=\"5\" fill=\"#7C3AED\" data-point=\"Thu\"/>\n206\t                <circle class=\"chart-dot\" cx=\"200\" cy=\"48\" r=\"5\" fill=\"#7C3AED\" data-point=\"Fri\"/>\n207\t                <circle class=\"chart-dot\" cx=\"250\" cy=\"40\" r=\"5\" fill=\"#7C3AED\" data-point=\"Sat\"/>\n208\t                <circle class=\"chart-dot\" cx=\"300\" cy=\"35\" r=\"5\" fill=\"#7C3AED\" data-point=\"Sun\"/>\n209\t\n210\t                <!-- X-axis labels -->\n211\t                <text x=\"0\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Mon</text>\n212\t                <text x=\"50\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Tue</text>\n213\t                <text x=\"100\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Wed</text>\n214\t                <text x=\"150\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Thu</text>\n215\t                <text x=\"200\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Fri</text>\n216\t                <text x=\"250\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sat</text>\n217\t                <text x=\"300\" y=\"132\" font-size=\"10\" fill=\"#6B7280\" text-anchor=\"middle\" font-family=\"Nunito\">Sun</text>\n218\t\n219\t                <!-- Gradient def -->\n220\t                <defs>\n221\t                  <linearGradient id=\"moodAreaGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n222\t                    <stop offset=\"0%\" stop-color=\"#7C3AED\" stop-opacity=\"0.2\"/>\n223\t                    <stop offset=\"100%\" stop-color=\"#7C3AED\" stop-opacity=\"0\"/>\n224\t                  </linearGradient>\n225\t                </defs>\n226\t              </svg>\n227\t            </div>\n228\t\n229\t            <!-- Legend -->\n230\t            <div data-flutter=\"row\" data-spacing=\"xs\" data-main-axis=\"start\" class=\"flex items-center gap-2 mt-3\">\n231\t              <span class=\"text-xs text-stone\">Score</span>\n232\t              <div class=\"w-2 h-2 rounded-full bg-lavender\"></div>\n233\t              <span class=\"text-xs text-stone\">Mood</span>\n234\t            </div>\n235\t          </div>\n236\t        </section>\n237\t\n238\t        <!-- Section 3: Energy Trend Chart -->\n239\t        <section class=\"mb-6 animate-section\" style=\"animation-delay: 100ms;\">\n240\t          <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4\">\n241\t            <!-- Header with toggle chips -->\n242\t            <div data-flutter=\"row\" data-main-axis=\"space-between\" data-cross-axis=\"center\" class=\"flex justify-between items-center mb-4\">\n243\t              <h3 class=\"text-base font-semibold text-graphite\" style=\"line-height: 24px;\">Energy Trend</h3>\n244\t              <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1\">\n245\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-mint text-graphite\" data-flutter=\"chip\" data-color=\"tertiary\">1W</button>\n246\t                <button class=\"chip-tap px-3 py-1.5 rounded-full text-xs font-semibold bg-misty-border text-graphite\" data-flutter=\"chip\">1M</button>\n247\t           