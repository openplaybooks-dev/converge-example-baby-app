"2\" d=\"M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z\"/>\n177\t                </svg>\n178\t              </div>\n179\t              <span class=\"text-base font-semibold text-graphite\">Body Changes</span>\n180\t            </div>\n181\t\n182\t            <!-- Maternal Care -->\n183\t            <div data-flutter=\"card\" data-color=\"primary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer stagger-item flex flex-col items-center gap-3\" style=\"animation-delay: 150ms;\" data-route=\"/education/maternal-care\">\n184\t              <div class=\"w-12 h-12 rounded-full bg-lavender/15 flex items-center justify-center\">\n185\t                <svg class=\"w-6 h-6 text-lavender\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n186\t                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z\"/>\n187\t                </svg>\n188\t              </div>\n189\t              <span class=\"text-base font-semibold text-graphite\">Maternal Care</span>\n190\t            </div>\n191\t\n192\t            <!-- Exercise -->\n193\t            <div data-flutter=\"card\" data-color=\"tertiary\" class=\"card-tap bg-mist rounded-card card-shadow p-4 cursor-pointer stagger-item flex flex-col items-center gap-3\" style=\"animation-delay: 200ms;\" data-route=\"/education/exercise\">\n194\t              <div class=\"w-12 h-12 rounded-full bg-mint/20 flex items-center justify-center\">\n195\t                <svg class=\"w-6 h-6 text-mint\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n196\t                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 10V3L4 14h7v7l9-11h-7z\"/>\n197\t                </svg>\n198\t              </div>\n199\t              <span class=\"te