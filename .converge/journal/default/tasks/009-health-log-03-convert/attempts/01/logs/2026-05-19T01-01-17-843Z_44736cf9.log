\n55\t    }\n56\t    @media (prefers-reduced-motion: reduce) {\n57\t      *, *::before, *::after {\n58\t        animation-duration: 0.01ms !important;\n59\t        transition-duration: 0.01ms !important;\n60\t      }\n61\t    }\n62\t    .card-shadow {\n63\t      box-shadow: 0 4px 16px rgba(0,0,0,0.08);\n64\t    }\n65\t    .entry-tap:active {\n66\t      transform: scale(0.98);\n67\t      transition: transform 200ms ease-out;\n68\t    }\n69\t    .fab-tap:active {\n70\t      transform: scale(0.90);\n71\t      transition: transform 200ms ease-out;\n72\t    }\n73\t    .badge-pill {\n74\t      padding: 4px 10px;\n75\t      border-radius: 999px;\n76\t      font-size: 11px;\n77\t      font-weight: 600;\n78\t    }\n79\t    .severity-dot {\n80\t      width: 8px;\n81\t      height: 8px;\n82\t      border-radius: 999px;\n83\t    }\n84\t    @keyframes fade-in {\n85\t      from { opacity: 0; transform: translateY(8px); }\n86\t      to { opacity: 1; transform: translateY(0); }\n87\t    }\n88\t    .animate-fade-in {\n89\t      animation: fade-in 300ms ease-out backwards;\n90\t    }\n91\t    @keyframes fab-appear {\n92\t      from { opacity: 0; transform: scale(0.95); }\n93\t      to { opacity: 1; transform: scale(1); }\n94\t    }\n95\t    .animate-fab {\n96\t      animation: fab-appear 200ms ease-out backwards;\n97\t      animation-delay: 300ms;\n98\t    }\n99\t  </style>\n100\t</head>\n101\t<body>\n102\t  <div class=\"phone\">\n103\t\n104\t    <!-- Scaffold -->\n105\t    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\">\n106\t\n107\t      <!-- AppBar -->\n108\t      <header data-flutter=\"app-bar\" class=\"flex items-center h-14 px-4 bg-lavender-tint\">\n109\t        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n110\t          <svg class=\"w-6 h-6 text-graphite\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n111\t         