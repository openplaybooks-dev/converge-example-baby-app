            'mist': '#FAFAFA',\n            'graphite': '#1F2937',\n            'stone': '#6B7280',\n            'misty-border': '#E5E7EB',\n            'coral': '#EF4444',\n            'warm-white': '#FFFFFF',\n          },\n          fontFamily: {\n            'nunito': ['Nunito', 'system-ui', 'sans-serif'],\n          },\n          borderRadius: {\n            'card': '16px',\n            'sheet': '28px',\n            'pill': '999px',\n          }\n        }\n      }\n    }\n  </script>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body {\n      font-family: 'Nunito', system-ui, sans-serif;\n      background: #E8E8E8;\n      display: flex;\n      justify-content: center;\n      padding: 32px 16px;\n      min-height: 100vh;\n    }\n    .phone {\n      width: 375px;\n      min-height: 812px;\n      border-radius: 40px;\n      overflow: hidden;\n      position: relative;\n      box-shadow: 0 24px 64px rgba(0,0,0,0.2);\n    }\n    @media (prefers-reduced-motion: reduce) {\n      *, *::before, *::after {\n        animation-duration: 0.01ms !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n    .card-shadow {\n      box-shadow: 0 4px 16px rgba(0,0,0,0.08);\n    }\n    .entry-tap:active {\n      transform: scale(0.98);\n      transition: transform 200ms ease-out;\n    }\n    .fab-tap:active {\n      transform: scale(0.90);\n      transition: transform 200ms ease-out;\n    }\n    .badge-pill {\n      padding: 4px 10px;\n      border-radius: 999px;\n      font-size: 11px;\n      font-weight: 600;\n    }\n    .severity-dot {\n      width: 8px;\n      height: 8px;\n      border-radius: 999px;\n    }\n    @keyframes fade-in {\n      from { opacity: 0; transform: translateY(8px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n    .animate-fade-in {\n      animation: fade-in 300ms ease-out backwards;\n    }\n    @keyframes fab-appear {\n      from { opacity: 0; transform: scale(0.95); }\n      to { opacity: 1; transform: scale(1); }\n    }\n    .animate-fab {\n      animation: fab-appear 200ms ease-out backwards;\n      animation-delay: 300ms;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"phone\">\n\n    <!-- Scaffold -->\n    <div data-flutter=\"scaffold\" class=\"scaffold flex flex-col min-h-screen bg-lavender-tint\">\n\n      <!-- AppBar -->\n      <header data-flutter=\"app-bar\" class=\"flex items-center h-14 px-4 bg-lavender-tint\">\n        <button data-flutter=\"icon-btn\" aria-label=\"Go back\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n          <svg class=\"w-6 h-6 text-graphite\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"/>\n          </svg>\n        </button>\n        <h1 class=\"flex-1 text-xl font-semibold text-graphite text-center pr-12\">Health Log</h1>\n        <button data-flutter=\"icon-btn\" aria-label=\"Filter entries\" class=\"w-12 h-12 flex items-center justify-center rounded-full hover:bg-lavender/10\">\n          <svg class=\"w-6 h-6 text-graphite\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z\"/>\n          </svg>\n        </button>\n      </header>\n\n      <!-- Body - ListView with sections -->\n      <main data-flutter=\"custom-scroll\" class=\"flex-1 overflow-y-auto px-4 pb-24\">\n\n        <!-- Section 1: Summary Stats Banner -->\n        <section class=\"mt-6 mb-6 animate-fade-in\" style=\"animation-delay: 0ms;\">\n          <div data-flutter=\"card\" class=\"bg-mist rounded-card card-shadow p-4\">\n            <div data-flutter=\"row\" data-main-axis=\"space-between\" class=\"flex justify-between items-center\">\n              <!-- Left: Symptom count -->\n              <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex items-center gap-2\">\n                <div class=\"w-10 h-10 rounded-full bg-lavender/15 flex items-center justify-center\">\n                  <svg class=\"w-5 h-5 text-lavender\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2\"/>\n                  </svg>\n                </div>\n                <div class=\"flex flex-col\">\n                  <span class=\"text-base font-semibold text-graphite\">3</span>\n                  <span class=\"text-xs text-stone\">symptoms this week</span>\n                </div>\n              </div>\n              <!-- Divider -->\n              <div class=\"w-px h-10 bg-misty-border\"></div>\n              <!-- Right: Next reminder -->\n              <div data-flutter=\"row\" data-spacing=\"sm\" class=\"flex items-center gap-2\">\n                <div class=\"w-10 h-10 rounded-full bg-mint/20 flex items-center justify-center\">\n                  <svg class=\"w-5 h-5 text-mint\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\"/>\n                  </svg>\n                </div>\n                <div class=\"flex flex-col\">\n                  <span class=\"text-xs text-stone\">Next</span>\n                  <span class=\"text-sm font-semibold text-graphite\">Prenatal on May 22</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <!-- Section 2: Timeline -->\n        <section class=\"mb-6\">\n          <!-- Date Header: Today -->\n          <div class=\"mb-3\">\n            <span class=\"text-xs font-medium text-stone uppercase tracking-wide\">Today</span>\n          </div>\n\n          <!-- Timeline entries -->\n          <div data-flutter=\"column\" data-spacing=\"sm\" class=\"flex flex-col gap-3\">\n\n            <!-- Entry 1: Symptom (lavender left border) -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"entry-tap bg-mist rounded-card card-shadow p-4 cursor-pointer relative overflow-hidden\" style=\"border-left: 4px solid #7C3AED;\">\n              <div data-flutter=\"row\" data-main-axis=\"space-between\" class=\"flex justify-between items-start mb-2\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Headache</h3>\n                  <!-- Severity dots -->\n                  <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1 mb-2\">\n                    <div class=\"severity-dot bg-lavender\"></div>\n                    <div class=\"severity-dot bg-lavender\"></div>\n                    <div class=\"severity-dot bg-stone/30\"></div>\n                    <span class=\"text-xs text-stone ml-1\">Moderate</span>\n                  </div>\n                  <p class=\"text-sm text-stone truncate\" style=\"line-height: 20px;\">Felt dizzy after standing up quickly</p>\n                </div>\n                <span class=\"text-xs text-stone shrink-0 ml-2\">2:30 PM</span>\n              </div>\n            </div>\n\n            <!-- Entry 2: Doctor Visit (blush left border) -->\n            <div data-flutter=\"card\" data-color=\"secondary\" class=\"entry-tap bg-mist rounded-card card-shadow p-4 cursor-pointer relative overflow-hidden\" style=\"border-left: 4px solid #F9A8D4;\">\n              <div data-flutter=\"row\" data-main-axis=\"space-between\" class=\"flex justify-between items-start mb-2\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Dr. Sarah Chen</h3>\n                  <p class=\"text-sm text-stone truncate mb-2\" style=\"line-height: 20px;\">Regular prenatal checkup, everything looks good</p>\n                  <span class=\"badge-pill bg-mint/20 text-graphite\">Next: May 29</span>\n                </div>\n                <span class=\"text-xs text-stone shrink-0 ml-2\">10:00 AM</span>\n              </div>\n            </div>\n\n          </div>\n\n          <!-- Date Header: Yesterday -->\n          <div class=\"mt-6 mb-3\">\n            <span class=\"text-xs font-medium text-stone uppercase tracking-wide\">Yesterday</span>\n          </div>\n\n          <!-- More entries -->\n          <div data-flutter=\"column\" data-spacing=\"sm\" class=\"flex flex-col gap-3\">\n\n            <!-- Entry 3: Symptom -->\n            <div data-flutter=\"card\" data-color=\"primary\" class=\"entry-tap bg-mist rounded-card card-shadow p-4 cursor-pointer relative overflow-hidden\" style=\"border-left: 4px solid #7C3AED;\">\n              <div data-flutter=\"row\" data-main-axis=\"space-between\" class=\"flex justify-between items-start mb-2\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Nausea</h3>\n                  <div data-flutter=\"row\" data-spacing=\"xs\" class=\"flex items-center gap-1 mb-2\">\n                    <div class=\"severity-dot bg-lavender\"></div>\n                    <div class=\"severity-dot bg-stone/30\"></div>\n                    <div class=\"severity-dot bg-stone/30\"></div>\n                    <span class=\"text-xs text-stone ml-1\">Mild</span>\n                  </div>\n                  <p class=\"text-sm text-stone truncate\" style=\"line-height: 20px;\">Morning sickness, took ginger tea</p>\n                </div>\n                <span class=\"text-xs text-stone shrink-0 ml-2\">8:15 AM</span>\n              </div>\n            </div>\n\n            <!-- Entry 4: Reminder (mint left border) -->\n            <div data-flutter=\"card\" data-color=\"tertiary\" class=\"entry-tap bg-mist rounded-card card-shadow p-4 cursor-pointer relative overflow-hidden\" style=\"border-left: 4px solid #6EE7B7;\">\n              <div data-flutter=\"row\" data-main-axis=\"space-between\" class=\"flex justify-between items-start mb-2\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Take Prenatal Vitamins</h3>\n                  <span class=\"badge-pill bg-blush/20 text-graphite\">Medication</span>\n                </div>\n                <span class=\"text-xs text-stone shrink-0 ml-2\">7:00 AM</span>\n              </div>\n              <div class=\"mt-2 flex items-center gap-1\">\n                <div class=\"w-2 h-2 rounded-full bg-mint\"></div>\n                <span class=\"text-xs text-mint font-medium\">Enabled</span>\n              </div>\n            </div>\n\n          </div>\n\n          <!-- Date Header: May 15, 2026 -->\n          <div class=\"mt-6 mb-3\">\n            <span class=\"text-xs font-medium text-stone uppercase tracking-wide\">May 15, 2026</span>\n          </div>\n\n          <div data-flutter=\"column\" data-spacing=\"sm\" class=\"flex flex-col gap-3\">\n\n            <!-- Entry 5: Doctor Visit -->\n            <div data-flutter=\"card\" data-color=\"secondary\" class=\"entry-tap bg-mist rounded-card card-shadow p-4 cursor-pointer relative overflow-hidden\" style=\"border-left: 4px solid #F9A8D4;\">\n              <div data-flutter=\"row\" data-main-axis=\"space-between\" class=\"flex justify-between items-start mb-2\">\n                <div class=\"flex-1\">\n                  <h3 class=\"text-base font-semibold text-graphite mb-1\" style=\"line-height: 24px;\">Dr. Emily Watson</h3>\n                  <p class=\"text-sm text-stone truncate mb-2\" style=\"line-height: 20px;\">22-week ultrasound scan</p>\n                  <span class=\"badge-pill bg-mint/20 text-graphite\">Next: Jun 12</span>\n                </div>\n                <span class=\"text-xs text-stone shrink-0 ml-2\">11:30 AM</span>\n              </div>\n            </div>\n\n          </div>\n\n        </section>\n\n      </main>\n\n      <!-- FAB - Add new entry -->\n      <button data-flutter=\"fab\" class=\"animate-fab fab-tap absolute bottom-6 right-4 w-14 h-14 rounded-full bg-lavender shadow-lg flex items-center justify-center\">\n        <svg class=\"w-7 h-7 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2.5\" d=\"M12 4v16m8-8H4\"/>\n        </svg>\n      </button>\n\n    </div>\n  </div>\n</body>\n</html>","numLines":278,"startLine":1,"totalLines":278}}}
