\n462\t                    crossAxisAlignment: CrossAxisAlignment.start,\n463\t                    children: [\n464\t                      Text(\n465\t                        widget.data.title,\n466\t                        style: textTheme.titleMedium,\n467\t                        maxLines: 2,\n468\t                        overflow: TextOverflow.ellipsis,\n469\t                      ),\n470\t                      const SizedBox(height: AppTheme.spaceXxs),\n471\t                      // Topic badge\n472\t                      Container(\n473\t                        padding: const EdgeInsets.symmetric(\n474\t                          horizontal: AppTheme.spaceXs,\n475\t                          vertical: AppTheme.spaceXxs,\n476\t                        ),\n477\t                        decoration: BoxDecoration(\n478\t                          color: AppTheme.lavenderBloom.withValues(alpha: 0.1),\n479\t                          borderRadius: BorderRadius.circular(AppTheme.radiusPill),\n480\t                        ),\n481\t                        child: Text(\n482\t                          widget.data.topic,\n483\t                          style: textTheme.labelSmall?.copyWith(\n484\t                            color: AppTheme.lavenderBloom,\n485\t                          ),\n486\t                        ),\n487\t                      ),\n488\t                      const SizedBox(height: AppTheme.spaceXxs),\n489\t                      // Read time\n490\t                      Row(\n491\t                        children: [\n492\t                          Icon(\n493\t                            Icons.access_time,\n494\t                            size: 12,\n495\t                            color: AppTheme.stoneGrey,\n496\t                          ),\n497\t                          const SizedBox(width: AppTheme.spaceXxs),\n498\t                          Text(\n499\t                            widget.data.readTime,\n500\t                            style: textTheme.labelSmall,\n501\t                          ),\n502\t                        ],\n503\t                      ),\n504\t                    ],\n505\t                  ),\n506\t                ),\n507\t              ],\n508\t            ),\n509\t          ),\n510\t        ),\n511\t      ),\n512\t    );\n513\t  }\n514\t}\n515\t\n516\tclass _SearchOverlay extends StatefulWidget {\n517\t  const _SearchOverlay();\n518\t\n519\t  @override\n520\t  State<_SearchOverlay> createState() => _SearchOverlayState();\n521\t}\n522\t\n523\tclass _SearchOverlayState extends State<_SearchOverlay> {\n524\t  final _searchController = TextEditingController();\n525\t  final _focusNode = FocusNode();\n526\t\n527\t  @override\n528\t  void initState() {\n529\t    super.initState();\n530\t    WidgetsBinding.instance.addPostFrameCallback((_) {\n531\t      _focusNode.requestFocus();\n532\t    });\n533\t  }\n534\t\n535\t  @override\n536\t  void dispose() {\n537\t    _searchController.dispose();\n538\t    _focusNode.dispose();\n539\t    super.dispose();\n540\t  }\n541\t\n542\t  @override\n543\t  Widget build(BuildContext context) {\n544\t    final theme = Theme.of(context);\n545\t    final textTheme = theme.textTheme;\n546\t    final isDark = theme.brightness == Brightness.dark;\n547\t\n548\t    return Container(\n549\t      height: MediaQuery.of(context).size.height * 0.85,\n550\t      decoration: BoxDecoration(\n551\t        color: isDark ? AppTheme.deepTwilight : AppTheme.warmWhite,\n552\t        borderRadius: const BorderRadius.vertical(\n553\t          top: Radius.circular(AppTheme.radiusLg),\n554\t        ),\n555\t      ),\n556\t      child: Column(\n557\t        children: [\n558\t          // Drag handle\n559\t          Padding(\n560\t            padding: const EdgeInsets.only(top: AppTheme.spaceSm),\n561\t            child: Container(\n562\t              width: 40,\n563\t              height: 4,\n564\t              decoration: BoxDecoration(\n565\t                color: AppTheme.mistyBorder,\n