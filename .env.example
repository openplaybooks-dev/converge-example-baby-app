# Copy this file to `.env` and fill in real values before running ./scripts/run.sh.
# Never commit a populated .env — it contains API credentials.

# MiniMax LLM (Anthropic-compatible endpoint). The playbook drives both the
# orchestrator (`claude` provider) and any agents (`acp` provider) through this.
MINIMAX_API_KEY=

# Image generation backend.
#   minimax   →  real SVG illustrations from MiniMax text-to-image (paid)
#   stub      →  deterministic grey-box SVGs, free, for CI and smoke runs
IMAGE_BACKEND=minimax

# Required when IMAGE_BACKEND=minimax. The exact URL of your image endpoint.
MINIMAX_IMAGE_ENDPOINT=https://api.minimax.io/v1/image/generate

# Optional. Defaults to image-01 if omitted.
MINIMAX_IMAGE_MODEL=image-01
